inst_slowdns() {
    local _SLOW_DIR="/etc/SSHPlus/slowdns"
    local _SLOW_KEY="/etc/SSHPlus/slowdns/keys"
    mkdir -p "$_SLOW_DIR" "$_SLOW_KEY"

    local _DNS_BIN=""
    case "$_ARCH_TYPE" in
        amd64)  _DNS_BIN="dns-server-linux-amd64" ;;
        arm64)  _DNS_BIN="dns-server-linux-arm64" ;;
        arm)    _DNS_BIN="dns-server-linux-arm"   ;;
        *)      _DNS_BIN="dns-server-linux-amd64" ;;
    esac

    # Intentar descargar binario SlowDNS (fuente principal y alternativa)
    if ! wget -q --timeout=15 \
        "https://raw.githubusercontent.com/khaledagn/VPS-AGN_English_Official/master/LINKS-LIBRARIES/dns-server" \
        -O "${_SLOW_DIR}/dns-server" 2>/dev/null || [[ ! -s "${_SLOW_DIR}/dns-server" ]]; then
        # Fallback: intentar desde otro mirror
        wget -q --timeout=15 \
            "https://github.com/juanitoprosniff/scriptsshmsy/raw/main/installer/dns-server" \
            -O "${_SLOW_DIR}/dns-server" 2>/dev/null
    fi

    [[ -s "${_SLOW_DIR}/dns-server" ]] && chmod +x "${_SLOW_DIR}/dns-server"

    # Instalar el script de gestión slowdns en /bin/
    wget -q https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main/Modulos/slowdns \
        -O /bin/slowdns 2>/dev/null
    [[ ! -s /bin/slowdns ]] && cp /bin/slowdns.sh /bin/slowdns 2>/dev/null
    chmod 755 /bin/slowdns 2>/dev/null

    # Abrir puertos necesarios
    iptables -I INPUT -p udp --dport 5300 -j ACCEPT 2>/dev/null
    iptables -t nat -I PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null
    command -v ufw &>/dev/null && ufw allow 5300/udp >/dev/null 2>&1
}
