inst_udp_zivpn() {
    local _ZIVPN_RELEASE="https://github.com/zahidbd2/udp-zivpn/releases/download/udp-zivpn_1.4.9"
    local _ZIVPN_BIN=""

    # Seleccionar binario según arquitectura
    case "$_ARCH_TYPE" in
        amd64)  _ZIVPN_BIN="udp-zivpn-linux-amd64" ;;
        arm64)  _ZIVPN_BIN="udp-zivpn-linux-arm64" ;;
        arm)    _ZIVPN_BIN="udp-zivpn-linux-arm"   ;;
        *)      _ZIVPN_BIN="udp-zivpn-linux-amd64" ;;
    esac

    systemctl stop zivpn.service 2>/dev/null

    # Descargar binario correcto
    wget -q "${_ZIVPN_RELEASE}/${_ZIVPN_BIN}" -O /usr/local/bin/zivpn 2>/dev/null
    chmod +x /usr/local/bin/zivpn

    mkdir -p /etc/zivpn

    # Descargar config
    wget -q https://raw.githubusercontent.com/zahidbd2/udp-zivpn/main/config.json \
        -O /etc/zivpn/config.json 2>/dev/null

    # Si no hay config, crear una por defecto
    [[ ! -s /etc/zivpn/config.json ]] && cat > /etc/zivpn/config.json <<'ZEOF'
{
  "listen_addr": ":36712",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "config": ["zi"],
  "obfs": ""
}
ZEOF

    # Generar certificados SSL para ZiVPN
    openssl req -new -newkey rsa:4096 -days 365 -nodes -x509 \
        -subj "/C=US/ST=California/L=Los Angeles/O=MSYVPN/OU=VPN/CN=zivpn" \
        -keyout /etc/zivpn/zivpn.key \
        -out /etc/zivpn/zivpn.crt >/dev/null 2>&1

    # Ajustar buffer de red para mayor rendimiento
    sysctl -w net.core.rmem_max=16777216 >/dev/null 2>&1
    sysctl -w net.core.wmem_max=16777216 >/dev/null 2>&1

    # Crear servicio systemd
    cat > /etc/systemd/system/zivpn.service <<'ZSEOF'
[Unit]
Description=UDP ZiVPN Service
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/zivpn server --config /etc/zivpn/config.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
ZSEOF

    systemctl daemon-reload
    systemctl enable zivpn.service >/dev/null 2>&1
    systemctl start zivpn.service >/dev/null 2>&1

    # Abrir puerto UDP 36712
    command -v ufw &>/dev/null && ufw allow 36712/udp >/dev/null 2>&1
    iptables -I INPUT -p udp --dport 36712 -j ACCEPT >/dev/null 2>&1
}
