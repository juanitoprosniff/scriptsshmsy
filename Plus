inst_pct() {
    _pacotes=("bc" "screen" "nano" "unzip" "lsof" "net-tools" "dos2unix" "nload" "jq" "curl" "figlet" "python3")
    for _prog in ${_pacotes[@]}; do
        apt install $_prog -y >/dev/null 2>&1
    done

    apt install net-tools -y >/dev/null 2>&1

    if [[ "$_UBUNTU_VER" -ge 22 ]]; then
        pip3 install speedtest-cli --break-system-packages >/dev/null 2>&1
    else
        pip3 install speedtest-cli >/dev/null 2>&1
    fi

    _open_fw_port() {
        local p="$1" pr="${2:-tcp}"
        command -v ufw &>/dev/null && ufw allow ${p}/${pr} >/dev/null 2>&1
        command -v iptables &>/dev/null && {
            iptables -C INPUT -p ${pr} --dport ${p} -j ACCEPT 2>/dev/null || \
            iptables -I INPUT -p ${pr} --dport ${p} -j ACCEPT 2>/dev/null
        }
        command -v firewall-cmd &>/dev/null && firewall-cmd --state 2>/dev/null | grep -q running && {
            firewall-cmd --zone=public --permanent --add-port=${p}/${pr} >/dev/null 2>&1
        }
    }
    for _p in 80 443 444 3128 5454 8080 8888 8880 8989; do _open_fw_port $_p tcp; done
    for _p in 7300; do _open_fw_port $_p udp; done
    command -v firewall-cmd &>/dev/null && firewall-cmd --reload >/dev/null 2>&1
}
