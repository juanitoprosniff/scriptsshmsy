#!/bin/bash
# ============================================================
# REINICIAR SERVICIOS — MSYVPN-SCRIPT
# Reinicia todos los servicios VPN/proxy en orden seguro.
# ============================================================

_step() {
    local _label="$1"; shift
    echo -ne "\033[1;33mREINICIANDO $_label "
    tput civis
    ( "$@" >/dev/null 2>&1 ) &
    local _bg=$!
    while kill -0 "$_bg" 2>/dev/null; do
        for c in / - \\ \|; do
            sleep 0.1; kill -0 "$_bg" 2>/dev/null || break
            echo -ne "\e[1D\033[1;32m$c"
        done
    done
    wait "$_bg" 2>/dev/null
    tput cnorm
    echo -e "\e[1D\033[1;32mOK\033[0m"
}

_svc_restart() {
    systemctl restart "$1" 2>/dev/null || service "$1" restart 2>/dev/null
}

# Mata screens que matcheen patrón y relanza desde /etc/autostart si tiene los binarios
_restart_screen_block() {
    local _kill_pat="$1" _start_re="$2"
    for pid in $(screen -ls 2>/dev/null | grep -E "$_kill_pat" | awk '{print $1}'); do
        screen -r -S "$pid" -X quit 2>/dev/null
    done
    screen -wipe >/dev/null 2>&1
    sleep 0.5
    if [[ -f /etc/autostart ]]; then
        while IFS= read -r _cmd; do
            [[ "$_cmd" =~ $_start_re ]] && eval "$_cmd" 2>/dev/null
        done < /etc/autostart
    fi
}

# 1. OpenSSH
_step "OPENSSH" _svc_restart ssh
[[ $(systemctl is-active sshd 2>/dev/null) = "active" ]] || _svc_restart sshd >/dev/null 2>&1

# 2. Dropbear (todas las versiones detectadas)
for _drop in dropbear dropbear-legacy dropbear-2020 dropbear-2022; do
    if systemctl list-unit-files 2>/dev/null | grep -q "^${_drop}\.service" || \
       [[ "$_drop" = "dropbear" && -e /etc/init.d/dropbear ]]; then
        if systemctl is-active --quiet "$_drop" 2>/dev/null; then
            _step "${_drop^^}" _svc_restart "$_drop"
        fi
    fi
done

# 3. Squid
if [[ -e /etc/squid/squid.conf ]]; then
    _step "SQUID" _svc_restart squid
elif [[ -e /etc/squid3/squid.conf ]]; then
    _step "SQUID3" _svc_restart squid3
fi

# 4. SSL Tunnel
if [[ -e /etc/stunnel/stunnel.conf ]]; then
    _step "SSL TUNNEL" _svc_restart stunnel4
fi

# 5. OpenVPN
if [[ -e /etc/openvpn/server.conf ]]; then
    _step "OPENVPN" _svc_restart openvpn
fi

# 6. Apache
if ss -tlpn 2>/dev/null | grep -q 'apache2' || netstat -nltp 2>/dev/null | grep -q 'apache2'; then
    _step "APACHE2" _svc_restart apache2
fi

# 7. Nginx
if systemctl is-active --quiet nginx 2>/dev/null; then
    _step "NGINX" _svc_restart nginx
fi

# 8. V2Ray
if systemctl list-unit-files 2>/dev/null | grep -q '^v2ray\.service' && \
   { systemctl is-enabled v2ray >/dev/null 2>&1 || systemctl is-active v2ray >/dev/null 2>&1; }; then
    _step "V2RAY" _svc_restart v2ray
fi

# 9. WebSocket / Socks proxies (wsproxy.py, proxy.py, open.py)
if pgrep -f '/etc/SSHPlus/(wsproxy|proxy|open)' >/dev/null 2>&1 || \
   grep -qE 'wsproxy|proxy\.py|open\.py' /etc/autostart 2>/dev/null; then
    _step "PROXY WS/SOCKS" \
        _restart_screen_block "\.ws[0-9]+|\.proxy[0-9]+|\.openpy[0-9]+" "wsproxy|proxy\.py|open\.py"
fi

# 10. SSL Dispatcher
if pgrep -f 'ssldispatcher.py' >/dev/null 2>&1 || \
   grep -q 'ssldispatcher.py' /etc/autostart 2>/dev/null; then
    _step "SSL DISPATCHER" \
        _restart_screen_block "\.ssldispatch" "ssldispatcher\.py"
fi

# 11. badvpn-udpgw
if pgrep -f 'badvpn-udpgw' >/dev/null 2>&1 || \
   grep -q 'badvpn-udpgw' /etc/autostart 2>/dev/null; then
    _step "BADVPN UDPGW" \
        _restart_screen_block "\.udpvpn" "badvpn-udpgw"
fi

echo ""
echo -e "\033[1;32m✓ SERVICIOS REINICIADOS CON ÉXITO!\033[0m"
sleep 1
