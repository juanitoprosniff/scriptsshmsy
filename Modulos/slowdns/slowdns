#!/bin/bash
# ============================================================
# SlowDNS Manager — MSYVPN-SCRIPT
# Acceso: escribir 'slowdns' en la terminal
# ============================================================
_REPO="https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main"
_REPO_RAW="https://github.com/juanitoprosniff/scriptsshmsy/raw/main"

_slowdns_header() {
    clear
    echo -e "\033[1;34m╔══════════════════════════════════════════════════╗\033[0m"
    tput setaf 7 ; tput setab 4 ; tput bold ; printf '%52s%s%-12s\n' "   SLOWDNS MANAGER — MSYVPN-SCRIPT   " ; tput sgr0
    echo -e "\033[1;34m╚══════════════════════════════════════════════════╝\033[0m"

    local _ns="" _key="" _port="" _status=""
    [[ -f /etc/slowdns/infons ]]     && _ns=$(cat /etc/slowdns/infons 2>/dev/null | tr -d '\n')
    [[ -f /root/server.pub ]]        && _key=$(cat /root/server.pub 2>/dev/null | tr -d '\n')
    [[ -f /etc/slowdns/infopuerto ]] && _port=$(cat /etc/slowdns/infopuerto 2>/dev/null | tr -d '\n')

    if ps aux 2>/dev/null | grep -v grep | grep -q 'dns-server'; then
        _status="\033[1;32m● ACTIVO\033[0m"
    else
        _status="\033[1;31m○ INACTIVO\033[0m"
    fi

    echo -e "\033[1;33m  Estado   : $_status"
    [[ -n "$_ns" ]]   && echo -e "\033[1;33m  NS       : \033[1;37m$_ns\033[0m"
    [[ -n "$_port" ]] && echo -e "\033[1;33m  Puerto   : \033[1;37m$_port (destino)\033[0m"
    echo ""
}

_slowdns_actualizar() {
    echo -e "\033[1;33mActualizando SlowDNS...\033[0m"
    mkdir -p /etc/slowdns/ssh
    cd /etc/slowdns
    wget -q "${_REPO_RAW}/Modulos/slowdns/dns-server"       -O dns-server       && chmod +x dns-server
    wget -q "${_REPO}/Modulos/slowdns/slowdns-instalar"      -O slowdns-instalar && chmod +x slowdns-instalar
    wget -q "${_REPO}/Modulos/slowdns/slowdns-info"          -O slowdns-info     && chmod +x slowdns-info
    wget -q "${_REPO}/Modulos/slowdns/remove-slow"           -O remove-slow      && chmod +x remove-slow
    wget -q "${_REPO}/Modulos/slowdns/stopdns"               -O stopdns          && chmod +x stopdns
    wget -q "${_REPO}/Modulos/slowdns/ssh/startdns"          -O ssh/startdns     && chmod +x ssh/startdns
    wget -q "${_REPO}/Modulos/slowdns/ssh/restartdns"        -O ssh/restartdns   && chmod +x ssh/restartdns
    ln -sf /etc/slowdns/ssh/startdns   /etc/slowdns/startdns
    ln -sf /etc/slowdns/ssh/restartdns /etc/slowdns/restartdns
    wget -q "${_REPO}/Modulos/slowdns/slowdns" -O /bin/slowdns && chmod +x /bin/slowdns
    cp -f /bin/slowdns /etc/slowdns/slowdns
    echo -e "\033[1;32m✓ SlowDNS actualizado correctamente.\033[0m"
    sleep 2
}

slowdns_menu() {
    _slowdns_header
    echo -e "\033[1;34m╔══════════════════════════════════════════════════╗\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m01\033[1;31m]\033[1;37m Instalar / Reconfigurar SlowDNS          \033[1;34m║\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m02\033[1;31m]\033[1;37m Ver información (NS + Key + Comando)     \033[1;34m║\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m03\033[1;31m]\033[1;37m Iniciar SlowDNS                          \033[1;34m║\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m04\033[1;31m]\033[1;37m Reiniciar SlowDNS                        \033[1;34m║\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m05\033[1;31m]\033[1;37m Detener SlowDNS                          \033[1;34m║\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m06\033[1;31m]\033[1;37m Remover SlowDNS completamente            \033[1;34m║\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m07\033[1;31m]\033[1;37m Actualizar SlowDNS                       \033[1;34m║\033[0m"
    echo -e "\033[1;34m║\033[1;31m[\033[1;36m00\033[1;31m]\033[1;37m Salir                                    \033[1;34m║\033[0m"
    echo -e "\033[1;34m╚══════════════════════════════════════════════════╝\033[0m"
    echo ""
    echo -ne "\033[1;32m¿Qué deseas hacer?: \033[1;37m" && read opcao

    case $opcao in
        1|01) bash /etc/slowdns/slowdns-instalar; slowdns_menu ;;
        2|02) bash /etc/slowdns/slowdns-info; slowdns_menu ;;
        3|03)
            echo -e "\n\033[1;33mIniciando SlowDNS...\033[0m"
            bash /etc/slowdns/startdns
            slowdns_menu
            ;;
        4|04)
            echo -e "\n\033[1;33mReiniciando SlowDNS...\033[0m"
            bash /etc/slowdns/restartdns
            slowdns_menu
            ;;
        5|05)
            bash /etc/slowdns/stopdns
            slowdns_menu
            ;;
        6|06)
            echo -ne "\n\033[1;31m¿Seguro que deseas eliminar SlowDNS? [s/N]: \033[1;37m"
            read _cfm
            if [[ "$_cfm" =~ ^[sSyY]$ ]]; then
                bash /etc/slowdns/stopdns
                bash /etc/slowdns/remove-slow
                echo -e "\n\033[1;32mSlowDNS eliminado. Saliendo...\033[0m"
                sleep 2
                exit 0
            fi
            slowdns_menu
            ;;
        7|07)
            _slowdns_actualizar
            slowdns_menu
            ;;
        0|00) exit 0 ;;
        *) echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1; slowdns_menu ;;
    esac
}

# Punto de entrada
slowdns_menu
