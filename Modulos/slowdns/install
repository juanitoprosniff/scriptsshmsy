#!/bin/bash
# ============================================================
# Instalador de SlowDNS Manager вЂ” MSYVPN-SCRIPT
# Descarga archivos desde el repositorio oficial del proyecto
# ============================================================
_REPO="https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main"
_REPO_RAW="https://github.com/juanitoprosniff/scriptsshmsy/raw/main"

fun_bar() {
    local _cmd="$1"
    (
        [[ -e $HOME/fim ]] && rm $HOME/fim
        $_cmd >/dev/null 2>&1
        touch $HOME/fim
    ) >/dev/null 2>&1 &
    tput civis
    echo -ne "  \033[1;33mESPERE \033[1;37m- \033[1;33m["
    while true; do
        for((i=0; i<18; i++)); do echo -ne "\033[1;31m#"; sleep 0.1s; done
        [[ -e $HOME/fim ]] && rm $HOME/fim && break
        echo -e "\033[1;33m]"; sleep 1s; tput cuu1; tput dl1
        echo -ne "  \033[1;33mESPERE \033[1;37m- \033[1;33m["
    done
    echo -e "\033[1;33m]\033[1;37m -\033[1;32m OK !\033[1;37m"
    tput cnorm
}

clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
tput setaf 7 ; tput setab 4 ; tput bold ; printf '%40s%s%-12s\n' "INSTALADOR SLOWDNS MANAGER" ; tput sgr0
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
echo -e "  Instalando SlowDNS Manager para MSYVPN-SCRIPT"
echo ""

echo -e "DESCARGANDO ARCHIVOS..."
_install_files() {
    apt-get install -y screen cron iptables >/dev/null 2>&1
    mkdir -p /etc/slowdns/ssh
    cd /etc/slowdns

    wget -q "${_REPO_RAW}/Modulos/slowdns/dns-server" -O dns-server
    chmod +x dns-server

    wget -q "${_REPO}/Modulos/slowdns/slowdns-instalar" -O slowdns-instalar && chmod +x slowdns-instalar
    wget -q "${_REPO}/Modulos/slowdns/slowdns-info"     -O slowdns-info     && chmod +x slowdns-info
    wget -q "${_REPO}/Modulos/slowdns/remove-slow"      -O remove-slow      && chmod +x remove-slow
    wget -q "${_REPO}/Modulos/slowdns/stopdns"          -O stopdns          && chmod +x stopdns

    wget -q "${_REPO}/Modulos/slowdns/ssh/startdns"     -O ssh/startdns   && chmod +x ssh/startdns
    wget -q "${_REPO}/Modulos/slowdns/ssh/restartdns"   -O ssh/restartdns && chmod +x ssh/restartdns
    ln -sf /etc/slowdns/ssh/startdns   /etc/slowdns/startdns
    ln -sf /etc/slowdns/ssh/restartdns /etc/slowdns/restartdns

    wget -q "${_REPO}/Modulos/slowdns/slowdns" -O slowdns && chmod +x slowdns
    cp -f slowdns /bin/slowdns
}
fun_bar '_install_files'

echo -e "ABRIENDO PUERTOS UDP..."
_open_ports() {
    iptables -I INPUT -p udp --dport 53   -j ACCEPT 2>/dev/null
    iptables -I INPUT -p udp --dport 5300 -j ACCEPT 2>/dev/null
}
fun_bar '_open_ports'

clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
tput setaf 7 ; tput setab 4 ; tput bold ; printf '%40s%s%-12s\n' "INSTALADOR SLOWDNS MANAGER" ; tput sgr0
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
echo -e "  \033[1;32mINSTALACIГ“N COMPLETA!\033[0m"
echo ""
echo -e "  Para abrir el menГє use el comando: \033[1;33mslowdns\033[0m"
echo ""
cd /root
rm -f install
