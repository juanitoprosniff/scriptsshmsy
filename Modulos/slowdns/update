#!/bin/bash
# Actualiza todos los archivos de SlowDNS desde el repositorio de MSYVPN-SCRIPT
_REPO="https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main"
_REPO_RAW="https://github.com/juanitoprosniff/scriptsshmsy/raw/main"

echo ""
echo -e "\033[1;33mACTUALIZANDO SLOWDNS...\033[0m"
echo ""

cd /etc/slowdns 2>/dev/null || { echo -e "\033[1;31m✗ SlowDNS no está instalado.\033[0m"; exit 1; }

# Detener servicio
screen -ls 2>/dev/null | grep 'slowdns' | awk '{print $1}' | xargs -I{} screen -X -S {} quit 2>/dev/null
pkill -f 'dns-server' 2>/dev/null
sleep 1

# Actualizar binario y scripts
wget -q "${_REPO_RAW}/Modulos/slowdns/dns-server"       -O dns-server       && chmod +x dns-server
wget -q "${_REPO}/Modulos/slowdns/slowdns-instalar"      -O slowdns-instalar && chmod +x slowdns-instalar
wget -q "${_REPO}/Modulos/slowdns/slowdns-info"          -O slowdns-info     && chmod +x slowdns-info
wget -q "${_REPO}/Modulos/slowdns/remove-slow"           -O remove-slow      && chmod +x remove-slow
wget -q "${_REPO}/Modulos/slowdns/stopdns"               -O stopdns          && chmod +x stopdns

mkdir -p ssh
wget -q "${_REPO}/Modulos/slowdns/ssh/startdns"   -O ssh/startdns   && chmod +x ssh/startdns
wget -q "${_REPO}/Modulos/slowdns/ssh/restartdns"  -O ssh/restartdns && chmod +x ssh/restartdns
ln -sf /etc/slowdns/ssh/startdns   /etc/slowdns/startdns
ln -sf /etc/slowdns/ssh/restartdns /etc/slowdns/restartdns

wget -q "${_REPO}/Modulos/slowdns/slowdns" -O /bin/slowdns && chmod +x /bin/slowdns
cp -f /bin/slowdns /etc/slowdns/slowdns

echo -e "\033[1;32m✓ SlowDNS actualizado correctamente.\033[0m"
echo ""

# Reiniciar si estaba instalado
if [[ -f /etc/slowdns/infons ]]; then
    /etc/slowdns/startdns >/dev/null 2>&1 &
    echo -e "\033[1;32m✓ SlowDNS reiniciado.\033[0m"
fi
echo ""
sleep 3
