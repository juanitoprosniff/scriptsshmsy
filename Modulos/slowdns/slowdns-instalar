#!/bin/bash
# ============================================================
# Instalador Unificado SlowDNS вЂ” MSYVPN-SCRIPT
# Reemplaza slowdns-ssh y slowdns-drop
# El puerto destino es configurable (SSH port 22, Dropbear, etc.)
# ============================================================
_REPO="https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main"
_REPO_RAW="https://github.com/juanitoprosniff/scriptsshmsy/raw/main"

fun_bar() {
    local _cmd="$1"
    (
        [[ -e $HOME/fim ]] && rm $HOME/fim
        $_cmd >/dev/null 2>&1
        touch $HOME/fim
    ) >/dev/null 2>&1 &
    tput civis
    echo -ne "  \033[1;33mESPERE \033[1;37m- \033[1;33m["
    while true; do
        for((i=0; i<18; i++)); do echo -ne "\033[1;31m#"; sleep 0.1s; done
        [[ -e $HOME/fim ]] && rm $HOME/fim && break
        echo -e "\033[1;33m]"; sleep 1s; tput cuu1; tput dl1
        echo -ne "  \033[1;33mESPERE \033[1;37m- \033[1;33m["
    done
    echo -e "\033[1;33m]\033[1;37m -\033[1;32m OK !\033[1;37m"
    tput cnorm
}

clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
tput setaf 7 ; tput setab 4 ; tput bold ; printf '%40s%s%-12s\n' "INSTALAR SLOWDNS" ; tput sgr0
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
echo -e "  SlowDNS crea un tГєnel DNS que permite conectarse"
echo -e "  al servidor a travГ©s del puerto UDP 53."
echo ""

# 1. Instalar dependencias
echo -e "INSTALANDO DEPENDENCIAS..."
_install_deps() {
    apt-get install -y screen cron iptables >/dev/null 2>&1
    service cron start >/dev/null 2>&1
    systemctl enable cron >/dev/null 2>&1
}
fun_bar '_install_deps'

# 2. Descargar binario si no existe
echo -e "VERIFICANDO BINARIO DNS..."
if [[ ! -x /etc/slowdns/dns-server ]]; then
    _download_bin() {
        mkdir -p /etc/slowdns
        cd /etc/slowdns
        wget -q "${_REPO_RAW}/Modulos/slowdns/dns-server" -O dns-server
        chmod +x dns-server
    }
    fun_bar '_download_bin'
fi

# 3. Detectar y mostrar puertos SSH/Dropbear disponibles
echo ""
echo -e "\033[1;33mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;33m     PUERTOS SSH/DROPBEAR DETECTADOS\033[0m"
echo -e "\033[1;33mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"

_ssh_port=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | head -1 | awk '{print $2}')
[[ -z "$_ssh_port" ]] && _ssh_port="22"
echo -e "\033[1;32m  OpenSSH            :\033[1;37m ${_ssh_port}\033[0m"

for _db_svc in dropbear dropbear-legacy dropbear-2016 dropbear-2020 dropbear-2022; do
    if systemctl is-active --quiet "$_db_svc" 2>/dev/null; then
        _db_p=$(systemctl show "$_db_svc" --property=ExecStart 2>/dev/null | grep -oP '(?<=-p )\d+' | head -1)
        [[ -n "$_db_p" ]] && echo -e "\033[1;32m  Dropbear ($_db_svc) :\033[1;37m $_db_p\033[0m"
    fi
done

_drop_ss=$(ss -tlpn 2>/dev/null | grep 'dropbear' | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | tr '\n' ' ')
[[ -n "$_drop_ss" ]] && echo -e "\033[1;32m  Dropbear (activos) :\033[1;37m $_drop_ss\033[0m"

echo -e "\033[1;33mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""

# 4. Seleccionar puerto destino
echo -e "\033[1;37m  SlowDNS redirige conexiones UDP-DNS al puerto"
echo -e "  SSH o Dropbear que elijas.\033[0m"
echo ""
echo -e "  \033[1;36m[22  ]\033[1;37m OpenSSH (por defecto)"
echo -e "  \033[1;36m[8080]\033[1;37m Dropbear estГЎndar"
echo -e "  \033[1;36m[    ]\033[1;37m O escribe cualquier puerto"
echo ""
echo -ne "\033[1;32mPUERTO DESTINO \033[1;33m[Enter = 22]\033[1;32m: \033[1;37m"
read _dest_port
[[ -z "$_dest_port" ]] && _dest_port="22"
[[ ! "$_dest_port" =~ ^[0-9]+$ ]] && _dest_port="22"
echo -e "\033[1;32mвњ“ Puerto destino seleccionado: \033[1;37m${_dest_port}\033[0m"

# 5. Pedir NS (Nameserver)
echo ""
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;31m  ATENCIГ“N вЂ” NAMESERVER (NS)\033[0m"
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo -e "\033[1;37m  El NS es el subdominio apuntando a este servidor."
echo -e "  Ejemplo: ns1.tudominio.com"
echo ""
echo -ne "\033[1;32mNAMESERVER (NS): \033[1;37m"
read _nameserver
[[ -z "$_nameserver" ]] && { echo -e "\033[1;31mвњ— El NS no puede estar vacГ­o. Abortando.\033[0m"; sleep 2; exit 1; }
echo -e "\033[1;32mвњ“ NS: \033[1;37m${_nameserver}\033[0m"

# Guardar configuraciГіn
mkdir -p /etc/slowdns
echo "$_nameserver" > /etc/slowdns/infons
echo "$_dest_port"  > /etc/slowdns/infopuerto

# 6. Descargar scripts de inicio
echo ""
echo -e "DESCARGANDO SCRIPTS DE INICIO..."
_download_scripts() {
    mkdir -p /etc/slowdns/ssh
    cd /etc/slowdns
    wget -q "${_REPO}/Modulos/slowdns/ssh/startdns"   -O ssh/startdns   && chmod +x ssh/startdns
    wget -q "${_REPO}/Modulos/slowdns/ssh/restartdns"  -O ssh/restartdns && chmod +x ssh/restartdns
    ln -sf /etc/slowdns/ssh/startdns   /etc/slowdns/startdns
    ln -sf /etc/slowdns/ssh/restartdns /etc/slowdns/restartdns
    cp -f ssh/startdns   /bin/startdns   2>/dev/null
    cp -f ssh/restartdns /bin/restartdns 2>/dev/null
}
fun_bar '_download_scripts'

# 7. Configurar iptables de forma segura (sin reemplazar rc.local)
echo -e "CONFIGURANDO IPTABLES Y ARRANQUE AUTOMГЃTICO..."
_setup_iptables() {
    # Aplicar reglas ahora mismo
    iptables -I INPUT  -p udp --dport 5300 -j ACCEPT 2>/dev/null
    iptables -t nat -I PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null

    # Agregar a rc.local solo si no estГЎn ya
    if [[ -f /etc/rc.local ]]; then
        if ! grep -q 'SLOWDNS_IPTABLES' /etc/rc.local 2>/dev/null; then
            # Insertar antes del 'exit 0' final
            sed -i '/^exit 0/i # SLOWDNS_IPTABLES вЂ” MSYVPN-SCRIPT\niptables -I INPUT -p udp --dport 5300 -j ACCEPT\niptables -t nat -I PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300' /etc/rc.local
        fi
    else
        cat > /etc/rc.local <<'RCEOF'
#!/bin/sh -e
# SLOWDNS_IPTABLES вЂ” MSYVPN-SCRIPT
iptables -I INPUT -p udp --dport 5300 -j ACCEPT
iptables -t nat -I PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300
exit 0
RCEOF
        chmod +x /etc/rc.local
    fi
    systemctl enable rc-local 2>/dev/null
    systemctl start  rc-local 2>/dev/null

    # Agregar a /etc/autostart para reinicio de servicios
    [[ ! -f /etc/autostart ]] && touch /etc/autostart
    sed -i '/startdns\|slowdns.*dns-server/d' /etc/autostart 2>/dev/null
    echo "ps aux | grep -v grep | grep -q 'dns-server' || /etc/slowdns/startdns" >> /etc/autostart
}
fun_bar '_setup_iptables'

# 8. Manejar clave (key)
echo ""
cd /root
key1="/root/server.key"
key2="/root/server.pub"
echo -e "VERIFICANDO CLAVE..."

if [[ -f "$key1" && -f "$key2" ]]; then
    echo ""
    echo -e "\033[1;32mвњ“ Clave existente encontrada.\033[0m"
    echo ""
    echo -e "  \033[1;36m[1]\033[1;37m Usar clave existente \033[1;33m(recomendado)\033[0m"
    echo -e "  \033[1;36m[2]\033[1;37m Generar nueva clave"
    echo -e "  \033[1;36m[3]\033[1;37m Usar clave predeterminada del repositorio"
    echo ""
    echo -ne "\033[1;32mOpciГіn \033[1;33m[1]\033[1;32m: \033[1;37m"
    read _key_opt
    [[ -z "$_key_opt" ]] && _key_opt="1"

    case "$_key_opt" in
        2)
            echo -e "Generando nueva clave..."
            rm -f server.key server.pub
            /etc/slowdns/dns-server -gen-key -privkey-file /root/server.key -pubkey-file /root/server.pub
            ;;
        3)
            echo -e "Descargando clave predeterminada..."
            rm -f server.key server.pub
            wget -q "${_REPO}/Modulos/slowdns/server.key" -O /root/server.key
            wget -q "${_REPO}/Modulos/slowdns/server.pub"  -O /root/server.pub
            ;;
        *)
            echo -e "\033[1;32mUsando clave existente.\033[0m"
            ;;
    esac
else
    echo -e "\033[1;33mNo hay clave registrada. ВїCГіmo deseas obtenerla?\033[0m"
    echo ""
    echo -e "  \033[1;36m[1]\033[1;37m Generar nueva clave \033[1;33m(recomendado)\033[0m"
    echo -e "  \033[1;36m[2]\033[1;37m Usar clave predeterminada del repositorio"
    echo ""
    echo -ne "\033[1;32mOpciГіn \033[1;33m[1]\033[1;32m: \033[1;37m"
    read _key_opt
    [[ -z "$_key_opt" ]] && _key_opt="1"

    case "$_key_opt" in
        2)
            echo -e "Descargando clave predeterminada..."
            wget -q "${_REPO}/Modulos/slowdns/server.key" -O /root/server.key
            wget -q "${_REPO}/Modulos/slowdns/server.pub"  -O /root/server.pub
            ;;
        *)
            echo -e "Generando nueva clave..."
            /etc/slowdns/dns-server -gen-key -privkey-file /root/server.key -pubkey-file /root/server.pub
            ;;
    esac
fi

# 9. Iniciar servicio
echo ""
echo -e "INICIANDO SLOWDNS..."
_start_slowdns() {
    screen -ls 2>/dev/null | grep 'slowdns' | awk '{print $1}' | xargs -I{} screen -X -S {} quit 2>/dev/null
    pkill -f 'dns-server' 2>/dev/null
    sleep 1
    /etc/slowdns/startdns >/dev/null 2>&1
}
fun_bar '_start_slowdns'

# 10. Resultado final
clear
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
tput setaf 7 ; tput setab 4 ; tput bold ; printf '%40s%s%-12s\n' "вњ“ SLOWDNS INSTALADO" ; tput sgr0
echo -e "\033[1;31mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m"
echo ""
echo -e "\033[1;33m  NS (Nameserver)  : \033[1;37m${_nameserver}\033[0m"
echo -e "\033[1;33m  Puerto destino   : \033[1;37m${_dest_port}\033[0m"

if [[ -f /root/server.pub ]]; then
    _key_val=$(cat /root/server.pub 2>/dev/null)
    echo -e "\033[1;33m  Clave pГєblica    : \033[1;37m${_key_val}\033[0m"
    echo ""
    echo -e "\033[1;33m  Comando cliente  : \033[1;37mslowdns ${_nameserver} ${_key_val}\033[0m"
fi
echo ""
echo -e "\033[1;33m  La clave estГЎ guardada en: /root/server.pub\033[0m"
echo -e "\033[1;33m  GuГЎrdala en un lugar seguro.\033[0m"
echo ""
read -p "Presione [Enter] para continuar"
