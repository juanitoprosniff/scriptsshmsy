# ============================================================
# FIX ENHANCED HTTP CUSTOM
# ============================================================
# PROBLEMA: Cuando HTTP Custom usa modo "Enhanced", envía una
# solicitud HTTP con cabeceras adicionales antes del handshake
# WebSocket/SSH. El proxy Python estándar responde con datos SSH
# directamente, causando "Illegal packet size! (1231976033)"
# que en hex es 0x496E7661 = "Inva" (inicio de "Invalid packet")
#
# SOLUCIÓN: El proxy WebSocket debe responder primero con un
# HTTP 200/101 cuando detecte una petición HTTP entrante,
# antes de pasar el tráfico SSH.
# ============================================================
_fix_enhanced_http_custom() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m      FIX ENHANCED — HTTP CUSTOM             \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""
    echo -e "\033[1;33mEste fix soluciona el error:\033[0m"
    echo -e "\033[1;37mConnection lost: Illegal packet size! (1231976033)\033[0m"
    echo -e "\033[1;37mque ocurre con modo Enhanced activado en HTTP Custom.\033[0m"
    echo ""
    echo -e "\033[1;32mEl problema: Enhanced envía cabeceras HTTP antes del\033[0m"
    echo -e "\033[1;32mtúnel SSH. El proxy debe responder HTTP 200/101 primero.\033[0m"
    echo ""
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mAplicar fix en proxy.py (SOCKS SSH)   \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mAplicar fix en wsproxy.py (WebSocket)  \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mAplicar fix en AMBOS                   \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mVer estado actual de los scripts       \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                                 \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read enh_opt

    case "$enh_opt" in
    1) _aplicar_fix_enhanced "proxy.py" ;;
    2) _aplicar_fix_enhanced "wsproxy.py" ;;
    3) _aplicar_fix_enhanced "proxy.py"; _aplicar_fix_enhanced "wsproxy.py" ;;
    4)
        echo ""
        for sc in proxy.py wsproxy.py; do
            if [[ -f /etc/SSHPlus/$sc ]]; then
                if grep -q "HTTP/1.1 200\|HTTP/1.1 101\|enhanced\|ENHANCED\|_handle_http" /etc/SSHPlus/$sc 2>/dev/null; then
                    echo -e "\033[1;32m✓ $sc — fix Enhanced YA APLICADO\033[0m"
                else
                    echo -e "\033[1;31m✕ $sc — fix Enhanced NO aplicado\033[0m"
                fi
            else
                echo -e "\033[1;33m? $sc — archivo no encontrado en /etc/SSHPlus/\033[0m"
            fi
        done
        echo ""
        echo -ne "\033[1;31mENTER \033[1;37mpara volver...\033[0m"; read
        _fix_enhanced_http_custom
        ;;
    0) fun_socks ;;
    *) echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1; _fix_enhanced_http_custom ;;
    esac
}

_aplicar_fix_enhanced() {
    local script="$1"
    local ruta="/etc/SSHPlus/$script"

    if [[ ! -f "$ruta" ]]; then
        echo -e "\033[1;31mArchivo $ruta no encontrado.\033[0m"
        echo -e "\033[1;33mAsegúrese de que el proxy esté instalado primero.\033[0m"
        sleep 2; return
    fi

    # Verificar si ya tiene el fix
    if grep -q "_handle_http_enhanced\|HTTP/1.1 200 Connection established\|HTTP/1.1 101 Switching" "$ruta" 2>/dev/null; then
        echo -e "\033[1;32m✓ $script ya tiene el fix Enhanced aplicado.\033[0m"
        sleep 2; return
    fi

    # Crear backup
    cp "$ruta" "${ruta}.bak.$(date +%Y%m%d%H%M%S)"
    echo -e "\033[1;33mBackup creado: ${ruta}.bak\033[0m"

    # Insertar función de manejo Enhanced al inicio del script Python
    # Este parche detecta cabeceras HTTP y responde correctamente
    python3 - "$ruta" <<'PYEOF'
import sys, re

path = sys.argv[1]
with open(path, 'r') as f:
    content = f.read()

# Código del fix Enhanced a insertar
fix_code = '''
# ── FIX ENHANCED HTTP CUSTOM ──────────────────────────────────
# Detecta si el cliente envía cabeceras HTTP antes del túnel SSH
# (modo Enhanced de HTTP Custom). Responde con HTTP 200/101 y
# luego pasa el control al handler original.
def _handle_http_enhanced(conn):
    """
    Devuelve True si se detectó y procesó una petición HTTP,
    False si el tráfico ya es SSH directo.
    """
    import socket
    try:
        conn.settimeout(3)
        primer_byte = conn.recv(4, socket.MSG_PEEK)
        conn.settimeout(None)
        if not primer_byte:
            return False
        # SSH comienza con "SSH-", HTTP con GET/POST/CONNECT etc.
        if primer_byte[:4] in (b"SSH-", b"\\x00\\x00\\x00"):
            return False  # tráfico SSH normal
        # Detectar método HTTP
        if primer_byte[:3] in (b"GET", b"POS", b"CON", b"HEA", b"PUT"):
            # Leer la petición HTTP completa (hasta \\r\\n\\r\\n)
            buf = b""
            conn.settimeout(5)
            while b"\\r\\n\\r\\n" not in buf:
                chunk = conn.recv(4096)
                if not chunk:
                    break
                buf += chunk
            conn.settimeout(None)
            # Determinar tipo de respuesta según cabecera
            if b"Upgrade: websocket" in buf or b"upgrade: websocket" in buf:
                # Respuesta WebSocket Upgrade (101)
                import hashlib, base64
                ws_key = b""
                for line in buf.split(b"\\r\\n"):
                    if b"Sec-WebSocket-Key:" in line:
                        ws_key = line.split(b": ")[1].strip()
                        break
                if ws_key:
                    magic = b"258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
                    accept = base64.b64encode(
                        hashlib.sha1(ws_key + magic).digest()
                    ).decode()
                    resp = (
                        "HTTP/1.1 101 Switching Protocols\\r\\n"
                        "Upgrade: websocket\\r\\n"
                        "Connection: Upgrade\\r\\n"
                        f"Sec-WebSocket-Accept: {accept}\\r\\n"
                        "\\r\\n"
                    )
                else:
                    resp = "HTTP/1.1 101 Switching Protocols\\r\\nUpgrade: websocket\\r\\nConnection: Upgrade\\r\\n\\r\\n"
                conn.sendall(resp.encode())
            elif b"CONNECT" in buf[:8]:
                # CONNECT proxy (túnel directo)
                conn.sendall(b"HTTP/1.1 200 Connection Established\\r\\n\\r\\n")
            else:
                # Respuesta genérica HTTP 200 para Enhanced/payload
                conn.sendall(
                    b"HTTP/1.1 200 OK\\r\\n"
                    b"Content-Type: text/html\\r\\n"
                    b"Connection: keep-alive\\r\\n"
                    b"\\r\\n"
                )
            return True
    except Exception:
        pass
    finally:
        try:
            conn.settimeout(None)
        except Exception:
            pass
    return False
# ── FIN FIX ENHANCED ─────────────────────────────────────────
'''

# Insertar después de los imports, antes de la primera función/clase
# Buscar primer def o class o bloque principal
insert_pos = 0
lines = content.split('\n')
for i, line in enumerate(lines):
    if line.startswith('def ') or line.startswith('class ') or (line.startswith('import ') and i > 5):
        insert_pos = i
        break

if insert_pos > 0:
    lines.insert(insert_pos, fix_code)
    new_content = '\n'.join(lines)
else:
    new_content = fix_code + '\n' + content

# Parchear el handler de conexión para llamar al fix
# Buscar patrones comunes de accept/handle
new_content = re.sub(
    r'(conn,\s*addr\s*=\s*server\.accept\(\))',
    r'\1\n        if _handle_http_enhanced(conn): pass  # FIX Enhanced',
    new_content
)

with open(path, 'w') as f:
    f.write(new_content)
print("OK")
PYEOF

    if [[ $? -eq 0 ]]; then
        echo -e "\033[1;32m✓ Fix Enhanced aplicado en $script\033[0m"
        # Reiniciar sesiones activas del script
        for pid in $(screen -ls 2>/dev/null | grep "${script%.*}" | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        screen -wipe >/dev/null 2>&1
        echo -e "\033[1;33mReinicie el proxy desde la opción 1 o 2 del menú Socks.\033[0m"
    else
        echo -e "\033[1;31mError al aplicar el fix. Revise el script manualmente.\033[0m"
        # Restaurar backup si falló
        ls "${ruta}.bak."* 2>/dev/null | tail -1 | xargs -I{} cp {} "$ruta" 2>/dev/null
    fi
    sleep 3
}

