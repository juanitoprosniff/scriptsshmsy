# MENÚ PRINCIPAL DE CONEXIÓN
# ============================================================

# ============================================================
# CREAR USUARIO — compatible con Dropbear 2016 y OpenSSH
# Dropbear 2016 no usa PAM extendido, pero sí /etc/shadow.
# El problema usual: passwd interactivo falla en scripts,
# usar chpasswd que escribe directo en /etc/shadow.
# ============================================================
criarusuario() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m            CRIAR USUÁRIO SSH             \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""

    # Mostrar puertos activos de todos los servicios SSH
    echo -e "\033[1;33m━━━━━ PUERTOS ACTIVOS ━━━━━\033[0m"
    _ssh_p=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | xargs)
    [[ -n "$_ssh_p" ]] && echo -e "\033[1;32mOpenSSH  :\033[1;37m $_ssh_p"

    # Dropbear normal
    _db_p=$(ss -tlpn 2>/dev/null | grep 'dropbear' | grep -v 'dropbear-legacy\|legacy' | \
            awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
    [[ -n "$_db_p" ]] && echo -e "\033[1;32mDropbear :\033[1;37m $_db_p"

    # Dropbear 2016 (legacy)
    _db16_p=$(systemctl show dropbear-legacy --property=ExecStart 2>/dev/null | \
              grep -oP '(?<=-p )\d+' | head -1)
    [[ -z "$_db16_p" ]] && _db16_p=$(ss -tlpn 2>/dev/null | grep 'legacy' | \
              awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
    [[ -n "$_db16_p" ]] && echo -e "\033[1;32mDB 2016  :\033[1;37m $_db16_p"

    # Proxy Socks / WebSocket
    _py_p=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
            awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
    [[ -n "$_py_p" ]] && echo -e "\033[1;32mProxy/WS :\033[1;37m $_py_p"

    # SSL Stunnel
    _ssl_p=$(ss -tlpn 2>/dev/null | grep 'stunnel' | \
             awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
    [[ -n "$_ssl_p" ]] && echo -e "\033[1;32mSSL      :\033[1;37m $_ssl_p"

    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""

    echo -ne "\033[1;32mUSUÁRIO : \033[1;37m"; read usuario
    [[ -z "$usuario" ]] && { echo -e "\033[1;31mUsuario vacío!\033[0m"; sleep 2; return; }

    # Verificar si ya existe
    if id "$usuario" &>/dev/null; then
        echo -e "\033[1;31mUsuario '$usuario' ya existe!\033[0m"; sleep 2; return
    fi

    echo -ne "\033[1;32mSENHA   : \033[1;37m"; read -s senha; echo ""
    [[ -z "$senha" ]] && { echo -e "\033[1;31mContraseña vacía!\033[0m"; sleep 2; return; }

    echo -ne "\033[1;32mDIAS    : \033[1;37m"; read dias
    [[ -z "$dias" ]] && dias=30

    # Crear usuario con home y shell bash
    # useradd -m -s /bin/bash: crea home, asigna bash
    # Dropbear 2016 autentica via /etc/shadow, esto lo genera chpasswd
    useradd -m -s /bin/bash "$usuario" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "\033[1;31mError creando usuario!\033[0m"; sleep 2; return
    fi

    # Establecer contraseña con chpasswd (compatible con Dropbear 2016)
    # Nota: NO usar 'passwd usuario' en scripts porque requiere TTY interactivo
    echo "${usuario}:${senha}" | chpasswd 2>/dev/null
    if [[ $? -ne 0 ]]; then
        # Fallback: openssl passwd + usermod
        _hash=$(openssl passwd -6 "$senha" 2>/dev/null || openssl passwd -1 "$senha")
        usermod -p "$_hash" "$usuario" 2>/dev/null
    fi

    # Establecer fecha de expiración
    _exp_date=$(date -d "+${dias} days" +%Y-%m-%d 2>/dev/null || \
                date -v +${dias}d +%Y-%m-%d 2>/dev/null)
    [[ -n "$_exp_date" ]] && chage -E "$_exp_date" "$usuario" 2>/dev/null

    # Guardar en registro SSHPlus si existe
    [[ -d /etc/SSHPlus ]] && echo "$usuario $dias" >> /etc/SSHPlus/usuarios 2>/dev/null

    echo ""
    echo -e "\033[1;32m✓ Usuario creado exitosamente!\033[0m"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;32mUsuario  :\033[1;37m $usuario"
    echo -e "\033[1;32mExpira   :\033[1;37m ${_exp_date:-en $dias días}"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;33m  PUERTOS PARA CONECTAR:\033[0m"
    [[ -n "$_ssh_p"  ]] && echo -e "\033[1;37m  SSH  → \033[1;32m$_ssh_p"
    [[ -n "$_db_p"   ]] && echo -e "\033[1;37m  DB   → \033[1;32m$_db_p"
    [[ -n "$_db16_p" ]] && echo -e "\033[1;37m  DB16 → \033[1;32m$_db16_p"
    [[ -n "$_py_p"   ]] && echo -e "\033[1;37m  Proxy→ \033[1;32m$_py_p"
    [[ -n "$_ssl_p"  ]] && echo -e "\033[1;37m  SSL  → \033[1;32m$_ssl_p"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""
}

