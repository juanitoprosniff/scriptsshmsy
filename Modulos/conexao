    echo -e "\033[1;33mRed       : \033[1;37mWebSocket"
    echo -e "\033[1;33mTLS       : \033[1;37mTLS (gestionado por stunnel)"
    echo -e "\033[1;33mSNI/Host  : \033[1;37m(bug host del operador)"
    echo ""
    echo -e "\033[1;35m── REVERSE SNI (Bug as Address) ────────────\033[0m"
    echo -e "\033[1;33mServidor  : \033[1;37m(dirección = bug/SNI del operador)"
    echo -e "\033[1;33mSNI       : \033[1;37m(mismo bug host)"
    echo -e "\033[1;33mHost      : \033[1;37m$_ip"
