        screen -dmS badvpn $_bv_bin --listen-addr 0.0.0.0:$_bvport 2>/dev/null
        _fw_open $_bvport udp
        sed -i '/udpvpn\|badvpn/d' /etc/autostart 2>/dev/null
        echo "ps x | grep -E 'udpvpn|badvpn' | grep -v grep || screen -dmS badvpn $_bv_bin --listen-addr 0.0.0.0:$_bvport" >> /etc/autostart
        sleep 1
        ps x | grep -E 'udpvpn|badvpn' | grep -v grep >/dev/null && \
            echo -e "\n\033[1;32m✓ BAD VPN ACTIVO EN PUERTO UDP $_bvport!\033[0m" || \
            echo -e "\n\033[1;31m⚠ BAD VPN no responde. Verifique la instalación.\033[0m"
        sleep 3; fun_badvpn ;;
    2)
        pkill -f 'udpvpn\|badvpn' 2>/dev/null
        screen -ls 2>/dev/null | grep 'badvpn' | awk '{print $1}' | while read p; do screen -r -S "$p" -X quit 2>/dev/null; done
        sed -i '/udpvpn\|badvpn/d' /etc/autostart 2>/dev/null
        echo -e "\n\033[1;31mBAD VPN DETENIDO!\033[0m"; sleep 2; fun_badvpn ;;
    0) fun_conexao ;;
    *) echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1 ;;
    esac
    done
}

