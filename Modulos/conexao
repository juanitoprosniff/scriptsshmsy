        echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"

        _py_active=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
        [[ -n "$_py_active" ]] && \
            echo -e "\033[1;32mPUERTOS ACTIVOS: \033[1;37m$_py_active\033[0m\n" || \
            echo -e "\033[1;31mNINGГљN PROXY ACTIVO\033[0m\n"

        echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mACTIVAR PROXY SOCKS"
        echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mACTIVAR WEBSOCKET"
        echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mCAMBIAR STATUS"
        echo -e "\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mDETENER PROXIES"
        echo -e "\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER\033[0m"
        echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read resp_sk

        case $resp_sk in
        1|01) _fun_activar_proxy "proxy.py" "PROXY SOCKS" ;;
        2|02) _fun_activar_proxy "wsproxy.py" "WEBSOCKET" ;;
        3|03) _fun_alterar_status "wsproxy.py" "WEBSOCKET" ;;
        4|04)
            for pid in $(screen -ls 2>/dev/null | grep -E '\.proxy|\.ws[0-9]|proxy[0-9]|ws[0-9]' | awk '{print $1}'); do
                screen -r -S "$pid" -X quit 2>/dev/null
            done
            pkill -f "/etc/SSHPlus/proxy.py" 2>/dev/null
            pkill -f "/etc/SSHPlus/wsproxy.py" 2>/dev/null
            screen -wipe >/dev/null 2>&1
            echo -e "\n\033[1;32mProxies detenidos!\033[0m"; sleep 2
            ;;
        0|00) fun_conexao; return ;;
        *) echo -e "\033[1;31mOpciГіn invГЎlida!\033[0m"; sleep 1 ;;
        esac
    done
}

_fun_activar_proxy() {
    local script_file="$1" titulo="$2"
    echo -ne "\n\033[1;32mPUERTO para $titulo: \033[1;37m"; read porta
    [[ -z "$porta" ]] && { fun_socks; return; }
    verif_ptrs "$porta"

    local _use_script="$script_file"
    [[ ! -f /etc/SSHPlus/$_use_script ]] && {
        echo -e "\033[1;31mScript $_use_script no encontrado en /etc/SSHPlus/\033[0m"
        sleep 2; fun_socks; return
    }

    local _screen_pfx="proxy"
    [[ "$script_file" = *"wsproxy"* || "$script_file" = *"ws"* ]] && _screen_pfx="ws"

    screen -dmS "${_screen_pfx}${porta}" python3 /etc/SSHPlus/$_use_script $porta
    echo "screen -dmS ${_screen_pfx}${porta} python3 /etc/SSHPlus/$_use_script $porta" >> /etc/autostart

    sleep 0.5
    if ss -tlpn 2>/dev/null | grep -q ":$porta "; then
        echo -e "\033[1;32mPuerto \033[1;37m$porta \033[1;32mactivado! вњ“\033[0m"
    else
        echo -e "\033[1;33mEsperando inicio del proxy en puerto $porta...\033[0m"
        sleep 1
        ss -tlpn 2>/dev/null | grep -q ":$porta " && \
            echo -e "\033[1;32m  вњ“ Puerto $porta OK\033[0m" || \
            echo -e "\033[1;31m  вњ• Puerto $porta no responde вЂ” verifique $_use_script\033[0m"
    fi
    echo -e "\n\033[1;32m$titulo ACTIVADO EN PUERTO $porta!\033[0m"; sleep 2; fun_socks
}

_fun_alterar_status() {
    local script_file="$1" titulo="$2"
    local _real_script="$script_file"

    if ps x | grep -w "$_real_script" | grep -v grep >/dev/null 2>&1; then
        local _use_script="$_real_script"
        [[ ! -f /etc/SSHPlus/$_use_script ]] && _use_script="$script_file"

        msgsocks=$(grep -E "MSG\s*=" /etc/SSHPlus/$_use_script 2>/dev/null | head -1 | awk -F= '{print $2}' | tr -d "' ")
        echo -e "\E[44;1;37m   STATUS вЂ” $titulo   \E[0m"
        echo -e "\n\033[1;33mSTATUS ACTUAL: \033[1;32m${msgsocks:-sin status}\033[0m"
        echo -ne "\n\033[1;32mNUEVO STATUS: \033[1;37m"; read msgg
        [[ -z "$msgg" ]] && { fun_socks; return; }
        echo -e "\033[1;31m[01] AZUL  [02] VERDE  [03] ROJO   [04] AMARILLO"
        echo -e "[05] ROSA  [06] CIAN   [07] NARANJA [08] MORADO  [10] SIN COLOR\033[0m"
        echo -ne "\033[1;32mCOLOR: \033[1;37m"; read sts_cor
        case "$sts_cor" in
        1|01) cor_sts='blue' ;;   2|02) cor_sts='green' ;;  3|03) cor_sts='red' ;;
        4|04) cor_sts='yellow' ;; 5|05) cor_sts='#F535AA' ;; 6|06) cor_sts='cyan' ;;
        7|07) cor_sts='#FF7F00' ;; 8|08) cor_sts='#9932CD' ;; *) cor_sts='null' ;;
        esac

        msgsocks2=$(grep "MSG\s*=" /etc/SSHPlus/$_use_script | head -1 | awk -F= '{print $2}')
        [[ -n "$msgsocks2" ]] && sed -i "s|$msgsocks2| '$msgg'|" /etc/SSHPlus/$_use_script
        cor_old=$(grep 'color=' /etc/SSHPlus/$_use_script 2>/dev/null | head -1 | cut -d'"' -f2)
        [[ -n "$cor_old" && "$cor_old" != "$cor_sts" ]] && \
            sed -i "s|color=\"$cor_old\"|color=\"$cor_sts\"|g" /etc/SSHPlus/$_use_script

        echo -e "\n\033[1;33mReiniciando proxy para aplicar cambios...\033[0m"
        local _active_ports
        _active_ports=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
            awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)

        local _screen_pfx="proxy"
        [[ "$_use_script" = *"wsproxy"* || "$_use_script" = *"ws"* ]] && _screen_pfx="ws"

        for pid in $(screen -ls 2>/dev/null | grep -E "\.${_screen_pfx}|${_screen_pfx}[0-9]" | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "/etc/SSHPlus/$_use_script" 2>/dev/null
        pkill -f "/etc/SSHPlus/$script_file"  2>/dev/null
        screen -wipe >/dev/null 2>&1
        sleep 1

        if [[ -n "$_active_ports" ]]; then
            for _pt in $_active_ports; do
                screen -dmS "${_screen_pfx}${_pt}" python3 /etc/SSHPlus/$_use_script $_pt
                echo -e "\033[1;32mPuerto \033[1;37m$_pt \033[1;32mreiniciado!\033[0m"
                sleep 0.2
            done
        else
            echo -e "\033[1;33mNo se detectaron puertos activos.\033[0m"
        fi
        echo -e "\n\033[1;32mSTATUS CAMBIADO Y PROXY REINICIADO!\033[0m"; sleep 2; fun_socks
    else
        echo -e "\033[1;31mACTIVE EL $titulo PRIMERO!\033[0m"; sleep 2; fun_socks
    fi
}

reiniciar_proxy_socks() {
    echo -e "\033[1;33mReiniciando Proxy Socks y WebSocket...\033[0m"
    local _reiniciados=0

    if [[ -f /etc/autostart ]]; then
        for pid in $(screen -ls 2>/dev/null | grep -E '\.proxy|\.ws[0-9]|\.openpy|proxy[0-9]|ws[0-9]' | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "/etc/SSHPlus/proxy.py"   2>/dev/null
        pkill -f "/etc/SSHPlus/wsproxy.py" 2>/dev/null
        pkill -f "/etc/SSHPlus/open.py"    2>/dev/null
        screen -wipe >/dev/null 2>&1
        sleep 1

        while IFS= read -r _cmd; do
            [[ "$_cmd" =~ proxy\.py|wsproxy|open\.py ]] && {
                eval "$_cmd" 2>/dev/null
                ((_reiniciados++))
            }
        done < /etc/autostart
    fi

    if [[ $_reiniciados -gt 0 ]]; then
        echo -e "\033[1;32mвњ“ $_reiniciados servicios proxy reiniciados.\033[0m"
    else
        echo -e "\033[1;33mNo hay proxies configurados en autostart.\033[0m"
    fi
}

