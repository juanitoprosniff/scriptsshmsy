               net.ipv4.tcp_mem net.core.netdev_max_backlog \
               net.ipv4.tcp_no_metrics_save net.ipv4.tcp_window_scaling; do
        sed -i "/${_k}/d" /etc/sysctl.conf
    done
    sed -i '/# MSYVPN вЂ” Buffers/d' /etc/sysctl.conf
    echo -e "\033[1;33m  вњ“ Buffers restaurados\033[0m"

    sysctl -p >/dev/null 2>&1
    echo -e "\n\033[1;33mвњ“ ConfiguraciГіn original restaurada.\033[0m"
    sleep 2
