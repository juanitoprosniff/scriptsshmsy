    local _vmess_json="{\"v\":\"2\",\"ps\":\"VPS-VMess-WS\",\"add\":\"${_ip}\",\"port\":\"80\",\"id\":\"${_uuid}\",\"aid\":\"0\",\"scy\":\"auto\",\"net\":\"ws\",\"type\":\"none\",\"host\":\"${_ip}\",\"path\":\"${_ws_path}\",\"tls\":\"\",\"sni\":\"\",\"alpn\":\"\"}"
    local _vmess_b64
    _vmess_b64=$(echo -n "$_vmess_json" | base64 -w 0)
