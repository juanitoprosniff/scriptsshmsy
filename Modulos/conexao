    echo -e "\n\033[1;32m✓ SSL + WEBSOCKET ACTIVO!\033[0m"
    echo -e "\033[1;37mFlujo: Cliente → stunnel(443/444/8443) → wsproxy:${ws_listen_port} → SSH:${ssh_dst_port}\033[0m"
    echo -e "\033[1;33mNota: Clientes SSL DIRECTO también conectan con estos puertos SSL.\033[0m"
    echo -e "\033[1;33m      Si desea SSL DIRECTO independiente, use puertos separados.\033[0m"
