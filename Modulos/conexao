x="ok"
clear
fun_conexao() {
    while true; do
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m             MODO DE CONEXIÓN            \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        _ssh_ports=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | xargs)
        echo -e "\033[1;32mOPENSSH\033[1;31m: \033[1;37m$_ssh_ports"
        _db16_on=$(screen -list 2>/dev/null | grep -c 'dropbear2016')
        [[ "$_db16_on" != '0' ]] && echo -e "\033[1;32mDROPBEAR 2016\033[1;31m: \033[1;37m$(screen -list 2>/dev/null | grep 'dropbear2016' | grep -oP '\d+(?=\.dropbear2016)' | head -1)"

        _py_active=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
        _check_proc 'docker'   && { echo -e "\033[1;32mCHISEL\033[1;31m: \033[1;37m$(get_ports_by_process 'docker')";   sts8="\033[1;32m✓ "; } || sts8="\033[1;31m✕ "
        _check_proc 'sslh'     && { echo -e "\033[1;32mSSLH\033[1;31m: \033[1;37m$(get_ports_by_process 'sslh')";       sts7="\033[1;32m✓ "; } || sts7="\033[1;31m✕ "
        _check_proc 'openvpn'  && { echo -e "\033[1;32mOPENVPN\033[1;31m: \033[1;37m$(get_ports_by_process 'openvpn')"; sts5="\033[1;32m✓ "; } || sts5="\033[1;31m✕ "
        [[ -n "$_py_active" ]]  && { echo -e "\033[1;32mPROXY SOCKS\033[1;31m: \033[1;37m$_py_active"; sts4="\033[1;32m✓ "; } || sts4="\033[1;31m✕ "
        [[ -e "/etc/stunnel/stunnel.conf" ]] && { echo -e "\033[1;32mSSL TUNNEL\033[1;31m: \033[1;37m$(get_ports_by_process 'stunnel')"; sts3="\033[1;32m✓ "; } || sts3="\033[1;31m✕ "
        _check_proc 'dropbear' && { echo -e "\033[1;32mDROPBEAR\033[1;31m: \033[1;37m$(get_ports_by_process 'dropbear')"; sts2="\033[1;32m✓ "; } || sts2="\033[1;31m✕ "
        _check_proc 'squid'    && { echo -e "\033[1;32mSQUID\033[1;31m: \033[1;37m$(get_ports_by_process 'squid')";     sts1="\033[1;32m✓ "; } || sts1="\033[1;31m✕ "
        ps x | grep 'slowdns' | grep -v grep >/dev/null 2>&1 && sts9="\033[1;32m✓ " || sts9="\033[1;31m✕ "
        ss -tlpn 2>/dev/null | grep -q 'v2ray' && xv2ray="\033[1;32m✓ " || xv2ray="\033[1;31m✕ "
        ss -tlpn 2>/dev/null | grep -q 'trojan' && trojansts="\033[1;32m✓ " || trojansts="\033[1;31m✕ "
        command -v hysteria-manager &>/dev/null && hysterasts="\033[1;32m✓ " || hysterasts="\033[1;31m✕ "
        [[ "$_db16_on" != '0' ]] && db16sts="\033[1;32m✓ " || db16sts="\033[1;31m✕ "

        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m01\033[1;31m] \033[1;33mOPENSSH                              \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m02\033[1;31m] \033[1;33mSQUID PROXY $sts1                    \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m03\033[1;31m] \033[1;33mDROPBEAR $sts2                       \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m04\033[1;31m] \033[1;33mOPENVPN $sts5                        \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m05\033[1;31m] \033[1;33mPROXY SOCKS $sts4                    \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m06\033[1;31m] \033[1;33mSSL TUNNEL $sts3                     \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m07\033[1;31m] \033[1;33mSSLH MULTIPLEX $sts7                 \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m08\033[1;31m] \033[1;33mCHISEL $sts8                         \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m09\033[1;31m] \033[1;33mSLOWDNS $sts9                        \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m10\033[1;31m] \033[1;33mV2RAY $xv2ray                          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m11\033[1;31m] \033[1;33mTROJAN-GO $trojansts                   \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m13\033[1;31m] \033[1;33mDROPBEAR 2016 $db16sts                 \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m14\033[1;31m] \033[1;33mHYSTERIA UDP $hysterasts               \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m12\033[1;31m] \033[1;33mVOLVER \033[1;32m<<<                          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m00\033[1;31m] \033[1;33mSALIR \033[1;32m<<<                            \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        tput civis
        echo -ne "\033[1;32mOpción: \033[1;37m"; read x
        tput cnorm
        case $x in
        1|01)  tput reset; clear; fun_openssh ;;
        2|02)  tput reset; clear; fun_squid ;;
        3|03)  tput reset; clear; fun_drop ;;
        4|04)  tput reset; clear; fun_openvpn ;;
        5|05)  tput reset; clear; fun_socks ;;
        6|06)  tput reset; clear; inst_ssl ;;
        7|07)  tput reset; clear; fun_sslh ;;
        8|08)  tput reset; clear; fun_chisel ;;
        9|09)  tput reset; clear; slow_setup ;;
        10)    tput reset; clear; v2raymanager; exit ;;
        11)    tput reset; clear; trojan-go ;;
        12)    tput reset; clear; menu ;;
        13)    tput reset; clear; fun_inst_dropbear2016 ;;
        14)    tput reset; clear; fun_hysteria ;;
        0|00)  tput reset; clear; echo -e "\033[1;31mSaliendo...\033[0m"; sleep 1; exit ;;
        *)     tput reset; clear; echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1 ;;
        esac
    done
}
tput reset
clear
fun_conexao
