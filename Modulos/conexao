    echo -e "\033[0;34m┃\E[44;1;37m   NGINX MULTIPLEX — SSL+WS+SSH mismo puerto   \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""
    echo -e "\033[1;37mEsta opción configura UN puerto que acepta TODO:\033[0m"
    echo -e "\033[1;32m  ✓\033[1;37m SSH directo (Dropbear 2016)"
    echo -e "\033[1;32m  ✓\033[1;37m STUNNEL / SSL puro (HTTP Custom SSL, SSLsocks)"
    echo -e "\033[1;32m  ✓\033[1;37m WebSocket + SSL (HTTP Injector, NapsternetV)"
    echo -e "\033[1;32m  ✓\033[1;37m Enhanced + SSL"
    echo -e "\033[1;32m  ✓\033[1;37m Funciona en puerto 80, 443, 8080, o cualquiera"
    echo ""
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mINSTALAR / RECONFIGURAR       \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mVER ESTADO ACTUAL             \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mELIMINAR CONFIGURACIÓN        \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                        \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read _nx_opt

    case "$_nx_opt" in
