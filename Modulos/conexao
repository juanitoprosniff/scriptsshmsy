_fun_socks_menu_destino() {
    local titulo="$1" screen_prefix="$2" script="$3"
    clear
    echo -e "\E[44;1;37m   $titulo вҖ” CONFIGURAR   \E[0m\n"
    echo -e "\033[1;33mPaso 1 вҖ” Destino:\033[0m\n"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mвҶ’ OpenSSH (22)"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mвҶ’ Dropbear 2016 (143)"
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read dst_sel
    case "$dst_sel" in
    1) _dst_port=22 ;;
    2) _dst_port=143 ;;
    *) echo -e "\033[1;31mOpciГіn invГЎlida!"; sleep 1; fun_socks; return ;;
    esac

    if [[ -f /etc/SSHPlus/$script ]] && [[ -n "$_dst_port" ]]; then
        sed -i "s|DEFAULT_HOST = ['\"]127\.0\.0\.1:[0-9]*['\"]|DEFAULT_HOST = '127.0.0.1:${_dst_port}'|" /etc/SSHPlus/$script 2>/dev/null
    fi

    echo -e "\n\033[1;33mPaso 2 вҖ” Puerto(s) de escucha:\033[0m\n"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mPuerto 80"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mPuerto 8080"
    echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mPuerto 8880"
    echo -e "\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mPuerto 8888"
    echo -e "\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mTODOS (80, 8080, 8880, 8888)"
    echo -e "\033[1;31m[\033[1;36m6\033[1;31m] \033[1;33mPuerto personalizado\033[0m"
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read listen_sel
    case "$listen_sel" in
    1) _listen_ports="80" ;;  2) _listen_ports="8080" ;; 3) _listen_ports="8880" ;;
    4) _listen_ports="8888" ;; 5) _listen_ports="80 8080 8880 8888" ;;
    6) echo -ne "\033[1;32mPUERTO(S): \033[1;37m"; read _listen_ports; [[ -z "$_listen_ports" ]] && { fun_socks; return; } ;;
    *) echo -e "\033[1;31mOpciГіn invГЎlida!"; sleep 1; fun_socks; return ;;
    esac

    sed -i "/$script/d" /etc/autostart 2>/dev/null
    [[ -n "$_dst_port" ]] && echo -e "\033[1;33mDestino: 127.0.0.1:$_dst_port\033[0m"
    echo -e "\033[1;32mIniciando $titulo...\033[0m\n"

    # Argumento de destino para cada instancia вҖ” esto evita el bug donde
    # el sed sobre el archivo afecta a todas las instancias por igual
    local _dst_arg=""
    [[ -n "$_dst_port" ]] && _dst_arg="127.0.0.1:${_dst_port}"

    # Usar wsproxy mejorado si existe
    local _use_script="$script"
    [[ "$script" = "wsproxy.py" && -f /etc/SSHPlus/wsproxy2.py ]] && _use_script="wsproxy2.py"

    for porta in $_listen_ports; do
        verif_ptrs $porta
        # Pasar destino como argumento вҖ” cada instancia independiente de las demГЎs
        screen -dmS ${screen_prefix}${porta} python3 /etc/SSHPlus/$_use_script $porta $_dst_arg
        _fw_open $porta tcp
        # Forzar iptables por si el puerto estГЎ bloqueado a nivel de kernel
        iptables -I INPUT -p tcp --dport $porta -j ACCEPT 2>/dev/null
        echo "ss -tlpn | grep -qw $porta || screen -dmS ${screen_prefix}${porta} python3 /etc/SSHPlus/$_use_script $porta $_dst_arg" >> /etc/autostart
        sleep 0.5
        # Verificar que realmente estГЎ escuchando
        if ss -tlpn 2>/dev/null | grep -q ":$porta "; then
            echo -e "\033[1;32mPuerto \033[1;37m$porta \033[1;32mactivado! вң“\033[0m"
        else
            echo -e "\033[1;33mPuerto \033[1;37m$porta \033[1;33mвҖ” esperando inicio del proxy...\033[0m"
            sleep 1
            ss -tlpn 2>/dev/null | grep -q ":$porta " && \
                echo -e "\033[1;32m  вң“ Puerto $porta OK\033[0m" || \
                echo -e "\033[1;31m  вң• Puerto $porta no responde вҖ” verifique python3 y el script $_use_script\033[0m"
        fi
    done
    echo -e "\n\033[1;32m$titulo ACTIVADO!\033[0m"; sleep 2; fun_socks
}

_fun_alterar_status() {
    local script_file="$1" titulo="$2"
    # Buscar el script activo вҖ” puede ser proxy.py, wsproxy.py, wsproxy2.py
    local _real_script="$script_file"
    [[ "$script_file" = "wsproxy.py" && -f /etc/SSHPlus/wsproxy2.py ]] && \
        ps x | grep -w wsproxy2.py | grep -v grep >/dev/null 2>&1 && _real_script="wsproxy2.py"

    if ps x | grep -w "$_real_script" | grep -v grep >/dev/null 2>&1 || \
       ps x | grep -w "$script_file"  | grep -v grep >/dev/null 2>&1; then

        local _use_script="$_real_script"
        [[ ! -f /etc/SSHPlus/$_use_script ]] && _use_script="$script_file"

        msgsocks=$(grep -E "MSG\s*=" /etc/SSHPlus/$_use_script 2>/dev/null | head -1 | awk -F= '{print $2}' | tr -d "' ")
        echo -e "\E[44;1;37m   STATUS вҖ” $titulo   \E[0m"
        echo -e "\n\033[1;33mSTATUS ACTUAL: \033[1;32m${msgsocks:-sin status}\033[0m"
        echo -ne "\n\033[1;32mNUEVO STATUS: \033[1;37m"; read msgg
        [[ -z "$msgg" ]] && { fun_conexao; return; }
        echo -e "\033[1;31m[01] AZUL  [02] VERDE  [03] ROJO   [04] AMARILLO"
        echo -e "[05] ROSA  [06] CIAN   [07] NARANJA [08] MORADO  [10] SIN COLOR\033[0m"
        echo -ne "\033[1;32mCOLOR: \033[1;37m"; read sts_cor
        case "$sts_cor" in
        1|01) cor_sts='blue' ;;   2|02) cor_sts='green' ;;  3|03) cor_sts='red' ;;
        4|04) cor_sts='yellow' ;; 5|05) cor_sts='#F535AA' ;; 6|06) cor_sts='cyan' ;;
        7|07) cor_sts='#FF7F00' ;; 8|08) cor_sts='#9932CD' ;; *) cor_sts='null' ;;
        esac
        # Editar MSG en el script
        msgsocks2=$(grep "MSG\s*=" /etc/SSHPlus/$_use_script | head -1 | awk -F= '{print $2}')
        [[ -n "$msgsocks2" ]] && sed -i "s|$msgsocks2| '$msgg'|" /etc/SSHPlus/$_use_script
        # Editar color
        cor_old=$(grep 'color=' /etc/SSHPlus/$_use_script 2>/dev/null | head -1 | cut -d'"' -f2)
        [[ -n "$cor_old" && "$cor_old" != "$cor_sts" ]] && \
            sed -i "s|color=\"$cor_old\"|color=\"$cor_sts\"|g" /etc/SSHPlus/$_use_script

        # в”Җв”Җ REINICIAR el proxy para aplicar el nuevo status в”Җв”Җ
        echo -e "\n\033[1;33mReiniciando proxy para aplicar cambios...\033[0m"
        # Capturar puertos activos antes de parar
        local _active_ports
        _active_ports=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
            awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)

        # Detectar prefijo de sesiГіn screen
        local _screen_pfx="proxy"
        [[ "$_use_script" = *"wsproxy"* || "$_use_script" = *"ws"* ]] && _screen_pfx="ws"

        # Parar todas las sesiones del script
        for pid in $(screen -ls 2>/dev/null | grep -E "\.${_screen_pfx}|${_screen_pfx}[0-9]" | \
                     awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        # Matar procesos Python del script
        pkill -f "/etc/SSHPlus/$_use_script" 2>/dev/null
        pkill -f "/etc/SSHPlus/$script_file"  2>/dev/null
        screen -wipe >/dev/null 2>&1
        sleep 1

        # Reiniciar en los mismos puertos
        if [[ -n "$_active_ports" ]]; then
            for _pt in $_active_ports; do
                screen -dmS "${_screen_pfx}${_pt}" python3 /etc/SSHPlus/$_use_script $_pt
                echo -e "\033[1;32mPuerto \033[1;37m$_pt \033[1;32mreiniciado!\033[0m"
                sleep 0.2
            done
        else
            echo -e "\033[1;33mNo se detectaron puertos activos. Inicie el proxy manualmente.\033[0m"
        fi

        echo -e "\n\033[1;32mSTATUS CAMBIADO Y PROXY REINICIADO!\033[0m"; sleep 2; fun_socks
    else
        echo -e "\033[1;31mACTIVE EL $titulo PRIMERO!\033[0m"; sleep 2; fun_socks
    fi
}

