fun_openssh() {
    clear
    echo -e "\E[44;1;37m            OPENSSH             \E[0m\n"
    _ssh_ports=$(grep '^Port' /etc/ssh/sshd_config | awk '{print $2}' | xargs)
    echo -e "\033[1;33mPUERTOS ACTIVOS: \033[1;37m$_ssh_ports\n"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mAGREGAR PUERTO"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR PUERTO"
    echo -e "\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER\033[0m"
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read resp
    if [[ "$resp" = '1' ]]; then
        echo -ne "\n\033[1;32mNUEVO PUERTO: \033[1;37m"; read pt; [[ -z "$pt" ]] && { fun_conexao; return; }
        verif_ptrs $pt; echo "Port $pt" >> /etc/ssh/sshd_config
        _restart_ssh; _fw_open $pt
        echo -e "\n\033[1;32mPUERTO $pt AGREGADO!\033[0m"; sleep 2; fun_conexao
    elif [[ "$resp" = '2' ]]; then
        echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read pt; [[ -z "$pt" ]] && { fun_conexao; return; }
        sed -i "/^Port $pt$/d" /etc/ssh/sshd_config; _restart_ssh
        echo -e "\n\033[1;32mPUERTO $pt ELIMINADO!\033[0m"; sleep 2; fun_conexao
    else
        fun_conexao
    fi
}

# ============================================================
# FUNCIГ“N INTERNA: Compilar o instalar un Dropbear desde fuente
# $1=versiГіn (ej: 2016.74) $2=puerto $3=servicio $4=directorio
# ============================================================
_instalar_dropbear_generico() {
    local ver="$1" porta="$2" servicio="$3" directorio="$4"
    local tarball="dropbear-${ver}.tar.bz2"
    local url_src="${_REPO_INST}/${tarball}"
    local dir_inst="/opt/${directorio}"
    local dir_conf="/etc/${directorio}"

    verif_ptrs "$porta"

    # Ubuntu 26+ в†’ binario precompilado para 2016
    # Para 2020 y 2022 compilamos (GCC los soporta bien)
    if [[ $_UBUNTU_VER -ge 26 && "$ver" == "2016.74" ]]; then
        echo -e "\033[1;33mUbuntu $_UBUNTU_VER в†’ instalando binario precompilado Dropbear $ver...\033[0m"
        apt-get install -y wget >/dev/null 2>&1
        mkdir -p "${dir_inst}/sbin" "${dir_inst}/bin" "$dir_conf"

        local _db_url _dbkey_url
        if [[ "$_ARCH" == "arm64" ]]; then
            _db_url="${_REPO_INST}/dropbear2016-bin-arm64"
            _dbkey_url="${_REPO_INST}/dropbearkey2016-bin-arm64"
        else
            _db_url="${_REPO_INST}/dropbear2016-bin-amd64"
            _dbkey_url="${_REPO_INST}/dropbearkey2016-bin-amd64"
        fi

        wget -q --timeout=60 -O "${dir_inst}/sbin/dropbear" "$_db_url"
        wget -q --timeout=60 -O "${dir_inst}/bin/dropbearkey" "$_dbkey_url"

        if [[ ! -s "${dir_inst}/sbin/dropbear" ]]; then
            echo -e "\033[1;31mвљ  No se pudo descargar el binario precompilado.\033[0m"
            sleep 3; fun_conexao; return
        fi
        chmod +x "${dir_inst}/sbin/dropbear" "${dir_inst}/bin/dropbearkey"
    else
        echo -e "\033[1;33mCompilando Dropbear $ver... (~3-5 min)\033[0m"
        apt-get update -y >/dev/null 2>&1
        apt-get install -y make gcc wget zlib1g-dev build-essential >/dev/null 2>&1

        cd /usr/src
        if [[ ! -s "$tarball" ]]; then
            echo -e "\033[1;33mDescargando fuente $tarball...\033[0m"
            wget -q --timeout=90 "${url_src}" -O "$tarball"
        fi

        if [[ ! -s "$tarball" ]]; then
            echo -e "\033[1;31mNo se pudo descargar $tarball\033[0m"
            echo -e "\033[1;33mURL: ${url_src}\033[0m"
            sleep 3; fun_conexao; return
        fi

        rm -rf "dropbear-${ver}" 2>/dev/null
        tar xjf "$tarball"
        cd "dropbear-${ver}"

        # Modificar identificador SSH
        for hdr in sysoptions.h default_options.h; do
            [[ -f "$hdr" ]] && {
                sed -i 's|^#define LOCAL_IDENT.*|#define LOCAL_IDENT "SSH-2.0-ByJuanitoProSniff"|' "$hdr" 2>/dev/null
                sed -i 's/SSH-2.0-dropbear/SSH-2.0-ByJuanitoProSniff/g' "$hdr" 2>/dev/null
            }
        done

        ./configure --prefix="$dir_inst" \
            --disable-zlib \
            --disable-wtmp \
            --disable-lastlog >/dev/null 2>&1

        if make -j$(nproc) PROGRAMS="dropbear dropbearkey" >/dev/null 2>&1; then
            make install PROGRAMS="dropbear dropbearkey" >/dev/null 2>&1
        else
            echo -e "\033[1;31mвљ  ERROR: No se pudo compilar Dropbear $ver\033[0m"
            cd /root; sleep 3; fun_conexao; return
        fi

        if [[ ! -f "${dir_inst}/sbin/dropbear" ]]; then
            echo -e "\033[1;31mвљ  ERROR: Binario no encontrado tras compilaciГіn.\033[0m"
            cd /root; sleep 3; fun_conexao; return
        fi
        echo -e "\033[1;32mвњ“ Dropbear $ver compilado exitosamente\033[0m"
    fi

    # Crear directorio de configuraciГіn y claves
    mkdir -p "$dir_conf"

    [[ ! -f "${dir_conf}/dropbear_rsa_host_key" ]] && \
        "${dir_inst}/bin/dropbearkey" -t rsa \
            -f "${dir_conf}/dropbear_rsa_host_key" -s 2048 >/dev/null 2>&1

    [[ ! -f "${dir_conf}/dropbear_dss_host_key" ]] && \
        "${dir_inst}/bin/dropbearkey" -t dss \
            -f "${dir_conf}/dropbear_dss_host_key" >/dev/null 2>&1 || true

    cat > "${dir_conf}/banner.txt" <<'BANEOF'
t.me/FREEINTERNETVPNMSY
BANEOF

    cat > "/etc/systemd/system/${servicio}.service" <<DBEOF
[Unit]
Description=Dropbear SSH ${ver} - Puerto ${porta}
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=${dir_inst}/sbin/dropbear -F -E -p ${porta} -r ${dir_conf}/dropbear_rsa_host_key -b ${dir_conf}/banner.txt -K 60 -I 300
ExecReload=/bin/kill -HUP \$MAINPID
Restart=always
RestartSec=3
KillMode=process

[Install]
WantedBy=multi-user.target
DBEOF

    systemctl daemon-reload
    systemctl enable "$servicio" >/dev/null 2>&1
    systemctl start "$servicio"
    _fw_open "$porta"

    echo ""
    echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"
    echo "VersiГіn Dropbear $ver instalada:"
    "${dir_inst}/sbin/dropbear" -V 2>&1 | head -n 1
    echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"

    sleep 1
    if systemctl is-active "$servicio" >/dev/null 2>&1; then
        echo -e "\n\033[1;32mвњ“ DROPBEAR $ver ACTIVO EN PUERTO $porta!\033[0m"
    else
        echo -e "\n\033[1;33mVerifique con: systemctl status $servicio\033[0m"
    fi
    cd /root; sleep 3; fun_conexao
}

