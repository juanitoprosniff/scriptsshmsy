# ============================================================
# SSL TUNNEL
# ============================================================
inst_ssl() {
    if _check_proc 'stunnel4'; then
        sslt=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
        [[ -z "$sslt" ]] && sslt="\033[1;31mNO DISPONIBLE"
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m           GESTIONAR SSL TUNNEL          \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -e "\033[0;34m╼ \033[1;32mPUERTO ACTIVO\033[1;37m: $sslt"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mCAMBIAR PUERTO SSL       \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR SSL TUNNEL      \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                   \033[0;34m┃"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta; echo ""
        [[ "$resposta" = '1' ]] && {
            echo -ne "\033[1;32mNUEVO PUERTO SSL: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            verif_ptrs $porta
            sed -i "s/accept  = .*/accept  = $porta/" /etc/stunnel/stunnel.conf
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            sleep 1
            _check_proc 'stunnel4' && echo -e "\n\033[1;32mPUERTO CAMBIADO!" || echo -e "\n\033[1;31mERROR!"
            sleep 2; inst_ssl; return
        }
        [[ "$resposta" = '2' ]] && {
            del_ssl() {
                pkill stunnel4 2>/dev/null; systemctl stop stunnel4 2>/dev/null; service stunnel4 stop 2>/dev/null
                apt-get remove --purge stunnel4 -y >/dev/null 2>&1
                rm -f /etc/stunnel/stunnel.conf /etc/stunnel/stunnel.pem /etc/stunnel/stunnel.key /etc/stunnel/stunnel.crt
            }
            fun_bar 'del_ssl'; echo -e "\n\033[1;32mSSL TUNNEL ELIMINADO!\033[0m"; sleep 2; fun_conexao; return
        }
        fun_conexao; return
    fi

    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           INSTALAR SSL TUNNEL           \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\n\033[1;33mSeleccione el destino del túnel SSL:\033[0m\n"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mSSL → SSH            (puerto 22)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mSSL → SSH Legado     (puerto 23)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mSSL → PROXY SOCKS    (puerto 80)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mSSL → DROPBEAR       (puerto 110)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mSSL → DROPBEAR 2016  (puerto 90)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m6\033[1;31m] \033[1;33mSSL → Puerto personalizado       \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                           \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta; echo ""
    case "$resposta" in
    1) portssl=22 ;;
    2) portssl=23 ;;
    3) portssl=80 ;;
    4) portssl=110 ;;
    5) portssl=90 ;;
    6) echo -ne "\033[1;32mPUERTO DESTINO: \033[1;37m"; read portssl; [[ -z "$portssl" ]] && { inst_ssl; return; } ;;
    0) fun_conexao; return ;;
    *) echo -e "\033[1;31mOpción inválida!"; sleep 1; inst_ssl; return ;;
    esac

    read -p "$(echo -e "\033[1;32mPUERTO SSL de escucha (defecto 443): \033[1;37m")" -e -i 443 porta
    [[ -z "$porta" ]] && porta=443
    verif_ptrs $porta

    echo -e "\n\033[1;32mINSTALANDO STUNNEL4...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y stunnel4 openssl >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
    mkdir -p /etc/stunnel

    echo -e "\033[1;32mGENERANDO CERTIFICADO SSL...\033[0m"
    ssl_certif() {
        rm -f /etc/stunnel/stunnel.pem /etc/stunnel/stunnel.key /etc/stunnel/stunnel.crt
        openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
            -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
            -keyout /etc/stunnel/stunnel.key \
            -out /etc/stunnel/stunnel.crt >/dev/null 2>&1
        cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
        chmod 600 /etc/stunnel/stunnel.pem
    }
    ssl_certif
    [[ ! -s /etc/stunnel/stunnel.pem ]] && { echo -e "\033[1;31mError al generar certificado!\033[0m"; sleep 2; inst_ssl; return; }

    cat > /etc/stunnel/stunnel.conf <<EOF
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

[sshtunnel]
accept  = $porta
connect = 127.0.0.1:$portssl
EOF

    echo -e "\033[1;32mINICIANDO SSL TUNNEL $porta → $portssl...\033[0m"
    fun_finssl() {
        if systemctl is-enabled stunnel4 >/dev/null 2>&1; then
            systemctl enable stunnel4 >/dev/null 2>&1; systemctl restart stunnel4 >/dev/null 2>&1
        else
            service stunnel4 restart >/dev/null 2>&1
        fi
        service ssh restart >/dev/null 2>&1; sleep 2
    }
    fun_bar 'fun_finssl'
    _abrir_puerto_fw $porta tcp
    sleep 1
    if ss -tlpn 2>/dev/null | grep -q ":$porta" || netstat -nltp 2>/dev/null | grep -q ":$porta" 2>/dev/null; then
        echo -e "\n\033[1;32mSSL TUNNEL ACTIVO! PUERTO: $porta → destino: $portssl\033[0m"
    else
        echo -e "\n\033[1;33mVerifique: systemctl status stunnel4\033[0m"
    fi
    sleep 2; inst_ssl
}

