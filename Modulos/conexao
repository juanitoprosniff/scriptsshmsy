net.core.rmem_max=26214400
net.core.wmem_max=26214400
net.core.rmem_default=1048576
net.core.wmem_default=1048576
net.ipv4.tcp_rmem=4096 1048576 26214400
net.ipv4.tcp_wmem=4096 1048576 26214400
net.ipv4.tcp_mem=65536 131072 262144
net.core.netdev_max_backlog=5000
net.ipv4.tcp_no_metrics_save=1
net.ipv4.tcp_window_scaling=1
BUFEOF
    echo -e "\033[1;32m  вњ“ Buffers optimizados\033[0m"

    sysctl -p >/dev/null 2>&1
    echo -e "\n\033[1;32mвњ“ TURBO VPN ACTIVADO вЂ” VPS optimizada para mГЎxima velocidad!\033[0m"
    sleep 3
