        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mELIMINAR SSL TUNNEL          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                       \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta; echo ""

        if [[ "$resposta" = '1' ]]; then
            echo -ne "\033[1;32mNUEVO PUERTO SSL: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            verif_ptrs $porta
            cat >> /etc/stunnel/stunnel.conf <<EOF

[sshtunnel${porta}]
accept  = $porta
connect = 127.0.0.1:${_SSL_DISP_PORT}
EOF
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            _fw_open $porta
            iptables -I INPUT -p tcp --dport $porta -j ACCEPT 2>/dev/null
            echo -e "\n\033[1;32mPUERTO $porta AGREGADO → dispatcher:$_SSL_DISP_PORT\033[0m"
            sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '2' ]]; then
            echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            sed -i "/\[sshtunnel${porta}\]/,/^$/d" /etc/stunnel/stunnel.conf 2>/dev/null
            sed -i "/accept  = ${porta}/d"          /etc/stunnel/stunnel.conf 2>/dev/null
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            echo -e "\n\033[1;32mPUERTO $porta ELIMINADO!\033[0m"; sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '3' ]]; then
            echo -e "\033[1;33mDestino SSH actual : \033[1;37m$_DISP_SSH"
            echo -e "\033[1;33mDestino WS  actual : \033[1;37m$_DISP_WS\033[0m\n"

            echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mSSH → OpenSSH (22)"
            echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mSSH → Dropbear 2016 (143)"
            echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mSSH → Puerto personalizado"
            echo -ne "\033[1;32mDestino SSH: \033[1;37m"; read _ssh_sel
            case "$_ssh_sel" in
            1) _new_ssh="127.0.0.1:22"  ;;
            2) _new_ssh="127.0.0.1:143" ;;
            3) echo -ne "\033[1;32mPuerto SSH: \033[1;37m"; read _sp
               _new_ssh="127.0.0.1:${_sp:-22}" ;;
            *) _new_ssh="$_DISP_SSH" ;;
            esac

            local _auto_ws
            _auto_ws=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
                       grep -v ":${_SSL_DISP_PORT} " | \
                       awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
            echo -e "\n\033[1;33mProxy WS detectado: \033[1;37m${_auto_ws:-ninguno}\033[0m"
            echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mWS → puerto 80"
            echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mWS → puerto 8080"
            echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mWS → detectado automáticamente (${_auto_ws:-80})"
            echo -e "\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mWS → puerto personalizado"
            echo -ne "\033[1;32mDestino WS: \033[1;37m"; read _ws_sel
            case "$_ws_sel" in
            1) _new_ws="127.0.0.1:80"   ;;
            2) _new_ws="127.0.0.1:8080" ;;
            3) _new_ws="127.0.0.1:${_auto_ws:-80}" ;;
            4) echo -ne "\033[1;32mPuerto WS: \033[1;37m"; read _wp
               _new_ws="127.0.0.1:${_wp:-80}" ;;
            *) _new_ws="$_DISP_WS" ;;
            esac

            sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
            echo "ss -tlpn | grep -qw ${_SSL_DISP_PORT} || screen -dmS ssldispatch python3 ${_SSL_DISP_SCRIPT} ${_SSL_DISP_PORT} ${_new_ssh} ${_new_ws}" >> /etc/autostart

            _ssl_start_dispatcher "$_new_ssh" "$_new_ws"
            echo -e "\n\033[1;32mBackends actualizados!\033[0m"; sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '4' ]]; then
            _ssl_start_dispatcher "$_DISP_SSH" "$_DISP_WS"
            sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '5' ]]; then
            pkill stunnel4 2>/dev/null; systemctl stop stunnel4 2>/dev/null
            apt-get remove --purge stunnel4 -y >/dev/null 2>&1
            rm -f /etc/stunnel/stunnel.conf /etc/stunnel/stunnel.pem \
                  /etc/stunnel/stunnel.key  /etc/stunnel/stunnel.crt
            for pid in $(screen -ls 2>/dev/null | grep '\.ssldispatch' | awk '{print $1}'); do
                screen -r -S "$pid" -X quit 2>/dev/null
            done
            pkill -f "ssldispatcher.py" 2>/dev/null
            sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
            echo -e "\n\033[1;32mSSL TUNNEL Y DISPATCHER ELIMINADOS!\033[0m"
            sleep 2; fun_conexao; return
        fi

        fun_conexao; return
    fi

    # ── INSTALACIÓN INICIAL ───────────────────────────────────
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           INSTALAR SSL TUNNEL           \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""
    echo -e "\033[1;33mModo: SSL DIRECTO + SSL WEBSOCKET simultáneos\033[0m"
    echo -e "\033[1;37mEl dispatcher detecta el protocolo automáticamente.\033[0m\n"

    echo -e "\033[1;33mPaso 1 — Destino SSH (sin WebSocket):\033[0m"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mOpenSSH puerto 22"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mDropbear 2016 puerto 143"
    echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mPuerto personalizado"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read _ssh_sel
    case "$_ssh_sel" in
    1) _ssh_dst="127.0.0.1:22"  ;;
    2) _ssh_dst="127.0.0.1:143" ;;
    3) echo -ne "\033[1;32mPuerto SSH destino: \033[1;37m"; read _sp
       _ssh_dst="127.0.0.1:${_sp:-22}" ;;
    *) _ssh_dst="127.0.0.1:143" ;;
    esac

    local _ws_auto
    _ws_auto=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
               awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
    [[ -z "$_ws_auto" ]] && _ws_auto=80

    echo -e "\n\033[1;33mPaso 2 — Destino WebSocket (wsproxy):\033[0m"
    echo -e "\033[1;37mDetectado automáticamente: \033[1;32m$_ws_auto\033[0m"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mUsar el detectado ($_ws_auto)"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mPuerto personalizado"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read _ws_sel
    case "$_ws_sel" in
    2) echo -ne "\033[1;32mPuerto WS: \033[1;37m"; read _wp
       _ws_dst="127.0.0.1:${_wp:-80}" ;;
    *) _ws_dst="127.0.0.1:$_ws_auto" ;;
    esac

    echo ""
    echo -e "\033[1;33mInstalando stunnel4...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y stunnel4 openssl >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
    mkdir -p /etc/stunnel

    echo -e "\033[1;32mGenerando certificado SSL...\033[0m"
    openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
        -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
        -keyout /etc/stunnel/stunnel.key \
        -out    /etc/stunnel/stunnel.crt >/dev/null 2>&1
    cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
    chmod 600 /etc/stunnel/stunnel.pem

    [[ ! -s /etc/stunnel/stunnel.pem ]] && {
        echo -e "\033[1;31mError al generar certificado!\033[0m"; sleep 2; inst_ssl; return
    }

    echo -e "\n\033[1;33mIniciando dispatcher SSL inteligente...\033[0m"
    if ! _ssl_start_dispatcher "$_ssh_dst" "$_ws_dst"; then
        echo -e "\033[1;31mNo se pudo iniciar el dispatcher. Verifique ssldispatcher.py\033[0m"
        sleep 3; return
    fi

    cat > /etc/stunnel/stunnel.conf <<EOF
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

# Stunnel descifra SSL y pasa tráfico en crudo al dispatcher.
# El dispatcher detecta SSH vs HTTP/WS y enruta al backend correcto.

[sshtunnel443]
accept  = 443
connect = 127.0.0.1:${_SSL_DISP_PORT}

[sshtunnel444]
accept  = 444
connect = 127.0.0.1:${_SSL_DISP_PORT}

[sshtunnel8443]
accept  = 8443
connect = 127.0.0.1:${_SSL_DISP_PORT}
EOF

    echo -e "\033[1;32mIniciando SSL Tunnel en puertos 443, 444, 8443...\033[0m"
    if systemctl is-enabled stunnel4 >/dev/null 2>&1; then
        systemctl enable stunnel4 >/dev/null 2>&1
        systemctl restart stunnel4 >/dev/null 2>&1
    else
        service stunnel4 restart >/dev/null 2>&1
    fi

    for _sslp in 443 444 8443; do
        _fw_open $_sslp
        iptables -I INPUT -p tcp --dport $_sslp -j ACCEPT 2>/dev/null
    done

    sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
    echo "ss -tlpn | grep -qw ${_SSL_DISP_PORT} || screen -dmS ssldispatch python3 ${_SSL_DISP_SCRIPT} ${_SSL_DISP_PORT} ${_ssh_dst} ${_ws_dst}" >> /etc/autostart

    sleep 1
    echo ""
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    if ss -tlpn 2>/dev/null | grep -q ":443 "; then
        echo -e "\033[1;32m✓ SSL TUNNEL ACTIVO!\033[0m"
        echo -e "\033[1;37m  Puertos SSL  : \033[1;32m443, 444, 8443"
        echo -e "\033[1;37m  → Dispatcher : \033[1;32m127.0.0.1:$_SSL_DISP_PORT"
        echo -e "\033[1;37m    ├ SSH raw  : \033[1;32m$_ssh_dst"
        echo -e "\033[1;37m    └ HTTP/WS  : \033[1;32m$_ws_dst\033[0m"
        if ! ss -tlpn 2>/dev/null | grep -q ":444 "; then
            echo -e "\033[1;33m⚠ Puerto 444 no visible — verifique el firewall del panel VPS.\033[0m"
        fi
    else
        echo -e "\n\033[1;33mVerifique: systemctl status stunnel4\033[0m"
    fi
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    sleep 4; inst_ssl
}

# ============================================================
# PROXY SOCKS + WEBSOCKET
# ============================================================
fun_socks() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m          GESTIONAR PROXY SOCKS          \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    _py_ports=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
    [[ -n "$_py_ports" ]] && echo -e "\033[0;34m╼ \033[1;32mPUERTOS ACTIVOS\033[1;37m: $_py_ports"
    [[ $(screen -list 2>/dev/null | grep -wc 'proxy') != '0' ]] && var_sks1="\033[1;32m✓" || var_sks1="\033[1;31m✕"
    [[ $(screen -list 2>/dev/null | grep -c '\.ws') != '0' ]] && var_sks2="\033[1;32m✓" || var_sks2="\033[1;31m✕"
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mWEBSOCKET $var_sks2                        \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mCAMBIAR STATUS WEBSOCKET             \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                               \033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta

    case "$resposta" in
    1)
        _ws_count=$(screen -list 2>/dev/null | grep -c '\.ws')
        if [[ $_ws_count -gt 0 ]]; then
            echo -e "\E[44;1;37m   WEBSOCKET ACTIVO   \E[0m"
            echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mDESACTIVAR TODOS"
            echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mAGREGAR PUERTO"
            echo -e "\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER"
            echo -ne "\033[1;32mOpción: \033[1;37m"; read ws_opt
            if [[ "$ws_opt" = '1' ]]; then
                for pid in $(screen -ls | grep "\.ws" | awk '{print $1}'); do screen -r -S "$pid" -X quit 2>/dev/null; done
                sed -i '/wsproxy/d' /etc/autostart 2>/dev/null; screen -wipe >/dev/null 2>&1
                echo -e "\n\033[1;32mTODOS LOS WEBSOCKETS DESACTIVADOS!\033[0m"; sleep 2; fun_socks
            elif [[ "$ws_opt" = '2' ]]; then
                _fun_socks_menu_destino "WEBSOCKET ADICIONAL" "ws" "wsproxy.py"
            else
                fun_socks
            fi
        else
            _fun_socks_menu_destino "WEBSOCKET" "ws" "wsproxy.py"
        fi ;;
    2) _fun_alterar_status "wsproxy.py" "WEBSOCKET" ;;
    0) fun_conexao ;;
    *) echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1; fun_socks ;;
    esac
}

_fun_socks_menu_destino() {
    local titulo="$1" screen_prefix="$2" script="$3"
    clear
    echo -e "\E[44;1;37m   $titulo — CONFIGURAR   \E[0m\n"
    echo -e "\033[1;33mPaso 1 — Destino:\033[0m\n"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33m→ OpenSSH (22)"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33m→ Dropbear 2016 (143)"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read dst_sel
    case "$dst_sel" in
    1) _dst_port=22 ;;
    2) _dst_port=143 ;;
    *) echo -e "\033[1;31mOpción inválida!"; sleep 1; fun_socks; return ;;
    esac

    if [[ -f /etc/SSHPlus/$script ]] && [[ -n "$_dst_port" ]]; then
        sed -i "s|DEFAULT_HOST = ['\"]127\.0\.0\.1:[0-9]*['\"]|DEFAULT_HOST = '127.0.0.1:${_dst_port}'|" /etc/SSHPlus/$script 2>/dev/null
    fi

    echo -e "\n\033[1;33mPaso 2 — Puerto(s) de escucha:\033[0m\n"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mPuerto 80"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mPuerto 8080"
    echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mPuerto 8880"
    echo -e "\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mPuerto 8888"
    echo -e "\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mTODOS (80, 8080, 8880, 8888)"
    echo -e "\033[1;31m[\033[1;36m6\033[1;31m] \033[1;33mPuerto personalizado\033[0m"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read listen_sel
    case "$listen_sel" in
    1) _listen_ports="80" ;;  2) _listen_ports="8080" ;; 3) _listen_ports="8880" ;;
    4) _listen_ports="8888" ;; 5) _listen_ports="80 8080 8880 8888" ;;
    6) echo -ne "\033[1;32mPUERTO(S): \033[1;37m"; read _listen_ports; [[ -z "$_listen_ports" ]] && { fun_socks; return; } ;;
    *) echo -e "\033[1;31mOpción inválida!"; sleep 1; fun_socks; return ;;
    esac

    sed -i "/$script/d" /etc/autostart 2>/dev/null
    [[ -n "$_dst_port" ]] && echo -e "\033[1;33mDestino: 127.0.0.1:$_dst_port\033[0m"
    echo -e "\033[1;32mIniciando $titulo...\033[0m\n"

    local _dst_arg=""
    [[ -n "$_dst_port" ]] && _dst_arg="127.0.0.1:${_dst_port}"

    local _use_script="$script"

    for porta in $_listen_ports; do
        verif_ptrs $porta
        screen -dmS ${screen_prefix}${porta} python3 /etc/SSHPlus/$_use_script $porta $_dst_arg
        _fw_open $porta tcp
        iptables -I INPUT -p tcp --dport $porta -j ACCEPT 2>/dev/null
        echo "ss -tlpn | grep -qw $porta || screen -dmS ${screen_prefix}${porta} python3 /etc/SSHPlus/$_use_script $porta $_dst_arg" >> /etc/autostart
        sleep 0.5
        if ss -tlpn 2>/dev/null | grep -q ":$porta "; then
            echo -e "\033[1;32mPuerto \033[1;37m$porta \033[1;32mactivado! ✓\033[0m"
        else
            echo -e "\033[1;33mPuerto \033[1;37m$porta \033[1;33m— esperando inicio del proxy...\033[0m"
            sleep 1
            ss -tlpn 2>/dev/null | grep -q ":$porta " && \
                echo -e "\033[1;32m  ✓ Puerto $porta OK\033[0m" || \
                echo -e "\033[1;31m  ✕ Puerto $porta no responde — verifique python3 y el script $_use_script\033[0m"
        fi
    done
    echo -e "\n\033[1;32m$titulo ACTIVADO!\033[0m"; sleep 2; fun_socks
}

_fun_alterar_status() {
    local script_file="$1" titulo="$2"
    local _real_script="$script_file"

    if ps x | grep -w "$_real_script" | grep -v grep >/dev/null 2>&1 || \
       ps x | grep -w "$script_file"  | grep -v grep >/dev/null 2>&1; then

        local _use_script="$_real_script"
        [[ ! -f /etc/SSHPlus/$_use_script ]] && _use_script="$script_file"

        msgsocks=$(grep -E "MSG\s*=" /etc/SSHPlus/$_use_script 2>/dev/null | head -1 | awk -F= '{print $2}' | tr -d "' ")
        echo -e "\E[44;1;37m   STATUS — $titulo   \E[0m"
        echo -e "\n\033[1;33mSTATUS ACTUAL: \033[1;32m${msgsocks:-sin status}\033[0m"
        echo -ne "\n\033[1;32mNUEVO STATUS: \033[1;37m"; read msgg
        [[ -z "$msgg" ]] && { fun_conexao; return; }
        echo -e "\033[1;31m[01] AZUL  [02] VERDE  [03] ROJO   [04] AMARILLO"
        echo -e "[05] ROSA  [06] CIAN   [07] NARANJA [08] MORADO  [10] SIN COLOR\033[0m"
        echo -ne "\033[1;32mCOLOR: \033[1;37m"; read sts_cor
        case "$sts_cor" in
        1|01) cor_sts='blue' ;;   2|02) cor_sts='green' ;;  3|03) cor_sts='red' ;;
        4|04) cor_sts='yellow' ;; 5|05) cor_sts='#F535AA' ;; 6|06) cor_sts='cyan' ;;
        7|07) cor_sts='#FF7F00' ;; 8|08) cor_sts='#9932CD' ;; *) cor_sts='null' ;;
        esac
        msgsocks2=$(grep "MSG\s*=" /etc/SSHPlus/$_use_script | head -1 | awk -F= '{print $2}')
        [[ -n "$msgsocks2" ]] && sed -i "s|$msgsocks2| '$msgg'|" /etc/SSHPlus/$_use_script
        cor_old=$(grep 'color=' /etc/SSHPlus/$_use_script 2>/dev/null | head -1 | cut -d'"' -f2)
        [[ -n "$cor_old" && "$cor_old" != "$cor_sts" ]] && \
            sed -i "s|color=\"$cor_old\"|color=\"$cor_sts\"|g" /etc/SSHPlus/$_use_script

        echo -e "\n\033[1;33mReiniciando proxy para aplicar cambios...\033[0m"
        local _active_ports
        _active_ports=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
            awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)

        local _screen_pfx="proxy"
        [[ "$_use_script" = *"wsproxy"* || "$_use_script" = *"ws"* ]] && _screen_pfx="ws"

        for pid in $(screen -ls 2>/dev/null | grep -E "\.${_screen_pfx}|${_screen_pfx}[0-9]" | \
                     awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "/etc/SSHPlus/$_use_script" 2>/dev/null
        pkill -f "/etc/SSHPlus/$script_file"  2>/dev/null
        screen -wipe >/dev/null 2>&1
        sleep 1

        if [[ -n "$_active_ports" ]]; then
            for _pt in $_active_ports; do
                screen -dmS "${_screen_pfx}${_pt}" python3 /etc/SSHPlus/$_use_script $_pt
                echo -e "\033[1;32mPuerto \033[1;37m$_pt \033[1;32mreiniciado!\033[0m"
                sleep 0.2
            done
        else
            echo -e "\033[1;33mNo se detectaron puertos activos. Inicie el proxy manualmente.\033[0m"
        fi

        echo -e "\n\033[1;32mSTATUS CAMBIADO Y PROXY REINICIADO!\033[0m"; sleep 2; fun_socks
    else
        echo -e "\033[1;31mACTIVE EL $titulo PRIMERO!\033[0m"; sleep 2; fun_socks
    fi
}

# ============================================================
# REINICIAR SERVICIOS DE PROXY SOCKS / WEBSOCKET
# Función exportable — llamada desde menu.sh reiniciarservicos
# ============================================================
reiniciar_proxy_socks() {
    echo -e "\033[1;33mReiniciando Proxy Socks y WebSocket...\033[0m"
    local _reiniciados=0

    if [[ -f /etc/autostart ]]; then
        for pid in $(screen -ls 2>/dev/null | grep -E '\.proxy|\.ws[0-9]|\.openpy|proxy[0-9]|ws[0-9]' | \
                     awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "/etc/SSHPlus/proxy.py"   2>/dev/null
        pkill -f "/etc/SSHPlus/wsproxy"    2>/dev/null
        pkill -f "/etc/SSHPlus/open.py"    2>/dev/null
        screen -wipe >/dev/null 2>&1
        sleep 1

        while IFS= read -r _cmd; do
            [[ "$_cmd" =~ proxy\.py|wsproxy|open\.py ]] && {
                eval "$_cmd" 2>/dev/null
                ((_reiniciados++))
            }
        done < /etc/autostart
    fi

    if [[ $_reiniciados -gt 0 ]]; then
        echo -e "\033[1;32m✓ $_reiniciados servicios proxy reiniciados.\033[0m"
    else
        echo -e "\033[1;33mNo hay proxies configurados en autostart.\033[0m"
    fi
}

# ============================================================
# V2RAY — VMess + VLess, Default SNI + Reverse SNI
# Puertos sin TLS: 80, 8080, 8880, 8888 (comparte con wsproxy)
# Puertos con TLS: 443, 444, 8443       (comparte con stunnel)
# ============================================================

_V2RAY_CORE_PORT=10085
_V2RAY_CONFIG="/etc/v2ray/config.json"
_V2RAY_SCRIPT="/etc/SSHPlus/v2ray_manager.py"

_v2ray_is_installed() {
    command -v v2ray &>/dev/null || [[ -f /usr/local/bin/v2ray ]] || [[ -f /usr/bin/v2ray ]]
}

_v2ray_is_running() {
    systemctl is-active v2ray >/dev/null 2>&1 || \
    pgrep -x v2ray >/dev/null 2>&1
}

_v2ray_get_uuid() {
    cat /etc/v2ray/uuid 2>/dev/null || cat /proc/sys/kernel/random/uuid
}

_v2ray_gen_uuid() {
    local _uuid
    _uuid=$(cat /proc/sys/kernel/random/uuid)
    echo "$_uuid" > /etc/v2ray/uuid
    echo "$_uuid"
}

_v2ray_get_ip() {
    curl -s4 https://ipinfo.io/ip 2>/dev/null || \
    curl -s4 https://api.ipify.org 2>/dev/null || \
    hostname -I 2>/dev/null | awk '{print $1}'
}

# ── Instalar V2Ray core ───────────────────────────────────────
_v2ray_install_core() {
    echo -e "\033[1;33mInstalando V2Ray core...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y curl unzip >/dev/null 2>&1

    # Usar el instalador oficial de V2Ray
    bash <(curl -sL https://raw.githubusercontent.com/v2fly/fhs-install-v2ray/master/install-release.sh) >/dev/null 2>&1

    if ! _v2ray_is_installed; then
        echo -e "\033[1;31m✗ No se pudo instalar V2Ray. Verifique la conexión a internet.\033[0m"
        return 1
    fi
    echo -e "\033[1;32m✓ V2Ray core instalado\033[0m"
    return 0
}

# ── Instalar script bridge de V2Ray ──────────────────────────
_v2ray_install_bridge() {
    if [[ ! -f "$_V2RAY_SCRIPT" ]]; then
        local _repo="https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main/Modulos/v2ray_manager.py"
        wget -q "$_repo" -O "$_V2RAY_SCRIPT" 2>/dev/null
        # Fallback: copiar desde home si existe
        [[ ! -s "$_V2RAY_SCRIPT" ]] && [[ -f "$HOME/v2ray_manager.py" ]] && \
            cp "$HOME/v2ray_manager.py" "$_V2RAY_SCRIPT"
        chmod 755 "$_V2RAY_SCRIPT" 2>/dev/null
    fi
}

# ── Generar config V2Ray multi-inbound ───────────────────────
# Soporta VMess + VLess, WS path configurable, sin TLS inbound
# (el TLS lo maneja stunnel externamente)
_v2ray_write_config() {
    local _uuid="$1"
    local _ws_path="${2:-/v2ray}"
    local _port="${3:-$_V2RAY_CORE_PORT}"

    mkdir -p /etc/v2ray

    cat > "$_V2RAY_CONFIG" <<EOF
{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/v2ray/access.log",
    "error": "/var/log/v2ray/error.log"
  },
  "inbounds": [
    {
      "port": ${_port},
      "listen": "127.0.0.1",
      "protocol": "vmess",
      "settings": {
        "clients": [
          {
            "id": "${_uuid}",
            "alterId": 0,
            "security": "auto"
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "${_ws_path}"
        }
      },
      "tag": "vmess-ws-in"
    },
    {
      "port": $((${_port} + 1)),
      "listen": "127.0.0.1",
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "${_uuid}",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "${_ws_path}"
        }
      },
      "tag": "vless-ws-in"
    },
    {
      "port": $((${_port} + 2)),
      "listen": "127.0.0.1",
      "protocol": "vmess",
      "settings": {
        "clients": [
          {
            "id": "${_uuid}",
            "alterId": 0,
            "security": "auto"
          }
        ]
      },
      "streamSettings": {
        "network": "tcp"
      },
      "tag": "vmess-tcp-in"
    },
    {
      "port": $((${_port} + 3)),
      "listen": "127.0.0.1",
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "${_uuid}",
            "flow": ""
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp"
      },
      "tag": "vless-tcp-in"
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {},
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "settings": {},
      "tag": "blocked"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "direct"
      }
    ]
  }
}
EOF
    echo -e "\033[1;32m✓ Configuración V2Ray generada\033[0m"
}

# ── Mostrar links de conexión ─────────────────────────────────
