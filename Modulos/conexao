    if [[ ! -s /usr/local/bin/hysteria ]]; then
        echo -e "\033[1;31mError al descargar Hysteria.\033[0m"; sleep 3; fun_conexao; return
    fi
    chmod +x /usr/local/bin/hysteria

    mkdir -p /etc/hysteria

    # Generar certificado
    echo -e "\033[1;33mGenerando certificado...\033[0m"
    openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
        -subj "/C=CO/ST=Colombia/O=MSYVPN/CN=msyvpn.local" \
        -keyout /etc/hysteria/server.key \
        -out    /etc/hysteria/server.crt >/dev/null 2>&1

    # Configuración Hysteria v2
    cat > /etc/hysteria/config.yaml <<EOF
listen: :${_hys_port}

tls:
  cert: /etc/hysteria/server.crt
  key:  /etc/hysteria/server.key

auth:
  type: disabled

masquerade:
  type: proxy
  proxy:
    url: https://news.ycombinator.com/
    rewriteHost: true
EOF

    # Servicio systemd
    cat > /etc/systemd/system/hysteria-server.service <<EOF
[Unit]
Description=Hysteria UDP Server — MSYVPN-SCRIPT
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/hysteria server --config /etc/hysteria/config.yaml
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable hysteria-server 2>/dev/null
    systemctl start hysteria-server 2>/dev/null

    _fw_open "$_hys_port" udp
    iptables -I INPUT -p udp --dport "$_hys_port" -j ACCEPT 2>/dev/null

    sleep 2
    echo ""
    if systemctl is-active hysteria-server &>/dev/null; then
        echo -e "\033[1;32m✓ HYSTERIA UDP ACTIVO!\033[0m"
        echo -e "\033[1;37m  Puerto  : \033[1;32m${_hys_port} (rango 20000-39999)"
