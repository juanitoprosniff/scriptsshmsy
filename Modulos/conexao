				echo -e "\n\033[1;32mSOCKS OPENVPN ATIVADO!\033[0m"; sleep 2; fun_socks
			fi

		elif [[ "$resposta" = '4' ]]; then
			if ps x | grep proxy.py | grep -v grep >/dev/null 2>&1; then
				echo -ne "\n\033[1;32mQUAL PORTA EXTRA: \033[1;37m"; read porta
				[[ -z "$porta" ]] && { fun_conexao; return; }
				verif_ptrs $porta
				screen -dmS proxy python3 /etc/SSHPlus/proxy.py $porta
				echo -e "\n\033[1;32mSOCKS ATIVO NA PORTA $porta!\033[0m"; sleep 2; fun_socks
			else
				echo -e "\033[1;31mATIVE O SOCKS PRIMEIRO!\033[0m"; sleep 2; fun_socks
			fi

