    local _uuid="$1"
    local _ws_path="${2:-/v2ray}"
    local _ip
    _ip=$(_v2ray_get_ip)

    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m         DATOS DE CONEXIÓN V2RAY         \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\033[1;33mIP VPS    : \033[1;37m$_ip"
    echo -e "\033[1;33mUUID      : \033[1;37m$_uuid"
    echo -e "\033[1;33mWS PATH   : \033[1;37m$_ws_path"
    echo ""
    echo -e "\033[1;35m── SIN TLS (HTTP/WS) ──────────────────────\033[0m"
    echo -e "\033[1;33mPuertos   : \033[1;37m80, 8080, 8880, 8888"
