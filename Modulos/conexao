_desactivar_todo_turbo() {
    echo -e "\n\033[1;33m[ TURBO VPN ] Restaurando configuraciГіn original...\033[0m\n"

    sed -i '/^Compression/d' /etc/ssh/sshd_config
    echo "Compression no" >> /etc/ssh/sshd_config
    _restart_ssh
    echo -e "\033[1;33m  вњ“ CompresiГіn SSH desactivada\033[0m"

    sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
