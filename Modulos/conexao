fun_update_script() {
    clear
    echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
    echo -e "\033[0;34mв”ѓ\E[44;1;37m         ACTUALIZAR SCRIPT SSHMSY            \E[0m\033[0;34mв”ѓ"
    echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
    echo ""

    # URL base del repositorio (editar segГєn su GitHub)
    local _REPO_BASE="https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main"
    local _VER_REMOTE _VER_LOCAL _VER_FILE="/usr/share/.plus/.version"

    echo -e "\033[1;33mVerificando versiГіn remota...\033[0m"

    # Obtener versiГіn remota
    _VER_REMOTE=$(curl -s --max-time 8 "${_REPO_BASE}/versao" 2>/dev/null || \
                  wget -qO- --timeout=8 "${_REPO_BASE}/versao" 2>/dev/null)

    # VersiГіn local
    _VER_LOCAL=$(cat "$_VER_FILE" 2>/dev/null || echo "0")

    if [[ -z "$_VER_REMOTE" ]]; then
        echo -e "\033[1;31mNo se pudo contactar el servidor. Verifique su conexiГіn.\033[0m"
        sleep 3; return
    fi

    echo -e "\033[1;37mVersiГіn local : \033[1;32m$_VER_LOCAL\033[0m"
    echo -e "\033[1;37mVersiГіn remota: \033[1;32m$_VER_REMOTE\033[0m"
    echo ""

    if [[ "$_VER_REMOTE" = "$_VER_LOCAL" ]]; then
        echo -e "\033[1;32mвњ“ Ya tienes la versiГіn mГЎs reciente.\033[0m"
        sleep 3; return
    fi

    echo -e "\033[1;33mВЎHay una nueva versiГіn disponible!\033[0m"
    echo ""
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mActualizar ahora (para todos los servicios)\033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mActualizar solo mГіdulo conexao              \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mActualizar solo menГє principal              \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mCancelar                                   \033[0;34mв”ѓ"
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read _upd_opt

    case "$_upd_opt" in
    1)
        echo -e "\n\033[1;33mDeteniendo servicios activos...\033[0m"
        # Parar proxies Python
        for pid in $(screen -ls 2>/dev/null | grep -E '\.proxy|\.ws|openpy' | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        screen -wipe >/dev/null 2>&1

        echo -e "\033[1;33mDescargando actualizaciГіn completa...\033[0m"
        _do_update_full "$_REPO_BASE"
        ;;
    2)
        echo -e "\033[1;33mActualizando mГіdulo de conexiГіn...\033[0m"
        _do_update_file "$_REPO_BASE" "conexao" "/bin/conexao"
        ;;
    3)
        echo -e "\033[1;33mActualizando menГє principal...\033[0m"
        _do_update_file "$_REPO_BASE" "menu" "/bin/menu"
        ;;
    0) return ;;
    esac
}

_do_update_file() {
    local base="$1" remote_name="$2" local_path="$3"
    local tmp="/tmp/_upd_${remote_name}"
    wget -q --timeout=15 "${base}/${remote_name}" -O "$tmp" 2>/dev/null || \
    curl -s --max-time 15 "${base}/${remote_name}" -o "$tmp" 2>/dev/null

    if [[ -s "$tmp" ]]; then
        cp "$local_path" "${local_path}.bak" 2>/dev/null
        mv "$tmp" "$local_path"
        chmod 755 "$local_path"
        echo -e "\033[1;32mвњ“ $remote_name actualizado!\033[0m"
    else
        echo -e "\033[1;31mError al descargar $remote_name\033[0m"
    fi
    sleep 2
}

_do_update_full() {
    local base="$1"
    local _ok=0

    for _mod in menu conexao; do
        local _dest
        [[ "$_mod" = "menu" ]] && _dest="/bin/menu" || _dest="/bin/conexao"
        local _tmp="/tmp/_upd_${_mod}"
        wget -q --timeout=15 "${base}/${_mod}" -O "$_tmp" 2>/dev/null || \
        curl -s --max-time 15 "${base}/${_mod}" -o "$_tmp" 2>/dev/null
        if [[ -s "$_tmp" ]]; then
            cp "$_dest" "${_dest}.bak" 2>/dev/null
            mv "$_tmp" "$_dest"
            chmod 755 "$_dest"
            echo -e "\033[1;32mвњ“ $_mod actualizado\033[0m"
            ((_ok++))
        else
            echo -e "\033[1;31mвњ— Error actualizando $_mod\033[0m"
        fi
    done

    # Actualizar versiГіn local
    if [[ $_ok -gt 0 ]]; then
        mkdir -p /usr/share/.plus
        echo "$_VER_REMOTE" > /usr/share/.plus/.version
        echo -e "\n\033[1;32mвњ“ ActualizaciГіn completada ($_ok mГіdulos).\033[0m"
        echo -e "\033[1;33mReiniciando menГє...\033[0m"
        sleep 2; exec menu
    fi
    sleep 3
}

# ============================================================
# SQUID
# ============================================================
inst_sqd() {
    if _check_proc 'squid'; then
        echo -e "\E[41;1;37m            REMOVER SQUID PROXY              \E[0m"
        echo -ne "\n\033[1;32mREMOVER SQUID? \033[1;31m[s/n]:\033[1;37m "; read resp
        [[ "$resp" = 's' ]] && {
            rem_sqd() {
                for d in /etc/squid /etc/squid3; do
                    [[ -d "$d" ]] && apt-get remove --purge -y squid squid3 >/dev/null 2>&1 && rm -rf "$d"
                done; apt autoremove -y >/dev/null 2>&1
            }; fun_bar 'rem_sqd'
            echo -e "\n\033[1;32mSQUID ELIMINADO!\033[0m"
        }; sleep 2; fun_conexao
    else
        echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
        echo -e "\033[0;34mв”ѓ\E[44;1;37m            INSTALAR SQUID PROXY         \E[0m\033[0;34mв”ѓ"
        echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
        IP=$(curl -s --max-time 5 ipv4.icanhazip.com || wget -qO- ipv4.icanhazip.com)
        echo -ne "\033[1;32mCONFIRME SU IP: \033[1;37m"; read -e -i $IP ipdovps
        echo -ne "\n\033[1;33mPUERTOS (EJ: 80 8080): \033[1;37m"; read portass
        [[ -z "$portass" ]] && { echo -e "\n\033[1;31mPuerto invГЎlido!"; sleep 2; fun_conexao; return; }
        for porta in $portass; do verif_ptrs $porta; done
        fun_bar 'apt update -y' "apt install squid -y"
        var_sqd="/etc/squid/squid.conf"; [[ -d /etc/squid3 ]] && var_sqd="/etc/squid3/squid.conf"
        cat > $var_sqd <<-EOF
			acl url1 dstdomain -i 127.0.0.1
			acl url2 dstdomain -i localhost
			acl url3 dstdomain -i $ipdovps
			acl all src 0.0.0.0/0
			http_access allow url1
			http_access allow url2
			http_access allow url3
			http_access deny all
			#Puertos
			visible_hostname SSHPLUS
			via off
			forwarded_for off
		EOF
        for Pts in $portass; do
            echo "http_port $Pts" >> $var_sqd
            _fw_open $Pts tcp
        done
        fun_bar 'service squid restart'
        echo -e "\n\033[1;32mSQUID INSTALADO!\033[0m"; sleep 2; fun_conexao
    fi
}

fun_squid() {
    if ! _check_proc 'squid'; then inst_sqd; return; fi
    sqdp=$(get_ports_by_process 'squid')
    echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
    echo -e "\033[0;34mв”ѓ\E[44;1;37m          GESTIONAR SQUID PROXY          \E[0m\033[0;34mв”ѓ"
    echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
    [[ -n "$sqdp" ]] && echo -e "\033[0;34mв•ј \033[1;32mPUERTOS\033[1;37m: $sqdp"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mINSTALAR/REMOVER  \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mAGREGAR PUERTO    \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mELIMINAR PUERTO   \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER            \033[0;34mв”ѓ"
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read x; clear
    case $x in
    1|01) inst_sqd ;;
    2|02)
        var_sqd="/etc/squid/squid.conf"; [[ -f /etc/squid3/squid.conf ]] && var_sqd="/etc/squid3/squid.conf"
        echo -ne "\033[1;32mPUERTO A AGREGAR: \033[1;37m"; read pt; [[ -z "$pt" ]] && { fun_conexao; return; }
        sed -i "s/#Puertos/#Puertos\nhttp_port $pt/" $var_sqd
        _fw_open $pt; fun_bar 'service squid restart' 'service squid3 restart'
        echo -e "\n\033[1;32mPUERTO AGREGADO!"; sleep 2; fun_squid ;;
    3|03)
        var_sqd="/etc/squid/squid.conf"; [[ -f /etc/squid3/squid.conf ]] && var_sqd="/etc/squid3/squid.conf"
        echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read pt
        sed -i "/http_port $pt/d" $var_sqd
        fun_bar 'service squid restart' 'service squid3 restart'
        echo -e "\n\033[1;32mPUERTO ELIMINADO!"; sleep 2; fun_squid ;;
    0|00) fun_conexao ;;
    *) echo -e "\033[1;31mOpciГіn invГЎlida!"; sleep 1; fun_squid ;;
    esac
}

