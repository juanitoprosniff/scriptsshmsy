_parchear_proxy() {
    local ruta="$1"
    [[ ! -f "$ruta" ]] && { echo -e "\033[1;31mArchivo $ruta no encontrado.\033[0m"; sleep 2; return; }

    if grep -q "ENHANCED_FIX\|_handle_enhanced\|SO_KEEPALIVE" "$ruta" 2>/dev/null; then
        echo -e "\033[1;32m✓ $(basename $ruta) ya tiene el fix aplicado.\033[0m"; sleep 2; return
    fi

    cp "$ruta" "${ruta}.bak.$(date +%Y%m%d%H%M%S)"

    # Escribir parche Python que agrega el handler al inicio del archivo
    python3 <<PYEOF
import sys, re

ruta = "$ruta"
with open(ruta, 'r') as f:
    content = f.read()

patch = '''
# ════════════════════════════════════════════════════════
# ENHANCED + BROKEN PIPE FIX — by SSHMSY
# Resuelve:
#  1) "Illegal packet size (1231976033)" con Enhanced/Auto Replace
#  2) "Broken pipe" con Dropbear/OpenSSH modernos
#  3) Keepalive TCP para conexiones largas
# ════════════════════════════════════════════════════════
import socket as _socket_mod, hashlib as _hashlib_mod, base64 as _base64_mod

def _handle_enhanced(conn):
    """
    Detecta si el cliente envía HTTP antes del túnel SSH.
    Modo Enhanced (HTTP Custom) = envía payload HTTP primero.
    Responde con 101/200 y devuelve True si era HTTP.
    Devuelve False si ya es tráfico SSH/binario directo.
    """
    # ENHANCED_FIX — marcador para evitar doble parche
    try:
        conn.settimeout(4)
        head = conn.recv(8, _socket_mod.MSG_PEEK)
        conn.settimeout(None)
    except Exception:
        conn.settimeout(None)
        return False

    if not head:
        return False

    # Primeros bytes de SSH: "SSH-" (0x5353482D)
    # Si no empieza con método HTTP conocido, es SSH directo
    http_methods = (b"GET ", b"POST", b"HEAD", b"CONN", b"PUT ", b"OPTI", b"DELE")
    if head[:4] not in [m[:4] for m in http_methods]:
        return False

    # Leer petición HTTP completa
    try:
        conn.settimeout(6)
        buf = b""
        while b"\\r\\n\\r\\n" not in buf and len(buf) < 8192:
            chunk = conn.recv(4096)
            if not chunk:
                break
            buf += chunk
        conn.settimeout(None)
    except Exception:
        conn.settimeout(None)
        return False

    try:
        if b"Upgrade: websocket" in buf or b"upgrade: websocket" in buf:
            # WebSocket upgrade — calcular Sec-WebSocket-Accept
            ws_key = b""
            for line in buf.split(b"\\r\\n"):
                if b"Sec-WebSocket-Key:" in line:
                    ws_key = line.split(b": ", 1)[1].strip()
                    break
            if ws_key:
                magic = b"258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
                accept = _base64_mod.b64encode(
                    _hashlib_mod.sha1(ws_key + magic).digest()
                ).decode()
                resp = ("HTTP/1.1 101 Switching Protocols\\r\\n"
                        "Upgrade: websocket\\r\\n"
                        "Connection: Upgrade\\r\\n"
                        f"Sec-WebSocket-Accept: {accept}\\r\\n\\r\\n")
            else:
                resp = "HTTP/1.1 101 Switching Protocols\\r\\nUpgrade: websocket\\r\\nConnection: Upgrade\\r\\n\\r\\n"
            conn.sendall(resp.encode())
        elif buf[:7] == b"CONNECT":
            conn.sendall(b"HTTP/1.1 200 Connection Established\\r\\n\\r\\n")
        else:
            # Enhanced / Auto Replace genérico
            conn.sendall(b"HTTP/1.1 200 OK\\r\\nContent-Type: text/html\\r\\nConnection: keep-alive\\r\\n\\r\\n")
    except Exception:
        return False

    # Activar keepalive TCP para evitar Broken pipe
    try:
        conn.setsockopt(_socket_mod.SOL_SOCKET, _socket_mod.SO_KEEPALIVE, 1)
        import struct
        if hasattr(_socket_mod, "TCP_KEEPIDLE"):
            conn.setsockopt(_socket_mod.IPPROTO_TCP, _socket_mod.TCP_KEEPIDLE, 30)
        if hasattr(_socket_mod, "TCP_KEEPINTVL"):
            conn.setsockopt(_socket_mod.IPPROTO_TCP, _socket_mod.TCP_KEEPINTVL, 10)
        if hasattr(_socket_mod, "TCP_KEEPCNT"):
            conn.setsockopt(_socket_mod.IPPROTO_TCP, _socket_mod.TCP_KEEPCNT, 5)
    except Exception:
        pass

    return True

def _apply_keepalive(sock):
    """Activa keepalive TCP en un socket para evitar Broken pipe."""
    try:
        sock.setsockopt(_socket_mod.SOL_SOCKET, _socket_mod.SO_KEEPALIVE, 1)
        if hasattr(_socket_mod, "TCP_KEEPIDLE"):
            sock.setsockopt(_socket_mod.IPPROTO_TCP, _socket_mod.TCP_KEEPIDLE, 30)
        if hasattr(_socket_mod, "TCP_KEEPINTVL"):
            sock.setsockopt(_socket_mod.IPPROTO_TCP, _socket_mod.TCP_KEEPINTVL, 10)
        if hasattr(_socket_mod, "TCP_KEEPCNT"):
            sock.setsockopt(_socket_mod.IPPROTO_TCP, _socket_mod.TCP_KEEPCNT, 5)
    except Exception:
        pass
# ════════════════════════════════════════════════════════
'''

# Insertar el parche al inicio, después de los imports
lines = content.split('\n')
insert_at = 0
for i, line in enumerate(lines):
    stripped = line.strip()
    if stripped and not stripped.startswith('#') and not stripped.startswith('import') and not stripped.startswith('from'):
        insert_at = i
        break

if insert_at == 0:
    insert_at = len(lines) // 4

lines.insert(insert_at, patch)
new_content = '\n'.join(lines)

# Parchear el accept() para llamar _handle_enhanced
new_content = re.sub(
    r'(conn\s*,\s*addr\s*=\s*\w+\.accept\s*\(\s*\))',
    r'\1\n        _handle_enhanced(conn); _apply_keepalive(conn)',
    new_content
)

with open(ruta, 'w') as f:
    f.write(new_content)
print("OK")
PYEOF

    if [[ $? -eq 0 ]]; then
        echo -e "\033[1;32m✓ Fix aplicado en $(basename $ruta)\033[0m"
        # Reiniciar sesiones activas
        local _sname="${ruta##*/}"; _sname="${_sname%.py}"
        for pid in $(screen -ls 2>/dev/null | grep "$_sname" | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        screen -wipe >/dev/null 2>&1
        echo -e "\033[1;33mReinicie el proxy desde opción 1/2 del menú Socks.\033[0m"
    else
        echo -e "\033[1;31mError al aplicar parche. Restaurando backup...\033[0m"
        ls "${ruta}.bak."* 2>/dev/null | tail -1 | xargs -I{} cp {} "$ruta"
    fi
    sleep 2
}

# ── Fix keepalive en SSH y Dropbear para Broken pipe ─────────
_fix_ssh_keepalive() {
    clear
    echo -e "\033[1;33mAplicando keepalive en OpenSSH y Dropbear...\033[0m"
    echo ""

    # OpenSSH sshd_config
    local _sshcfg="/etc/ssh/sshd_config"
    if [[ -f "$_sshcfg" ]]; then
        # Remover entradas previas
        sed -i '/^ClientAliveInterval/d' $_sshcfg
        sed -i '/^ClientAliveCountMax/d' $_sshcfg
        sed -i '/^TCPKeepAlive/d' $_sshcfg
        # Agregar keepalive
        cat >> $_sshcfg <<EOF

# KEEPALIVE — evita Broken pipe
ClientAliveInterval 30
ClientAliveCountMax 10
TCPKeepAlive yes
EOF
        _restart_ssh
        echo -e "\033[1;32m✓ Keepalive aplicado en OpenSSH\033[0m"
    fi

    # Dropbear — agregar -K (keepalive) al comando de inicio
    if [[ -f /etc/systemd/system/dropbear.service.d/override.conf ]]; then
        # Agregar keepalive al ExecStart de Dropbear si no está
        if ! grep -q "\-K " /etc/systemd/system/dropbear.service.d/override.conf; then
            sed -i 's|dropbear -F|dropbear -F -K 30 -I 120|' \
                /etc/systemd/system/dropbear.service.d/override.conf
            systemctl daemon-reload 2>/dev/null
            systemctl restart dropbear 2>/dev/null
            echo -e "\033[1;32m✓ Keepalive aplicado en Dropbear\033[0m"
        fi
    fi

    # Dropbear 2016
    if grep -q 'dropbear2016' /etc/autostart 2>/dev/null; then
        if ! grep -q "\-K " /etc/autostart; then
            sed -i 's|dropbear -r|dropbear -K 30 -I 120 -r|' /etc/autostart
            echo -e "\033[1;32m✓ Keepalive aplicado en Dropbear 2016\033[0m"
            # Reiniciar
            for _sid in $(screen -ls 2>/dev/null | grep 'dropbear2016' | awk '{print $1}'); do
                screen -r -S "$_sid" -X quit 2>/dev/null
            done
            sleep 1
            local _db16_cmd=$(grep 'dropbear2016' /etc/autostart | tail -1)
            [[ -n "$_db16_cmd" ]] && eval "$_db16_cmd"
        fi
    fi

    echo ""
    echo -e "\033[1;32m✓ Keepalive configurado. Los Broken pipe deberían reducirse.\033[0m"
    sleep 3; _fix_enhanced_broken_pipe
}

