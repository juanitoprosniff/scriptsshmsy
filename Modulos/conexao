criarteste() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           CRIAR USUÁRIO TESTE            \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""
    echo -ne "\033[1;32mUSUÁRIO : \033[1;37m"; read usuario
    [[ -z "$usuario" ]] && { echo -e "\033[1;31mUsuario vacío!\033[0m"; sleep 2; return; }
    if id "$usuario" &>/dev/null; then
        echo -e "\033[1;31mUsuario '$usuario' ya existe!\033[0m"; sleep 2; return
    fi
    echo -ne "\033[1;32mSENHA   : \033[1;37m"; read -s senha; echo ""
    [[ -z "$senha" ]] && senha="$usuario"
    echo -ne "\033[1;32mDIAS    : \033[1;37m"; read dias
    [[ -z "$dias" ]] && dias=1

    useradd -m -s /bin/bash "$usuario" 2>/dev/null
    echo "${usuario}:${senha}" | chpasswd 2>/dev/null || {
        _hash=$(openssl passwd -6 "$senha" 2>/dev/null || openssl passwd -1 "$senha")
        usermod -p "$_hash" "$usuario" 2>/dev/null
    }
    _exp_date=$(date -d "+${dias} days" +%Y-%m-%d 2>/dev/null)
    [[ -n "$_exp_date" ]] && chage -E "$_exp_date" "$usuario" 2>/dev/null

    _ssh_p=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | xargs)
    _db16_p=$(systemctl show dropbear-legacy --property=ExecStart 2>/dev/null | grep -oP '(?<=-p )\d+' | head -1)
    _py_p=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
    _ssl_p=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)

    echo ""
    echo -e "\033[1;32m✓ Usuario TESTE creado!\033[0m"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;32mUsuario  :\033[1;37m $usuario"
    echo -e "\033[1;32mSenha    :\033[1;37m $senha"
    echo -e "\033[1;32mExpira   :\033[1;37m ${_exp_date:-$dias día(s)}"
    echo -e "\033[1;33m━━━━━ PUERTOS ━━━━━\033[0m"
    [[ -n "$_ssh_p"  ]] && echo -e "\033[1;37m  SSH  → \033[1;32m$_ssh_p"
    [[ -n "$_db16_p" ]] && echo -e "\033[1;37m  DB16 → \033[1;32m$_db16_p"
    [[ -n "$_py_p"   ]] && echo -e "\033[1;37m  Proxy→ \033[1;32m$_py_p"
    [[ -n "$_ssl_p"  ]] && echo -e "\033[1;37m  SSL  → \033[1;32m$_ssl_p"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""
}

