_nginx_check_stream() {
    # Verificar que nginx tenga el mГіdulo stream instalado
    nginx -V 2>&1 | grep -q 'stream' && return 0
    # En Ubuntu 20/22/24 nginx-full tiene stream, nginx no siempre
    apt-get install -y nginx-full 2>/dev/null | grep -q 'already' && return 0
    dpkg -l nginx-full 2>/dev/null | grep -q '^ii' && return 0
    return 1
}

