# SSLH
# ============================================================
fun_sslh() {
    _sslh_run=$(ss -tlpn 2>/dev/null | grep -c 'sslh')
    [[ "$_sslh_run" = '0' ]] && {
        echo -e "\E[44;1;37m             INSTALAR SSLH               \E[0m\n"
        echo -ne "\033[1;32mINSTALAR SSLH EN PUERTO 443? \033[1;33m[s/n]: \033[1;37m"; read resp
        [[ "$resp" = 's' ]] && {
            verif_ptrs 443
            fun_instsslh() {
                ptssl=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | head -1); [[ -z "$ptssl" ]] && ptssl=3128
                ptvpn=$(ss -tlpn 2>/dev/null | grep 'openvpn' | awk '{print $4}' | rev | cut -d: -f1 | rev | head -1); [[ -z "$ptvpn" ]] && ptvpn=1194
                DEBIAN_FRONTEND=noninteractive apt-get -y install sslh >/dev/null 2>&1
                printf "RUN=yes\nDAEMON=/usr/sbin/sslh\nDAEMON_OPTS='--user sslh --listen 0.0.0.0:443 --ssh 127.0.0.1:22 --ssl 127.0.0.1:%s --http 127.0.0.1:80 --openvpn 127.0.0.1:%s --pidfile /var/run/sslh/sslh.pid'\n" "$ptssl" "$ptvpn" > /etc/default/sslh
                service sslh start >/dev/null 2>&1
            }
            fun_bar 'fun_instsslh'
            _abrir_puerto_fw 443 tcp
            _ok=$(ss -tlpn 2>/dev/null | grep -wc 'sslh')
            [[ "$_ok" != '0' ]] && echo -e "\n\033[1;32mSSLH INSTALADO!\033[0m" || echo -e "\n\033[1;31mERROR!\033[0m"
        }
        sleep 2; fun_conexao
    } || {
        echo -e "\E[41;1;37m             REMOVER SSLH               \E[0m\n"
        echo -ne "\033[1;32mREMOVER SSLH? \033[1;33m[s/n]: \033[1;37m"; read respo
        [[ "$respo" = 's' ]] && { service sslh stop >/dev/null 2>&1; apt-get remove --purge sslh -y >/dev/null 2>&1; echo -e "\n\033[1;32mSSLH ELIMINADO!\033[0m"; }
        sleep 2; fun_conexao
    }
}

