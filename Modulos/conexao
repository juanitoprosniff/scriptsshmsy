    local _hys_url
    case "$_ARCH" in
        amd64) _hys_url="https://github.com/apernet/hysteria/releases/latest/download/hysteria-linux-amd64" ;;
        arm64) _hys_url="https://github.com/apernet/hysteria/releases/latest/download/hysteria-linux-arm64" ;;
        arm)   _hys_url="https://github.com/apernet/hysteria/releases/latest/download/hysteria-linux-arm" ;;
        *)     _hys_url="https://github.com/apernet/hysteria/releases/latest/download/hysteria-linux-amd64" ;;
