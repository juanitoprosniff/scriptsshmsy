#!/usr/bin/env python3
# wsproxy2.py — WebSocket Proxy mejorado
# Autor: SSHMSY | Versión: 2.0
# Soporta: Enhanced, Auto Replace, Multi-conexión, Keepalive
# Compatible: HTTP Custom, HTTP Injector, NapsternetV

import socket, threading, select, sys, hashlib, base64, signal, os

# ── Configuración ────────────────────────────────────────────
LISTEN_PORT   = int(sys.argv[1]) if len(sys.argv) > 1 else 8080
DEFAULT_HOST  = '127.0.0.1:${_dst_p}'
MSG           = 'SSHMSY VPN'
BUFFER_SIZE   = 65536   # 64 KB — mayor velocidad
MAX_CONNS     = 500     # máximo de conexiones simultáneas
KEEPALIVE_INT = 30      # segundos entre keepalives TCP

# ── Respuesta WebSocket ───────────────────────────────────────
def ws_accept_key(key_bytes):
    magic = b"258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
    return base64.b64encode(hashlib.sha1(key_bytes + magic).digest()).decode()

def build_ws_response(headers_bytes):
    ws_key = b""
    for line in headers_bytes.split(b"\r\n"):
        if b"Sec-WebSocket-Key:" in line:
            ws_key = line.split(b": ", 1)[1].strip()
            break
    accept = ws_accept_key(ws_key) if ws_key else "dGhlIHNhbXBsZSBub25jZQ=="
    return (
        "HTTP/1.1 101 Switching Protocols\r\n"
        "Upgrade: websocket\r\n"
        "Connection: Upgrade\r\n"
        f"Sec-WebSocket-Accept: {accept}\r\n"
        "\r\n"
    ).encode()

# ── Detectar y manejar HTTP inicial (Enhanced / Auto Replace) ─
def handle_http_preamble(client):
    """
    Si el cliente envía HTTP antes del túnel SSH, responder
    con 101/200/CONNECT según corresponda y devolver True.
    Para tráfico SSH directo devuelve False.
    """
    try:
        client.settimeout(5)
        peek = client.recv(8, socket.MSG_PEEK)
        client.settimeout(None)
    except Exception:
        client.settimeout(None)
        return False

    if not peek:
        return False

    # SSH empieza con "SSH-"
    if peek[:4] == b"SSH-" or peek[0] in (0, 5, 10, 20, 21):
        return False

    http_starts = (b"GET ", b"POST", b"HEAD", b"CONN", b"PUT ", b"OPTI")
    if peek[:4] not in [s[:4] for s in http_starts]:
        return False

    # Leer cabeceras completas
    buf = b""
    try:
        client.settimeout(8)
        while b"\r\n\r\n" not in buf and len(buf) < 16384:
            chunk = client.recv(4096)
            if not chunk:
                break
            buf += chunk
        client.settimeout(None)
    except Exception:
        client.settimeout(None)

    if not buf:
        return False

    try:
        if b"Upgrade: websocket" in buf or b"upgrade: websocket" in buf:
            client.sendall(build_ws_response(buf))
        elif buf[:7] == b"CONNECT":
            client.sendall(b"HTTP/1.1 200 Connection Established\r\n\r\n")
        else:
            # Enhanced genérico / Auto Replace / payload
            resp = (
                "HTTP/1.1 200 OK\r\n"
                f"Content-Type: text/html\r\n"
                "Connection: keep-alive\r\n"
                f"X-Status: {MSG}\r\n"
                "\r\n"
            )
            client.sendall(resp.encode())
    except Exception:
        return False

    return True

# ── Keepalive TCP ─────────────────────────────────────────────
def set_keepalive(sock, idle=KEEPALIVE_INT):
    try:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_KEEPALIVE, 1)
        if hasattr(socket, "TCP_KEEPIDLE"):
            sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPIDLE, idle)
        if hasattr(socket, "TCP_KEEPINTVL"):
            sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPINTVL, 10)
        if hasattr(socket, "TCP_KEEPCNT"):
            sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPCNT, 6)
    except Exception:
        pass

# ── Relay de datos entre dos sockets ─────────────────────────
def relay(src, dst):
    src.settimeout(120)
    dst.settimeout(120)
    while True:
        try:
            r, _, e = select.select([src, dst], [], [src, dst], 60)
            if e:
                break
            if not r:
                continue
            for s in r:
                data = s.recv(BUFFER_SIZE)
                if not data:
                    return
                other = dst if s is src else src
                other.sendall(data)
        except Exception:
            break

# ── Manejador de cada conexión ────────────────────────────────
def handle_client(client, addr):
    target = None
    try:
        set_keepalive(client)
        handle_http_preamble(client)

        host, port = DEFAULT_HOST.rsplit(":", 1)
        target = socket.create_connection((host, int(port)), timeout=10)
        set_keepalive(target)
        relay(client, target)
    except Exception:
        pass
    finally:
        for s in (client, target):
            if s:
                try:
                    s.close()
                except Exception:
                    pass

# ── Servidor principal ────────────────────────────────────────
def main():
    server = socket.socket(socket.AF_INET6 if ":" in "0.0.0.0" else socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    # IPv4 + IPv6 dual stack
    try:
        server2 = socket.socket(socket.AF_INET6, socket.SOCK_STREAM)
        server2.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server2.setsockopt(socket.IPPROTO_IPV6, socket.IPV6_V6ONLY, 0)
        server2.bind(("::", LISTEN_PORT))
        server2.listen(MAX_CONNS)
        server = server2
    except Exception:
        server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server.bind(("0.0.0.0", LISTEN_PORT))
        server.listen(MAX_CONNS)

    signal.signal(signal.SIGCHLD, signal.SIG_IGN)
    print(f"[wsproxy2] Puerto {LISTEN_PORT} → {DEFAULT_HOST} | Enhanced: ON | Keepalive: ON")

    while True:
        try:
            client, addr = server.accept()
            t = threading.Thread(target=handle_client, args=(client, addr), daemon=True)
            t.start()
        except KeyboardInterrupt:
            break
        except Exception:
            pass

if __name__ == "__main__":
    main()
WSPY

