# ============================================================
# WSPROXY — Script Python para WebSocket SSH
# Generado automáticamente, compatible Python 3.6–3.12
# Soporta argumento de destino: python3 wsproxy.py PUERTO [HOST:PUERTO_DESTINO]
# ============================================================
_generar_wsproxy() {
    mkdir -p /etc/SSHPlus
    cat > /etc/SSHPlus/wsproxy.py <<'PYEOF'
#!/usr/bin/env python3
# wsproxy.py — WebSocket SSH proxy
# Uso: python3 wsproxy.py <puerto_listen> [host:puerto_destino]
# Compatible: Python 3.6–3.12, Ubuntu 18–26
import sys, socket, select, threading, time

MSG    = 'SSH-MSY VPN'
color  = "green"
STATUS = f'HTTP/1.1 101 {MSG}\r\nContent-Length: 0\r\nUpgrade: WebSocket\r\nConnection: Upgrade\r\nSec-WebSocket-Accept: {MSG}\r\n\r\n'
BADREQ = b'HTTP/1.1 400 Bad Request\r\nContent-Length: 0\r\nConnection: close\r\n\r\n'

DEFAULT_HOST = '127.0.0.1:22'

def handle(client, remote_host, remote_port):
    try:
        # Leer solicitud HTTP/WebSocket del cliente
        buf = b''
        while b'\r\n\r\n' not in buf:
            chunk = client.recv(4096)
            if not chunk:
                return
            buf += chunk
        # Responder con 101 Switching Protocols
        client.sendall(STATUS.encode())
        # Conectar al backend SSH (Dropbear / OpenSSH)
        back = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        back.connect((remote_host, remote_port))
        # Tunnel bidireccional
        def fwd(src, dst):
            try:
                while True:
                    data = src.recv(65536)
                    if not data:
                        break
                    dst.sendall(data)
            except:
                pass
            finally:
                for s in (src, dst):
                    try: s.shutdown(socket.SHUT_RDWR)
                    except: pass
                    try: s.close()
                    except: pass
        t1 = threading.Thread(target=fwd, args=(client, back), daemon=True)
        t2 = threading.Thread(target=fwd, args=(back, client), daemon=True)
        t1.start(); t2.start()
        t1.join(); t2.join()
    except Exception as e:
        try: client.close()
        except: pass

def main():
    listen_port = int(sys.argv[1]) if len(sys.argv) > 1 else 80
    dest = sys.argv[2] if len(sys.argv) > 2 else DEFAULT_HOST
    if ':' in dest:
        remote_host, remote_port = dest.rsplit(':', 1)
        remote_port = int(remote_port)
    else:
        remote_host = '127.0.0.1'
        remote_port = int(dest)

    srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    srv.bind(('0.0.0.0', listen_port))
    srv.listen(512)
    print(f'[wsproxy] Escuchando :{listen_port} → {remote_host}:{remote_port}')
    while True:
        try:
            cli, _ = srv.accept()
            threading.Thread(target=handle, args=(cli, remote_host, remote_port), daemon=True).start()
        except:
            pass

if __name__ == '__main__':
    main()
PYEOF
    chmod 755 /etc/SSHPlus/wsproxy.py
    echo -e "\033[1;32m✓ wsproxy.py generado/actualizado.\033[0m"
}

# ============================================================
# SSL TUNNEL — Arquitectura dual: DIRECTO y SSL+WS
#
# FLUJOS:
#  [A] SSL STUNNEL DIRECTO
#      Cliente → stunnel(443/444/8443) → Dropbear:143 (o OpenSSH:22)
#      Uso: clientes que solo soportan SSL plano
#
#  [B] SSL + WEBSOCKET
#      Cliente → stunnel(443/444/8443) → wsproxy(80) → Dropbear:143
#      Uso: clientes con payload WebSocket (SNI, HTTP Injector, etc.)
#      El wsproxy maneja el handshake WS ANTES de pasar a Dropbear
#
# PUERTOS:
#  - 443, 444, 8443  →  stunnel escucha (TLS termination)
#  - 80, 8080, 8880  →  wsproxy escucha (solo en modo SSL+WS)
#
# REGLA:
#  - Modo DIRECTO:  stunnel connect = 127.0.0.1:<puerto_ssh>
#  - Modo SSL+WS:   stunnel connect = 127.0.0.1:<puerto_wsproxy>
#                   wsproxy connect = 127.0.0.1:<puerto_ssh>
# ============================================================
inst_ssl() {
    if _check_proc 'stunnel4'; then
        # ── SSL ya instalado: menú de gestión ────────────────
        sslt=$(ss -tlpn 2>/dev/null | grep 'stunnel' | \
               awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
        [[ -z "$sslt" ]] && sslt="\033[1;31mINDISPONIBLE"

        # Detectar modo actual
        local _modo_actual="DIRECTO"
        if grep -q "^connect.*= 127.0.0.1:8[0-9]$\|^connect.*= 127.0.0.1:80$" \
                /etc/stunnel/stunnel.conf 2>/dev/null; then
            _modo_actual="SSL+WEBSOCKET"
        fi

        # Detectar destino SSH
        local _dst_actual
        if [[ "$_modo_actual" = "SSL+WEBSOCKET" ]]; then
            # En modo WS, el destino SSH está en el wsproxy activo
            _dst_actual=$(ps aux 2>/dev/null | grep wsproxy | grep -v grep | \
                          grep -oP '127\.0\.0\.1:\d+' | head -1)
            [[ -z "$_dst_actual" ]] && _dst_actual="wsproxy (ver estado WS)"
        else
            _dst_actual=$(grep '^connect' /etc/stunnel/stunnel.conf 2>/dev/null | \
                          head -1 | awk -F= '{print $2}' | tr -d ' ')
        fi

        clear
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m           GESTIONAR SSL TUNNEL          \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -e "\033[0;34m╼ \033[1;32mPUERTOS SSL\033[1;37m: $sslt"
        echo -e "\033[0;34m╼ \033[1;32mMODO\033[1;37m: $_modo_actual"
        echo -e "\033[0;34m╼ \033[1;32mDESTINO\033[1;37m: $_dst_actual"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mAGREGAR PUERTO SSL       \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR PUERTO SSL      \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mCAMBIAR MODO (Dir/WS)    \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mCAMBIAR DESTINO SSH      \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mELIMINAR SSL TUNNEL      \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                   \033[0;34m┃"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta; echo ""

        case "$resposta" in
        1)
            # Agregar puerto SSL — hereda modo y destino actual
            echo -ne "\033[1;32mNUEVO PUERTO SSL: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            verif_ptrs $porta
            local _connect
            if [[ "$_modo_actual" = "SSL+WEBSOCKET" ]]; then
                # En modo WS el destino del stunnel es el wsproxy
                local _ws_p=$(_get_wsproxy_port)
                [[ -z "$_ws_p" ]] && _ws_p=80
                _connect="127.0.0.1:${_ws_p}"
            else
                _connect=$(grep '^connect' /etc/stunnel/stunnel.conf | \
                           head -1 | awk -F= '{print $2}' | tr -d ' ')
                [[ -z "$_connect" ]] && _connect="127.0.0.1:22"
            fi
            cat >> /etc/stunnel/stunnel.conf <<EOF

[sshtunnel${porta}]
accept  = $porta
connect = $_connect
EOF
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            _fw_open $porta
            echo -e "\n\033[1;32mPUERTO $porta AGREGADO! (→ $_connect)\033[0m"
            sleep 2; inst_ssl; return
            ;;
        2)
            echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            sed -i "/\[sshtunnel${porta}\]/,/^$/d" /etc/stunnel/stunnel.conf 2>/dev/null
            sed -i "/accept  = ${porta}/d" /etc/stunnel/stunnel.conf 2>/dev/null
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            echo -e "\n\033[1;32mPUERTO $porta ELIMINADO!\033[0m"; sleep 2; inst_ssl; return
            ;;
        3)
            # ── CAMBIAR MODO: DIRECTO ↔ SSL+WEBSOCKET ────────
            _cambiar_modo_ssl
            ;;
        4)
            # ── CAMBIAR DESTINO SSH ───────────────────────────
            _cambiar_destino_ssl "$_modo_actual"
            ;;
        5)
            pkill stunnel4 2>/dev/null; systemctl stop stunnel4 2>/dev/null
            apt-get remove --purge stunnel4 -y >/dev/null 2>&1
            rm -f /etc/stunnel/stunnel.conf /etc/stunnel/stunnel.pem \
                  /etc/stunnel/stunnel.key /etc/stunnel/stunnel.crt
            echo -e "\n\033[1;32mSSL TUNNEL ELIMINADO!\033[0m"; sleep 2; fun_conexao; return
            ;;
        0|00) fun_conexao; return ;;
        esac
        fun_conexao; return
    fi

    # ── Instalación nueva ─────────────────────────────────────
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           INSTALAR SSL TUNNEL           \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\n\033[1;33mSeleccione MODO del túnel SSL:\033[0m\n"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mSSL DIRECTO     \033[1;37m(stunnel → SSH/Dropbear) \033[0;34m┃"
    echo -e "\033[0;34m┃                \033[1;37mUso: clientes SSL plano          \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mSSL + WEBSOCKET \033[1;37m(stunnel → wsproxy → SSH)\033[0;34m┃"
    echo -e "\033[0;34m┃                \033[1;37mUso: HTTP Injector, SNI, payload \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                                    \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read ssl_modo; echo ""

    case "$ssl_modo" in
    1) _instalar_ssl_directo ;;
    2) _instalar_ssl_websocket ;;
    0) fun_conexao; return ;;
    *) echo -e "\033[1;31mOpción inválida!"; sleep 1; inst_ssl; return ;;
    esac
}

# ── SELECCIÓN DE DESTINO SSH (común para ambos modos) ────────
