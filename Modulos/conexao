_parchear_proxy() {
    local ruta="$1"
    [[ ! -f "$ruta" ]] && { echo -e "\033[1;31mArchivo $ruta no encontrado.\033[0m"; sleep 2; return; }

    if grep -q "ENHANCED_FIX\|_handle_enhanced\|SO_KEEPALIVE" "$ruta" 2>/dev/null; then
        echo -e "\033[1;32mвњ“ $(basename $ruta) ya tiene el fix aplicado.\033[0m"; sleep 2; return
    fi

    cp "$ruta" "${ruta}.bak.$(date +%Y%m%d%H%M%S)"

    # Escribir parche Python que agrega el handler al inicio del archivo
    python3 <<PYEOF
import sys, re

ruta = "$ruta"
with open(ruta, 'r') as f:
    content = f.read()

patch = '''
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# ENHANCED + BROKEN PIPE FIX вЂ” by SSHMSY
# Resuelve:
#  1) "Illegal packet size (1231976033)" con Enhanced/Auto Replace
#  2) "Broken pipe" con Dropbear/OpenSSH modernos
#  3) Keepalive TCP para conexiones largas
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
import socket as _socket_mod, hashlib as _hashlib_mod, base64 as _base64_mod

def _handle_enhanced(conn):
    """
    Detecta si el cliente envГ­a HTTP antes del tГєnel SSH.
    Modo Enhanced (HTTP Custom) = envГ­a payload HTTP primero.
    Responde con 101/200 y devuelve True si era HTTP.
    Devuelve False si ya es trГЎfico SSH/binario directo.
    """
    # ENHANCED_FIX вЂ” marcador para evitar doble parche
    try:
        conn.settimeout(4)
        head = conn.recv(8, _socket_mod.MSG_PEEK)
        conn.settimeout(None)
    except Exception:
        conn.settimeout(None)
        return False

    if not head:
        return False

    # Primeros bytes de SSH: "SSH-" (0x5353482D)
    # Si no empieza con mГ©todo HTTP conocido, es SSH directo
    http_methods = (b"GET ", b"POST", b"HEAD", b"CONN", b"PUT ", b"OPTI", b"DELE")
    if head[:4] not in [m[:4] for m in http_methods]:
        return False

    # Leer peticiГіn HTTP completa
    try:
        conn.settimeout(6)
        buf = b""
        while b"\\r\\n\\r\\n" not in buf and len(buf) < 8192:
            chunk = conn.recv(4096)
            if not chunk:
