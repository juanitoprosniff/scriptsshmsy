        echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
        echo -e "\033[0;34mв•ј \033[1;32mPUERTOS ACTIVOS\033[1;37m: $sslt"
        echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mAGREGAR PUERTO SSL   \033[0;34mв”ѓ"
        echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR PUERTO SSL  \033[0;34mв”ѓ"
        echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mELIMINAR SSL TUNNEL  \033[0;34mв”ѓ"
        echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER               \033[0;34mв”ѓ"
        echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read resposta; echo ""

        if [[ "$resposta" = '1' ]]; then
            echo -ne "\033[1;32mNUEVO PUERTO SSL: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            verif_ptrs $porta
            # Agregar nueva secciГіn al stunnel.conf
            local _dst=$(grep 'connect' /etc/stunnel/stunnel.conf | head -1 | awk -F: '{print $2}' | tr -d ' ')
            [[ -z "$_dst" ]] && _dst=22
            cat >> /etc/stunnel/stunnel.conf <<EOF

[sshtunnel${porta}]
accept  = $porta
connect = 127.0.0.1:${_dst}
EOF
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            _fw_open $porta
            echo -e "\n\033[1;32mPUERTO $porta AGREGADO!\033[0m"; sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '2' ]]; then
            echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            # Eliminar bloque de ese puerto del conf
            sed -i "/\[sshtunnel${porta}\]/,/^$/d" /etc/stunnel/stunnel.conf 2>/dev/null
            sed -i "/accept  = ${porta}/d" /etc/stunnel/stunnel.conf 2>/dev/null
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            echo -e "\n\033[1;32mPUERTO $porta ELIMINADO!\033[0m"; sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '3' ]]; then
            pkill stunnel4 2>/dev/null; systemctl stop stunnel4 2>/dev/null
            apt-get remove --purge stunnel4 -y >/dev/null 2>&1
            rm -f /etc/stunnel/stunnel.conf /etc/stunnel/stunnel.pem /etc/stunnel/stunnel.key /etc/stunnel/stunnel.crt
            echo -e "\n\033[1;32mSSL TUNNEL ELIMINADO!\033[0m"; sleep 2; fun_conexao; return
        fi
        fun_conexao; return
    fi

    # в”Ђв”Ђ InstalaciГіn con 3 puertos: 443, 444, 8443 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    clear
    echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
    echo -e "\033[0;34mв”ѓ\E[44;1;37m           INSTALAR SSL TUNNEL           \E[0m\033[0;34mв”ѓ"
    echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
    echo -e "\n\033[1;33mSeleccione destino del tГєnel SSL:\033[0m\n"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mSSL в†’ OpenSSH         (puerto 22) \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mSSL в†’ Proxy WS        (puerto 80) \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mSSL в†’ Dropbear 2016  (puerto 143) \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mSSL в†’ Puerto personalizado        \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                            \033[0;34mв”ѓ"
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read resposta; echo ""
    case "$resposta" in
    1) portssl=22 ;;
    2) portssl=80 ;;
    3) portssl=143 ;;
    4) echo -ne "\033[1;32mPUERTO DESTINO: \033[1;37m"; read portssl; [[ -z "$portssl" ]] && { inst_ssl; return; } ;;
    0) fun_conexao; return ;;
    *) echo -e "\033[1;31mOpciГіn invГЎlida!"; sleep 1; inst_ssl; return ;;
    esac

    echo -e "\n\033[1;33mInstalando stunnel4...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y stunnel4 openssl >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
    mkdir -p /etc/stunnel

    echo -e "\033[1;32mGenerando certificado SSL...\033[0m"
    openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
        -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
        -keyout /etc/stunnel/stunnel.key \
        -out /etc/stunnel/stunnel.crt >/dev/null 2>&1
    cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
    chmod 600 /etc/stunnel/stunnel.pem

    [[ ! -s /etc/stunnel/stunnel.pem ]] && {
        echo -e "\033[1;31mError al generar certificado!\033[0m"; sleep 2; inst_ssl; return
    }

    # ConfiguraciГіn con 3 puertos: 443, 444, 8443
    cat > /etc/stunnel/stunnel.conf <<EOF
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

[sshtunnel443]
accept  = 443
connect = 127.0.0.1:$portssl

[sshtunnel444]
accept  = 444
connect = 127.0.0.1:$portssl

[sshtunnel8443]
accept  = 8443
connect = 127.0.0.1:$portssl
EOF

    echo -e "\033[1;32mIniciando SSL Tunnel en puertos 443, 444, 8443...\033[0m"
    if systemctl is-enabled stunnel4 >/dev/null 2>&1; then
        systemctl enable stunnel4 >/dev/null 2>&1; systemctl restart stunnel4 >/dev/null 2>&1
    else
        service stunnel4 restart >/dev/null 2>&1
    fi

    # Abrir TODOS los puertos SSL en el firewall (incluyendo 444 que a veces falla)
    for _sslp in 443 444 8443; do
        _fw_open $_sslp
        # Forzar iptables directo por si el 444 estГЎ bloqueado
        iptables -I INPUT -p tcp --dport $_sslp -j ACCEPT 2>/dev/null
    done
    sleep 1

    if ss -tlpn 2>/dev/null | grep -q ":443 "; then
        echo -e "\n\033[1;32mвњ“ SSL TUNNEL ACTIVO!\033[0m"
        echo -e "\033[1;37mPuertos: \033[1;32m443, 444, 8443 в†’ 127.0.0.1:$portssl\033[0m"
        # Verificar si el 444 estГЎ escuchando
        if ! ss -tlpn 2>/dev/null | grep -q ":444 "; then
            echo -e "\033[1;33mвљ  Puerto 444 no detectado localmente вЂ” puede estar bloqueado por el proveedor.\033[0m"
            echo -e "\033[1;33m  Verifique las reglas del firewall/panel de su VPS para abrir el puerto 444.\033[0m"
        fi
    else
        echo -e "\n\033[1;33mVerifique: systemctl status stunnel4\033[0m"
    fi
    sleep 3; inst_ssl
}

