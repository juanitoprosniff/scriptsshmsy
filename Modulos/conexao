            echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mWS в†’ puerto 8080"
            echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mWS в†’ detectado automГЎticamente (${_auto_ws:-80})"
