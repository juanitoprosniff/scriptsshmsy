INFO

    sleep 4; fun_nginx_multiplex
}

_fun_nginx_status() {
    clear
    echo -e "\033[1;33mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ ESTADO NGINX MULTIPLEX в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
