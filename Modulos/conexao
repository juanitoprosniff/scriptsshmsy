# ── INSTALAR SSL DIRECTO ──────────────────────────────────────
# stunnel(443/444/8443) → 127.0.0.1:<puerto_ssh>
_instalar_ssl_directo() {
    _seleccionar_destino_ssh || return
    local portssl="$_SSH_DST_PORT"

    echo -e "\n\033[1;33mInstalando stunnel4...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y stunnel4 openssl >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
    mkdir -p /etc/stunnel

    echo -e "\033[1;32mGenerando certificado SSL...\033[0m"
    openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
        -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
        -keyout /etc/stunnel/stunnel.key \
        -out /etc/stunnel/stunnel.crt >/dev/null 2>&1
    cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
    chmod 600 /etc/stunnel/stunnel.pem

    [[ ! -s /etc/stunnel/stunnel.pem ]] && {
        echo -e "\033[1;31mError al generar certificado!\033[0m"; sleep 2; inst_ssl; return
    }

    # Guardar modo en archivo de estado
    echo "DIRECTO" > /etc/stunnel/.ssl_mode
    echo "$portssl" >> /etc/stunnel/.ssl_mode

    cat > /etc/stunnel/stunnel.conf <<EOF
# SSL TUNNEL DIRECTO — v3.0
# Flujo: Cliente → stunnel → 127.0.0.1:$portssl
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

[sshtunnel443]
accept  = 443
connect = 127.0.0.1:$portssl

[sshtunnel444]
accept  = 444
connect = 127.0.0.1:$portssl

[sshtunnel8443]
accept  = 8443
connect = 127.0.0.1:$portssl
EOF

    _arrancar_stunnel
    echo -e "\n\033[1;32m✓ SSL DIRECTO ACTIVO!\033[0m"
    echo -e "\033[1;37mFlujo: Cliente → stunnel(443/444/8443) → SSH:$portssl\033[0m"
    sleep 3; inst_ssl
}

# ── INSTALAR SSL + WEBSOCKET ──────────────────────────────────
# stunnel(443/444/8443) → wsproxy(80) → 127.0.0.1:<puerto_ssh>
#
# EXPLICACIÓN DEL FLUJO:
#  1. El cliente hace conexión TLS al puerto 443/444/8443
#  2. stunnel desencripta el TLS y pasa el tráfico a wsproxy:80
#  3. wsproxy recibe la solicitud HTTP con cabeceras WS (Upgrade: websocket)
#     y responde 101 Switching Protocols
#  4. wsproxy crea el tunnel TCP hacia Dropbear:143 (o el SSH elegido)
#  5. El cliente SSH viaja dentro del túnel WS→TLS
_instalar_ssl_websocket() {
    _seleccionar_destino_ssh || return
    local ssh_dst_port="$_SSH_DST_PORT"

    # Puerto de escucha del wsproxy (destino del stunnel)
    echo -e "\n\033[1;33mPuerto del wsproxy (el stunnel conecta aquí):\033[0m"
    echo -e "\033[1;37m  Defecto: 80 (recomendado, no interfiere con SSL)\033[0m"
    echo -ne "\033[1;32mPuerto wsproxy [80]: \033[1;37m"; read ws_listen_port
    [[ -z "$ws_listen_port" ]] && ws_listen_port=80

    echo -e "\n\033[1;33mInstalando stunnel4 y python3...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y stunnel4 openssl python3 >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
    mkdir -p /etc/stunnel /etc/SSHPlus

    echo -e "\033[1;32mGenerando certificado SSL...\033[0m"
    openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
        -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
        -keyout /etc/stunnel/stunnel.key \
        -out /etc/stunnel/stunnel.crt >/dev/null 2>&1
    cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
    chmod 600 /etc/stunnel/stunnel.pem

    [[ ! -s /etc/stunnel/stunnel.pem ]] && {
        echo -e "\033[1;31mError al generar certificado!\033[0m"; sleep 2; inst_ssl; return
    }

    # Generar / actualizar wsproxy.py
    _generar_wsproxy

    # Parar wsproxy anterior si existe en ese puerto
    for pid in $(screen -ls 2>/dev/null | grep "ws${ws_listen_port}" | awk '{print $1}'); do
        screen -r -S "$pid" -X quit 2>/dev/null
    done
    pkill -f "wsproxy.py $ws_listen_port" 2>/dev/null
    sleep 0.5

    # Arrancar wsproxy apuntando al SSH destino
    verif_ptrs $ws_listen_port
    screen -dmS "ws${ws_listen_port}" python3 /etc/SSHPlus/wsproxy.py \
        $ws_listen_port "127.0.0.1:${ssh_dst_port}"
    _fw_open $ws_listen_port tcp
    iptables -I INPUT -p tcp --dport $ws_listen_port -j ACCEPT 2>/dev/null

    # Agregar al autostart
    sed -i "/wsproxy.py $ws_listen_port/d" /etc/autostart 2>/dev/null
    echo "ss -tlpn | grep -qw $ws_listen_port || screen -dmS ws${ws_listen_port} python3 /etc/SSHPlus/wsproxy.py $ws_listen_port 127.0.0.1:${ssh_dst_port}" >> /etc/autostart

    # Guardar modo y parámetros en archivo de estado
    echo "SSL+WS" > /etc/stunnel/.ssl_mode
    echo "$ws_listen_port" >> /etc/stunnel/.ssl_mode
    echo "$ssh_dst_port" >> /etc/stunnel/.ssl_mode

    # Configurar stunnel apuntando al WSPROXY
    cat > /etc/stunnel/stunnel.conf <<EOF
# SSL + WEBSOCKET — v3.0
# Flujo: Cliente → stunnel(TLS) → wsproxy:$ws_listen_port → SSH:$ssh_dst_port
# IMPORTANTE: stunnel conecta al wsproxy, NO al SSH directamente
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

[sshtunnel443]
accept  = 443
connect = 127.0.0.1:$ws_listen_port

[sshtunnel444]
accept  = 444
connect = 127.0.0.1:$ws_listen_port

[sshtunnel8443]
accept  = 8443
connect = 127.0.0.1:$ws_listen_port
EOF

    _arrancar_stunnel

    # Verificar que wsproxy levantó
    sleep 1
    if ss -tlpn 2>/dev/null | grep -q ":${ws_listen_port} "; then
        echo -e "\n\033[1;32m✓ wsproxy activo en :${ws_listen_port} ✓\033[0m"
    else
        echo -e "\n\033[1;33m⚠ wsproxy en :${ws_listen_port} no detectado — esperando...\033[0m"
        sleep 2
