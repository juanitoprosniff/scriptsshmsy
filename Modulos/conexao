        echo -e "\033[1;31mLsh no disponible en este Ubuntu.\033[0m"
        echo -e "\033[1;33mPara clientes muy antiguos, use OpenSSH con:\033[0m"
        echo -e "\033[1;37mHostKeyAlgorithms +ssh-rsa,ssh-dss\033[0m"
        echo -e "\033[1;37mKexAlgorithms +diffie-hellman-group1-sha1\033[0m"
        echo -e "\033[1;37mCiphers +aes256-cbc,3des-cbc\033[0m"
        echo ""
        echo -ne "\033[1;32mAplicar parche compatibilidad en OpenSSH? [s/n]: \033[1;37m"; read _lsh_patch
        [[ "$_lsh_patch" = 's' ]] && _patch_openssh_legacy "$l_port"
        sleep 3; fun_alt_ssh; return
    fi

    # Configurar lsh
    mkdir -p /etc/lsh
    [[ ! -f /etc/lsh/host-key ]] && lsh-keygen 2>/dev/null
    cat > /etc/lsh/lshd_config <<EOF
port = $l_port
interface = 0.0.0.0
allow-root-login = yes
password-authentication = yes
EOF
    service lsh-server start 2>/dev/null || lshd --port=$l_port &
    _fw_open $l_port
    echo -e "\n\033[1;32m✓ Lsh ACTIVO EN PUERTO $l_port!\033[0m"
    sleep 2; fun_alt_ssh
}

# ── Parche OpenSSH para clientes LEGACY (apps de tunelización viejas) ──
_patch_openssh_legacy() {
    local pt="${1:-22}"
    local _sshd_cfg="/etc/ssh/sshd_config"
    cp $_sshd_cfg ${_sshd_cfg}.bak 2>/dev/null

    # Agregar bloque de compatibilidad si no existe
    if ! grep -q "# LEGACY COMPAT" $_sshd_cfg; then
        cat >> $_sshd_cfg <<'EOF'

# LEGACY COMPAT — agregado por SSHMSY para clientes antiguos
HostKeyAlgorithms +ssh-rsa,ssh-dss
PubkeyAcceptedAlgorithms +ssh-rsa,ssh-dss
KexAlgorithms +diffie-hellman-group14-sha1,diffie-hellman-group1-sha1
Ciphers +aes256-cbc,aes128-cbc,3des-cbc,blowfish-cbc
MACs +hmac-sha1,hmac-md5
EOF
    fi
    _restart_ssh
    echo -e "\033[1;32m✓ OpenSSH configurado para clientes legacy!\033[0m"
}

# ── SSH Relay/Proxy — OpenSSH en modo relay ───────────────────
_fun_ssh_relay() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m       SSH RELAY / PROXY TRANSPARENTE        \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\033[1;37m• Puerto extra que redirige al SSH principal\033[0m"
    echo -e "\033[1;37m• Útil para esquivar bloqueos de puertos\033[0m"
    echo -e "\033[1;37m• Usa socat (sin instalar otro servidor)\033[0m"
    echo ""

    # Mostrar relays activos
    local _relays=$(grep 'socat.*tcp-listen' /etc/autostart 2>/dev/null | grep -oP '\d+(?=,fork)')
    [[ -n "$_relays" ]] && echo -e "\033[1;33mRelays activos en puertos: \033[1;37m$_relays\033[0m\n"

    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mCREAR RELAY       \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR RELAY    \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mCOMPAT LEGACY SSH \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER            \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read r_opt

    case "$r_opt" in
    1)
        apt-get install -y socat >/dev/null 2>&1
        echo -ne "\033[1;32mPUERTO RELAY (externo): \033[1;37m"; read r_ext
        echo -ne "\033[1;32mPUERTO DESTINO SSH (defecto 22): \033[1;37m"; read r_dst; [[ -z "$r_dst" ]] && r_dst=22
        [[ -z "$r_ext" ]] && { fun_alt_ssh; return; }
        verif_ptrs $r_ext
        screen -dmS "relay${r_ext}" socat TCP-LISTEN:${r_ext},fork TCP:127.0.0.1:${r_dst} &
        echo "screen -ls | grep -q relay${r_ext} || screen -dmS relay${r_ext} socat TCP-LISTEN:${r_ext},fork TCP:127.0.0.1:${r_dst}" >> /etc/autostart
        _fw_open $r_ext
        echo -e "\n\033[1;32m✓ Relay activo: $r_ext → 127.0.0.1:$r_dst\033[0m"; sleep 2; _fun_ssh_relay ;;
    2)
        echo -ne "\033[1;32mPUERTO RELAY A ELIMINAR: \033[1;37m"; read r_del
        for pid in $(screen -ls 2>/dev/null | grep "relay${r_del}" | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        sed -i "/relay${r_del}/d" /etc/autostart 2>/dev/null
        echo -e "\n\033[1;32mRelay $r_del eliminado!\033[0m"; sleep 2; _fun_ssh_relay ;;
    3)
        echo -ne "\033[1;32mAplicar compatibilidad legacy a OpenSSH? [s/n]: \033[1;37m"; read _lp
        [[ "$_lp" = 's' ]] && { _patch_openssh_legacy; echo -e "\n\033[1;32m✓ Parche aplicado!\033[0m"; sleep 2; }
        _fun_ssh_relay ;;
    0) fun_alt_ssh ;;
    esac
}

# ============================================================
# SSL TUNNEL — 3 puertos: 443, 444, 8443
# ============================================================
inst_ssl() {
    if _check_proc 'stunnel4'; then
        sslt=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
        [[ -z "$sslt" ]] && sslt="\033[1;31mINDISPONIBLE"
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m           GESTIONAR SSL TUNNEL          \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -e "\033[0;34m╼ \033[1;32mPUERTOS ACTIVOS\033[1;37m: $sslt"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mAGREGAR PUERTO SSL   \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR PUERTO SSL  \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mELIMINAR SSL TUNNEL  \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER               \033[0;34m┃"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta; echo ""

        if [[ "$resposta" = '1' ]]; then
            echo -ne "\033[1;32mNUEVO PUERTO SSL: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            verif_ptrs $porta
            # Agregar nueva sección al stunnel.conf
            local _dst=$(grep 'connect' /etc/stunnel/stunnel.conf | head -1 | awk -F: '{print $2}' | tr -d ' ')
            [[ -z "$_dst" ]] && _dst=22
            cat >> /etc/stunnel/stunnel.conf <<EOF

[sshtunnel${porta}]
accept  = $porta
connect = 127.0.0.1:${_dst}
EOF
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            _fw_open $porta
            echo -e "\n\033[1;32mPUERTO $porta AGREGADO!\033[0m"; sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '2' ]]; then
            echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            # Eliminar bloque de ese puerto del conf
            sed -i "/\[sshtunnel${porta}\]/,/^$/d" /etc/stunnel/stunnel.conf 2>/dev/null
            sed -i "/accept  = ${porta}/d" /etc/stunnel/stunnel.conf 2>/dev/null
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            echo -e "\n\033[1;32mPUERTO $porta ELIMINADO!\033[0m"; sleep 2; inst_ssl; return
        fi

        if [[ "$resposta" = '3' ]]; then
            pkill stunnel4 2>/dev/null; systemctl stop stunnel4 2>/dev/null
            apt-get remove --purge stunnel4 -y >/dev/null 2>&1
            rm -f /etc/stunnel/stunnel.conf /etc/stunnel/stunnel.pem /etc/stunnel/stunnel.key /etc/stunnel/stunnel.crt
            echo -e "\n\033[1;32mSSL TUNNEL ELIMINADO!\033[0m"; sleep 2; fun_conexao; return
        fi
        fun_conexao; return
    fi

    # ── Instalación con 3 puertos: 443, 444, 8443 ────────────
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           INSTALAR SSL TUNNEL           \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\n\033[1;33mSeleccione destino del túnel SSL:\033[0m\n"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mSSL → SSH            (puerto 22)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mSSL → SSH Legado     (puerto 23)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mSSL → PROXY SOCKS    (puerto 80)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mSSL → DROPBEAR       (puerto 110)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mSSL → DROPBEAR 2016  (puerto 143)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m6\033[1;31m] \033[1;33mSSL → WEBSOCKET      (puerto 8080)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m7\033[1;31m] \033[1;33mSSL → Puerto personalizado       \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                           \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta; echo ""
    case "$resposta" in
    1) portssl=22 ;;  2) portssl=23 ;;  3) portssl=80 ;;
    4) portssl=110 ;; 5) portssl=143 ;; 6) portssl=8080 ;;
    7) echo -ne "\033[1;32mPUERTO DESTINO: \033[1;37m"; read portssl; [[ -z "$portssl" ]] && { inst_ssl; return; } ;;
    0) fun_conexao; return ;;
    *) echo -e "\033[1;31mOpción inválida!"; sleep 1; inst_ssl; return ;;
    esac

    echo -e "\n\033[1;33mInstalando stunnel4...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y stunnel4 openssl >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
    mkdir -p /etc/stunnel

    echo -e "\033[1;32mGenerando certificado SSL...\033[0m"
    openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
        -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
        -keyout /etc/stunnel/stunnel.key \
        -out /etc/stunnel/stunnel.crt >/dev/null 2>&1
    cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
    chmod 600 /etc/stunnel/stunnel.pem

    [[ ! -s /etc/stunnel/stunnel.pem ]] && {
        echo -e "\033[1;31mError al generar certificado!\033[0m"; sleep 2; inst_ssl; return
    }

    # Configuración con 3 puertos: 443, 444, 8443
    cat > /etc/stunnel/stunnel.conf <<EOF
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

[sshtunnel443]
accept  = 443
connect = 127.0.0.1:$portssl

[sshtunnel444]
accept  = 444
connect = 127.0.0.1:$portssl

[sshtunnel8443]
accept  = 8443
connect = 127.0.0.1:$portssl
EOF

    echo -e "\033[1;32mIniciando SSL Tunnel en puertos 443, 444, 8443...\033[0m"
    if systemctl is-enabled stunnel4 >/dev/null 2>&1; then
        systemctl enable stunnel4 >/dev/null 2>&1; systemctl restart stunnel4 >/dev/null 2>&1
    else
        service stunnel4 restart >/dev/null 2>&1
    fi

    for _sslp in 443 444 8443; do _fw_open $_sslp; done
    sleep 1

    if ss -tlpn 2>/dev/null | grep -q ":443 "; then
        echo -e "\n\033[1;32m✓ SSL TUNNEL ACTIVO!\033[0m"
        echo -e "\033[1;37mPuertos: \033[1;32m443, 444, 8443 → 127.0.0.1:$portssl\033[0m"
    else
        echo -e "\n\033[1;33mVerifique: systemctl status stunnel4\033[0m"
    fi
    sleep 2; inst_ssl
}

