_toggle_compresion_ssh() {
    if grep -q "^Compression yes" /etc/ssh/sshd_config 2>/dev/null; then
        sed -i 's/^Compression yes/Compression no/' /etc/ssh/sshd_config
        sed -i 's/^#Compression.*/Compression no/' /etc/ssh/sshd_config
        _restart_ssh
        echo -e "\n\033[1;33mвњ“ CompresiГіn SSH DESACTIVADA\033[0m"
    else
        sed -i '/^Compression/d' /etc/ssh/sshd_config
        echo "Compression yes" >> /etc/ssh/sshd_config
        # CompressionLevel 6 = balance velocidad/CPU (1=rГЎpido 9=mГЎximo)
        sed -i '/^#CompressionLevel/d' /etc/ssh/sshd_config
        _restart_ssh
        echo -e "\n\033[1;32mвњ“ CompresiГіn SSH ACTIVADA (nivel 6 вЂ” balance Гіptimo)\033[0m"
        echo -e "\033[1;37m  Mejora: tunnels lentos, redes congestionadas\033[0m"
        echo -e "\033[1;31m  Nota: en redes rГЎpidas puede agregar latencia\033[0m"
    fi
    sleep 2
}

_toggle_bbr() {
    if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
        # Restaurar a cubic (default de Linux)
        sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;33mвњ“ BBR DESACTIVADO вЂ” restaurado a cubic\033[0m"
    else
        # Verificar soporte del kernel
        if ! modprobe tcp_bbr 2>/dev/null; then
            echo -e "\n\033[1;31mвњ— Kernel no soporta BBR (requiere Linux 4.9+)\033[0m"
            echo -e "\033[1;33m  Kernel actual: $(uname -r)\033[0m"
            sleep 3; return
        fi
        sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
        echo "net.core.default_qdisc=fq" >> /etc/sysctl.conf
        echo "net.ipv4.tcp_congestion_control=bbr" >> /etc/sysctl.conf
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;32mвњ“ BBR ACTIVADO\033[0m"
        echo -e "\033[1;37m  BBR mejora velocidad y estabilidad en redes con pГ©rdida\033[0m"
        echo -e "\033[1;37m  Ideal para VPN SSH con mГєltiples clientes simultГЎneos\033[0m"
    fi
    sleep 2
}

_toggle_buffers() {
    if grep -q "^net.core.rmem_max=26214400" /etc/sysctl.conf 2>/dev/null; then
        # Eliminar configuraciones de buffers
        sed -i '/net.core.rmem_max/d' /etc/sysctl.conf
        sed -i '/net.core.wmem_max/d' /etc/sysctl.conf
        sed -i '/net.core.rmem_default/d' /etc/sysctl.conf
        sed -i '/net.core.wmem_default/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_rmem/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_mem/d' /etc/sysctl.conf
        sed -i '/net.core.netdev_max_backlog/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_no_metrics_save/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_window_scaling/d' /etc/sysctl.conf
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;33mвњ“ Buffers de red RESTAURADOS a valores del sistema\033[0m"
    else
        # Eliminar duplicados antes de agregar
        sed -i '/net.core.rmem_max/d' /etc/sysctl.conf
        sed -i '/net.core.wmem_max/d' /etc/sysctl.conf
        sed -i '/net.core.rmem_default/d' /etc/sysctl.conf
        sed -i '/net.core.wmem_default/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_rmem/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_mem/d' /etc/sysctl.conf
        sed -i '/net.core.netdev_max_backlog/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_no_metrics_save/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_window_scaling/d' /etc/sysctl.conf

        cat >> /etc/sysctl.conf <<'BUFEOF'
# MSYVPN вЂ” Buffers optimizados para VPN SSH
net.core.rmem_max=26214400
net.core.wmem_max=26214400
net.core.rmem_default=1048576
net.core.wmem_default=1048576
net.ipv4.tcp_rmem=4096 1048576 26214400
net.ipv4.tcp_wmem=4096 1048576 26214400
net.ipv4.tcp_mem=65536 131072 262144
net.core.netdev_max_backlog=5000
net.ipv4.tcp_no_metrics_save=1
net.ipv4.tcp_window_scaling=1
BUFEOF
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;32mвњ“ Buffers de red OPTIMIZADOS\033[0m"
        echo -e "\033[1;37m  rmem/wmem: 25MB max вЂ” mejor para mГєltiples clientes VPN\033[0m"
        echo -e "\033[1;37m  tcp_window_scaling: permite ventanas TCP grandes\033[0m"
    fi
    sleep 2
}

_activar_todo_turbo() {
    echo -e "\n\033[1;33m[ TURBO VPN ] Activando todas las optimizaciones...\033[0m\n"

    # CompresiГіn SSH
    sed -i '/^Compression/d' /etc/ssh/sshd_config
    echo "Compression yes" >> /etc/ssh/sshd_config
    _restart_ssh
    echo -e "\033[1;32m  вњ“ CompresiГіn SSH activada\033[0m"

    # BBR
    if modprobe tcp_bbr 2>/dev/null; then
        sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
        echo "net.core.default_qdisc=fq" >> /etc/sysctl.conf
        echo "net.ipv4.tcp_congestion_control=bbr" >> /etc/sysctl.conf
        echo -e "\033[1;32m  вњ“ BBR activado\033[0m"
    else
        echo -e "\033[1;31m  вњ— BBR no disponible (kernel $(uname -r) < 4.9)\033[0m"
    fi

    # Buffers
    for _k in net.core.rmem_max net.core.wmem_max net.core.rmem_default \
               net.core.wmem_default net.ipv4.tcp_rmem net.ipv4.tcp_wmem \
