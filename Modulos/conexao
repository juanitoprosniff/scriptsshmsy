            if [[ "$_nhp" -lt 20000 ]] || [[ "$_nhp" -gt 39999 ]] 2>/dev/null; then
                echo -e "\033[1;31m¡Puerto fuera del rango 20000-39999!\033[0m"; sleep 2; fun_hysteria; return
            fi
            verif_ptrs "$_nhp"
            sed -i "s|listen:.*|listen: :${_nhp}|g" /etc/hysteria/config.yaml 2>/dev/null
