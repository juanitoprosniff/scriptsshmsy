_fun_nginx_instalar() {
    clear
    echo -e "\033[1;33mInstalando dependencias...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y nginx-full stunnel4 openssl >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4

    # Verificar módulo stream
    if ! nginx -V 2>&1 | grep -q '\-\-with-stream'; then
        echo -e "\033[1;31mNginx sin módulo stream. Instalando nginx-extras...\033[0m"
        apt-get install -y libnginx-mod-stream 2>/dev/null || \
        apt-get install -y nginx-extras 2>/dev/null
    fi

    echo ""
    # ── Detectar puertos y servicios activos ──────────────────
    _db16_port=$(systemctl show dropbear-legacy --property=ExecStart 2>/dev/null | \
                 grep -oP '(?<=-p )\d+' | head -1)
    [[ -z "$_db16_port" ]] && _db16_port=$(ss -tlpn 2>/dev/null | grep 'dropbear' | \
                 awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
    [[ -z "$_db16_port" ]] && _db16_port=143

    _ws_port=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
               awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
    [[ -z "$_ws_port" ]] && _ws_port=8080

    echo -e "\033[1;33mDetectado — Dropbear 2016: \033[1;37m$_db16_port\033[0m"
    echo -e "\033[1;33mDetectado — WebSocket/Proxy: \033[1;37m$_ws_port\033[0m"
    echo ""
    echo -ne "\033[1;32mPuerto Dropbear 2016 (Enter=\033[1;37m$_db16_port\033[1;32m): \033[1;37m"
    read _in; [[ -n "$_in" ]] && _db16_port="$_in"
    echo -ne "\033[1;32mPuerto WebSocket/Proxy (Enter=\033[1;37m$_ws_port\033[1;32m): \033[1;37m"
    read _in; [[ -n "$_in" ]] && _ws_port="$_in"

    echo ""
    echo -e "\033[1;33m¿En qué puertos quieres el multiplex?\033[0m"
    echo -e "\033[1;37m(Puedes poner varios separados por espacio: 80 443 8080 8880 8888 444)\033[0m"
    echo -ne "\033[1;32mPuertos (Enter=80 443 8080 8880 8888 444): \033[1;37m"
    read _mux_ports
    [[ -z "$_mux_ports" ]] && _mux_ports="80 443 8080 8880 8888 444"

    # Puerto interno para stunnel (no público, solo interno)
    _stunnel_internal=7300

    # ── Generar certificado SSL ───────────────────────────────
    mkdir -p /etc/stunnel
    if [[ ! -s /etc/stunnel/stunnel.pem ]]; then
        echo -e "\033[1;32mGenerando certificado SSL...\033[0m"
        openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
            -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
            -keyout /etc/stunnel/stunnel.key \
            -out /etc/stunnel/stunnel.crt >/dev/null 2>&1
        cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
        chmod 600 /etc/stunnel/stunnel.pem
    fi

    # ── Configurar stunnel — solo escucha en localhost ────────
    # stunnel ya NO escucha en puertos públicos, nginx le pasa el tráfico
    cat > /etc/stunnel/stunnel.conf <<EOF
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

# Stunnel escucha solo en localhost — nginx le manda el TLS
[ssl-to-proxy]
accept  = 127.0.0.1:${_stunnel_internal}
connect = 127.0.0.1:${_ws_port}
EOF

    systemctl enable stunnel4 >/dev/null 2>&1
    systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
    sleep 1

    # ── Configurar nginx stream ───────────────────────────────
    # Necesita ir en /etc/nginx/nginx.conf fuera del bloque http{}
    # o en /etc/nginx/modules-enabled/ / stream.d/

    mkdir -p /etc/nginx/stream.d

    # Construir bloques server para cada puerto multiplex
    local _stream_servers=""
    for _p in $_mux_ports; do
        _stream_servers+="
    # Puerto multiplex $_p — SSH directo o TLS (stunnel+ws)
    server {
        listen ${_p};
        ssl_preread on;
        proxy_pass \$upstream_mux;
        proxy_connect_timeout 10s;
        proxy_timeout 300s;
    }"
    done

    cat > /etc/nginx/stream.d/multiplex.conf <<EOF
# ═══════════════════════════════════════════════════════════
# NGINX STREAM MULTIPLEX — generado por SSHMSY
# Detecta el protocolo y enruta sin descifrar (ssl_preread)
#
# Flujo:
#   TLS detectado  → stunnel:${_stunnel_internal} → wsproxy:${_ws_port} → DB2016:${_db16_port}
#   No-TLS (SSH)   → Dropbear 2016:${_db16_port} directamente
# ═══════════════════════════════════════════════════════════

upstream upstream_ssh_direct {
    server 127.0.0.1:${_db16_port};
}

upstream upstream_stunnel {
    server 127.0.0.1:${_stunnel_internal};
}

map \$ssl_preread_protocol \$upstream_mux {
    # Si es TLS (cualquier versión) → stunnel → descifra → wsproxy → SSH
    "TLSv1.3"  upstream_stunnel;
    "TLSv1.2"  upstream_stunnel;
    "TLSv1.1"  upstream_stunnel;
    "TLSv1.0"  upstream_stunnel;
    # Si no es TLS (SSH directo, proxy HTTP, etc.) → Dropbear directo
    default    upstream_ssh_direct;
}
${_stream_servers}
EOF

    # Incluir stream.d en nginx.conf si no está
    if ! grep -q 'stream.d' /etc/nginx/nginx.conf 2>/dev/null; then
        # Agregar bloque stream al final de nginx.conf
        if ! grep -q '^stream' /etc/nginx/nginx.conf 2>/dev/null; then
            cat >> /etc/nginx/nginx.conf <<'NGINXEOF'

stream {
    include /etc/nginx/stream.d/*.conf;
}
NGINXEOF
        fi
    fi

    # Verificar config nginx
    nginx -t 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "\033[1;31mError en configuración nginx. Revisando...\033[0m"
        nginx -t
        sleep 3; fun_nginx_multiplex; return
    fi

    systemctl enable nginx >/dev/null 2>&1
    systemctl restart nginx 2>/dev/null || service nginx restart 2>/dev/null
    sleep 1

    # Abrir puertos en firewall
    for _p in $_mux_ports; do _fw_open $_p; done

    echo ""
    echo -e "\033[1;32m✓ NGINX MULTIPLEX CONFIGURADO!\033[0m"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;37mPuertos activos: \033[1;32m$_mux_ports\033[0m"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;37mCada puerto acepta:\033[0m"
    echo -e "\033[1;32m  SSH directo\033[1;37m → Dropbear 2016 ($_db16_port) sin necesidad de payload"
    echo -e "\033[1;32m  SSL/TLS\033[1;37m     → stunnel descifra → WebSocket ($_ws_port) → Dropbear 2016"
    echo -e "\033[1;32m  WS+SSL\033[1;37m      → mismo flujo TLS, el proxy maneja el handshake WS"
    echo -e "\033[1;32m  Enhanced+SSL\033[1;37m → mismo flujo, el proxy responde HTTP antes de SSH"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;33mCONFIGURACIÓN EN TU APP:\033[0m"
    echo -e "\033[1;37m  IP:        IP del VPS"
    echo -e "\033[1;37m  Puerto:    80 / 443 / 8080 / 8880 / 8888 / 444 (cualquiera)"
    echo -e "\033[1;37m  Usuario:   tu usuario SSH"
    echo -e "\033[1;37m  SSL/SNI:   activar para modo SSL+WS"
    echo -e "\033[1;37m  Payload:   opcional (el proxy lo maneja solo)"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"

    # Guardar config para referencia
    cat > /etc/SSHPlus/nginx_mux_info 2>/dev/null <<INFO
PUERTOS_MUX=$_mux_ports
DB16_PORT=$_db16_port
WS_PORT=$_ws_port
STUNNEL_INTERNAL=$_stunnel_internal
INFO

    sleep 4; fun_nginx_multiplex
}

_fun_nginx_status() {
    clear
    echo -e "\033[1;33m━━━━━━ ESTADO NGINX MULTIPLEX ━━━━━━\033[0m"
