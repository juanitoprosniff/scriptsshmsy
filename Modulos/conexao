# ============================================================
# SLOWDNS вҖ” renovado, compatible con todos los servidores
# Rutas: /etc/SSHPlus/slowdns/  (binario + llaves + config)
# ============================================================
_SLOW_DIR="/etc/SSHPlus/slowdns"
_SLOW_BIN="$_SLOW_DIR/dns-server"
_SLOW_KEY="$_SLOW_DIR/server.key"
_SLOW_PUB="$_SLOW_DIR/server.pub"
_SLOW_NS="$_SLOW_DIR/domain_ns"
_SLOW_PORT="$_SLOW_DIR/puerto"

_slow_status() {
    pgrep -f "dns-server.*5300" >/dev/null 2>&1
}

_slow_info() {
    clear
    echo -e "\033[0;34mв”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”“\033[0m"
    echo -e "\033[0;34mв”ғ\E[44;1;37m          INFORMACIГ“N SLOWDNS            \E[0m\033[0;34mв”ғ"
    echo -e "\033[0;34mв”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ӣ\033[0m"
    local _ns _pub _pt
    _ns=$(cat "$_SLOW_NS"  2>/dev/null)
    _pub=$(cat "$_SLOW_PUB" 2>/dev/null)
    _pt=$(cat "$_SLOW_PORT" 2>/dev/null)
    if [[ -z "$_ns" || -z "$_pub" ]]; then
        echo -e "\033[1;31mвҡ  SlowDNS no configurado aГәn.\033[0m"
        sleep 2; return
    fi
    echo -e "\033[1;33mNS (Nameserver) : \033[1;32m$_ns"
    echo -e "\033[1;33mClave pГәblica   : \033[1;32m$_pub"
    echo -e "\033[1;33mPuerto destino  : \033[1;32m$_pt"
    _slow_status && echo -e "\033[1;33mEstado          : \033[1;32mвң“ ACTIVO" || \
                    echo -e "\033[1;33mEstado          : \033[1;31mвң• INACTIVO"
    echo ""
    echo -ne "\033[1;37mPresione ENTER para volver...\033[0m"; read
}

_slow_download_bin() {
    mkdir -p "$_SLOW_DIR"
    # Binario Гәnico compatible con amd64, arm64 y arm
    local _url_base="https://raw.githubusercontent.com/khaledagn/VPS-AGN_English_Official/master/LINKS-LIBRARIES"
    local _bin_name="dns-server"
    # Seleccionar binario segГәn arquitectura
    case "$_ARCH_TAG" in
        arm64) _url="${_url_base}/dns-server-arm64" ;;
        arm)   _url="${_url_base}/dns-server-arm"   ;;
        *)     _url="${_url_base}/dns-server"        ;;
    esac
    echo -e "\033[1;33mDescargando binario dns-server [$_ARCH_TAG]...\033[0m"
    wget -q --timeout=20 "$_url" -O "$_SLOW_BIN" 2>/dev/null || \
    curl -sL --max-time 20 "$_url" -o "$_SLOW_BIN" 2>/dev/null
    # Fallback: binario genГ©rico amd64
    [[ ! -s "$_SLOW_BIN" ]] && {
        wget -q --timeout=20 "${_url_base}/dns-server" -O "$_SLOW_BIN" 2>/dev/null
    }
    if [[ -s "$_SLOW_BIN" ]]; then
        chmod +x "$_SLOW_BIN"
        echo -e "\033[1;32mвң“ Binario descargado correctamente.\033[0m"
        return 0
    else
        echo -e "\033[1;31mвң— No se pudo descargar el binario.\033[0m"
        return 1
    fi
}

_slow_genkey() {
    rm -f "$_SLOW_KEY" "$_SLOW_PUB"
    "$_SLOW_BIN" -gen-key -privkey-file "$_SLOW_KEY" -pubkey-file "$_SLOW_PUB" >/dev/null 2>&1
    if [[ -s "$_SLOW_PUB" ]]; then
        echo -e "\033[1;32mвң“ Clave generada: \033[1;37m$(cat $_SLOW_PUB)\033[0m"
        return 0
    else
        echo -e "\033[1;31mвң— Error generando clave.\033[0m"
        return 1
    fi
}

_slow_start() {
    local _ns _pt
    _ns=$(cat "$_SLOW_NS"   2>/dev/null)
    _pt=$(cat "$_SLOW_PORT" 2>/dev/null)
    [[ -z "$_ns" || -z "$_pt" ]] && { echo -e "\033[1;31mFaltan NS o puerto. Configure primero.\033[0m"; return 1; }
    # Abrir puertos en firewall
    iptables -I INPUT -p udp --dport 5300 -j ACCEPT 2>/dev/null
    iptables -t nat -I PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null
    command -v ufw &>/dev/null && ufw allow 5300/udp >/dev/null 2>&1
    # Parar instancia anterior
    pkill -f "dns-server.*5300" 2>/dev/null
    screen -ls 2>/dev/null | grep '\.slowdns' | awk '{print $1}' | xargs -I{} screen -r -S {} -X quit 2>/dev/null
    screen -wipe >/dev/null 2>&1; sleep 0.5
    # Iniciar
    screen -dmS slowdns "$_SLOW_BIN" -udp :5300 \
        -privkey-file "$_SLOW_KEY" "$_ns" "127.0.0.1:$_pt"
    sleep 1
    if _slow_status; then
        echo -e "\033[1;32mвң“ SlowDNS iniciado вҶ’ NS: $_ns | Puerto: $_pt\033[0m"
        # Guardar en autostart
        sed -i '/slowdns\|dns-server/d' /etc/autostart 2>/dev/null
        echo "pgrep -f 'dns-server.*5300' >/dev/null || screen -dmS slowdns ${_SLOW_BIN} -udp :5300 -privkey-file ${_SLOW_KEY} ${_ns} 127.0.0.1:${_pt}" >> /etc/autostart
        return 0
    else
        echo -e "\033[1;31mвң— SlowDNS no respondiГі. Verifique el NS y el binario.\033[0m"
        return 1
    fi
}

slow_setup() {
    while true; do
        clear
        echo -e "\033[0;34mв”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”“\033[0m"
        echo -e "\033[0;34mв”ғ\E[44;1;37m            GESTIONAR SLOWDNS            \E[0m\033[0;34mв”ғ"
        echo -e "\033[0;34mв”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ӣ\033[0m"
        _slow_status && _sst="\033[1;32mвң“ ACTIVO" || _sst="\033[1;31mвң• INACTIVO"
        echo -e "\033[1;33mEstado   : $_sst\033[0m"
        [[ -f "$_SLOW_NS"  ]] && echo -e "\033[1;33mNS       : \033[1;37m$(cat $_SLOW_NS)"
        [[ -f "$_SLOW_PORT"]] && echo -e "\033[1;33mPuerto   : \033[1;37m$(cat $_SLOW_PORT)"
        echo -e "\033[0;34mв”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”“\033[0m"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mVER INFORMACIГ“N               \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mINSTALAR / CONFIGURAR         \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mINICIAR SlowDNS               \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mREINICIAR SlowDNS             \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mDETENER SlowDNS               \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                        \033[0;34mв”ғ"
        echo -e "\033[0;34mв”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ӣ\033[0m"
        echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read _slow_opt

        case "$_slow_opt" in
        1) _slow_info ;;

        2) # в”Җв”Җ InstalaciГіn/configuraciГіn completa в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
            clear
            echo -e "\033[0;34mв”ғ\E[44;1;37m       INSTALAR / CONFIGURAR SLOWDNS     \E[0m\033[0;34mв”ғ\n"
            mkdir -p "$_SLOW_DIR"

            # Paso 1: binario
            if [[ ! -x "$_SLOW_BIN" ]]; then
                _slow_download_bin || { sleep 3; continue; }
            else
                echo -e "\033[1;32mвң“ Binario ya existe.\033[0m"
                echo -ne "\033[1;33mВҝDescargar de nuevo? [s/N]: \033[1;37m"; read _redown
                [[ "$_redown" =~ ^[sS]$ ]] && _slow_download_bin
            fi

            # Paso 2: puerto destino SSH/Proxy
            echo ""
            echo -e "\033[1;33mPaso 1 вҖ” Puerto de destino (SSH/proxy):\033[0m"
            # Mostrar puertos disponibles
            echo -e "\033[1;37mPuertos detectados:\033[0m"
            ss -tlpn 2>/dev/null | grep -E 'sshd|dropbear|python|stunnel4' | \
                awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | \
                while read _p; do
                    _svc=$(ss -tlpn 2>/dev/null | grep ":$_p " | \
                           grep -oP '(?<=\().*(?=,)' | head -1)
                    echo -e "  \033[1;36m$_p\033[1;37m вҶ’ $_svc"
                done
            echo -ne "\033[1;32mPuerto destino: \033[1;37m"; read _dport
            [[ -z "$_dport" ]] && { echo -e "\033[1;31mPuerto invГЎlido.\033[0m"; sleep 1; continue; }
            echo "$_dport" > "$_SLOW_PORT"

            # Paso 3: NS (Nameserver)
            echo ""
            echo -e "\033[1;33mPaso 2 вҖ” Nameserver (NS) de SlowDNS:\033[0m"
            echo -e "\033[1;37m  Ejemplo: ns1.misitio.com\033[0m"
            local _old_ns; _old_ns=$(cat "$_SLOW_NS" 2>/dev/null)
            [[ -n "$_old_ns" ]] && echo -e "\033[1;37m  NS actual: \033[1;32m$_old_ns\033[0m"
            echo -ne "\033[1;32mNS domain: \033[1;37m"; read _ns_input
            [[ -z "$_ns_input" && -n "$_old_ns" ]] && _ns_input="$_old_ns"
            [[ -z "$_ns_input" ]] && { echo -e "\033[1;31mNS invГЎlido.\033[0m"; sleep 1; continue; }
            echo "$_ns_input" > "$_SLOW_NS"

            # Paso 4: clave pГәblica
            echo ""
            echo -e "\033[1;33mPaso 3 вҖ” Clave de cifrado:\033[0m"
            if [[ -s "$_SLOW_PUB" ]]; then
                echo -e "\033[1;37m  Clave actual: \033[1;32m$(cat $_SLOW_PUB)\033[0m"
                echo -ne "\033[1;33mВҝUsar clave existente? [S/n]: \033[1;37m"; read _exkey
                if [[ "$_exkey" =~ ^[nN]$ ]]; then
                    _slow_genkey || { sleep 2; continue; }
                fi
            else
                _slow_genkey || { sleep 2; continue; }
            fi

            # Paso 5: iniciar
            echo ""
            echo -e "\033[1;33mIniciando SlowDNS...\033[0m"
            _slow_start
            sleep 3
            ;;

        3) echo -e "\n\033[1;33mIniciando SlowDNS...\033[0m"
           _slow_start; sleep 2 ;;

        4) echo -e "\n\033[1;33mReiniciando SlowDNS...\033[0m"
           pkill -f "dns-server.*5300" 2>/dev/null
           screen -ls 2>/dev/null | grep '\.slowdns' | awk '{print $1}' | \
               xargs -I{} screen -r -S {} -X quit 2>/dev/null
           sleep 1; _slow_start; sleep 2 ;;

        5) echo -e "\n\033[1;33mDeteniendo SlowDNS...\033[0m"
           pkill -f "dns-server.*5300" 2>/dev/null
           screen -ls 2>/dev/null | grep '\.slowdns' | awk '{print $1}' | \
               xargs -I{} screen -r -S {} -X quit 2>/dev/null
           sed -i '/slowdns\|dns-server/d' /etc/autostart 2>/dev/null
           echo -e "\033[1;32mвң“ SlowDNS detenido.\033[0m"; sleep 2 ;;

        0) fun_conexao; return ;;
        *) echo -e "\033[1;31mOpciГіn invГЎlida!\033[0m"; sleep 1 ;;
        esac
    done
}

# ============================================================
# UDP ZiVPN вҖ” compatible AMD64, ARM64, ARM
# Basado en: github.com/zahidbd2/udp-zivpn
# ============================================================
_ZIVPN_BIN="/usr/local/bin/zivpn"
_ZIVPN_CFG="/etc/zivpn/config.json"
_ZIVPN_SVC="/etc/systemd/system/zivpn.service"

fun_zivpn() {
    while true; do
        clear
        echo -e "\033[0;34mв”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”“\033[0m"
