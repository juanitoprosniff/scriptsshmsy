#!/bin/bash
cor1='\033[41;1;37m'
cor2='\033[44;1;37m'
scor='\033[0m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
SCOLOR='\033[0m'

	system=$(cat /etc/issue.net)

	fun_bar() {
		comando[0]="$1"
		comando[1]="$2"
		(
			[[ -e $HOME/fim ]] && rm $HOME/fim
			[[ ! -d /etc/SSHPlus ]] && rm -rf /bin/menu
			${comando[0]} >/dev/null 2>&1
			${comando[1]} >/dev/null 2>&1
			touch $HOME/fim
		) >/dev/null 2>&1 &
		tput civis
		echo -ne "\033[1;33mAGUARDE \033[1;37m- \033[1;33m["
		while true; do
			for ((i = 0; i < 18; i++)); do
				echo -ne "\033[1;31m#"
				sleep 0.1s
			done
			[[ -e $HOME/fim ]] && rm $HOME/fim && break
			echo -e "\033[1;33m]"
			sleep 1s
			tput cuu1; tput dl1
			echo -ne "\033[1;33mAGUARDE \033[1;37m- \033[1;33m["
		done
		echo -e "\033[1;33m]\033[1;37m -\033[1;32m OK !\033[1;37m"
		tput cnorm
	}

	verif_ptrs() {
		porta=$1
		if command -v ss &>/dev/null; then
			for pton in $(ss -tlpn 2>/dev/null | grep "LISTEN" | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u); do
				svcs=$(ss -tlpn 2>/dev/null | grep ":$pton " | awk '{print $6}' | grep -oP '(?<=\().*(?=,)' | head -1)
				[[ "$porta" = "$pton" ]] && {
					echo -e "\n\033[1;31mPORTA \033[1;33m$porta \033[1;31mEM USO POR \033[1;37m$svcs\033[0m"
					sleep 3; fun_conexao
				}
			done
		else
			PT=$(lsof -V -i tcp -P -n 2>/dev/null | grep "LISTEN")
			for pton in $(echo "$PT" | cut -d: -f2 | cut -d' ' -f1 | uniq); do
				svcs=$(echo "$PT" | grep -w "$pton" | awk '{print $1}' | uniq)
				[[ "$porta" = "$pton" ]] && {
					echo -e "\n\033[1;31mPORTA \033[1;33m$porta \033[1;31mEM USO POR \033[1;37m$svcs\033[0m"
					sleep 3; fun_conexao
				}
			done
		fi
	}

	get_ports_by_process() {
		local proc="$1"
		if command -v ss &>/dev/null; then
			ss -tlpn 2>/dev/null | grep "$proc" | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs
		else
			netstat -nplt 2>/dev/null | grep "$proc" | awk '{print $4}' | cut -d: -f2 | xargs
		fi
	}

	_check_proc() {
		ss -tlpn 2>/dev/null | grep -q "$1" || netstat -tlpn 2>/dev/null | grep -q "$1" 2>/dev/null
	}

	slow_setup() {
		[[ -e "/bin/slowdns" ]] && slowdns || {
			cd $HOME
			wget https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main/Slowdns/install -O /dev/null
			chmod 777 install && ./install
		}
	}

	# ============================================================
	# SQUID
	# ============================================================
	inst_sqd() {
		if _check_proc 'squid'; then
			echo -e "\E[41;1;37m            REMOVER SQUID PROXY              \E[0m"
			echo -ne "\n\033[1;32mREMOVER SQUID? \033[1;31m[s/n]:\033[1;37m "; read resp
			[[ "$resp" = 's' ]] && {
				rem_sqd() {
					for d in /etc/squid /etc/squid3; do
						[[ -d "$d" ]] && apt-get remove --purge -y squid squid3 >/dev/null 2>&1 && rm -rf "$d"
					done
					apt autoremove -y >/dev/null 2>&1
				}
				fun_bar 'rem_sqd'
				echo -e "\n\033[1;32mSQUID REMOVIDO!\033[0m"
			}
			sleep 2; fun_conexao
		else
			echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
			echo -e "\033[0;34mв”ѓ\E[44;1;37m            INSTALAR SQUID PROXY         \E[0m\033[0;34mв”ѓ"
			echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
			IP=$(wget -qO- ipv4.icanhazip.com)
			echo -ne "\033[1;32mCONFIRME SEU IP: \033[1;37m"; read -e -i $IP ipdovps
			echo -ne "\n\033[1;33mPORTAS (EX: 80 8080): \033[1;37m"; read portass
			[[ -z "$portass" ]] && { echo -e "\n\033[1;31mPorta invГЎlida!"; sleep 2; fun_conexao; return; }
			for porta in $portass; do verif_ptrs $porta; done
			fun_bar 'apt update -y' "apt install squid -y"
			var_sqd="/etc/squid/squid.conf"; [[ -d /etc/squid3 ]] && var_sqd="/etc/squid3/squid.conf"
			cat > $var_sqd <<-EOF
				acl url1 dstdomain -i 127.0.0.1
				acl url2 dstdomain -i localhost
				acl url3 dstdomain -i $ipdovps
				acl all src 0.0.0.0/0
				http_access allow url1
				http_access allow url2
				http_access allow url3
				http_access deny all
				#Portas
				visible_hostname SSHPLUS
				via off
				forwarded_for off
			EOF
			for Pts in $portass; do
				echo "http_port $Pts" >> $var_sqd
				command -v ufw &>/dev/null && ufw allow $Pts/tcp >/dev/null 2>&1
			done
			fun_bar 'service squid restart'
			echo -e "\n\033[1;32mSQUID INSTALADO!\033[0m"; sleep 2; fun_conexao
		fi
	}

	fun_squid() {
		if ! _check_proc 'squid'; then inst_sqd; return; fi
		sqdp=$(get_ports_by_process 'squid')
		echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
		echo -e "\033[0;34mв”ѓ\E[44;1;37m          GERENCIAR SQUID PROXY          \E[0m\033[0;34mв”ѓ"
		echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
		[[ -n "$sqdp" ]] && echo -e "\033[0;34mв•ј \033[1;32mPORTAS\033[1;37m: $sqdp"
		echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mINSTALAR/REMOVER SQUID  \033[0;34mв”ѓ"
		echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mADICIONAR PORTA         \033[0;34mв”ѓ"
		echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mREMOVER PORTA           \033[0;34mв”ѓ"
		echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLTAR                  \033[0;34mв”ѓ"
		echo -ne "\033[1;32mOpГ§ГЈo: \033[1;37m"; read x; clear
		case $x in
		1|01) inst_sqd ;;
		2|02)
			var_sqd="/etc/squid/squid.conf"; [[ -f /etc/squid3/squid.conf ]] && var_sqd="/etc/squid3/squid.conf"
			echo -ne "\033[1;32mPORTA ADICIONAR: \033[1;37m"; read pt; [[ -z "$pt" ]] && { fun_conexao; return; }
			sed -i "s/#Portas/#Portas\nhttp_port $pt/" $var_sqd
			fun_bar 'service squid restart' 'service squid3 restart'
			echo -e "\n\033[1;32mPORTA ADICIONADA!"; sleep 2; fun_squid ;;
		3|03)
			var_sqd="/etc/squid/squid.conf"; [[ -f /etc/squid3/squid.conf ]] && var_sqd="/etc/squid3/squid.conf"
			echo -ne "\033[1;32mPORTA REMOVER: \033[1;37m"; read pt
			sed -i "/http_port $pt/d" $var_sqd
			fun_bar 'service squid restart' 'service squid3 restart'
			echo -e "\n\033[1;32mPORTA REMOVIDA!"; sleep 2; fun_squid ;;
		0|00) fun_conexao ;;
		*) echo -e "\033[1;31mOpГ§ГЈo invГЎlida!"; sleep 1; fun_squid ;;
		esac
	}

	# ============================================================
	# DROPBEAR normal + Dropbear 2016.74
	# ============================================================
	fun_drop() {
		if _check_proc 'dropbear'; then
			dpbr=$(get_ports_by_process 'dropbear'); [[ -z "$dpbr" ]] && dpbr="\033[1;31mINDISPONГЌVEL"
			stats=$(ps x | grep "limiter" | grep -v grep >/dev/null 2>&1 && echo '\033[1;32mвњ“ ' || echo '\033[1;31mвњ• ')
			echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
			echo -e "\033[0;34mв”ѓ\E[44;1;37m           GERENCIAR DROPBEAR            \E[0m\033[0;34mв”ѓ"
			echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
			echo -e "\033[0;34mв•ј \033[1;32mPORTAS\033[1;37m: $dpbr"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mLIMITER DROPBEAR $stats \033[0;34mв”ѓ"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mALTERAR PORTA           \033[0;34mв”ѓ"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mREMOVER DROPBEAR        \033[0;34mв”ѓ"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mINSTALAR DROPBEAR 2016  \033[0;34mв”ѓ"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLTAR                  \033[0;34mв”ѓ"
			echo -ne "\033[1;32mOpГ§ГЈo: \033[1;37m"; read resposta
			if [[ "$resposta" = '1' ]]; then
				if ps x | grep "limiter" | grep -v grep >/dev/null 2>&1; then
					fun_stplimiter() { kill -9 $(ps x | grep "limiter" | grep -v grep | awk '{print $1}') 2>/dev/null; screen -wipe >/dev/null; }
					fun_bar 'fun_stplimiter'; echo -e "\n\033[1;31mLIMITER DESATIVADO\033[0m"; sleep 2; fun_drop
				else
					fun_bar 'screen -d -m -t limiter droplimiter' 'sleep 3'; echo -e "\n\033[1;32mLIMITER ATIVADO\033[0m"; sleep 2; fun_drop
				fi
			elif [[ "$resposta" = '2' ]]; then
				echo -ne "\n\033[1;32mQUAL PORTA: \033[1;37m"; read pt; verif_ptrs $pt
				var1=$(grep 'DROPBEAR_PORT=' /etc/default/dropbear | cut -d'=' -f2)
				sed -i "s/\b$var1\b/$pt/g" /etc/default/dropbear >/dev/null 2>&1
				fun_bar 'service dropbear restart'; echo -e "\n\033[1;32mPORTA ALTERADA!\033[0m"; sleep 2; fun_conexao
			elif [[ "$resposta" = '3' ]]; then
				fun_dropuninstall() { service dropbear stop 2>/dev/null; apt-get remove --purge dropbear -y >/dev/null 2>&1; rm -rf /etc/default/dropbear; }
				fun_bar 'fun_dropuninstall'; echo -e "\n\033[1;32mDROPBEAR REMOVIDO!\033[0m"; sleep 2; fun_conexao
			elif [[ "$resposta" = '4' ]]; then
				fun_inst_dropbear2016
			else
				fun_conexao
			fi
		else
			echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
			echo -e "\033[0;34mв”ѓ\E[44;1;37m           INSTALAR DROPBEAR             \E[0m\033[0;34mв”ѓ"
			echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mINSTALAR DROPBEAR NORMAL    \033[0;34mв”ѓ"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mINSTALAR DROPBEAR 2016.74   \033[0;34mв”ѓ"
			echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLTAR                      \033[0;34mв”ѓ"
			echo -ne "\033[1;32mOpГ§ГЈo: \033[1;37m"; read opc
			if [[ "$opc" = '1' ]]; then
				echo -ne "\n\033[1;33mPORTA (padrГЈo 110): \033[1;37m"; read porta; [[ -z "$porta" ]] && porta=110
				verif_ptrs $porta
				apt-get update -y >/dev/null 2>&1; apt-get install dropbear -y >/dev/null 2>&1
				sed -i 's/NO_START=1/NO_START=0/' /etc/default/dropbear 2>/dev/null
				sed -i "s/DROPBEAR_PORT=22/DROPBEAR_PORT=$porta/" /etc/default/dropbear 2>/dev/null
				fun_bar 'service dropbear start'
				echo -e "\n\033[1;32mDROPBEAR INSTALADO! PORTA: $porta\033[0m"; sleep 2; fun_conexao
			elif [[ "$opc" = '2' ]]; then
				fun_inst_dropbear2016
			else
				fun_conexao
			fi
		fi
	}

	fun_inst_dropbear2016() {
		clear
		echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
		echo -e "\033[0;34mв”ѓ\E[44;1;37m        INSTALAR DROPBEAR 2016.74        \E[0m\033[0;34mв”ѓ"
		echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
		echo -e "\n\033[1;33mProcesso de compilaГ§ГЈo: ~2-3 minutos.\033[0m"
		echo -ne "\033[1;32mPORTA (padrГЈo 90): \033[1;37m"; read porta_db16; [[ -z "$porta_db16" ]] && porta_db16=90
		verif_ptrs $porta_db16
		echo -e "\n\033[1;32mINSTALANDO DEPENDГЉNCIAS...\033[0m"
		apt-get update -y >/dev/null 2>&1
		apt-get install -y make gcc wget >/dev/null 2>&1
		GCC_VER=$(gcc -dumpversion 2>/dev/null | cut -d. -f1)
		compilar_dropbear2016() {
			cd /usr/src
			if [[ ! -f dropbear-2016.74.tar.bz2 ]]; then
				echo -e "\033[1;33mBaixando Dropbear 2016.74...\033[0m"
				wget -q https://github.com/juanitoprosniff/script_msyvpn/raw/refs/heads/main/installer/dropbear-2016.74.tar.bz2
				[[ ! -f dropbear-2016.74.tar.bz2 ]] && { echo -e "\033[1;31mFalha ao baixar!\033[0m"; return 1; }
			fi
			rm -rf dropbear-2016.74 2>/dev/null
			tar xjf dropbear-2016.74.tar.bz2 2>/dev/null
			[[ ! -d dropbear-2016.74 ]] && { echo -e "\033[1;31mFalha ao extrair!\033[0m"; return 1; }
			cd dropbear-2016.74
			for f in sysoptions.h default_options.h; do
				[[ -f "$f" ]] && sed -i 's|#define LOCAL_IDENT.*|#define LOCAL_IDENT "SSH-2.0-DropbearVPN"|' "$f" 2>/dev/null
			done
			EXTRA_CFLAGS=""
			if [[ "${GCC_VER:-0}" -ge 12 ]]; then
				EXTRA_CFLAGS="-Wno-error=implicit-function-declaration -Wno-error=implicit-int -Wno-error=int-conversion"
				echo -e "\033[1;33mAplicando CFLAGS para GCC $GCC_VER\033[0m"
			fi
			export CFLAGS="$EXTRA_CFLAGS"
			./configure --prefix=/opt/dropbear-2016 --disable-zlib --disable-wtmp --disable-lastlog >/dev/null 2>&1
			echo -e "\033[1;33mCompilando... aguarde...\033[0m"
			if ! make -j$(nproc) PROGRAMS="dropbear dropbearkey" CFLAGS="$EXTRA_CFLAGS" >/dev/null 2>&1; then
				echo -e "\033[1;31mmake falhou!\033[0m"; cd /root; unset CFLAGS; return 1
			fi
			make install PROGRAMS="dropbear dropbearkey" >/dev/null 2>&1
			unset CFLAGS
			[[ ! -f /opt/dropbear-2016/sbin/dropbear ]] && { echo -e "\033[1;31mBinГЎrio nГЈo encontrado!\033[0m"; cd /root; return 1; }
			cd /root; echo -e "\033[1;32mвњ“ Dropbear 2016.74 compilado!\033[0m"; return 0
		}
		if compilar_dropbear2016; then
			mkdir -p /etc/dropbear-2016
			[[ ! -f /etc/dropbear-2016/dropbear_rsa_host_key ]] && \
				/opt/dropbear-2016/bin/dropbearkey -t rsa -f /etc/dropbear-2016/dropbear_rsa_host_key >/dev/null 2>&1
			[[ ! -f /etc/dropbear-2016/dropbear_ecdsa_host_key ]] && \
				/opt/dropbear-2016/bin/dropbearkey -t ecdsa -f /etc/dropbear-2016/dropbear_ecdsa_host_key >/dev/null 2>&1
			# Parar sesiГіn anterior si existe
			for _sid in $(screen -ls 2>/dev/null | grep 'dropbear2016' | awk '{print $1}'); do
				screen -r -S "$_sid" -X quit 2>/dev/null
			done
			screen -dmS dropbear2016 /opt/dropbear-2016/sbin/dropbear \
				-r /etc/dropbear-2016/dropbear_rsa_host_key \
				-r /etc/dropbear-2016/dropbear_ecdsa_host_key \
				-p $porta_db16 -F -E 2>/dev/null &
			_db16_cmd="screen -ls | grep -q 'dropbear2016' || screen -dmS dropbear2016 /opt/dropbear-2016/sbin/dropbear -r /etc/dropbear-2016/dropbear_rsa_host_key -r /etc/dropbear-2016/dropbear_ecdsa_host_key -p $porta_db16 -F -E"
			grep -q 'dropbear2016' /etc/autostart 2>/dev/null && sed -i '/dropbear2016/d' /etc/autostart
