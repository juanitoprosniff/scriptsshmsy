        usermod -p "$_hash" "$usuario" 2>/dev/null
    }
    _exp_date=$(date -d "+${dias} days" +%Y-%m-%d 2>/dev/null)
    [[ -n "$_exp_date" ]] && chage -E "$_exp_date" "$usuario" 2>/dev/null

    _ssh_p=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | xargs)
    _db16_p=$(systemctl show dropbear-legacy --property=ExecStart 2>/dev/null | grep -oP '(?<=-p )\d+' | head -1)
    _py_p=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
    _ssl_p=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)

    echo ""
    echo -e "\033[1;32m✓ Usuario TESTE creado!\033[0m"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;32mUsuario  :\033[1;37m $usuario"
    echo -e "\033[1;32mSenha    :\033[1;37m $senha"
    echo -e "\033[1;32mExpira   :\033[1;37m ${_exp_date:-$dias día(s)}"
    echo -e "\033[1;33m━━━━━ PUERTOS ━━━━━\033[0m"
    [[ -n "$_ssh_p"  ]] && echo -e "\033[1;37m  SSH  → \033[1;32m$_ssh_p"
    [[ -n "$_db16_p" ]] && echo -e "\033[1;37m  DB16 → \033[1;32m$_db16_p"
    [[ -n "$_py_p"   ]] && echo -e "\033[1;37m  Proxy→ \033[1;32m$_py_p"
    [[ -n "$_ssl_p"  ]] && echo -e "\033[1;37m  SSL  → \033[1;32m$_ssl_p"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""
}
# ============================================================
# SLOWDNS — Módulo integrado MSYVPN-SCRIPT
# Rutas: /etc/SSHPlus/slowdns/  (unificado con SSHPlus)
# Compatible: ARM + AMD64 | Ubuntu 18-25+
# ============================================================
_SLOW_BASE="/etc/SSHPlus/slowdns"
_SLOW_KEY="${_SLOW_BASE}/keys"
_SLOW_BIN="${_SLOW_BASE}/dns-server"

_slow_check_or_download_bin() {
    [[ -x "$_SLOW_BIN" ]] && return 0
    mkdir -p "$_SLOW_BASE"
    echo -e "\033[1;33m  Descargando binario dns-server...\033[0m"
    local _urls=(
        "https://raw.githubusercontent.com/khaledagn/VPS-AGN_English_Official/master/LINKS-LIBRARIES/dns-server"
        "https://github.com/juanitoprosniff/scriptsshmsy/raw/main/installer/dns-server"
    )
    for _u in "${_urls[@]}"; do
        wget -q --timeout=20 "$_u" -O "$_SLOW_BIN" 2>/dev/null
        if [[ -s "$_SLOW_BIN" ]]; then
            chmod +x "$_SLOW_BIN"
            echo -e "\033[1;32m  ✓ Binario descargado.\033[0m"
            return 0
        fi
        rm -f "$_SLOW_BIN" 2>/dev/null
    done
    echo -e "\033[1;31m  ✗ No se pudo descargar dns-server.\033[0m"
    echo -e "\033[1;33m  Colóquelo manualmente en: $_SLOW_BIN\033[0m"
    return 1
}

slow_menu() {
    while true; do
        clear
        mkdir -p "$_SLOW_BASE" "$_SLOW_KEY"
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m         SLOWDNS — MSYVPN-SCRIPT         \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        # Estado en tiempo real
        local _slow_ns _slow_pt
        _slow_ns=$(cat "${_SLOW_KEY}/domain_ns" 2>/dev/null || echo "sin configurar")
        _slow_pt=$(cat "${_SLOW_KEY}/puerto"    2>/dev/null || echo "sin configurar")
        if screen -ls 2>/dev/null | grep -q "slowdns"; then
            echo -e "  Estado : \033[1;32m● ACTIVO\033[0m"
        else
            echo -e "  Estado : \033[1;31m● INACTIVO\033[0m"
        fi
        echo -e "  NS     : \033[1;33m${_slow_ns}\033[0m"
        echo -e "  Puerto : \033[1;33m${_slow_pt}\033[0m"
        echo ""
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mVer información SlowDNS          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mInstalar / Configurar SlowDNS    \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;32mReiniciar SlowDNS                \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mCambiar NS / Puerto / Claves     \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;31mDetener SlowDNS                  \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVolver                           \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read _sopt
        case "$_sopt" in
        1) _slow_info ;;
        2) _slow_install ;;
        3) _slow_restart ;;
        4) _slow_change ;;
        5) _slow_stop ;;
        0) tput reset; fun_conexao; return ;;
        *) echo -e "\033[1;31mOpción inválida.\033[0m"; sleep 1 ;;
        esac
    done
}

_slow_info() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m      INFORMACIÓN SLOWDNS              \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    local _ns _key _port
    _ns=$(cat "${_SLOW_KEY}/domain_ns" 2>/dev/null)
    _key=$(cat "${_SLOW_KEY}/server.pub" 2>/dev/null)
    _port=$(cat "${_SLOW_KEY}/puerto"   2>/dev/null)
    if [[ -z "$_ns" || -z "$_key" ]]; then
        echo -e "\033[1;31m  ✗ SlowDNS no configurado.\033[0m"
        echo -e "\033[1;33m  Use opción [2] para configurar.\033[0m"
    else
        screen -ls 2>/dev/null | grep -q "slowdns" && \
            echo -e "  Estado       : \033[1;32m● ACTIVO\033[0m" || \
            echo -e "  Estado       : \033[1;31m● INACTIVO\033[0m"
        echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        echo -e "  \033[1;33mNS (Nameserver): \033[1;32m$_ns\033[0m"
        echo -e "  \033[1;33mClave pública  : \033[1;32m$_key\033[0m"
        echo -e "  \033[1;33mPuerto destino : \033[1;32m${_port:-?}\033[0m"
        echo -e "  \033[1;33mPuerto SlowDNS : \033[1;32m5300 UDP\033[0m"
        echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        echo -e "  \033[1;37mApp cliente — NS: \033[1;32m$_ns\033[0m"
        echo -e "  \033[1;37mApp cliente — Clave: \033[1;32m$_key\033[0m"
    fi
    echo ""; read -p "  Presione ENTER para continuar..." _p
}

_slow_install() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m      INSTALAR / CONFIGURAR SLOWDNS      \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    mkdir -p "$_SLOW_BASE" "$_SLOW_KEY"
    _slow_check_or_download_bin || { sleep 3; return; }

    # Listar puertos activos
    echo -e "\n\033[1;33m  Servicios disponibles para tunelizar:\033[0m"
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    declare -A _s_seen; local _sn=1
    declare -a _s_ports=()
    while IFS= read -r _raw; do
        local _spr _spt
        _spr=$(echo "$_raw" | awk '{print $1}')
        _spt=$(echo "$_raw" | awk '{print $4}' | rev | cut -d: -f1 | rev)
        [[ -z "$_spt" || "${_s_seen[$_spt]}" ]] && continue
        case "$_spr" in sshd|dropbear|stunnel4|stunnel|python|python3) : ;; *) continue ;; esac
        _s_seen[$_spt]=1
        printf "  \033[1;31m[%s]\033[0m \033[1;33m%-14s\033[0m \033[1;36m%s\033[0m\n" "$_sn" "$_spr" "$_spt"
        _s_ports+=("$_spt"); ((_sn++))
    done < <(ss -tlpn 2>/dev/null | grep "LISTEN")
    # Agregar SSH manual si no apareció
    local _ssh_man; _ssh_man=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | head -1)
    if [[ -n "$_ssh_man" && -z "${_s_seen[$_ssh_man]}" ]]; then
        printf "  \033[1;31m[%s]\033[0m \033[1;33m%-14s\033[0m \033[1;36m%s\033[0m\n" "$_sn" "sshd" "$_ssh_man"
        _s_ports+=("$_ssh_man"); ((_sn++))
    fi
    echo -e "\033[1;33m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    local _sm=$(( _sn - 1 ))
    echo -ne "\033[1;32m  Seleccione servicio [1-$_sm]: \033[1;37m"; read _ssel
    [[ -z "$_ssel" || "$_ssel" -lt 1 || "$_ssel" -gt "$_sm" ]] 2>/dev/null && {
        echo -e "\033[1;31m  Opción inválida.\033[0m"; sleep 2; return
    }
    local _SPORT="${_s_ports[$(( _ssel - 1 ))]}"
    echo "$_SPORT" > "${_SLOW_KEY}/puerto"
    echo -e "  \033[1;33mPuerto seleccionado: \033[1;32m$_SPORT\033[0m"

    # Ingresar NS
    local _SNS=""
    while [[ -z "$_SNS" ]]; do
        echo -ne "\n  \033[1;33mNS (Nameserver): \033[1;37m"; read _SNS
    done
    echo "$_SNS" > "${_SLOW_KEY}/domain_ns"
    echo -e "  \033[1;33mNS guardado: \033[1;32m$_SNS\033[0m"

    # Gestión de clave
    local _spub; _spub=$(cat "${_SLOW_KEY}/server.pub" 2>/dev/null)
    if [[ -n "$_spub" ]]; then
        echo -e "\n  \033[1;33mClave existente: \033[1;32m$_spub\033[0m"
        echo -ne "  \033[1;33m¿Usar clave existente? \033[1;31m[s/n]: \033[1;37m"; read _sue
        [[ "$_sue" =~ ^[nN]$ ]] && {
            rm -f "${_SLOW_KEY}/server.key" "${_SLOW_KEY}/server.pub"
            "$_SLOW_BIN" -gen-key -privkey-file "${_SLOW_KEY}/server.key" \
                -pubkey-file "${_SLOW_KEY}/server.pub" 2>/dev/null
            echo -e "  \033[1;32mNueva clave: $(cat ${_SLOW_KEY}/server.pub)\033[0m"
        }
    else
        echo -e "\n  \033[1;33mGenerando par de claves...\033[0m"
        rm -f "${_SLOW_KEY}/server.key" "${_SLOW_KEY}/server.pub"
        "$_SLOW_BIN" -gen-key -privkey-file "${_SLOW_KEY}/server.key" \
            -pubkey-file "${_SLOW_KEY}/server.pub" 2>/dev/null
        if [[ -s "${_SLOW_KEY}/server.pub" ]]; then
            echo -e "  \033[1;32mClave pública: $(cat ${_SLOW_KEY}/server.pub)\033[0m"
        else
            echo -e "\033[1;31m  ✗ No se pudo generar la clave.\033[0m"; sleep 3; return
        fi
    fi

    # Firewall
    iptables -I INPUT  -p udp --dport 5300 -j ACCEPT 2>/dev/null
    iptables -t nat -I PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300 2>/dev/null
    command -v ufw &>/dev/null && ufw allow 5300/udp >/dev/null 2>&1

    # Iniciar SlowDNS
    screen -ls 2>/dev/null | grep "slowdns" | cut -d. -f1 | awk '{print $1}' | xargs kill 2>/dev/null
    sleep 1
    if screen -dmS slowdns "$_SLOW_BIN" -udp :5300 \
        -privkey-file "${_SLOW_KEY}/server.key" "$_SNS" "127.0.0.1:$_SPORT"; then
        echo -e "\n\033[1;32m  ✓ SlowDNS iniciado correctamente!\033[0m"
    else
        echo -e "\033[1;31m  ✗ Error al iniciar SlowDNS.\033[0m"
    fi

    # Autostart
    sed -i '/slowdns/d' /etc/autostart 2>/dev/null
    echo "screen -ls | grep -q slowdns || screen -dmS slowdns ${_SLOW_BIN} -udp :5300 -privkey-file ${_SLOW_KEY}/server.key \$(cat ${_SLOW_KEY}/domain_ns) 127.0.0.1:\$(cat ${_SLOW_KEY}/puerto)" >> /etc/autostart

    echo ""; read -p "  Presione ENTER para continuar..." _p
}

_slow_restart() {
    clear
    local _ns _port
    _ns=$(cat "${_SLOW_KEY}/domain_ns" 2>/dev/null)
    _port=$(cat "${_SLOW_KEY}/puerto"  2>/dev/null)
    if [[ -z "$_ns" || -z "$_port" ]]; then
        echo -e "\033[1;31m  ✗ SlowDNS no configurado.\033[0m"; sleep 2; return
    fi
    _slow_check_or_download_bin || { sleep 3; return; }
    screen -ls 2>/dev/null | grep "slowdns" | cut -d. -f1 | awk '{print $1}' | xargs kill 2>/dev/null
    sleep 1
    if screen -dmS slowdns "$_SLOW_BIN" -udp :5300 \
        -privkey-file "${_SLOW_KEY}/server.key" "$_ns" "127.0.0.1:$_port"; then
        echo -e "\033[1;32m  ✓ SlowDNS reiniciado!\033[0m"
    else
        echo -e "\033[1;31m  ✗ Error al reiniciar.\033[0m"
    fi
    sleep 2
}

_slow_stop() {
    clear
    echo -e "\033[1;33m  Deteniendo SlowDNS...\033[0m"
    screen -ls 2>/dev/null | grep "slowdns" | cut -d. -f1 | awk '{print $1}' | xargs kill 2>/dev/null
    screen -wipe >/dev/null 2>&1
    echo -e "\033[1;32m  ✓ SlowDNS detenido.\033[0m"; sleep 2
}

_slow_change() {
    clear
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mCambiar Nameserver (NS)  \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mCambiar Puerto destino   \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mRegenenar claves         \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVolver                   \033[0;34m┃"
    echo -ne "\033[1;32m  Opción: \033[1;37m"; read _co
    case "$_co" in
    1) echo -ne "\n  \033[1;33mNuevo NS: \033[1;37m"; read _nns
       [[ -n "$_nns" ]] && echo "$_nns" > "${_SLOW_KEY}/domain_ns" && \
           echo -e "\033[1;32m  ✓ NS actualizado. Reinicie SlowDNS.\033[0m" ;;
    2) echo -ne "\n  \033[1;33mNuevo Puerto: \033[1;37m"; read _npt
       [[ -n "$_npt" ]] && echo "$_npt" > "${_SLOW_KEY}/puerto" && \
           echo -e "\033[1;32m  ✓ Puerto actualizado. Reinicie SlowDNS.\033[0m" ;;
    3) rm -f "${_SLOW_KEY}/server.key" "${_SLOW_KEY}/server.pub"
       [[ -x "$_SLOW_BIN" ]] && \
       "$_SLOW_BIN" -gen-key -privkey-file "${_SLOW_KEY}/server.key" \
           -pubkey-file "${_SLOW_KEY}/server.pub" 2>/dev/null && \
       echo -e "\033[1;32m  ✓ Nuevas claves:\033[0m $(cat ${_SLOW_KEY}/server.pub)" ;;
    0) return ;;
    esac
    sleep 3
}

# ============================================================
# UDP ZIVPN — Módulo integrado MSYVPN-SCRIPT
# Detección automática ARM / AMD64
# ============================================================
fun_udp_zivpn() {
    # Detectar arquitectura
    local _arch _arch_label _bin_name
    case "$(uname -m)" in
        x86_64)        _arch="amd64"; _arch_label="AMD64"  ;;
        aarch64|arm64) _arch="arm64"; _arch_label="ARM64"  ;;
        armv7l|armv6l) _arch="arm";   _arch_label="ARM32"  ;;
        *)             _arch="amd64"; _arch_label="AMD64"  ;;
    esac
    _bin_name="udp-zivpn-linux-${_arch}"
    local _ZREL="https://github.com/zahidbd2/udp-zivpn/releases/download/udp-zivpn_1.4.9"

    while true; do
        clear
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m         UDP ZIVPN — MSYVPN-SCRIPT       \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -e "  Arquitectura : \033[1;32m$_arch_label\033[0m"
        # Estado del servicio
        if systemctl is-active zivpn.service >/dev/null 2>&1; then
            echo -e "  Servicio     : \033[1;32m● ACTIVO\033[0m"
        elif [[ -f /usr/local/bin/zivpn ]]; then
            echo -e "  Servicio     : \033[1;33m● INSTALADO / INACTIVO\033[0m"
        else
            echo -e "  Servicio     : \033[1;31m● NO INSTALADO\033[0m"
        fi
        [[ -f /etc/zivpn/config.json ]] && \
            echo -e "  Puerto UDP   : \033[1;33m$(grep -oP '"listen_addr":\s*":[0-9]+' /etc/zivpn/config.json | grep -oP '[0-9]+$')\033[0m"
        echo ""
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mInstalar UDP ZiVPN           \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;32mReiniciar ZiVPN              \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mCambiar contraseñas          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;31mDetener / Desinstalar        \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVolver                       \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read _zopt

        case "$_zopt" in
        1)
            clear
            echo -e "\033[1;33m  Instalando UDP ZiVPN ($_arch_label)...\033[0m\n"
            systemctl stop zivpn.service 2>/dev/null

            echo -e "  \033[1;37mDescargando binario $_bin_name...\033[0m"
            wget -q --timeout=30 "${_ZREL}/${_bin_name}" -O /usr/local/bin/zivpn 2>/dev/null
            if [[ ! -s /usr/local/bin/zivpn ]]; then
                echo -e "\033[1;31m  ✗ Error al descargar el binario.\033[0m"
                sleep 3; continue
            fi
            chmod +x /usr/local/bin/zivpn
            mkdir -p /etc/zivpn

            # Descargar config
            wget -q --timeout=10 \
                https://raw.githubusercontent.com/zahidbd2/udp-zivpn/main/config.json \
                -O /etc/zivpn/config.json 2>/dev/null

            # Config por defecto si falló la descarga
            [[ ! -s /etc/zivpn/config.json ]] && cat > /etc/zivpn/config.json <<'ZCFG'
{
  "listen_addr": ":36712",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "config": ["zi"],
  "obfs": ""
}
ZCFG

            # Pedir contraseñas
            echo -ne "\n  \033[1;33mContraseñas (ej: pass1,pass2) [Enter = 'zi']: \033[1;37m"
            read _zpasses
            if [[ -n "$_zpasses" ]]; then
                # Formatear array JSON
                local _zconfig_arr
                _zconfig_arr=$(echo "$_zpasses" | tr ',' '\n' | \
                    awk '{printf "\"%s\", ", $1}' | sed 's/, $//')
                sed -i -E "s/\"config\": ?\[[^]]*\]/\"config\": [${_zconfig_arr}]/" \
                    /etc/zivpn/config.json 2>/dev/null
            fi

            # Puerto
            echo -ne "  \033[1;33mPuerto UDP [Enter = 36712]: \033[1;37m"; read _zport
            [[ -n "$_zport" ]] && sed -i "s|\":36712\"|\":${_zport}\"|g" /etc/zivpn/config.json

            # Generar certificados SSL
            echo -e "  \033[1;37mGenerando certificados SSL...\033[0m"
            openssl req -new -newkey rsa:4096 -days 365 -nodes -x509 \
                -subj "/C=US/ST=California/L=LA/O=MSYVPN/CN=zivpn" \
                -keyout /etc/zivpn/zivpn.key \
                -out    /etc/zivpn/zivpn.crt >/dev/null 2>&1

            # Optimizar red
            sysctl -w net.core.rmem_max=16777216 >/dev/null 2>&1
            sysctl -w net.core.wmem_max=16777216 >/dev/null 2>&1

            # Servicio systemd
            cat > /etc/systemd/system/zivpn.service <<'ZSVC'
[Unit]
Description=UDP ZiVPN Service — MSYVPN-SCRIPT
After=network.target
[Service]
Type=simple
ExecStart=/usr/local/bin/zivpn server --config /etc/zivpn/config.json
Restart=always
RestartSec=3
[Install]
WantedBy=multi-user.target
ZSVC
            systemctl daemon-reload
            systemctl enable zivpn.service >/dev/null 2>&1
            systemctl start  zivpn.service >/dev/null 2>&1

            # Abrir puerto
            local _zp; _zp=$(grep -oP '"listen_addr":\s*":[0-9]+' /etc/zivpn/config.json | grep -oP '[0-9]+$')
            _zp=${_zp:-36712}
            _fw_open "$_zp" udp
            iptables -I INPUT -p udp --dport "$_zp" -j ACCEPT 2>/dev/null

            echo ""
            systemctl is-active zivpn.service >/dev/null 2>&1 && \
                echo -e "\033[1;32m  ✓ UDP ZiVPN activo en puerto UDP $_zp\033[0m" || \
                echo -e "\033[1;33m  ⚠ Verifique: systemctl status zivpn\033[0m"
            sleep 3 ;;
        2)
            systemctl restart zivpn.service 2>/dev/null && \
                echo -e "\033[1;32m  ✓ ZiVPN reiniciado!\033[0m" || \
                echo -e "\033[1;31m  ✗ Error al reiniciar.\033[0m"
            sleep 2 ;;
        3)
            clear
            echo -ne "  \033[1;33mNuevas contraseñas (ej: pass1,pass2) [Enter = 'zi']: \033[1;37m"
            read _znewpasses
            if [[ -n "$_znewpasses" ]]; then
                local _znca; _znca=$(echo "$_znewpasses" | tr ',' '\n' | \
                    awk '{printf "\"%s\", ", $1}' | sed 's/, $//')
                sed -i -E "s/\"config\": ?\[[^]]*\]/\"config\": [${_znca}]/" \
                    /etc/zivpn/config.json 2>/dev/null
                systemctl restart zivpn.service 2>/dev/null
                echo -e "\033[1;32m  ✓ Contraseñas actualizadas y ZiVPN reiniciado.\033[0m"
            fi
            sleep 2 ;;
        4)
            echo -ne "\n  \033[1;33m¿Desinstalar ZiVPN? \033[1;31m[s/n]: \033[1;37m"; read _zdel
            [[ "$_zdel" =~ ^[sS]$ ]] && {
                systemctl stop    zivpn.service 2>/dev/null
                systemctl disable zivpn.service 2>/dev/null
                rm -f /usr/local/bin/zivpn /etc/systemd/system/zivpn.service
                rm -rf /etc/zivpn
                systemctl daemon-reload 2>/dev/null
                echo -e "\033[1;32m  ✓ ZiVPN desinstalado.\033[0m"
            }
            sleep 2 ;;
        0) tput reset; fun_conexao; return ;;
        *) echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1 ;;
        esac
    done
}

