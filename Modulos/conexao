				1|01) cor_sts='blue' ;; 2|02) cor_sts='green' ;; 3|03) cor_sts='red' ;;
				4|04) cor_sts='yellow' ;; 5|05) cor_sts='#F535AA' ;; 6|06) cor_sts='cyan' ;;
				7|07) cor_sts='#FF7F00' ;; 8|08) cor_sts='#9932CD' ;; 9|09) cor_sts='black' ;;
				10) cor_sts='null' ;; *) echo -e "\n\033[1;33mOPÇÃO INVÁLIDA !"; cor_sts='null' ;;
				esac
				fun_msgwssocks() {
					msgsocks2=$(cat /etc/SSHPlus/wsproxy.py | grep "MSG =" | awk -F = '{print $2}')
					sed -i "s/$msgsocks2/ '$msgg'/g" /etc/SSHPlus/wsproxy.py
					sleep 1
					cor_old=$(grep 'color=' /etc/SSHPlus/wsproxy.py | cut -d '"' -f2)
					sed -i "s/\b$cor_old\b/$cor_sts/g" /etc/SSHPlus/wsproxy.py
				}
				echo ""
				echo -e "\033[1;32mALTERANDO STATUS!"
				echo ""
				fun_bar 'fun_msgwssocks'
				restartwssocks() {
					# Reiniciar todas las sesiones WebSocket activas
					for pidproxy in $(screen -ls | grep "\.ws" | awk '{print $1}'); do
						_pname=$(screen -ls | grep "$pidproxy" | grep -oP '\d+\.\Kws\S+')
						_pt=$(echo $_pname | grep -oP '\d+$')
						screen -r -S "$pidproxy" -X quit 2>/dev/null
						sleep 0.5
						[[ -n "$_pt" ]] && screen -dmS ws${_pt} python3 /etc/SSHPlus/wsproxy.py $_pt
					done
					screen -wipe >/dev/null
				}
				echo ""
				echo -e "\033[1;32mREINICIANDO WEBSOCKET(S)!"
				echo ""
				fun_bar 'restartwssocks'
				echo ""
				echo -e "\033[1;32mSTATUS ALTERADO COM SUCESSO!"
				sleep 2
				fun_socks
			else
				echo -e "\033[1;31mFUNÇÃO INDISPONÍVEL\n\n\033[1;33mATIVE O WEBSOCKET PRIMEIRO !\033[1;33m"
				sleep 2
				fun_socks
			fi

		elif [[ "$resposta" = '0' ]]; then
			echo ""
			echo -e "\033[1;31mVoltando...\033[0m"
			sleep 1
			fun_conexao
		else
			echo ""
			echo -e "\033[1;31mOpção inválida !\033[0m"
			sleep 1
			fun_socks
		fi
	}

	fun_openssh() {
		clear
		echo -e "\E[44;1;37m            OPENSSH             \E[0m\n"
		echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;37m• \033[1;33mADICIONAR PORTA\033[1;31m
[\033[1;36m2\033[1;31m] \033[1;37m• \033[1;33mREMOVER PORTA\033[1;31m
[\033[1;36m3\033[1;31m] \033[1;37m• \033[1;33mVOLTAR\033[0m"
		echo ""
		echo -ne "\033[1;32mO QUE DESEJA FAZER \033[1;33m?\033[1;37m "
		read resp
		if [[ "$resp" = '1' ]]; then
			echo -e "\E[44;1;37m         ADICIONAR PORTA AO SSH         \E[0m\n"
			echo -ne "\033[1;32mQUAL PORTA DESEJA ADICIONAR \033[1;33m?\033[1;37m "
			read pt
			[[ -z "$pt" ]] && {
				echo -e "\n\033[1;31mPorta inválida!"
				sleep 3
				fun_conexao
			}
			verif_ptrs $pt
			echo -e "\n\033[1;32mADICIONANDO PORTA AO SSH\033[0m"
			echo ""
			fun_addpssh() {
				echo "Port $pt" >>/etc/ssh/sshd_config
				service ssh restart
			}
			fun_bar 'fun_addpssh'
			echo -e "\n\033[1;32mPORTA ADICIONADA COM SUCESSO\033[0m"
			sleep 3
			fun_conexao
		elif [[ "$resp" = '2' ]]; then
			echo -e "\E[41;1;37m         REMOVER PORTA DO SSH         \E[0m"
			echo -e "\n\033[1;33m[\033[1;31m!\033[1;33m] \033[1;32mPORTA PADRÃO \033[1;37m22 \033[1;33mCUIDADO !\033[0m"
			echo -e "\n\033[1;33mPORTAS EM USO: \033[1;37m$(grep 'Port' /etc/ssh/sshd_config | cut -d' ' -f2 | grep -v 'no' | xargs)\n"
			echo -ne "\033[1;32mQUAL PORTA DESEJA REMOVER \033[1;33m?\033[1;37m "
			read pt
			[[ -z "$pt" ]] && {
				echo -e "\n\033[1;31mPorta inválida!"
				sleep 2
				fun_conexao
			}
			[[ $(grep -wc "$pt" '/etc/ssh/sshd_config') != '0' ]] && {
				echo -e "\n\033[1;32mREMOVENDO PORTA DO SSH\033[0m"
				echo ""
				fun_delpssh() {
					sed -i "/Port $pt/d" /etc/ssh/sshd_config
					service ssh restart
				}
				fun_bar 'fun_delpssh'
				echo -e "\n\033[1;32mPORTA REMOVIDA COM SUCESSO\033[0m"
				sleep 2
				fun_conexao
			} || {
				echo -e "\n\033[1;31mPorta inválida!"
				sleep 2
				fun_conexao
			}
		elif [[ "$resp" = '3' ]]; then
			echo -e "\n\033[1;31mVoltando.."
			sleep 2
			fun_conexao
		else
			echo -e "\n\033[1;31mOpção inválida!"
			sleep 2
			fun_conexao
		fi
	}

	fun_sslh() {
		if command -v ss &>/dev/null; then
			_sslh_running=$(ss -tlpn 2>/dev/null | grep -c 'sslh')
		else
			_sslh_running=$(netstat -nltp 2>/dev/null | grep -c 'sslh')
		fi
		[[ "$_sslh_running" = '0' ]] && {
			echo -e "\E[44;1;37m             INSTALAR SSLH               \E[0m\n"
			echo -e "\n\033[1;33m[\033[1;31m!\033[1;33m] \033[1;32mA PORTA \033[1;37m443 \033[1;32mSERÁ USADA POR PADRÃO\033[0m\n"
			echo -ne "\033[1;32mREALMENTE DESEJA INSTALAR O SSLH \033[1;31m? \033[1;33m[s/n]:\033[1;37m "
			read resp
			[[ "$resp" = 's' ]] && {
				verif_ptrs 443
				fun_instsslh() {
					[[ -e "/etc/stunnel/stunnel.conf" ]] && ptssl="$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)" || ptssl='3128'
					[[ -e "/etc/openvpn/server.conf" ]] && ptvpn="$(ss -tlpn 2>/dev/null | grep 'openvpn' | awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)" || ptvpn='1194'
					DEBIAN_FRONTEND=noninteractive apt-get -y install sslh
					echo -e "#Modo autônomo\n\nRUN=yes\n\nDAEMON=/usr/sbin/sslh\n\nDAEMON_OPTS='--user sslh --listen 0.0.0.0:443 --ssh 127.0.0.1:22 --ssl 127.0.0.1:$ptssl --http 127.0.0.1:80 --openvpn 127.0.0.1:$ptvpn --pidfile /var/run/sslh/sslh.pid'" >/etc/default/sslh
					/etc/init.d/sslh start && service sslh start
				}
				echo -e "\n\033[1;32mINSTALANDO O SSLH !\033[0m\n"
				fun_bar 'fun_instsslh'
				echo -e "\n\033[1;32mINICIANDO O SSLH !\033[0m\n"
				fun_bar '/etc/init.d/sslh restart && service sslh restart'
				_chk=$(ss -tlpn 2>/dev/null | grep -wc 'sslh')
				[[ $_chk != '0' ]] && echo -e "\n\033[1;32mINSTALADO COM SUCESSO !\033[0m" || echo -e "\n\033[1;31mERRO INESPERADO !\033[0m"
				sleep 3
				fun_conexao
			} || {
				echo -e "\n\033[1;31mVoltando.."
				sleep 2
				fun_conexao
			}
		} || {
			echo -e "\E[41;1;37m             REMOVER O SSLH               \E[0m\n"
			echo -ne "\033[1;32mREALMENTE DESEJA REMOVER O SSLH \033[1;31m? \033[1;33m[s/n]:\033[1;37m "
			read respo
			[[ "$respo" = "s" ]] && {
				fun_delsslh() {
					/etc/init.d/sslh stop && service sslh stop
					apt-get remove sslh -y
					apt-get purge sslh -y
				}
				echo -e "\n\033[1;32mREMOVENDO O SSLH !\033[0m\n"
				fun_bar 'fun_delsslh'
				echo -e "\n\033[1;32mREMOVIDO COM SUCESSO !\033[0m\n"
				sleep 2
				fun_conexao
			} || {
				echo -e "\n\033[1;31mVoltando.."
				sleep 2
				fun_conexao
			}
		}
	}

	x="ok"
	clear
	fun_conexao() {
		while true; do
			echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
			echo -e "\033[0;34m┃\E[44;1;37m             MODO DE CONEXÃO             \E[0m\033[0;34m┃"
			echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
			echo -e "\033[1;32mOPENSSH\033[1;31m: \033[1;37m$(grep 'Port' /etc/ssh/sshd_config | cut -d' ' -f2 | grep -v 'no' | xargs)" && sts6="\033[1;32m✓ "

			# Detectar processos — compatível com Ubuntu 22+ (ss) e anteriores (netstat)
			_check_proc() {
				local p="$1"
				ss -tlpn 2>/dev/null | grep -q "$p" || netstat -tlpn 2>/dev/null | grep -q "$p"
			}

			_check_proc 'docker' && {
				echo -e "\033[1;32mCHISEL\033[1;32m: \033[1;37m$(get_ports_by_process 'docker')"
				sts8="\033[1;32m✓ "
			} || { sts8="\033[1;31m✕ "; }

			[[ "$(ps x | grep 'slowdns' | grep -v 'grep' | wc -l)" != '0' ]] && sts9="\033[1;32m✓ " || sts9="\033[1;31m✕ "

			_check_proc 'sslh' && {
				echo -e "\033[1;32mSSLH\033[1;31m: \033[1;37m$(get_ports_by_process 'sslh')"
				sts7="\033[1;32m✓ "
			} || { sts7="\033[1;31m✕ "; }

			_check_proc 'openvpn' && {
				echo -e "\033[1;32mOPENVPN\033[1;31m: \033[1;37m$(get_ports_by_process 'openvpn')"
				sts5="\033[1;32m✓ "
			} || { sts5="\033[1;31m✕ "; }

			# Detectar python3 para proxy/websocket (Ubuntu 22+ usa python3)
			_py_active=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
			[[ -n "$_py_active" ]] && {
				echo -e "\033[1;32mPROXY SOCKS\033[1;31m: \033[1;37m$_py_active"
				sts4="\033[1;32m✓ "
			} || { sts4="\033[1;31m✕ "; }

			[[ -e "/etc/stunnel/stunnel.conf" ]] && {
				echo -e "\033[1;32mSSL TUNNEL\033[1;31m: \033[1;37m$(get_ports_by_process 'stunnel')"
				sts3="\033[1;32m✓ "
			} || { sts3="\033[1;31m✕ "; }

			_check_proc 'dropbear' && {
				echo -e "\033[1;32mDROPBEAR\033[1;31m: \033[1;37m$(get_ports_by_process 'dropbear')"
				sts2="\033[1;32m✓ "
			} || { sts2="\033[1;31m✕ "; }

			_check_proc 'squid' && {
				echo -e "\033[1;32mSQUID\033[1;31m: \033[1;37m$(get_ports_by_process 'squid')"
				sts1="\033[1;32m✓ "
			} || { sts1="\033[1;31m✕ "; }

			ss -tlpn 2>/dev/null | grep -q 'trojan-go' || netstat -tunlp 2>/dev/null | grep -q 'trojan-go' && trojansts="\033[1;32m✓ " || trojansts="\033[1;31m✕ "
			ss -tlpn 2>/dev/null | grep -q 'v2ray' || netstat -tunlp 2>/dev/null | grep -q 'v2ray' && xv2ray="\033[1;32m✓ " || xv2ray="\033[1;31m✕ "

			echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m01\033[1;31m] \033[1;37m• \033[1;33mOPENSSH $sts6                        \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m02\033[1;31m] \033[1;37m• \033[1;33mSQUID PROXY $sts1                    \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m03\033[1;31m] \033[1;37m• \033[1;33mDROPBEAR $sts2                       \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m04\033[1;31m] \033[1;37m• \033[1;33mOPENVPN $sts5                        \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m05\033[1;31m] \033[1;37m• \033[1;33mPROXY SOCKS $sts4                    \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m06\033[1;31m] \033[1;37m• \033[1;33mSSL TUNNEL $sts3                     \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m07\033[1;31m] \033[1;37m• \033[1;33mSSLH MULTIPLEX $sts7                 \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m08\033[1;31m] \033[1;37m• \033[1;33mCHISEL $sts8                         \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m09\033[1;31m] \033[1;37m• \033[1;33mSLOWDNS $sts9                        \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m10\033[1;31m] \033[1;37m• \033[1;33mV2RAY $xv2ray                          \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m11\033[1;31m] \033[1;37m• \033[1;33mTROJAN-GO $trojansts                      \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m12\033[1;31m] \033[1;37m• \033[1;33mVOLTAR \033[1;32m<\033[1;33m<\033[1;31m<                        \033[0;34m┃"
			echo -e "\033[0;34m┃\033[1;31m[\033[1;36m00\033[1;31m] \033[1;37m• \033[1;33mSAIR \033[1;32m<\033[1;33m<\033[1;31m<                          \033[0;34m┃"
			echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
			tput civis
			echo -ne "\033[1;32mO QUE DESEJA FAZER \033[1;37m?\033[1;31m?\033[1;37m : ";
			read x
			tput cnorm
			case $x in
			1 | 01) tput reset; clear; fun_openssh ;;
			2 | 02) tput reset; clear; fun_squid ;;
			3 | 03) tput reset; clear; fun_drop ;;
			4 | 04) tput reset; clear; fun_openvpn ;;
			5 | 05) tput reset; clear; fun_socks ;;
			6 | 06) tput reset; clear; inst_ssl ;;
			7 | 07) tput reset; clear; fun_sslh ;;
			8 | 08) tput reset; clear; fun_chisel ;;
			9 | 09) tput reset; clear; slow_setup ;;
			10)     tput reset; clear; v2raymanager; exit ;;
			11)     tput reset; clear; trojan-go ;;
			12)     tput reset; clear; menu ;;
			0 | 00)
				tput reset; clear
				echo -e "\033[1;31mSaindo...\033[0m"
				sleep 1
				exit
				;;
			*)
				tput reset; clear
				echo -e "\033[1;31mOpção inválida !\033[0m"
				sleep 1
				;;
			esac
		done
	}
	tput reset
	clear
	fun_conexao
}
