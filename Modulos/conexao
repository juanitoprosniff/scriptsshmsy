            pkill -f tinysshd 2>/dev/null; sleep 1
            _tiny_pt=$(grep 'tinysshd' /etc/autostart 2>/dev/null | grep -oP '\d+' | tail -1)
            [[ -n "$_tiny_pt" ]] && tcpserver -HRDl0 0.0.0.0 $_tiny_pt /usr/sbin/tinysshd /etc/tinyssh/sshkeydir &
            echo -e "\n\033[1;32mTinySSH reiniciado!\033[0m"; sleep 2; fun_alt_ssh ;;
        3)
            pkill -f tinysshd 2>/dev/null
            apt-get remove --purge tinyssh ucspi-tcp -y >/dev/null 2>&1
            sed -i '/tinysshd/d' /etc/autostart 2>/dev/null
            echo -e "\n\033[1;32mTinySSH eliminado!\033[0m"; sleep 2; fun_alt_ssh ;;
        0) fun_alt_ssh ;;
        esac
        return
    fi

    echo -ne "\033[1;32mPUERTO (defecto 2222): \033[1;37m"; read t_port; [[ -z "$t_port" ]] && t_port=2222
    verif_ptrs $t_port

    echo -e "\n\033[1;33mInstalando TinySSH...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y tinyssh ucspi-tcp 2>/dev/null || \
    apt-get install -y tinyssh ucspi-tcp-ipv6 2>/dev/null

    if ! command -v tinysshd &>/dev/null; then
        echo -e "\033[1;31mTinySSH no disponible en este repositorio.\033[0m"
        echo -e "\033[1;33mIntentando compilar desde fuente...\033[0m"
        _instalar_tinyssh_source "$t_port"
        return
    fi

    # Generar claves ed25519
    mkdir -p /etc/tinyssh/sshkeydir
    tinyssh-makekey /etc/tinyssh/sshkeydir 2>/dev/null || \
        tinysshd-makekey /etc/tinyssh/sshkeydir 2>/dev/null

    # Iniciar con tcpserver
    tcpserver -HRDl0 0.0.0.0 $t_port /usr/sbin/tinysshd /etc/tinyssh/sshkeydir &
    echo "tcpserver -HRDl0 0.0.0.0 $t_port /usr/sbin/tinysshd /etc/tinyssh/sshkeydir &" >> /etc/autostart
    _fw_open $t_port

    echo -e "\n\033[1;32mвњ“ TinySSH ACTIVO EN PUERTO $t_port!\033[0m"
    sleep 2; fun_alt_ssh
}

_instalar_tinyssh_source() {
    local port="$1"
    # Compilar TinySSH desde GitHub (solo requiere libc)
    apt-get install -y make gcc wget git >/dev/null 2>&1
    cd /tmp
    git clone --depth=1 https://github.com/janmojzis/tinyssh.git 2>/dev/null
    if [[ -d tinyssh ]]; then
        cd tinyssh
        make -j$(nproc) 2>/dev/null && make install 2>/dev/null
        cd /tmp; rm -rf tinyssh
        if command -v tinysshd &>/dev/null; then
            mkdir -p /etc/tinyssh/sshkeydir
            tinyssh-makekey /etc/tinyssh/sshkeydir 2>/dev/null
            tcpserver -HRDl0 0.0.0.0 $port /usr/sbin/tinysshd /etc/tinyssh/sshkeydir &
            echo "tcpserver -HRDl0 0.0.0.0 $port /usr/sbin/tinysshd /etc/tinyssh/sshkeydir &" >> /etc/autostart
            _fw_open $port
            echo -e "\n\033[1;32mвњ“ TinySSH compilado e instalado!\033[0m"
        else
            echo -e "\033[1;31mNo se pudo instalar TinySSH.\033[0m"
        fi
    else
        echo -e "\033[1;31mNo se pudo descargar TinySSH.\033[0m"
    fi
    sleep 2; fun_alt_ssh
}

