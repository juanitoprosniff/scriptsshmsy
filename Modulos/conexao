				echo -ne "\033[1;32mUSUГЃRIO: \033[1;37m"; read username
				echo -ne "\033[1;32mSENHA: \033[1;37m"; read password
				docker run --name chisel -p $porta:$porta -d --restart always jpillora/chisel server -p $porta --socks5 --key supersecret --auth "$username:$password" >/dev/null 2>&1
				echo -e "\n\033[1;32mCHISEL ATIVO NA PORTA $porta!\033[0m"; sleep 2; fun_chisel
			fi
		elif [[ "$resposta" = '2' ]]; then
			docker restart chisel 2>/dev/null; echo -e "\n\033[1;32mCHISEL REINICIADO!\033[0m"; sleep 1; fun_chisel
		else
			fun_conexao
		fi
	}

