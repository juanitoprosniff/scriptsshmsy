x="ok"; clear
fun_conexao() {
    while true; do
        clear
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m             MODO DE CONEXIÓN            \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"

        _ssh_ports=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | xargs)
        echo -e "\033[1;32mOPENSSH\033[1;31m: \033[1;37m${_ssh_ports:-22}"

        _db16_on=0
        screen -list 2>/dev/null | grep -q 'dropbear2016' && _db16_on=1
        systemctl is-active dropbear-legacy >/dev/null 2>&1 && _db16_on=1
        [[ "$_db16_on" != '0' ]] && {
            _db16_port=$(systemctl show dropbear-legacy --property=ExecStart 2>/dev/null | \
                         grep -oP '(?<=-p )\d+' | head -1)
            [[ -n "$_db16_port" ]] && echo -e "\033[1;32mDROPBEAR 2016\033[1;31m: \033[1;37m$_db16_port"
        }

        _py_active=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
                     awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
        [[ -n "$_py_active" ]] && sts4="\033[1;32m✓ " || sts4="\033[1;31m✕ "
        [[ -n "$_py_active" ]] && echo -e "\033[1;32mPROXY/WS\033[1;31m: \033[1;37m$_py_active"

        if [[ -e "/etc/stunnel/stunnel.conf" ]]; then
            sts3="\033[1;32m✓ "
            _ssl_ports=$(get_ports_by_process 'stunnel')
            _ssl_modo=""
            [[ -f /etc/stunnel/.ssl_mode ]] && _ssl_modo=" [$(head -1 /etc/stunnel/.ssl_mode)]"
            echo -e "\033[1;32mSSL${_ssl_modo}\033[1;31m: \033[1;37m$_ssl_ports"
        else
            sts3="\033[1;31m✕ "
        fi

        ps x | grep 'slowdns' | grep -v grep >/dev/null 2>&1 && sts9="\033[1;32m✓ " || sts9="\033[1;31m✕ "
        ss -tlpn 2>/dev/null | grep -q 'v2ray'   && xv2ray="\033[1;32m✓ "   || xv2ray="\033[1;31m✕ "
        ss -tlpn 2>/dev/null | grep -q 'trojan'  && trojansts="\033[1;32m✓ " || trojansts="\033[1;31m✕ "
        command -v hysteria-manager &>/dev/null   && hysterasts="\033[1;32m✓ " || hysterasts="\033[1;31m✕ "
        [[ "$_db16_on" != '0' ]] && db16sts="\033[1;32m✓ " || db16sts="\033[1;31m✕ "

        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m01\033[1;31m] \033[1;33mOPENSSH                              \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m02\033[1;31m] \033[1;33mPROXY SOCKS / WEBSOCKET $sts4         \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m03\033[1;31m] \033[1;33mSSL TUNNEL $sts3                      \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m04\033[1;31m] \033[1;33mSLOWDNS $sts9                         \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m05\033[1;31m] \033[1;33mV2RAY $xv2ray                           \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m06\033[1;31m] \033[1;33mTROJAN-GO $trojansts                    \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m07\033[1;31m] \033[1;33mDROPBEAR 2016 $db16sts                  \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m08\033[1;31m] \033[1;33mHYSTERIA UDP $hysterasts                \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m09\033[1;31m] \033[1;33mVOLVER \033[1;32m<<<                           \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m00\033[1;31m] \033[1;33mSALIR \033[1;32m<<<                             \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        tput civis
        echo -ne "\033[1;32mOpción: \033[1;37m"; read x
        tput cnorm
        case $x in
        1|01)  tput reset; fun_openssh ;;
        2|02)  tput reset; fun_socks ;;
        3|03)  tput reset; inst_ssl ;;
        4|04)  tput reset; slow_setup ;;
        5|05)  tput reset; v2raymanager; exit ;;
        6|06)  tput reset; trojan-go ;;
        7|07)  tput reset; fun_inst_dropbear2016 ;;
        8|08)  tput reset; fun_hysteria ;;
        9|09)  tput reset; menu ;;
        0|00)  tput reset; echo -e "\033[1;31mSaliendo...\033[0m"; sleep 1; exit ;;
        *)     echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1 ;;
        esac
    done
}
tput reset; clear
fun_conexao
