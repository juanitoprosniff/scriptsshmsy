}

# ── Instalar Dropbear normal con fix Ubuntu 22+ ──────────────
_instalar_dropbear_normal() {
    local porta="$1"
    apt-get update -y >/dev/null 2>&1
    apt-get install dropbear -y >/dev/null 2>&1

    # Ubuntu 22+ usa dropbear.conf en lugar de /etc/default/dropbear con NO_START
    if [[ -f /etc/default/dropbear ]]; then
        # Habilitar servicio (quitar NO_START)
        sed -i 's/NO_START=1/NO_START=0/' /etc/default/dropbear 2>/dev/null
        sed -i 's/^#NO_START/NO_START/' /etc/default/dropbear 2>/dev/null
        _dropbear_set_port "$porta"
    fi

    # Asegurarse que no haya bandera de deshabilitado en systemd
    systemctl unmask dropbear 2>/dev/null
    systemctl enable dropbear 2>/dev/null

    # Iniciar con reintentos
    service dropbear start 2>/dev/null || systemctl start dropbear 2>/dev/null

    sleep 1
    if _check_proc 'dropbear'; then
        _abrir_puerto_fw $porta tcp
        echo -e "\n\033[1;32mDROPBEAR INSTALADO! PUERTO: $porta\033[0m"
    else
        echo -e "\n\033[1;31mError al iniciar Dropbear. Verificando...\033[0m"
        _fix_dropbear_ubuntu22 "$porta"
    fi
    sleep 2; fun_conexao
}

# ── Fix Dropbear en Ubuntu 22/24 ─────────────────────────────
# Problema: systemd usa socket activation y el binario cambia de ruta
_fix_dropbear_ubuntu22() {
    local porta="$1"
    # Ubuntu 22+ puede tener dropbear como socket-activated
    if [[ -f /lib/systemd/system/dropbear.socket ]]; then
        sed -i "s/ListenStream=.*/ListenStream=$porta/" /lib/systemd/system/dropbear.socket 2>/dev/null
        sed -i "s/ListenStream=.*/ListenStream=$porta/" /etc/systemd/system/dropbear.socket 2>/dev/null
        systemctl daemon-reload 2>/dev/null
        systemctl enable dropbear.socket 2>/dev/null
        systemctl start dropbear.socket 2>/dev/null
    fi
    # Verificar si hay servicio override
    mkdir -p /etc/systemd/system/dropbear.service.d/
    cat > /etc/systemd/system/dropbear.service.d/override.conf <<EOF
[Service]
ExecStart=
ExecStart=/usr/sbin/dropbear -F -p $porta
EOF
    systemctl daemon-reload 2>/dev/null
    systemctl restart dropbear 2>/dev/null
    sleep 1
    if _check_proc 'dropbear'; then
        _abrir_puerto_fw $porta tcp
        echo -e "\033[1;32mDropbear activo (modo fix Ubuntu 22+), PUERTO: $porta\033[0m"
    else
        echo -e "\033[1;31mNo se pudo iniciar Dropbear. Use la versión 2016.74 como alternativa.\033[0m"
    fi
}

# ── Cambiar puerto de Dropbear (compatible Ubuntu 18-25) ─────
_dropbear_set_port() {
    local pt="$1"
    # Método 1: /etc/default/dropbear
    if [[ -f /etc/default/dropbear ]]; then
        if grep -q "DROPBEAR_PORT" /etc/default/dropbear; then
            var1=$(grep 'DROPBEAR_PORT=' /etc/default/dropbear | cut -d'=' -f2)
            sed -i "s/DROPBEAR_PORT=$var1/DROPBEAR_PORT=$pt/" /etc/default/dropbear 2>/dev/null
        else
            echo "DROPBEAR_PORT=$pt" >> /etc/default/dropbear
        fi
        if grep -q "DROPBEAR_EXTRA_ARGS" /etc/default/dropbear; then
            sed -i "s/-p [0-9]*/-p $pt/" /etc/default/dropbear 2>/dev/null
        fi
    fi
    # Método 2: override systemd
    if [[ -d /etc/systemd/system/dropbear.service.d ]]; then
        sed -i "s/-p [0-9]*/-p $pt/" /etc/systemd/system/dropbear.service.d/override.conf 2>/dev/null
        systemctl daemon-reload 2>/dev/null
    fi
    # Método 3: socket unit
    if [[ -f /lib/systemd/system/dropbear.socket ]]; then
        sed -i "s/ListenStream=.*/ListenStream=$pt/" /lib/systemd/system/dropbear.socket 2>/dev/null
        systemctl daemon-reload 2>/dev/null
    fi
    service dropbear restart 2>/dev/null || systemctl restart dropbear 2>/dev/null
}

fun_inst_dropbear2016() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m        INSTALAR DROPBEAR 2016.74        \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\n\033[1;33mCompilación: ~2-3 minutos.\033[0m"
    echo -ne "\033[1;32mPUERTO (defecto 90): \033[1;37m"; read porta_db16; [[ -z "$porta_db16" ]] && porta_db16=90
    verif_ptrs $porta_db16
    echo -e "\n\033[1;32mINSTALANDO DEPENDENCIAS...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y make gcc wget >/dev/null 2>&1
    GCC_VER=$(gcc -dumpversion 2>/dev/null | cut -d. -f1)
    compilar_dropbear2016() {
        cd /usr/src
        if [[ ! -f dropbear-2016.74.tar.bz2 ]]; then
            echo -e "\033[1;33mDescargando Dropbear 2016.74...\033[0m"
            wget -q https://github.com/juanitoprosniff/script_msyvpn/raw/refs/heads/main/installer/dropbear-2016.74.tar.bz2
            [[ ! -f dropbear-2016.74.tar.bz2 ]] && { echo -e "\033[1;31mError al descargar!\033[0m"; return 1; }
        fi
        rm -rf dropbear-2016.74 2>/dev/null
        tar xjf dropbear-2016.74.tar.bz2 2>/dev/null
        [[ ! -d dropbear-2016.74 ]] && { echo -e "\033[1;31mError al extraer!\033[0m"; return 1; }
        cd dropbear-2016.74
        for f in sysoptions.h default_options.h; do
            [[ -f "$f" ]] && sed -i 's|#define LOCAL_IDENT.*|#define LOCAL_IDENT "SSH-2.0-DropbearVPN"|' "$f" 2>/dev/null
        done
        EXTRA_CFLAGS=""
        if [[ "${GCC_VER:-0}" -ge 12 ]]; then
            EXTRA_CFLAGS="-Wno-error=implicit-function-declaration -Wno-error=implicit-int -Wno-error=int-conversion"
            echo -e "\033[1;33mAplicando CFLAGS para GCC $GCC_VER\033[0m"
        fi
        export CFLAGS="$EXTRA_CFLAGS"
        ./configure --prefix=/opt/dropbear-2016 --disable-zlib --disable-wtmp --disable-lastlog >/dev/null 2>&1
        echo -e "\033[1;33mCompilando... espere...\033[0m"
        if ! make -j$(nproc) PROGRAMS="dropbear dropbearkey" CFLAGS="$EXTRA_CFLAGS" >/dev/null 2>&1; then
            echo -e "\033[1;31mError en make!\033[0m"; cd /root; unset CFLAGS; return 1
        fi
        make install PROGRAMS="dropbear dropbearkey" >/dev/null 2>&1
        unset CFLAGS
