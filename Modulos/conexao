# ── Menú de gestión V2Ray (ya instalado) ─────────────────────
_v2ray_manage() {
    local _uuid
    _uuid=$(_v2ray_get_uuid)
    local _ws_path
    _ws_path=$(grep -oP '"path":\s*"\K[^"]+' "$_V2RAY_CONFIG" 2>/dev/null | head -1)
    [[ -z "$_ws_path" ]] && _ws_path="/v2ray"

    local _v2sts="\033[1;31m✕ INACTIVO"
    _v2ray_is_running && _v2sts="\033[1;32m✓ ACTIVO"

    local _bridge_sts="\033[1;31m✕"
    ss -tlpn 2>/dev/null | grep -q "python" && _bridge_sts="\033[1;32m✓"

    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           GESTIONAR V2RAY               \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\033[0;34m╼ \033[1;33mV2RAY CORE  : $_v2sts"
    echo -e "\033[0;34m╼ \033[1;33mBRIDGE PY   : $_bridge_sts"
    echo -e "\033[0;34m╼ \033[1;33mUUID        : \033[1;37m$_uuid"
    echo -e "\033[0;34m╼ \033[1;33mWS PATH     : \033[1;37m$_ws_path"
    echo -e "\033[0;34m╼ \033[1;33mPUERTOS HTTP: \033[1;37m80, 8080, 8880, 8888 (sin TLS)"
    echo -e "\033[0;34m╼ \033[1;33mPUERTOS SSL : \033[1;37m443, 444, 8443 (con TLS via stunnel)"
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mINICIAR/REINICIAR V2RAY             \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mDETENER V2RAY                       \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mCAMBIAR WS PATH                     \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mREGENERAR UUID                      \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mINICIAR BRIDGE SIN TLS              \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m6\033[1;31m] \033[1;33mVER LINKS DE CONEXIÓN               \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m7\033[1;31m] \033[1;33mACTUALIZAR DISPATCHER SSL           \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m8\033[1;31m] \033[1;33mELIMINAR V2RAY                      \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                              \033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read resp_v2

    case "$resp_v2" in
    1)
        systemctl restart v2ray 2>/dev/null || \
        systemctl start v2ray 2>/dev/null
        sleep 1
        _v2ray_is_running && \
            echo -e "\n\033[1;32m✓ V2Ray reiniciado!\033[0m" || \
            echo -e "\n\033[1;31m✗ Error al iniciar. Revise: journalctl -u v2ray -n 20\033[0m"
        sleep 2; _v2ray_manage ;;
    2)
        systemctl stop v2ray 2>/dev/null
        echo -e "\n\033[1;32mV2Ray detenido.\033[0m"; sleep 2; _v2ray_manage ;;
    3)
        echo -ne "\n\033[1;32mNUEVO WS PATH (ej: /v2ray): \033[1;37m"; read _new_path
        [[ -z "$_new_path" ]] && { _v2ray_manage; return; }
        [[ "${_new_path:0:1}" != "/" ]] && _new_path="/$_new_path"
        _v2ray_write_config "$_uuid" "$_new_path" "$_V2RAY_CORE_PORT"
        systemctl restart v2ray 2>/dev/null
        # Actualizar ssldispatcher con nuevo path
        sed -i "s|V2RAY_WS_PATHS = \[.*\]|V2RAY_WS_PATHS = ['${_new_path}', '/vmess', '/vless', '/ws']|" \
            /etc/SSHPlus/ssldispatcher.py 2>/dev/null
        echo -e "\n\033[1;32mWS PATH cambiado a: $_new_path\033[0m"; sleep 2; _v2ray_manage ;;
    4)
        local _new_uuid
        _new_uuid=$(_v2ray_gen_uuid)
        _v2ray_write_config "$_new_uuid" "$_ws_path" "$_V2RAY_CORE_PORT"
        systemctl restart v2ray 2>/dev/null
        echo -e "\n\033[1;32mNuevo UUID: $_new_uuid\033[0m"; sleep 3; _v2ray_manage ;;
    5)
        # Iniciar bridge Python en puertos sin TLS (comparte con wsproxy)
        _v2ray_install_bridge
        echo -e "\n\033[1;33mPuertos sin TLS para V2Ray bridge:\033[0m"
        echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mPuerto 80"
        echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mPuerto 8080"
        echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mPuerto 8880"
        echo -e "\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mPuerto 8888"
        echo -e "\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mTODOS (80, 8080, 8880, 8888)"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read _p_sel
        case "$_p_sel" in
        1) _v2_ports="80" ;; 2) _v2_ports="8080" ;; 3) _v2_ports="8880" ;;
        4) _v2_ports="8888" ;; 5) _v2_ports="80 8080 8880 8888" ;;
        *) _v2_ports="80 8080" ;;
        esac
        # NOTA: wsproxy detecta automáticamente tráfico V2Ray WS
        # y lo reenvía al bridge. El bridge no necesita su propio puerto
        # de escucha externo — V2Ray core escucha en 127.0.0.1:10085.
        # Aquí iniciamos el bridge solo si se quiere separado de wsproxy.
        sed -i '/v2ray_manager/d' /etc/autostart 2>/dev/null
        for _vp in $_v2_ports; do
            screen -dmS "v2ray${_vp}" python3 "$_V2RAY_SCRIPT" "$_vp" "127.0.0.1:${_V2RAY_CORE_PORT}"
            echo "ss -tlpn | grep -qw $_vp || screen -dmS v2ray${_vp} python3 $_V2RAY_SCRIPT $_vp 127.0.0.1:${_V2RAY_CORE_PORT}" >> /etc/autostart
            _fw_open $_vp
            echo -e "\033[1;32mBridge V2Ray puerto \033[1;37m$_vp \033[1;32mactivado ✓\033[0m"
            sleep 0.3
        done
        sleep 2; _v2ray_manage ;;
    6)
        _v2ray_show_links "$_uuid" "$_ws_path"
        echo -ne "\n\033[1;33mPresione ENTER para continuar...\033[0m"; read
        _v2ray_manage ;;
    7)
        # Actualizar ssldispatcher para incluir backend V2Ray
        local _v2_backend="127.0.0.1:${_V2RAY_CORE_PORT}"
        local _ws_auto
        _ws_auto=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
                   grep -v ":${_SSL_DISP_PORT} " | \
                   awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
        [[ -z "$_ws_auto" ]] && _ws_auto=80
        _ssl_disp_get_targets 2>/dev/null
        [[ -z "$_DISP_SSH" ]] && _DISP_SSH="127.0.0.1:143"
        [[ -z "$_DISP_WS" ]]  && _DISP_WS="127.0.0.1:${_ws_auto}"

        # Matar dispatcher actual y reiniciar con V2Ray backend
        for pid in $(screen -ls 2>/dev/null | grep '\.ssldispatch' | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "ssldispatcher.py" 2>/dev/null
        screen -wipe >/dev/null 2>&1
        sleep 0.5

        screen -dmS ssldispatch python3 "$_SSL_DISP_SCRIPT" \
            "$_SSL_DISP_PORT" "$_DISP_SSH" "$_DISP_WS" "$_v2_backend"
        sleep 1

        # Actualizar autostart
        sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
        echo "ss -tlpn | grep -qw ${_SSL_DISP_PORT} || screen -dmS ssldispatch python3 ${_SSL_DISP_SCRIPT} ${_SSL_DISP_PORT} ${_DISP_SSH} ${_DISP_WS} ${_v2_backend}" >> /etc/autostart

        if ss -tlpn 2>/dev/null | grep -q ":${_SSL_DISP_PORT} "; then
            echo -e "\n\033[1;32m✓ Dispatcher SSL actualizado con V2Ray backend!\033[0m"
            echo -e "\033[1;37m  SSH  → \033[1;32m$_DISP_SSH"
            echo -e "\033[1;37m  WS   → \033[1;32m$_DISP_WS"
            echo -e "\033[1;37m  V2Ray→ \033[1;35m$_v2_backend\033[0m"
        else
            echo -e "\n\033[1;31m✗ Dispatcher no respondió. Verifique ssldispatcher.py\033[0m"
        fi
        sleep 3; _v2ray_manage ;;
    8)
        echo -ne "\n\033[1;31m¿Confirmar eliminación de V2Ray? [s/N]: \033[1;37m"; read _confirm
        [[ "$_confirm" != "s" && "$_confirm" != "S" ]] && { _v2ray_manage; return; }
        systemctl stop v2ray 2>/dev/null
        systemctl disable v2ray 2>/dev/null
        for pid in $(screen -ls 2>/dev/null | grep '\.v2ray' | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "v2ray_manager.py" 2>/dev/null
        sed -i '/v2ray/d' /etc/autostart 2>/dev/null
        echo -e "\n\033[1;32mV2Ray eliminado!\033[0m"; sleep 2; fun_conexao ;;
    0) fun_conexao ;;
    *) echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1; _v2ray_manage ;;
    esac
}

# ── Menú de instalación inicial de V2Ray ─────────────────────
fun_v2ray() {
    if _v2ray_is_installed; then
        _v2ray_manage
        return
    fi

    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           INSTALAR V2RAY                \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""
    echo -e "\033[1;33mProtocolos : \033[1;37mVMess + VLess"
    echo -e "\033[1;33mTransporte : \033[1;37mWebSocket + TCP"
    echo -e "\033[1;33mSin TLS    : \033[1;37mPuertos 80, 8080, 8880, 8888 (comparte wsproxy)"
    echo -e "\033[1;33mCon TLS    : \033[1;37mPuertos 443, 444, 8443 (comparte stunnel)"
    echo -e "\033[1;33mSNI        : \033[1;37mDefault SNI + Reverse SNI/Bug as address"
    echo ""

    echo -ne "\033[1;32mNUEVO WS PATH (ENTER = /v2ray): \033[1;37m"; read _ws_path_in
    [[ -z "$_ws_path_in" ]] && _ws_path_in="/v2ray"
    [[ "${_ws_path_in:0:1}" != "/" ]] && _ws_path_in="/$_ws_path_in"

    echo ""
    echo -e "\033[1;33mInstalando V2Ray... (puede tardar 1-2 minutos)\033[0m"
    if ! _v2ray_install_core; then
        sleep 3; fun_conexao; return
    fi

    # Generar UUID y configurar
    local _uuid
    _uuid=$(_v2ray_gen_uuid)
    mkdir -p /etc/v2ray /var/log/v2ray

    _v2ray_write_config "$_uuid" "$_ws_path_in" "$_V2RAY_CORE_PORT"
    _v2ray_install_bridge

    # Habilitar y arrancar V2Ray
    systemctl enable v2ray >/dev/null 2>&1
    systemctl restart v2ray >/dev/null 2>&1
    sleep 2

    # Abrir firewall para puertos V2Ray (sin TLS)
    # NOTA: los puertos ya están abiertos por wsproxy y stunnel
    # Solo necesitamos asegurarnos del core port local (no público)
    _fw_open $_V2RAY_CORE_PORT tcp 2>/dev/null || true

    # Actualizar ssldispatcher SSL con backend V2Ray si stunnel está activo
    if [[ -f /etc/stunnel/stunnel.conf ]]; then
        echo -e "\033[1;33mActualizando dispatcher SSL con V2Ray...\033[0m"
        _ssl_disp_get_targets 2>/dev/null
        [[ -z "$_DISP_SSH" ]] && _DISP_SSH="127.0.0.1:143"
        [[ -z "$_DISP_WS"  ]] && _DISP_WS="127.0.0.1:80"

        for pid in $(screen -ls 2>/dev/null | grep '\.ssldispatch' | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "ssldispatcher.py" 2>/dev/null
        screen -wipe >/dev/null 2>&1
        sleep 0.5

        screen -dmS ssldispatch python3 "$_SSL_DISP_SCRIPT" \
            "$_SSL_DISP_PORT" "$_DISP_SSH" "$_DISP_WS" "127.0.0.1:${_V2RAY_CORE_PORT}"
        sleep 1

        sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
        echo "ss -tlpn | grep -qw ${_SSL_DISP_PORT} || screen -dmS ssldispatch python3 ${_SSL_DISP_SCRIPT} ${_SSL_DISP_PORT} ${_DISP_SSH} ${_DISP_WS} 127.0.0.1:${_V2RAY_CORE_PORT}" >> /etc/autostart
        echo -e "\033[1;32m✓ Dispatcher SSL actualizado con V2Ray backend\033[0m"
    fi

    echo ""
    if _v2ray_is_running; then
        echo -e "\033[1;32m✓ V2RAY INSTALADO Y ACTIVO!\033[0m"
    else
        echo -e "\033[1;31m✗ V2Ray instalado pero no inició. Revise: journalctl -u v2ray -n 20\033[0m"
    fi

    sleep 2
    _v2ray_show_links "$_uuid" "$_ws_path_in"
    echo -ne "\n\033[1;33mPresione ENTER para ir al menú de gestión...\033[0m"; read
    _v2ray_manage
}

