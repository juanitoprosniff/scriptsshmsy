    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVolver                           \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read _hopt
    [[ "$_hopt" != "1" ]] && { fun_conexao; return; }

    # Puerto (rango 20000-39999)
    local _hys_port=36712
    echo -ne "\n\033[1;32mPuerto Hysteria (20000-39999, defecto 36712): \033[1;37m"; read _inp
    [[ -n "$_inp" ]] && _hys_port="$_inp"
