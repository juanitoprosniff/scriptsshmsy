        echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                   \033[0;34mв”ѓ"
        echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read opc
