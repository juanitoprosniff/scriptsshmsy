# в”Ђв”Ђ Parche OpenSSH para clientes LEGACY (apps de tunelizaciГіn viejas) в”Ђв”Ђ
_patch_openssh_legacy() {
    local pt="${1:-22}"
    local _sshd_cfg="/etc/ssh/sshd_config"
    cp $_sshd_cfg ${_sshd_cfg}.bak 2>/dev/null

    # Agregar bloque de compatibilidad si no existe
    if ! grep -q "# LEGACY COMPAT" $_sshd_cfg; then
        cat >> $_sshd_cfg <<'EOF'

# LEGACY COMPAT вЂ” agregado por SSHMSY para clientes antiguos
HostKeyAlgorithms +ssh-rsa,ssh-dss
PubkeyAcceptedAlgorithms +ssh-rsa,ssh-dss
KexAlgorithms +diffie-hellman-group14-sha1,diffie-hellman-group1-sha1
Ciphers +aes256-cbc,aes128-cbc,3des-cbc,blowfish-cbc
MACs +hmac-sha1,hmac-md5
EOF
    fi
    _restart_ssh
    echo -e "\033[1;32mвњ“ OpenSSH configurado para clientes legacy!\033[0m"
}

# в”Ђв”Ђ SSH Relay/Proxy вЂ” OpenSSH en modo relay в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
_fun_ssh_relay() {
    clear
    echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
    echo -e "\033[0;34mв”ѓ\E[44;1;37m       SSH RELAY / PROXY TRANSPARENTE        \E[0m\033[0;34mв”ѓ"
    echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
    echo -e "\033[1;37mвЂў Puerto extra que redirige al SSH principal\033[0m"
    echo -e "\033[1;37mвЂў Гљtil para esquivar bloqueos de puertos\033[0m"
    echo -e "\033[1;37mвЂў Usa socat (sin instalar otro servidor)\033[0m"
    echo ""

    # Mostrar relays activos
    local _relays=$(grep 'socat.*tcp-listen' /etc/autostart 2>/dev/null | grep -oP '\d+(?=,fork)')
    [[ -n "$_relays" ]] && echo -e "\033[1;33mRelays activos en puertos: \033[1;37m$_relays\033[0m\n"

    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mCREAR RELAY       \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR RELAY    \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mCOMPAT LEGACY SSH \033[0;34mв”ѓ"
    echo -e "\033[0;34mв”ѓ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER            \033[0;34mв”ѓ"
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read r_opt

    case "$r_opt" in
    1)
        apt-get install -y socat >/dev/null 2>&1
        echo -ne "\033[1;32mPUERTO RELAY (externo): \033[1;37m"; read r_ext
        echo -ne "\033[1;32mPUERTO DESTINO SSH (defecto 22): \033[1;37m"; read r_dst; [[ -z "$r_dst" ]] && r_dst=22
        [[ -z "$r_ext" ]] && { fun_alt_ssh; return; }
        verif_ptrs $r_ext
        screen -dmS "relay${r_ext}" socat TCP-LISTEN:${r_ext},fork TCP:127.0.0.1:${r_dst} &
        echo "screen -ls | grep -q relay${r_ext} || screen -dmS relay${r_ext} socat TCP-LISTEN:${r_ext},fork TCP:127.0.0.1:${r_dst}" >> /etc/autostart
        _fw_open $r_ext
        echo -e "\n\033[1;32mвњ“ Relay activo: $r_ext в†’ 127.0.0.1:$r_dst\033[0m"; sleep 2; _fun_ssh_relay ;;
    2)
        echo -ne "\033[1;32mPUERTO RELAY A ELIMINAR: \033[1;37m"; read r_del
        for pid in $(screen -ls 2>/dev/null | grep "relay${r_del}" | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        sed -i "/relay${r_del}/d" /etc/autostart 2>/dev/null
        echo -e "\n\033[1;32mRelay $r_del eliminado!\033[0m"; sleep 2; _fun_ssh_relay ;;
    3)
        echo -ne "\033[1;32mAplicar compatibilidad legacy a OpenSSH? [s/n]: \033[1;37m"; read _lp
        [[ "$_lp" = 's' ]] && { _patch_openssh_legacy; echo -e "\n\033[1;32mвњ“ Parche aplicado!\033[0m"; sleep 2; }
        _fun_ssh_relay ;;
    0) fun_alt_ssh ;;
    esac
}

