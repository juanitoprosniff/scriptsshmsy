# ── CAMBIAR DESTINO SSH (sin cambiar modo) ────────────────────
_cambiar_destino_ssl() {
    local modo="$1"
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m          CAMBIAR DESTINO SSH            \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\n\033[1;37mModo actual: $modo\033[0m\n"
    _seleccionar_destino_ssh || return
    local nuevo_dst="$_SSH_DST_PORT"

    if [[ "$modo" = "SSL+WEBSOCKET" ]]; then
        # Cambiar solo el destino del wsproxy (stunnel sigue apuntando a wsproxy)
        local _ws_p=$(_get_wsproxy_port)
        [[ -z "$_ws_p" ]] && _ws_p=80

        # Parar wsproxy actual
        for pid in $(screen -ls 2>/dev/null | grep "ws${_ws_p}" | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        pkill -f "wsproxy.py $_ws_p" 2>/dev/null
        sleep 0.5

        # Relanzar con nuevo destino
        screen -dmS "ws${_ws_p}" python3 /etc/SSHPlus/wsproxy.py \
            $_ws_p "127.0.0.1:${nuevo_dst}"

        # Actualizar autostart
        sed -i "/wsproxy.py $_ws_p/d" /etc/autostart 2>/dev/null
        echo "ss -tlpn | grep -qw $_ws_p || screen -dmS ws${_ws_p} python3 /etc/SSHPlus/wsproxy.py $_ws_p 127.0.0.1:${nuevo_dst}" >> /etc/autostart

        # Actualizar estado
        sed -i '3d' /etc/stunnel/.ssl_mode 2>/dev/null
        echo "$nuevo_dst" >> /etc/stunnel/.ssl_mode

        echo -e "\n\033[1;32m✓ wsproxy ahora apunta a SSH:${nuevo_dst}\033[0m"
        echo -e "\033[1;37mFlujo: stunnel → wsproxy:${_ws_p} → SSH:${nuevo_dst}\033[0m"
    else
        # Modo DIRECTO: reemplazar connect en stunnel.conf
        sed -i "s|connect = 127.0.0.1:[0-9]*|connect = 127.0.0.1:${nuevo_dst}|g" \
            /etc/stunnel/stunnel.conf 2>/dev/null
        sed -i '2d' /etc/stunnel/.ssl_mode 2>/dev/null
        echo "$nuevo_dst" >> /etc/stunnel/.ssl_mode
        systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
        echo -e "\n\033[1;32m✓ stunnel ahora apunta a SSH:${nuevo_dst}\033[0m"
    fi
    sleep 2; inst_ssl
}

# ── Arrancar stunnel y abrir puertos ─────────────────────────
_arrancar_stunnel() {
    if systemctl is-enabled stunnel4 >/dev/null 2>&1; then
        systemctl enable stunnel4 >/dev/null 2>&1
        systemctl restart stunnel4 >/dev/null 2>&1
    else
        service stunnel4 restart >/dev/null 2>&1
    fi

    for _sslp in 443 444 8443; do
        _fw_open $_sslp
        iptables -I INPUT -p tcp --dport $_sslp -j ACCEPT 2>/dev/null
    done
    sleep 1

    if ss -tlpn 2>/dev/null | grep -q ":443 "; then
        echo -e "\033[1;32m✓ stunnel activo en 443, 444, 8443\033[0m"
        if ! ss -tlpn 2>/dev/null | grep -q ":444 "; then
            echo -e "\033[1;33m⚠ Puerto 444 puede estar bloqueado por el proveedor.\033[0m"
        fi
    else
        echo -e "\033[1;33mVerifique: systemctl status stunnel4\033[0m"
    fi
}

