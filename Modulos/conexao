_fun_nginx_remover() {
    echo -ne "\033[1;31m¿Eliminar configuración nginx multiplex? [s/n]: \033[1;37m"; read _conf
    [[ "$_conf" != 's' ]] && { fun_nginx_multiplex; return; }
    rm -f /etc/nginx/stream.d/multiplex.conf
    # Quitar el bloque stream del nginx.conf si está vacío
    sed -i '/^stream {/,/^}/{ /include.*stream.d/d }' /etc/nginx/nginx.conf 2>/dev/null
    nginx -t >/dev/null 2>&1 && systemctl reload nginx 2>/dev/null
    rm -f /etc/SSHPlus/nginx_mux_info
    echo -e "\033[1;32mConfiguración eliminada.\033[0m"; sleep 2; fun_nginx_multiplex
}

