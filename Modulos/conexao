# HYSTERIA UDP MANAGER
# ============================================================
fun_hysteria() {
    clear
    echo -e "\E[38;5;18m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\E[38;5;18m┃\E[44;1;37m          HYSTERIA UDP MANAGER           \E[0m\E[38;5;18m┃"
    echo -e "\E[38;5;18m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    if command -v hysteria-manager &>/dev/null; then
        echo -e "\033[1;32mHysteria UDP ya instalado. Abriendo manager...\033[0m"
        sleep 1; hysteria-manager; return
    fi
    echo -e "\E[38;5;196m|\E[38;5;33m01\E[38;5;196m|\033[1;37m➜ \E[38;5;195mINSTALAR HYSTERIA UDP"
    echo -e "\E[38;5;196m|\E[38;5;33m00\E[38;5;196m|\033[1;37m➜ \E[38;5;195mVOLVER"
    echo ""
    echo -ne "\033[1;32mQUÉ DESEA HACER \033[1;37m?\033[1;31m?\033[1;37m : "; read opc
    [[ "$opc" != '1' && "$opc" != '01' ]] && { fun_conexao; return; }
    echo -e "\n\033[1;32mInstalando Hysteria UDP Manager...\033[0m"
    BASE_URL="https://raw.githubusercontent.com/juanitoprosniff/script_msyvpn/main/installer"
    wget -q -O /root/install_agnudp.sh  "$BASE_URL/install_agnudp.sh"  2>/dev/null
    wget -q -O /root/agnudp_manager.sh  "$BASE_URL/agnudp_manager.sh"  2>/dev/null
    if [[ -f /root/install_agnudp.sh ]] && [[ -f /root/agnudp_manager.sh ]]; then
        chmod +x /root/install_agnudp.sh /root/agnudp_manager.sh
        bash /root/install_agnudp.sh
        cp /root/agnudp_manager.sh /usr/local/bin/hysteria-manager
        chmod +x /usr/local/bin/hysteria-manager
        echo -e "\n\033[1;32m✓ Hysteria UDP instalado con éxito!\033[0m"
        sleep 1; hysteria-manager
    else
        echo -e "\n\033[1;31m⚠ No fue posible descargar Hysteria UDP.\033[0m"
        echo -e "\033[1;33mVerifique su conexión a internet.\033[0m"
        sleep 3; fun_conexao
    fi
}

# ============================================================
# MENÚ PRINCIPAL DE CONEXIÓN
# ============================================================
x="ok"; clear
fun_conexao() {
    while true; do
        clear

        # ── Puertos activos ───────────────────────────────────
        _ssh_ports=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | xargs)
        _ws_pts=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs | tr ' ' ',')
        _ssl_pts=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs | tr ' ' ',')
        _udp_pts=$(ss -ulpn 2>/dev/null | grep -E 'udpvpn|badvpn' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs | tr ' ' ',')
        _hyst_pts=$(ss -ulpn 2>/dev/null | grep 'hysteria' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs | tr ' ' ',')

        _db16_on=0
        screen -list 2>/dev/null | grep -q 'dropbear2016' && _db16_on=1
        systemctl is-active dropbear-legacy >/dev/null 2>&1 && _db16_on=1
        [[ "$_db16_on" != '0' ]] && {
            _db16_port=$(systemctl show dropbear-legacy --property=ExecStart 2>/dev/null | grep -oP '(?<=-p )\d+' | head -1)
            [[ -z "$_db16_port" ]] && _db16_port=$(screen -list 2>/dev/null | grep 'dropbear2016' | grep -oP '\d+(?=\.dropbear2016)' | head -1)
        }

        # ── Status para el menú ───────────────────────────────
        [[ -n "$_ws_pts" ]] && sts4="\033[1;32m✓ " || sts4="\033[1;31m✕ "
        [[ -e "/etc/stunnel/stunnel.conf" ]] && sts3="\033[1;32m✓ " || sts3="\033[1;31m✕ "
        [[ "$_db16_on" != '0' ]] && db16sts="\033[1;32m✓ " || db16sts="\033[1;31m✕ "
        stsu=$(ps x | grep "udpvpn\|badvpn" | grep -v grep >/dev/null && echo -e "\033[1;32m✓ " || echo -e "\033[1;31m✕ ")
        stshy=$(command -v hysteria-manager &>/dev/null && echo -e "\033[1;32m✓ " || echo -e "\033[1;31m✕ ")

        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m       MSY VPN SCRIPT — CONEXIÓN         \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"

        # Puertos activos resumen
        echo -e "\033[1;32mOPENSSH\033[1;31m : \033[1;37m${_ssh_ports:-22}   \033[1;33mARCH: \033[1;32m${_ARCH}\033[0m"
        [[ "$_db16_on" != '0' && -n "$_db16_port" ]] && \
            echo -e "\033[1;32mDROPBEAR\033[1;31m: \033[1;37m$_db16_port"
        [[ -n "$_ws_pts"   ]] && echo -e "\033[1;32mWEBSOCKET\033[1;31m: \033[1;37m$_ws_pts"
        [[ -n "$_ssl_pts"  ]] && echo -e "\033[1;32mSSL      \033[1;31m: \033[1;37m$_ssl_pts"
        [[ -n "$_udp_pts"  ]] && echo -e "\033[1;32mBAD VPN  \033[1;31m: \033[1;37m$_udp_pts (UDP)"
        [[ -n "$_hyst_pts" ]] && echo -e "\033[1;32mHYSTERIA \033[1;31m: \033[1;37m$_hyst_pts (UDP)"

        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m01\033[1;31m] \033[1;33mOPENSSH                              \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m02\033[1;31m] \033[1;33mPROXY SOCKS / WEBSOCKET $sts4         \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m03\033[1;31m] \033[1;33mSSL TUNNEL $sts3                      \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m04\033[1;31m] \033[1;33mDROPBEAR 2016 $db16sts                 \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m05\033[1;31m] \033[1;33mBAD VPN $stsu                          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m06\033[1;31m] \033[1;33mHYSTERIA UDP MANAGER $stshy            \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m07\033[1;31m] \033[1;33mVOLVER \033[1;32m<<<                          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m00\033[1;31m] \033[1;33mSALIR \033[1;32m<<<                            \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        tput civis
        echo -ne "\033[1;32mOpción: \033[1;37m"; read x
        tput cnorm
        case $x in
        1|01)  tput reset; fun_openssh ;;
        2|02)  tput reset; fun_socks ;;
        3|03)  tput reset; inst_ssl ;;
        4|04)  tput reset; fun_inst_dropbear2016 ;;
        5|05)  tput reset; fun_badvpn ;;
        6|06)  tput reset; fun_hysteria ;;
        7|07)  tput reset; menu ;;
        0|00)  tput reset; echo -e "\033[1;31mSaliendo...\033[0m"; sleep 1; exit ;;
        *)     echo -e "\033[1;31mOpción inválida!\033[0m"; sleep 1 ;;
        esac
    done
}
tput reset; clear
fun_conexao
