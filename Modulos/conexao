        echo -e "\033[0;34mв”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ӣ\033[0m"
        systemctl is-active zivpn >/dev/null 2>&1 && \
            _zvst="\033[1;32mвң“ ACTIVO" || _zvst="\033[1;31mвң• INACTIVO"
        echo -e "\033[1;33mEstado       : $_zvst\033[0m"
        echo -e "\033[1;33mArquitectura : \033[1;37m$_ARCH [$_ARCH_TAG]\033[0m"
        [[ -f "$_ZIVPN_CFG" ]] && {
            local _zport; _zport=$(grep -oP '"port":\s*\K\d+' "$_ZIVPN_CFG" 2>/dev/null | head -1)
            [[ -n "$_zport" ]] && echo -e "\033[1;33mPuerto UDP   : \033[1;37m$_zport"
        }
        echo -e "\033[0;34mв”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”“\033[0m"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mINSTALAR UDP ZiVPN            \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mCONFIGURAR (puerto/contraseГұa)\033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mINICIAR servicio              \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mREINICIAR servicio            \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mDETENER servicio              \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m6\033[1;31m] \033[1;33mDESINSTALAR                   \033[0;34mв”ғ"
        echo -e "\033[0;34mв”ғ\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                        \033[0;34mв”ғ"
        echo -e "\033[0;34mв”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ӣ\033[0m"
        echo -ne "\033[1;32mOpciГіn: \033[1;37m"; read _zopt

        case "$_zopt" in
        1) # в”Җв”Җ InstalaciГіn в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
            clear
            echo -e "\033[0;34mв”ғ\E[44;1;37m          INSTALAR UDP ZiVPN             \E[0m\033[0;34mв”ғ\n"
            echo -e "\033[1;33mArquitectura detectada: \033[1;32m$_ARCH [$_ARCH_TAG]\033[0m\n"

            # Seleccionar binario segГәn arquitectura
            local _zurl_base="https://github.com/zahidbd2/udp-zivpn/releases/download/udp-zivpn_1.4.9"
            case "$_ARCH_TAG" in
                arm64) _zbin_url="${_zurl_base}/udp-zivpn-linux-arm64" ;;
                arm)   _zbin_url="${_zurl_base}/udp-zivpn-linux-arm"   ;;
                *)     _zbin_url="${_zurl_base}/udp-zivpn-linux-amd64" ;;
            esac

            echo -e "\033[1;33mDescargando binario ZiVPN...\033[0m"
            systemctl stop zivpn 2>/dev/null
            wget -q --timeout=30 "$_zbin_url" -O "$_ZIVPN_BIN" 2>/dev/null || \
            curl -sL --max-time 30 "$_zbin_url" -o "$_ZIVPN_BIN" 2>/dev/null
            if [[ ! -s "$_ZIVPN_BIN" ]]; then
                echo -e "\033[1;31mвң— Error al descargar el binario.\033[0m"; sleep 3; continue
            fi
            chmod +x "$_ZIVPN_BIN"

            # Descargar config.json base
            mkdir -p /etc/zivpn
            wget -q --timeout=15 \
                "https://raw.githubusercontent.com/zahidbd2/udp-zivpn/main/config.json" \
                -O "$_ZIVPN_CFG" 2>/dev/null

            # Generar certificados SSL
            echo -e "\033[1;33mGenerando certificados SSL...\033[0m"
            openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
                -subj "/C=CO/ST=Colombia/L=Bogota/O=MSYVPN/CN=zivpn.local" \
                -keyout /etc/zivpn/zivpn.key \
                -out    /etc/zivpn/zivpn.crt >/dev/null 2>&1
            sysctl -w net.core.rmem_max=16777216 >/dev/null 2>&1
            sysctl -w net.core.wmem_max=16777216 >/dev/null 2>&1

            # Puerto UDP
            echo -ne "\n\033[1;32mPuerto UDP ZiVPN \033[1;37m[defecto: 7300]: \033[1;37m"; read _zport
            [[ -z "$_zport" ]] && _zport=7300

            # ContraseГұas
            echo -ne "\033[1;32mContraseГұas (ej: pass1,pass2) \033[1;37m[defecto: zi]: \033[1;37m"; read _zpasses
            [[ -z "$_zpasses" ]] && _zpasses="zi"

            # Aplicar puerto y contraseГұas al config.json
            if [[ -f "$_ZIVPN_CFG" ]]; then
                sed -i "s/\"port\": [0-9]*/\"port\": $_zport/" "$_ZIVPN_CFG" 2>/dev/null
                # Construir array de passwords
                local _zpass_arr
                _zpass_arr=$(echo "$_zpasses" | tr ',' '\n' | \
                             sed 's/^/"/;s/$/"/' | paste -sd ',' -)
                sed -i -E "s/\"config\": ?\[[^]]*\]/\"config\": [${_zpass_arr}]/" \
                    "$_ZIVPN_CFG" 2>/dev/null
            fi

            # Crear servicio systemd
            cat > "$_ZIVPN_SVC" <<ZISVC
[Unit]
Description=UDP ZiVPN Server вҖ” MSYVPN-SCRIPT
After=network.target

[Service]
Type=simple
ExecStart=${_ZIVPN_BIN} server --config ${_ZIVPN_CFG}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
ZISVC
            systemctl daemon-reload
            systemctl enable zivpn >/dev/null 2>&1
            systemctl start  zivpn

            # Abrir puerto UDP en firewall
            _fw_open $_zport udp
            iptables -I INPUT -p udp --dport $_zport -j ACCEPT 2>/dev/null

            sleep 1
            if systemctl is-active zivpn >/dev/null 2>&1; then
                echo -e "\n\033[1;32mвң“ UDP ZiVPN ACTIVO en puerto UDP $_zport!\033[0m"
                echo -e "\033[1;37m  Arquitectura: \033[1;32m$_ARCH_TAG"
                echo -e "\033[1;37m  ContraseГұas : \033[1;32m$_zpasses\033[0m"
            else
                echo -e "\n\033[1;33mVerifique: systemctl status zivpn\033[0m"
            fi
            sleep 3 ;;

        2) # в”Җв”Җ Reconfigurar puerto y contraseГұas в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
            [[ ! -f "$_ZIVPN_CFG" ]] && { echo -e "\033[1;31mInstale primero.\033[0m"; sleep 2; continue; }
            echo -ne "\033[1;32mNuevo puerto UDP \033[1;37m[actual: $(grep -oP '"port":\s*\K\d+' $_ZIVPN_CFG | head -1)]: \033[1;37m"; read _znp
            [[ -n "$_znp" ]] && sed -i "s/\"port\": [0-9]*/\"port\": $_znp/" "$_ZIVPN_CFG"
            echo -ne "\033[1;32mNuevas contraseГұas (ej: p1,p2): \033[1;37m"; read _znpass
            if [[ -n "$_znpass" ]]; then
                local _znpa; _znpa=$(echo "$_znpass" | tr ',' '\n' | sed 's/^/"/;s/$/"/' | paste -sd ',' -)
                sed -i -E "s/\"config\": ?\[[^]]*\]/\"config\": [${_znpa}]/" "$_ZIVPN_CFG" 2>/dev/null
            fi
            systemctl restart zivpn 2>/dev/null
            echo -e "\n\033[1;32mConfiguraciГіn actualizada y servicio reiniciado.\033[0m"; sleep 2 ;;

        3) systemctl start  zivpn && echo -e "\033[1;32mвң“ ZiVPN iniciado.\033[0m" || \
                                     echo -e "\033[1;31mвң— Error.\033[0m"; sleep 2 ;;
        4) systemctl restart zivpn && echo -e "\033[1;32mвң“ ZiVPN reiniciado.\033[0m" || \
                                      echo -e "\033[1;31mвң— Error.\033[0m"; sleep 2 ;;
        5) systemctl stop   zivpn && echo -e "\033[1;32mвң“ ZiVPN detenido.\033[0m" || \
                                     echo -e "\033[1;31mвң— Error.\033[0m"; sleep 2 ;;

        6) # в”Җв”Җ Desinstalar в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
            echo -ne "\033[1;31mВҝConfirmar desinstalaciГіn? [s/N]: \033[1;37m"; read _zdel
            [[ "$_zdel" =~ ^[sS]$ ]] && {
                systemctl stop    zivpn 2>/dev/null
                systemctl disable zivpn 2>/dev/null
                rm -f "$_ZIVPN_BIN" "$_ZIVPN_SVC"
                rm -rf /etc/zivpn
                systemctl daemon-reload
                echo -e "\033[1;32mвң“ ZiVPN desinstalado.\033[0m"
            }; sleep 2 ;;

        0) fun_conexao; return ;;
        *) echo -e "\033[1;31mOpciГіn invГЎlida!\033[0m"; sleep 1 ;;
        esac
    done
}

