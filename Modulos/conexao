		_chisel_on=$(_check_proc 'docker' && echo 1 || echo 0)
		[[ "$_chisel_on" = '1' ]] && chiselsts="\033[1;32mвњ“ " || chiselsts="\033[1;31mвњ• "
		echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mATIVAR/DESATIVAR CHISEL $chiselsts"
