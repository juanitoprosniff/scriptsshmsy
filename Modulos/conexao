	_fun_alterar_status() {
		local script_file="$1"; local titulo="$2"
		if ps x | grep -w "$script_file" | grep -v grep >/dev/null 2>&1; then
			msgsocks=$(grep -E "MSG =" /etc/SSHPlus/$script_file | awk -F= '{print $2}' | tr -d "' ")
			echo -e "\E[44;1;37m   STATUS вЂ” $titulo   \E[0m"
			echo -e "\n\033[1;33mSTATUS ATUAL: \033[1;32m$msgsocks\033[0m"
			echo -ne "\n\033[1;32mNOVO STATUS: \033[1;37m"; read msgg
			[[ -z "$msgg" ]] && { fun_conexao; return; }
			echo -e "\n\033[1;31m[01]\033[1;33m AZUL  [02]\033[1;33m VERDE  [03]\033[1;33m VERMELHO  [04]\033[1;33m AMARELO"
			echo -e "\033[1;31m[05]\033[1;33m ROSA  [06]\033[1;33m CIANO  [07]\033[1;33m LARANJA   [08]\033[1;33m ROXO"
			echo -e "\033[1;31m[09]\033[1;33m PRETO [10]\033[1;33m SEM COR\033[0m"
			echo -ne "\033[1;32mCOR: \033[1;37m"; read sts_cor
			case "$sts_cor" in
			1|01) cor_sts='blue' ;; 2|02) cor_sts='green' ;; 3|03) cor_sts='red' ;;
			4|04) cor_sts='yellow' ;; 5|05) cor_sts='#F535AA' ;; 6|06) cor_sts='cyan' ;;
			7|07) cor_sts='#FF7F00' ;; 8|08) cor_sts='#9932CD' ;; 9|09) cor_sts='black' ;;
			10) cor_sts='null' ;; *) cor_sts='null' ;;
			esac
			msgsocks2=$(grep "MSG =" /etc/SSHPlus/$script_file | awk -F= '{print $2}')
			sed -i "s/$msgsocks2/ '$msgg'/" /etc/SSHPlus/$script_file
			cor_old=$(grep 'color=' /etc/SSHPlus/$script_file | cut -d'"' -f2)
			sed -i "s/$cor_old/$cor_sts/" /etc/SSHPlus/$script_file
			echo -e "\n\033[1;32mSTATUS ALTERADO!\033[0m"; sleep 2; fun_socks
		else
			echo -e "\033[1;31mATIVE O $titulo PRIMEIRO!\033[0m"; sleep 2; fun_socks
		fi
	}

	# ============================================================
	# SSLH
	# ============================================================
	fun_sslh() {
		_sslh_run=$(ss -tlpn 2>/dev/null | grep -c 'sslh')
		[[ "$_sslh_run" = '0' ]] && {
			echo -e "\E[44;1;37m             INSTALAR SSLH               \E[0m\n"
			echo -ne "\033[1;32mINSTALAR SSLH NA PORTA 443? \033[1;33m[s/n]: \033[1;37m"; read resp
			[[ "$resp" = 's' ]] && {
				verif_ptrs 443
				fun_instsslh() {
					ptssl=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | head -1); [[ -z "$ptssl" ]] && ptssl=3128
					ptvpn=$(ss -tlpn 2>/dev/null | grep 'openvpn' | awk '{print $4}' | rev | cut -d: -f1 | rev | head -1); [[ -z "$ptvpn" ]] && ptvpn=1194
					DEBIAN_FRONTEND=noninteractive apt-get -y install sslh >/dev/null 2>&1
					printf "RUN=yes\nDAEMON=/usr/sbin/sslh\nDAEMON_OPTS='--user sslh --listen 0.0.0.0:443 --ssh 127.0.0.1:22 --ssl 127.0.0.1:%s --http 127.0.0.1:80 --openvpn 127.0.0.1:%s --pidfile /var/run/sslh/sslh.pid'\n" "$ptssl" "$ptvpn" > /etc/default/sslh
					service sslh start >/dev/null 2>&1
				}
				fun_bar 'fun_instsslh'
				_ok=$(ss -tlpn 2>/dev/null | grep -wc 'sslh')
				[[ "$_ok" != '0' ]] && echo -e "\n\033[1;32mSSLH INSTALADO!\033[0m" || echo -e "\n\033[1;31mERRO!\033[0m"
			}
			sleep 2; fun_conexao
		} || {
			echo -e "\E[41;1;37m             REMOVER SSLH               \E[0m\n"
			echo -ne "\033[1;32mREMOVER SSLH? \033[1;33m[s/n]: \033[1;37m"; read respo
			[[ "$respo" = 's' ]] && { service sslh stop >/dev/null 2>&1; apt-get remove --purge sslh -y >/dev/null 2>&1; echo -e "\n\033[1;32mSSLH REMOVIDO!\033[0m"; }
			sleep 2; fun_conexao
		}
	}

