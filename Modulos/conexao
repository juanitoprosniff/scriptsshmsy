#!/bin/bash
# ============================================================
# MÓDULO: MODO DE CONEXIÓN — v2.0
# Compatible: Ubuntu 18 / 20 / 22 / 24 / 25+
# FIXES:
#  - Dropbear 2016 GCC 12/13 (Ubuntu 22/24)
#  - Broken pipe / Enhanced HTTP Custom
#  - SSL multi-puerto 443, 444, 8443
#  - 5 servidores SSH: OpenSSH, Dropbear, DB2016, tinySSH, Lsh, OSSH
#  - Proxy WebSocket multi-conexión mejorado
#  - Sistema de actualización vía GitHub
# ============================================================

_UBUNTU_VER=$(lsb_release -rs 2>/dev/null | cut -d. -f1 || grep -oP '(?<=Ubuntu )\d+' /etc/issue.net 2>/dev/null || echo "0")
_GCC_VER=$(gcc -dumpversion 2>/dev/null | cut -d. -f1 || echo "0")

fun_bar() {
    comando[0]="$1"; comando[1]="$2"
    (
        [[ -e $HOME/fim ]] && rm $HOME/fim
        [[ ! -d /etc/SSHPlus ]] && rm -rf /bin/menu
        ${comando[0]} >/dev/null 2>&1
        ${comando[1]} >/dev/null 2>&1
        touch $HOME/fim
    ) >/dev/null 2>&1 &
    tput civis
    echo -ne "\033[1;33mESPERE \033[1;37m- \033[1;33m["
    while true; do
        for ((i=0; i<18; i++)); do echo -ne "\033[1;31m#"; sleep 0.1s; done
        [[ -e $HOME/fim ]] && rm $HOME/fim && break
        echo -e "\033[1;33m]"; sleep 1s; tput cuu1; tput dl1
        echo -ne "\033[1;33mESPERE \033[1;37m- \033[1;33m["
    done
    echo -e "\033[1;33m]\033[1;37m -\033[1;32m LISTO!\033[1;37m"
    tput cnorm
}

verif_ptrs() {
    porta=$1
    if command -v ss &>/dev/null; then
        for pton in $(ss -tlpn 2>/dev/null | grep "LISTEN" | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u); do
            svcs=$(ss -tlpn 2>/dev/null | grep ":$pton " | awk '{print $6}' | grep -oP '(?<=\().*(?=,)' | head -1)
            [[ "$porta" = "$pton" ]] && {
                echo -e "\n\033[1;31mPUERTO \033[1;33m$porta \033[1;31mEN USO POR \033[1;37m$svcs\033[0m"
                sleep 3; fun_conexao
            }
        done
    else
        PT=$(netstat -tlpn 2>/dev/null | grep "LISTEN")
        for pton in $(echo "$PT" | awk '{print $4}' | cut -d: -f2 | sort -u); do
            svcs=$(echo "$PT" | grep -w ":$pton " | awk '{print $7}' | cut -d/ -f2 | head -1)
            [[ "$porta" = "$pton" ]] && {
                echo -e "\n\033[1;31mPUERTO \033[1;33m$porta \033[1;31mEN USO POR \033[1;37m$svcs\033[0m"
                sleep 3; fun_conexao
            }
        done
    fi
}

get_ports_by_process() {
    local proc="$1"
    if command -v ss &>/dev/null; then
        ss -tlpn 2>/dev/null | grep "$proc" | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs
    else
        netstat -nplt 2>/dev/null | grep "$proc" | awk '{print $4}' | cut -d: -f2 | xargs
    fi
}

_check_proc() {
    ss -tlpn 2>/dev/null | grep -q "$1" || netstat -tlpn 2>/dev/null | grep -q "$1" 2>/dev/null
}

# ── Abrir puerto en TODOS los firewalls activos ───────────────
_fw_open() {
    local pt="$1" pr="${2:-tcp}"
    command -v ufw &>/dev/null && ufw status 2>/dev/null | grep -q "active" && \
        ufw allow ${pt}/${pr} >/dev/null 2>&1
    command -v iptables &>/dev/null && {
        iptables -C INPUT -p ${pr} --dport ${pt} -j ACCEPT 2>/dev/null || \
        iptables -I INPUT -p ${pr} --dport ${pt} -j ACCEPT >/dev/null 2>&1
    }
    command -v firewall-cmd &>/dev/null && firewall-cmd --state 2>/dev/null | grep -q "running" && {
        firewall-cmd --zone=public --permanent --add-port=${pt}/${pr} >/dev/null 2>&1
        firewall-cmd --reload >/dev/null 2>&1
    }
}

# ── Reiniciar servicio SSH correctamente según versión ────────
_restart_ssh() {
    systemctl restart ssh 2>/dev/null || \
    systemctl restart sshd 2>/dev/null || \
    service ssh restart 2>/dev/null || \
    service sshd restart 2>/dev/null
}

# ============================================================
# SISTEMA DE ACTUALIZACIÓN VÍA GITHUB
# ============================================================
fun_update_script() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m         ACTUALIZAR SCRIPT SSHMSY            \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""

    # URL base del repositorio (editar según su GitHub)
    local _REPO_BASE="https://raw.githubusercontent.com/juanitoprosniff/scriptsshmsy/main"
    local _VER_REMOTE _VER_LOCAL _VER_FILE="/usr/share/.plus/.version"

    echo -e "\033[1;33mVerificando versión remota...\033[0m"

    # Obtener versión remota
    _VER_REMOTE=$(curl -s --max-time 8 "${_REPO_BASE}/versao" 2>/dev/null || \
                  wget -qO- --timeout=8 "${_REPO_BASE}/versao" 2>/dev/null)

    # Versión local
    _VER_LOCAL=$(cat "$_VER_FILE" 2>/dev/null || echo "0")

    if [[ -z "$_VER_REMOTE" ]]; then
        echo -e "\033[1;31mNo se pudo contactar el servidor. Verifique su conexión.\033[0m"
        sleep 3; return
    fi

    echo -e "\033[1;37mVersión local : \033[1;32m$_VER_LOCAL\033[0m"
    echo -e "\033[1;37mVersión remota: \033[1;32m$_VER_REMOTE\033[0m"
    echo ""

    if [[ "$_VER_REMOTE" = "$_VER_LOCAL" ]]; then
        echo -e "\033[1;32m✓ Ya tienes la versión más reciente.\033[0m"
        sleep 3; return
    fi

    echo -e "\033[1;33m¡Hay una nueva versión disponible!\033[0m"
    echo ""
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mActualizar ahora (para todos los servicios)\033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mActualizar solo módulo conexao              \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mActualizar solo menú principal              \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mCancelar                                   \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read _upd_opt

    case "$_upd_opt" in
    1)
        echo -e "\n\033[1;33mDeteniendo servicios activos...\033[0m"
        # Parar proxies Python
        for pid in $(screen -ls 2>/dev/null | grep -E '\.proxy|\.ws|openpy' | awk '{print $1}'); do
            screen -r -S "$pid" -X quit 2>/dev/null
        done
        screen -wipe >/dev/null 2>&1

        echo -e "\033[1;33mDescargando actualización completa...\033[0m"
        _do_update_full "$_REPO_BASE"
        ;;
    2)
        echo -e "\033[1;33mActualizando módulo de conexión...\033[0m"
        _do_update_file "$_REPO_BASE" "conexao" "/bin/conexao"
        ;;
    3)
        echo -e "\033[1;33mActualizando menú principal...\033[0m"
        _do_update_file "$_REPO_BASE" "menu" "/bin/menu"
        ;;
    0) return ;;
    esac
}

_do_update_file() {
    local base="$1" remote_name="$2" local_path="$3"
    local tmp="/tmp/_upd_${remote_name}"
    wget -q --timeout=15 "${base}/${remote_name}" -O "$tmp" 2>/dev/null || \
    curl -s --max-time 15 "${base}/${remote_name}" -o "$tmp" 2>/dev/null

    if [[ -s "$tmp" ]]; then
        cp "$local_path" "${local_path}.bak" 2>/dev/null
        mv "$tmp" "$local_path"
        chmod 755 "$local_path"
        echo -e "\033[1;32m✓ $remote_name actualizado!\033[0m"
    else
        echo -e "\033[1;31mError al descargar $remote_name\033[0m"
    fi
    sleep 2
}

_do_update_full() {
    local base="$1"
    local _ok=0

    for _mod in menu conexao; do
        local _dest
        [[ "$_mod" = "menu" ]] && _dest="/bin/menu" || _dest="/bin/conexao"
        local _tmp="/tmp/_upd_${_mod}"
        wget -q --timeout=15 "${base}/${_mod}" -O "$_tmp" 2>/dev/null || \
        curl -s --max-time 15 "${base}/${_mod}" -o "$_tmp" 2>/dev/null
        if [[ -s "$_tmp" ]]; then
            cp "$_dest" "${_dest}.bak" 2>/dev/null
            mv "$_tmp" "$_dest"
            chmod 755 "$_dest"
            echo -e "\033[1;32m✓ $_mod actualizado\033[0m"
            ((_ok++))
        else
            echo -e "\033[1;31m✗ Error actualizando $_mod\033[0m"
        fi
    done

    # Actualizar versión local
    if [[ $_ok -gt 0 ]]; then
        mkdir -p /usr/share/.plus
        echo "$_VER_REMOTE" > /usr/share/.plus/.version
        echo -e "\n\033[1;32m✓ Actualización completada ($_ok módulos).\033[0m"
        echo -e "\033[1;33mReiniciando menú...\033[0m"
        sleep 2; exec menu
    fi
    sleep 3
}

# ============================================================
# SQUID
# ============================================================
inst_sqd() {
    if _check_proc 'squid'; then
        echo -e "\E[41;1;37m            REMOVER SQUID PROXY              \E[0m"
        echo -ne "\n\033[1;32mREMOVER SQUID? \033[1;31m[s/n]:\033[1;37m "; read resp
        [[ "$resp" = 's' ]] && {
            rem_sqd() {
                for d in /etc/squid /etc/squid3; do
                    [[ -d "$d" ]] && apt-get remove --purge -y squid squid3 >/dev/null 2>&1 && rm -rf "$d"
                done; apt autoremove -y >/dev/null 2>&1
            }; fun_bar 'rem_sqd'
            echo -e "\n\033[1;32mSQUID ELIMINADO!\033[0m"
        }; sleep 2; fun_conexao
    else
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m            INSTALAR SQUID PROXY         \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        IP=$(curl -s --max-time 5 ipv4.icanhazip.com || wget -qO- ipv4.icanhazip.com)
        echo -ne "\033[1;32mCONFIRME SU IP: \033[1;37m"; read -e -i $IP ipdovps
        echo -ne "\n\033[1;33mPUERTOS (EJ: 80 8080): \033[1;37m"; read portass
        [[ -z "$portass" ]] && { echo -e "\n\033[1;31mPuerto inválido!"; sleep 2; fun_conexao; return; }
        for porta in $portass; do verif_ptrs $porta; done
        fun_bar 'apt update -y' "apt install squid -y"
        var_sqd="/etc/squid/squid.conf"; [[ -d /etc/squid3 ]] && var_sqd="/etc/squid3/squid.conf"
        cat > $var_sqd <<-EOF
			acl url1 dstdomain -i 127.0.0.1
			acl url2 dstdomain -i localhost
			acl url3 dstdomain -i $ipdovps
			acl all src 0.0.0.0/0
			http_access allow url1
			http_access allow url2
			http_access allow url3
			http_access deny all
			#Puertos
			visible_hostname SSHPLUS
			via off
			forwarded_for off
		EOF
        for Pts in $portass; do
            echo "http_port $Pts" >> $var_sqd
            _fw_open $Pts tcp
        done
        fun_bar 'service squid restart'
        echo -e "\n\033[1;32mSQUID INSTALADO!\033[0m"; sleep 2; fun_conexao
    fi
}

fun_squid() {
    if ! _check_proc 'squid'; then inst_sqd; return; fi
    sqdp=$(get_ports_by_process 'squid')
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m          GESTIONAR SQUID PROXY          \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    [[ -n "$sqdp" ]] && echo -e "\033[0;34m╼ \033[1;32mPUERTOS\033[1;37m: $sqdp"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mINSTALAR/REMOVER  \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mAGREGAR PUERTO    \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mELIMINAR PUERTO   \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER            \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read x; clear
    case $x in
    1|01) inst_sqd ;;
    2|02)
        var_sqd="/etc/squid/squid.conf"; [[ -f /etc/squid3/squid.conf ]] && var_sqd="/etc/squid3/squid.conf"
        echo -ne "\033[1;32mPUERTO A AGREGAR: \033[1;37m"; read pt; [[ -z "$pt" ]] && { fun_conexao; return; }
        sed -i "s/#Puertos/#Puertos\nhttp_port $pt/" $var_sqd
        _fw_open $pt; fun_bar 'service squid restart' 'service squid3 restart'
        echo -e "\n\033[1;32mPUERTO AGREGADO!"; sleep 2; fun_squid ;;
    3|03)
        var_sqd="/etc/squid/squid.conf"; [[ -f /etc/squid3/squid.conf ]] && var_sqd="/etc/squid3/squid.conf"
        echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read pt
        sed -i "/http_port $pt/d" $var_sqd
        fun_bar 'service squid restart' 'service squid3 restart'
        echo -e "\n\033[1;32mPUERTO ELIMINADO!"; sleep 2; fun_squid ;;
    0|00) fun_conexao ;;
    *) echo -e "\033[1;31mOpción inválida!"; sleep 1; fun_squid ;;
    esac
}

# ============================================================
# OPENSSH
# ============================================================
fun_openssh_legacy() {
    clear
    if ss -tlpn 2>/dev/null | grep -q ':23 '; then
        echo -e "\n\033[1;32mOpenSSH ya activo en puerto 23.\033[0m"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mDESACTIVAR 23  \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER         \033[0;34m┃"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read opc
        [[ "$opc" = '1' ]] && { sed -i '/^Port 23$/d' /etc/ssh/sshd_config; _restart_ssh; echo -e "\n\033[1;32mPuerto 23 eliminado!\033[0m"; }
        sleep 2; fun_conexao; return
    fi
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mACTIVAR puerto 23  \033[0;34m┃"
    echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER             \033[0;34m┃"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read opc
    if [[ "$opc" = '1' ]]; then
        verif_ptrs 23
        grep -q "^Port 23$" /etc/ssh/sshd_config || echo "Port 23" >> /etc/ssh/sshd_config
        _restart_ssh; _fw_open 23
        echo -e "\n\033[1;32mOpenSSH activo en 22 y 23!\033[0m"; sleep 2; fun_conexao
    else
        fun_conexao
    fi
}

fun_openssh() {
    clear
    echo -e "\E[44;1;37m            OPENSSH             \E[0m\n"
    _ssh_ports=$(grep '^Port' /etc/ssh/sshd_config | awk '{print $2}' | xargs)
    echo -e "\033[1;33mPUERTOS ACTIVOS: \033[1;37m$_ssh_ports\n"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mAGREGAR PUERTO"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR PUERTO"
    echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mOPENSSH LEGADO (puerto 23)"
    echo -e "\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER\033[0m"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read resp
    if [[ "$resp" = '1' ]]; then
        echo -ne "\n\033[1;32mNUEVO PUERTO: \033[1;37m"; read pt; [[ -z "$pt" ]] && { fun_conexao; return; }
        verif_ptrs $pt; echo "Port $pt" >> /etc/ssh/sshd_config
        _restart_ssh; _fw_open $pt
        echo -e "\n\033[1;32mPUERTO $pt AGREGADO!\033[0m"; sleep 2; fun_conexao
    elif [[ "$resp" = '2' ]]; then
        echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read pt; [[ -z "$pt" ]] && { fun_conexao; return; }
        sed -i "/^Port $pt$/d" /etc/ssh/sshd_config; _restart_ssh
        echo -e "\n\033[1;32mPUERTO $pt ELIMINADO!\033[0m"; sleep 2; fun_conexao
    elif [[ "$resp" = '3' ]]; then
        fun_openssh_legacy
    else
        fun_conexao
    fi
}

# ============================================================
# DROPBEAR 2016.74 — Versión probada con systemd service
# Compatible: Ubuntu 18 / 20 / 22 / 24 / 25+
# ============================================================
fun_inst_dropbear2016() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m        INSTALAR DROPBEAR 2016.74        \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo -e "\n\033[1;37mUbuntu: $_UBUNTU_VER  GCC: $_GCC_VER\033[0m"
    echo -e "\033[1;33mCompilación: ~3-5 minutos.\033[0m"
    echo -ne "\033[1;32mPUERTO (defecto 143): \033[1;37m"; read porta_db16; [[ -z "$porta_db16" ]] && porta_db16=143
    verif_ptrs $porta_db16

    echo -e "\n\033[1;32mInstalando dependencias...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y make gcc wget zlib1g-dev build-essential >/dev/null 2>&1

    echo "=========================================="
    echo "Compilando Dropbear 2016.74 desde fuente..."
    echo "Esto puede tardar unos minutos..."
    echo "=========================================="

    cd /usr/src

    # Descargar Dropbear 2016.74
    if [[ ! -f dropbear-2016.74.tar.bz2 ]] || [[ ! -s dropbear-2016.74.tar.bz2 ]]; then
        echo "Descargando Dropbear 2016.74..."
        wget -q --timeout=60 \
            https://github.com/juanitoprosniff/script_msyvpn/raw/refs/heads/main/installer/dropbear-2016.74.tar.bz2
    fi

    # Verificar descarga
    if [[ ! -s dropbear-2016.74.tar.bz2 ]]; then
        echo -e "\033[1;31mNo se pudo descargar el fuente.\033[0m"
        echo -e "\033[1;33mSuba manualmente dropbear-2016.74.tar.bz2 a /usr/src/ e intente de nuevo.\033[0m"
        sleep 3; fun_conexao; return
    fi

    # Extraer
    echo "Extrayendo archivos..."
    rm -rf dropbear-2016.74 2>/dev/null
    tar xjf dropbear-2016.74.tar.bz2
    cd dropbear-2016.74

    # Modificar identificador SSH
    echo "Modificando identificador SSH..."
    if [[ -f sysoptions.h ]]; then
        sed -i 's|^#define LOCAL_IDENT.*|#define LOCAL_IDENT "SSH-2.0-ByJuanitoProSniff"|' sysoptions.h 2>/dev/null || true
        echo "✓ Modificado en sysoptions.h"
    elif [[ -f default_options.h ]]; then
        sed -i 's/#define LOCAL_IDENT "SSH-2.0-dropbear_" DROPBEAR_VERSION/#define LOCAL_IDENT "SSH-2.0-ByJuanitoProSniff"/' default_options.h 2>/dev/null || true
        sed -i 's/SSH-2.0-dropbear/SSH-2.0-ByJuanitoProSniff/g' default_options.h 2>/dev/null || true
        echo "✓ Modificado en default_options.h"
    fi

    # Configurar compilación
    echo "Configurando compilación..."
    ./configure --prefix=/opt/dropbear-2016 \
        --disable-zlib \
        --disable-wtmp \
        --disable-lastlog

    # Compilar
    echo "Compilando... (puede tardar 2-3 minutos)"
    if make -j$(nproc) PROGRAMS="dropbear dropbearkey"; then
        echo "Instalando..."
        make install PROGRAMS="dropbear dropbearkey"
    else
        echo -e "\033[1;31m⚠ ERROR: No se pudo compilar Dropbear 2016\033[0m"
        echo -e "\033[1;33mContinuando sin Dropbear Legacy...\033[0m"
        cd /root; sleep 3; fun_conexao; return
    fi

    # Verificar instalación del binario
    if [[ ! -f /opt/dropbear-2016/sbin/dropbear ]]; then
        echo -e "\033[1;31m⚠ ERROR: Binario no encontrado tras compilación.\033[0m"
        cd /root; sleep 3; fun_conexao; return
    fi

    echo "✓ Dropbear 2016.74 compilado exitosamente"

    # Crear directorio para llaves
    mkdir -p /etc/dropbear-legacy

    # Generar llaves SSH para Dropbear 2016
    echo "Generando llaves SSH para Dropbear 2016..."
    [[ ! -f /etc/dropbear-legacy/dropbear_rsa_host_key ]] && \
        /opt/dropbear-2016/bin/dropbearkey -t rsa \
            -f /etc/dropbear-legacy/dropbear_rsa_host_key -s 2048

    [[ ! -f /etc/dropbear-legacy/dropbear_dss_host_key ]] && \
        /opt/dropbear-2016/bin/dropbearkey -t dss \
            -f /etc/dropbear-legacy/dropbear_dss_host_key

    # Crear banner
    cat > /etc/dropbear-legacy/banner.txt <<'BANEOF'
t.me/FREEINTERNETVPNMSY
BANEOF

    # Crear servicio systemd para Dropbear 2016
    cat > /etc/systemd/system/dropbear-legacy.service <<DBEOF
[Unit]
Description=Dropbear SSH Legacy 2016.74 - Puerto $porta_db16
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/opt/dropbear-2016/sbin/dropbear -F -E -p $porta_db16 -r /etc/dropbear-legacy/dropbear_rsa_host_key -d /etc/dropbear-legacy/dropbear_dss_host_key -b /etc/dropbear-legacy/banner.txt -K 60 -I 300
ExecReload=/bin/kill -HUP \$MAINPID
Restart=always
RestartSec=3
KillMode=process

[Install]
WantedBy=multi-user.target
DBEOF

    # Activar e iniciar servicio
    systemctl daemon-reload
    systemctl enable dropbear-legacy
    systemctl start dropbear-legacy

    _fw_open $porta_db16

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Versión de Dropbear 2016 instalada:"
    /opt/dropbear-2016/sbin/dropbear -V 2>&1 | head -n 1
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    sleep 1
    if systemctl is-active dropbear-legacy >/dev/null 2>&1; then
        echo -e "\n\033[1;32m✓ DROPBEAR 2016.74 ACTIVO EN PUERTO $porta_db16!\033[0m"
    else
        echo -e "\n\033[1;33mVerifique con: systemctl status dropbear-legacy\033[0m"
    fi

    cd /root
    sleep 3; fun_conexao
}

# ============================================================
# SSL TUNNEL — 3 puertos: 443, 444, 8443
# Con dispatcher inteligente SSH ↔ WebSocket en mismo puerto
# ============================================================

# ── Puerto interno del dispatcher ────────────────────────────
_SSL_DISP_PORT=10443
_SSL_DISP_SCRIPT="/etc/SSHPlus/ssldispatcher.py"

# Iniciar/reiniciar el dispatcher SSL
_ssl_start_dispatcher() {
    local _ssh_dst="$1"   # e.g. 127.0.0.1:143
    local _ws_dst="$2"    # e.g. 127.0.0.1:80

    # Parar instancia anterior si existe
    for pid in $(screen -ls 2>/dev/null | grep '\.ssldispatch' | awk '{print $1}'); do
        screen -r -S "$pid" -X quit 2>/dev/null
    done
    pkill -f "ssldispatcher.py" 2>/dev/null
    screen -wipe >/dev/null 2>&1
    sleep 0.5

    if [[ ! -f "$_SSL_DISP_SCRIPT" ]]; then
        echo -e "\033[1;31mERROR: No se encuentra ssldispatcher.py en /etc/SSHPlus/\033[0m"
        echo -e "\033[1;33mCopie ssldispatcher.py a /etc/SSHPlus/ e intente de nuevo.\033[0m"
        return 1
    fi

    screen -dmS ssldispatch python3 "$_SSL_DISP_SCRIPT" \
        "$_SSL_DISP_PORT" "$_ssh_dst" "$_ws_dst"
    sleep 1

    if ss -tlpn 2>/dev/null | grep -q ":${_SSL_DISP_PORT} "; then
        echo -e "\033[1;32m✓ Dispatcher activo en puerto interno $_SSL_DISP_PORT\033[0m"
        echo -e "\033[1;37m  SSH raw  → \033[1;32m$_ssh_dst"
        echo -e "\033[1;37m  HTTP/WS  → \033[1;32m$_ws_dst\033[0m"
        return 0
    else
        echo -e "\033[1;31m✗ Dispatcher no respondió en puerto $_SSL_DISP_PORT\033[0m"
        return 1
    fi
}

# Detectar destinos actuales del dispatcher desde autostart
_ssl_disp_get_targets() {
    local _line
    _line=$(grep 'ssldispatcher.py' /etc/autostart 2>/dev/null | tail -1)
    if [[ -n "$_line" ]]; then
        _DISP_SSH=$(echo "$_line" | grep -oP '127\.0\.0\.1:\d+' | sed -n '2p')
        _DISP_WS=$(echo "$_line"  | grep -oP '127\.0\.0\.1:\d+' | sed -n '3p')
    fi
    [[ -z "$_DISP_SSH" ]] && _DISP_SSH="127.0.0.1:143"
    [[ -z "$_DISP_WS"  ]] && {
        local _wp
        _wp=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
              grep -v ":${_SSL_DISP_PORT} " | \
              awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
        [[ -n "$_wp" ]] && _DISP_WS="127.0.0.1:$_wp" || _DISP_WS="127.0.0.1:80"
    }
}

inst_ssl() {
    if _check_proc 'stunnel4'; then
        sslt=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
        [[ -z "$sslt" ]] && sslt="\033[1;31mINDISPONIBLE"

        # Estado del dispatcher
        local _disp_sts="\033[1;31m✕ INACTIVO"
        ss -tlpn 2>/dev/null | grep -q ":${_SSL_DISP_PORT} " && \
            _disp_sts="\033[1;32m✓ ACTIVO (puerto $_SSL_DISP_PORT)"
        _ssl_disp_get_targets

        clear
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[44;1;37m           GESTIONAR SSL TUNNEL          \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -e "\033[0;34m╼ \033[1;32mSSL PUERTOS \033[1;37m: $sslt"
        echo -e "\033[0;34m╼ \033[1;32mDISPATCHER  : $_disp_sts"
        echo -e "\033[0;34m╼ \033[1;33mSSH backend : \033[1;37m$_DISP_SSH"
        echo -e "\033[0;34m╼ \033[1;33mWS  backend : \033[1;37m$_DISP_WS"
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mAGREGAR PUERTO SSL           \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mELIMINAR PUERTO SSL          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mCAMBIAR BACKEND SSH/WS       \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mREINICIAR DISPATCHER         \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;33mELIMINAR SSL TUNNEL          \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                       \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read resposta; echo ""

        # 1 — Agregar puerto SSL
        if [[ "$resposta" = '1' ]]; then
            echo -ne "\033[1;32mNUEVO PUERTO SSL: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            verif_ptrs $porta
            cat >> /etc/stunnel/stunnel.conf <<EOF

[sshtunnel${porta}]
accept  = $porta
connect = 127.0.0.1:${_SSL_DISP_PORT}
EOF
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            _fw_open $porta
            iptables -I INPUT -p tcp --dport $porta -j ACCEPT 2>/dev/null
            echo -e "\n\033[1;32mPUERTO $porta AGREGADO → dispatcher:$_SSL_DISP_PORT\033[0m"
            sleep 2; inst_ssl; return
        fi

        # 2 — Eliminar puerto SSL
        if [[ "$resposta" = '2' ]]; then
            echo -ne "\033[1;32mPUERTO A ELIMINAR: \033[1;37m"; read porta
            [[ -z "$porta" ]] && { inst_ssl; return; }
            sed -i "/\[sshtunnel${porta}\]/,/^$/d" /etc/stunnel/stunnel.conf 2>/dev/null
            sed -i "/accept  = ${porta}/d"          /etc/stunnel/stunnel.conf 2>/dev/null
            systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
            echo -e "\n\033[1;32mPUERTO $porta ELIMINADO!\033[0m"; sleep 2; inst_ssl; return
        fi

        # 3 — Cambiar backends SSH/WS del dispatcher
        if [[ "$resposta" = '3' ]]; then
            echo -e "\033[1;33mDestino SSH actual : \033[1;37m$_DISP_SSH"
            echo -e "\033[1;33mDestino WS  actual : \033[1;37m$_DISP_WS\033[0m\n"

            echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mSSH → OpenSSH (22)"
            echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mSSH → Dropbear 2016 (143)"
            echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mSSH → Puerto personalizado"
            echo -ne "\033[1;32mDestino SSH: \033[1;37m"; read _ssh_sel
            case "$_ssh_sel" in
            1) _new_ssh="127.0.0.1:22"  ;;
            2) _new_ssh="127.0.0.1:143" ;;
            3) echo -ne "\033[1;32mPuerto SSH: \033[1;37m"; read _sp
               _new_ssh="127.0.0.1:${_sp:-22}" ;;
            *) _new_ssh="$_DISP_SSH" ;;
            esac

            # Detectar wsproxy activo
            local _auto_ws
            _auto_ws=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
                       grep -v ":${_SSL_DISP_PORT} " | \
                       awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
            echo -e "\n\033[1;33mProxy WS detectado: \033[1;37m${_auto_ws:-ninguno}\033[0m"
            echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mWS → puerto 80"
            echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mWS → puerto 8080"
            echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mWS → detectado automáticamente (${_auto_ws:-80})"
            echo -e "\033[1;31m[\033[1;36m4\033[1;31m] \033[1;33mWS → puerto personalizado"
            echo -ne "\033[1;32mDestino WS: \033[1;37m"; read _ws_sel
            case "$_ws_sel" in
            1) _new_ws="127.0.0.1:80"   ;;
            2) _new_ws="127.0.0.1:8080" ;;
            3) _new_ws="127.0.0.1:${_auto_ws:-80}" ;;
            4) echo -ne "\033[1;32mPuerto WS: \033[1;37m"; read _wp
               _new_ws="127.0.0.1:${_wp:-80}" ;;
            *) _new_ws="$_DISP_WS" ;;
            esac

            # Actualizar autostart
            sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
            echo "ss -tlpn | grep -qw ${_SSL_DISP_PORT} || screen -dmS ssldispatch python3 ${_SSL_DISP_SCRIPT} ${_SSL_DISP_PORT} ${_new_ssh} ${_new_ws}" >> /etc/autostart

            _ssl_start_dispatcher "$_new_ssh" "$_new_ws"
            echo -e "\n\033[1;32mBackends actualizados!\033[0m"; sleep 2; inst_ssl; return
        fi

        # 4 — Reiniciar dispatcher
        if [[ "$resposta" = '4' ]]; then
            _ssl_start_dispatcher "$_DISP_SSH" "$_DISP_WS"
            sleep 2; inst_ssl; return
        fi

        # 5 — Eliminar todo
        if [[ "$resposta" = '5' ]]; then
            pkill stunnel4 2>/dev/null; systemctl stop stunnel4 2>/dev/null
            apt-get remove --purge stunnel4 -y >/dev/null 2>&1
            rm -f /etc/stunnel/stunnel.conf /etc/stunnel/stunnel.pem \
                  /etc/stunnel/stunnel.key  /etc/stunnel/stunnel.crt
            for pid in $(screen -ls 2>/dev/null | grep '\.ssldispatch' | awk '{print $1}'); do
                screen -r -S "$pid" -X quit 2>/dev/null
            done
            pkill -f "ssldispatcher.py" 2>/dev/null
            sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
            echo -e "\n\033[1;32mSSL TUNNEL Y DISPATCHER ELIMINADOS!\033[0m"
            sleep 2; fun_conexao; return
        fi

        fun_conexao; return
    fi

    # ── INSTALACIÓN INICIAL ───────────────────────────────────
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m           INSTALAR SSL TUNNEL           \E[0m\033[0;34m┃"
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    echo ""
    echo -e "\033[1;33mModo: SSL DIRECTO + SSL WEBSOCKET simultáneos\033[0m"
    echo -e "\033[1;37mEl dispatcher detecta el protocolo automáticamente.\033[0m\n"

    # ── Paso 1: Backend SSH ───────────────────────────────────
    echo -e "\033[1;33mPaso 1 — Destino SSH (sin WebSocket):\033[0m"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mOpenSSH puerto 22"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mDropbear 2016 puerto 143"
    echo -e "\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mPuerto personalizado"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read _ssh_sel
    case "$_ssh_sel" in
    1) _ssh_dst="127.0.0.1:22"  ;;
    2) _ssh_dst="127.0.0.1:143" ;;
    3) echo -ne "\033[1;32mPuerto SSH destino: \033[1;37m"; read _sp
       _ssh_dst="127.0.0.1:${_sp:-22}" ;;
    *) _ssh_dst="127.0.0.1:143" ;;
    esac

    # ── Paso 2: Backend WS ────────────────────────────────────
    local _ws_auto
    _ws_auto=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
               awk '{print $4}' | rev | cut -d: -f1 | rev | head -1)
    [[ -z "$_ws_auto" ]] && _ws_auto=80

    echo -e "\n\033[1;33mPaso 2 — Destino WebSocket (wsproxy):\033[0m"
    echo -e "\033[1;37mDetectado automáticamente: \033[1;32m$_ws_auto\033[0m"
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mUsar el detectado ($_ws_auto)"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mPuerto personalizado"
    echo -ne "\033[1;32mOpción: \033[1;37m"; read _ws_sel
    case "$_ws_sel" in
    2) echo -ne "\033[1;32mPuerto WS: \033[1;37m"; read _wp
       _ws_dst="127.0.0.1:${_wp:-80}" ;;
    *) _ws_dst="127.0.0.1:$_ws_auto" ;;
    esac

    echo ""
    echo -e "\033[1;33mInstalando stunnel4...\033[0m"
    apt-get update -y >/dev/null 2>&1
    apt-get install -y stunnel4 openssl >/dev/null 2>&1
    [[ -f /etc/default/stunnel4 ]] && sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
    mkdir -p /etc/stunnel

    echo -e "\033[1;32mGenerando certificado SSL...\033[0m"
    openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 \
        -subj "/C=CO/ST=Colombia/L=Bogota/O=SSHPlus/CN=sshplus.local" \
        -keyout /etc/stunnel/stunnel.key \
        -out    /etc/stunnel/stunnel.crt >/dev/null 2>&1
    cat /etc/stunnel/stunnel.crt /etc/stunnel/stunnel.key > /etc/stunnel/stunnel.pem
    chmod 600 /etc/stunnel/stunnel.pem

    [[ ! -s /etc/stunnel/stunnel.pem ]] && {
        echo -e "\033[1;31mError al generar certificado!\033[0m"; sleep 2; inst_ssl; return
    }

    # ── Iniciar dispatcher ANTES de configurar stunnel ────────
    echo -e "\n\033[1;33mIniciando dispatcher SSL inteligente...\033[0m"
    if ! _ssl_start_dispatcher "$_ssh_dst" "$_ws_dst"; then
        echo -e "\033[1;31mNo se pudo iniciar el dispatcher. Verifique ssldispatcher.py\033[0m"
        sleep 3; return
    fi

    # ── Configurar stunnel → dispatcher ──────────────────────
    cat > /etc/stunnel/stunnel.conf <<EOF
cert = /etc/stunnel/stunnel.pem
client = no
socket = a:SO_REUSEADDR=1
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

# Stunnel descifra SSL y pasa tráfico en crudo al dispatcher.
# El dispatcher detecta SSH vs HTTP/WS y enruta al backend correcto.

[sshtunnel443]
accept  = 443
connect = 127.0.0.1:${_SSL_DISP_PORT}

[sshtunnel444]
accept  = 444
connect = 127.0.0.1:${_SSL_DISP_PORT}

[sshtunnel8443]
accept  = 8443
connect = 127.0.0.1:${_SSL_DISP_PORT}
EOF

    echo -e "\033[1;32mIniciando SSL Tunnel en puertos 443, 444, 8443...\033[0m"
    if systemctl is-enabled stunnel4 >/dev/null 2>&1; then
        systemctl enable stunnel4 >/dev/null 2>&1
        systemctl restart stunnel4 >/dev/null 2>&1
    else
        service stunnel4 restart >/dev/null 2>&1
    fi

    for _sslp in 443 444 8443; do
        _fw_open $_sslp
        iptables -I INPUT -p tcp --dport $_sslp -j ACCEPT 2>/dev/null
    done

    # Guardar en autostart para reinicio del servidor
    sed -i '/ssldispatcher.py/d' /etc/autostart 2>/dev/null
    echo "ss -tlpn | grep -qw ${_SSL_DISP_PORT} || screen -dmS ssldispatch python3 ${_SSL_DISP_SCRIPT} ${_SSL_DISP_PORT} ${_ssh_dst} ${_ws_dst}" >> /etc/autostart

    sleep 1
    echo ""
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    if ss -tlpn 2>/dev/null | grep -q ":443 "; then
        echo -e "\033[1;32m✓ SSL TUNNEL ACTIVO!\033[0m"
        echo -e "\033[1;37m  Puertos SSL  : \033[1;32m443, 444, 8443"
        echo -e "\033[1;37m  → Dispatcher : \033[1;32m127.0.0.1:$_SSL_DISP_PORT"
        echo -e "\033[1;37m    ├ SSH raw  : \033[1;32m$_ssh_dst"
        echo -e "\033[1;37m    └ HTTP/WS  : \033[1;32m$_ws_dst\033[0m"
        if ! ss -tlpn 2>/dev/null | grep -q ":444 "; then
            echo -e "\033[1;33m⚠ Puerto 444 no visible — verifique el firewall del panel VPS.\033[0m"
        fi
    else
        echo -e "\n\033[1;33mVerifique: systemctl status stunnel4\033[0m"
    fi
    echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
    sleep 4; inst_ssl
}

# ============================================================
# PROXY SOCKS + WEBSOCKET — mejorado para multi-conexión
# ============================================================
fun_socks() {
    clear
    echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
    echo -e "\033[0;34m┃\E[44;1;37m          GESTIONAR PROXY SOCKS          \E[0m\033[0;34m┃"
