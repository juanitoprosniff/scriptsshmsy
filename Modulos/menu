echo -e "\E[38;5;18m╰━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╯\033[0m"
echo ""

# ── Instalar CLI oficial Ookla si no existe ───────────────────
if ! command -v speedtest &>/dev/null && ! command -v speedtest-cli &>/dev/null; then
	echo -e "\033[1;33m  Instalando CLI oficial speedtest.net...\033[0m"
	curl -s https://packagecloud.io/install/repositories/ookla/speedtest-cli/script.deb.sh \
		| bash >/dev/null 2>&1
	apt-get install -y speedtest >/dev/null 2>&1
	# Fallback: speedtest-cli Python
	if ! command -v speedtest &>/dev/null; then
		echo -e "\033[1;33m  Usando speedtest-cli (Python) como alternativa...\033[0m"
		apt-get install -y python3-pip >/dev/null 2>&1
		if [[ "${_UBUNTU_VER_V:-0}" -ge 22 ]]; then
			pip3 install speedtest-cli --break-system-packages -q 2>/dev/null
		else
			pip3 install speedtest-cli -q 2>/dev/null
		fi
	fi
fi

# ── Determinar binario ────────────────────────────────────────
_spd_bin=""
command -v speedtest     &>/dev/null && _spd_bin="ookla"
[[ -z "$_spd_bin" ]] && command -v speedtest-cli &>/dev/null && _spd_bin="python"

if [[ -z "$_spd_bin" ]]; then
	echo -e "\033[1;31m  No se pudo instalar speedtest. Intente: apt install speedtest\033[0m"
	echo -ne "\n\033[1;31mENTER \033[1;37mpara volver al \033[1;32mMENÚ!\033[0m"; read; return
fi

echo -e "\033[1;33m  Ejecutando prueba... espere hasta 90 seg...\033[0m"
echo ""

_ping="" _down="" _up="" _link="" _server="" _isp=""

if [[ "$_spd_bin" = "ookla" ]]; then
	_result=$(timeout 90 speedtest \
		--accept-license --accept-gdpr --progress=no 2>/dev/null)
	_ping=$(echo "$_result"   | grep -i 'Latency\|Idle'    | grep -oP '[\d.]+\s*ms'    | head -1)
	_down=$(echo "$_result"   | grep -i 'Download'          | grep -oP '[\d.]+\s*\w+bps' | head -1)
	_up=$(echo "$_result"     | grep -i 'Upload'            | grep -oP '[\d.]+\s*\w+bps' | head -1)
	_link=$(echo "$_result"   | grep -i 'Result URL\|Share' | grep -oP 'https?://\S+'    | head -1)
	_server=$(echo "$_result" | grep -i 'Server'            | head -1 | sed 's/Server://i;s/^[[:space:]]*//')
	_isp=$(echo "$_result"    | grep -i 'ISP'               | head -1 | sed 's/ISP://i;s/^[[:space:]]*//')
else
	_result=$(timeout 90 speedtest-cli --simple 2>/dev/null)
	_ping=$(echo "$_result" | grep -i 'Ping'     | awk '{print $2 " " $3}')
	_down=$(echo "$_result" | grep -i 'Download' | awk '{print $2 " " $3}')
	_up=$(echo "$_result"   | grep -i 'Upload'   | awk '{print $2 " " $3}')
	_link=$(timeout 20 speedtest-cli --share 2>/dev/null | grep -oP 'https?://\S+' | head -1)
fi

clear
echo -e "\E[38;5;18m╭━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╮\033[0m"
echo -e "\E[38;5;18m┃\E[44;1;37m      RESULTADO — speedtest.net          \E[0m\E[38;5;18m┃"
echo -e "\E[38;5;18m╰━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╯\033[0m"
