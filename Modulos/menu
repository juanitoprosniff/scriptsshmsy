# ============================================================
# BACKUP DE USUARIOS вЂ” Exportar e importar usuarios SSH
# ============================================================
userbackup() {
clear
echo -e "\E[38;5;18mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
echo -e "\E[38;5;18mв”ѓ\E[44;1;37m         BACKUP DE USUARIOS SSH          \E[0m\E[38;5;18mв”ѓ"
echo -e "\E[38;5;18mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
echo -e "\E[38;5;196m|\E[38;5;33m01\E[38;5;196m|\033[1;37mвћњ \E[38;5;195mEXPORTAR USUARIOS"
echo -e "\E[38;5;196m|\E[38;5;33m02\E[38;5;196m|\033[1;37mвћњ \E[38;5;195mIMPORTAR USUARIOS"
echo -e "\E[38;5;196m|\E[38;5;33m03\E[38;5;196m|\033[1;37mвћњ \E[38;5;195mVER BACKUPS GUARDADOS"
echo -e "\E[38;5;196m|\E[38;5;33m04\E[38;5;196m|\033[1;37mвћњ \E[38;5;195mELIMINAR BACKUP"
echo -e "\E[38;5;196m|\E[38;5;33m00\E[38;5;196m|\033[1;37mвћњ \E[38;5;195mVOLVER AL MENГљ"
echo ""
echo -ne "\033[1;32mQUГ‰ DESEA HACER \033[1;37m?\033[1;31m?\033[1;37m : "; read bk_op

case "$bk_op" in
1|01)
	clear
	_bk_dir="/root/backups_msy"
	mkdir -p "$_bk_dir"
	_bk_file="$_bk_dir/usuarios_$(date +%Y%m%d_%H%M%S).bak"
	echo -e "\033[1;33mExportando usuarios...\033[0m"
	# Exportar usuarios con UID >= 1000 (no system, no nobody)
	while IFS=: read -r _u _p _uid _gid _ge _home _shell; do
		[[ "$_uid" -lt 1000 ]] && continue
		[[ "$_u" = "nobody" ]] && continue
		# Obtener hash de contraseГ±a
		_hash=$(getent shadow "$_u" 2>/dev/null | cut -d: -f2)
		# Obtener fecha de expiraciГіn
		_exp=$(chage -l "$_u" 2>/dev/null | grep "Account expires" | cut -d: -f2 | xargs)
		echo "$_u:$_hash:$_exp" >> "$_bk_file"
	done < /etc/passwd
	_total=$(wc -l < "$_bk_file" 2>/dev/null || echo "0")
	echo -e "\n\033[1;32mвњ“ Backup creado: \033[1;37m$_bk_file"
	echo -e "\033[1;32mвњ“ Total usuarios exportados: \033[1;37m$_total\033[0m"
	sleep 3
	userbackup
	;;
2|02)
	clear
	_bk_dir="/root/backups_msy"
	echo -e "\033[1;33mBACKUPS DISPONIBLES:\033[0m\n"
	if [[ -z "$(ls $_bk_dir/*.bak 2>/dev/null)" ]]; then
		echo -e "\033[1;31mNo hay backups disponibles.\033[0m"
		sleep 2; userbackup; return
	fi
	ls -1 "$_bk_dir"/*.bak 2>/dev/null | nl
	echo ""
	echo -ne "\033[1;32mNombre del archivo a importar (completo): \033[1;37m"; read _imp_file
	[[ ! -f "$_imp_file" ]] && {
		echo -e "\033[1;31mArchivo no encontrado!\033[0m"; sleep 2; userbackup; return
	}
	echo -e "\033[1;33mImportando usuarios...\033[0m"
	_imp_count=0
	while IFS=: read -r _u _hash _exp; do
		[[ -z "$_u" ]] && continue
		if ! id "$_u" &>/dev/null; then
			useradd -M -s /bin/false "$_u" 2>/dev/null
		fi
		# Restaurar hash de contraseГ±a
		[[ -n "$_hash" && "$_hash" != "!" && "$_hash" != "*" ]] && \
			usermod -p "$_hash" "$_u" 2>/dev/null
		# Restaurar fecha de expiraciГіn
		[[ -n "$_exp" && "$_exp" != "never" ]] && \
			chage -E "$_exp" "$_u" 2>/dev/null
		((_imp_count++))
	done < "$_imp_file"
	echo -e "\n\033[1;32mвњ“ Importados: \033[1;37m$_imp_count usuarios\033[0m"
	sleep 3; userbackup
	;;
3|03)
	clear
	_bk_dir="/root/backups_msy"
	echo -e "\033[1;33mBACKUPS GUARDADOS:\033[0m\n"
	if [[ -z "$(ls $_bk_dir/*.bak 2>/dev/null)" ]]; then
		echo -e "\033[1;31mNo hay backups.\033[0m"
	else
		ls -lh "$_bk_dir"/*.bak 2>/dev/null
	fi
	echo -ne "\n\033[1;31mENTER \033[1;37mpara volver\033[0m"; read
	userbackup
	;;
4|04)
	clear
	_bk_dir="/root/backups_msy"
	echo -e "\033[1;33mBACKUPS DISPONIBLES:\033[0m\n"
	ls -1 "$_bk_dir"/*.bak 2>/dev/null | nl
	echo ""
	echo -ne "\033[1;32mNombre del archivo a eliminar (completo): \033[1;37m"; read _del_file
	[[ -f "$_del_file" ]] && rm -f "$_del_file" && \
		echo -e "\033[1;32mвњ“ Backup eliminado!\033[0m" || \
		echo -e "\033[1;31mArchivo no encontrado!\033[0m"
	sleep 2; userbackup
	;;
0|00) menu ;;
*) echo -e "\n\033[1;31mOpciГіn invГЎlida!\033[0m"; sleep 2; userbackup ;;
esac
}

