echo -e "\033[0;34mв”ѓ\E[44;1;37m        CAMBIAR FECHA DE EXPIRACIГ“N      \E[0m\033[0;34mв”ѓ"
echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
echo -e "\E[38;5;196m|\E[38;5;33m01\E[38;5;196m|\033[1;37mвћњ \033[1;33mCAMBIAR FECHA DE EXPIRACIГ“N\033[0m"
echo -e "\E[38;5;196m|\E[38;5;33m00\E[38;5;196m|\033[1;37mвћњ \033[1;33mVOLVER\033[0m"
echo -ne "\E[38;5;40mQUГ‰ DESEA HACER \033[1;37m?\033[1;31m?\033[1;37m: "; read x
