# ============================================================
# REINICIAR SERVICIOS — incluye Proxy Socks y WebSocket
# ============================================================
reiniciarservicos() {
clear
echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
echo -e "\033[0;34m┃\E[44;1;37m         REINICIANDO SERVICIOS           \E[0m\033[0;34m┃"
echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
echo ""

# SSH
echo -ne "\033[1;33m  OpenSSH...         \033[0m"
service ssh restart >/dev/null 2>&1 || systemctl restart ssh >/dev/null 2>&1
echo -e "\033[1;32mOK\033[0m"

# Dropbear normal
if command -v dropbear &>/dev/null || systemctl list-units --type=service 2>/dev/null | grep -q 'dropbear'; then
	echo -ne "\033[1;33m  Dropbear...        \033[0m"
	systemctl restart dropbear 2>/dev/null || service dropbear restart 2>/dev/null
	echo -e "\033[1;32mOK\033[0m"
fi

# Dropbear 2016 (systemd)
if systemctl list-units --type=service 2>/dev/null | grep -q 'dropbear-legacy'; then
	echo -ne "\033[1;33m  Dropbear 2016...   \033[0m"
	systemctl restart dropbear-legacy 2>/dev/null
	echo -e "\033[1;32mOK\033[0m"
fi

# Squid
if _sq=$(command -v squid || command -v squid3); then
	echo -ne "\033[1;33m  Squid...           \033[0m"
	service squid restart >/dev/null 2>&1 || service squid3 restart >/dev/null 2>&1
	echo -e "\033[1;32mOK\033[0m"
fi

# SSL Tunnel
if command -v stunnel4 &>/dev/null && [[ -f /etc/stunnel/stunnel.conf ]]; then
	echo -ne "\033[1;33m  SSL Tunnel...      \033[0m"
	systemctl restart stunnel4 2>/dev/null || service stunnel4 restart 2>/dev/null
	echo -e "\033[1;32mOK\033[0m"
fi

# OpenVPN
if command -v openvpn &>/dev/null && systemctl is-active openvpn >/dev/null 2>&1; then
	echo -ne "\033[1;33m  OpenVPN...         \033[0m"
	systemctl restart openvpn >/dev/null 2>&1
	echo -e "\033[1;32mOK\033[0m"
fi

# ── PROXY SOCKS y WEBSOCKET ───────────────────────────────────
# Capturar puertos activos ANTES de parar
_proxy_activos=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | \
	awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | xargs)

if [[ -n "$_proxy_activos" ]] || grep -qE 'proxy\.py|wsproxy|open\.py' /etc/autostart 2>/dev/null; then
	echo -ne "\033[1;33m  Proxy Socks/WS...  \033[0m"

	# Parar todas las sesiones screen de proxy
	for _pid in $(screen -ls 2>/dev/null | \
			grep -E '\.proxy|\.ws[0-9]|proxy[0-9]|ws[0-9]|openpy' | \
			awk '{print $1}'); do
		screen -r -S "$_pid" -X quit 2>/dev/null
	done
	pkill -f '/etc/SSHPlus/proxy.py'    2>/dev/null
	pkill -f '/etc/SSHPlus/wsproxy'     2>/dev/null
	pkill -f '/etc/SSHPlus/open.py'     2>/dev/null
	screen -wipe >/dev/null 2>&1
	sleep 1

	# Relanzar desde /etc/autostart
	local _relanzados=0
	if [[ -f /etc/autostart ]]; then
		while IFS= read -r _cmd; do
			[[ "$_cmd" =~ proxy\.py|wsproxy|open\.py ]] && {
				eval "$_cmd" 2>/dev/null
				((_relanzados++))
			}
		done < /etc/autostart
	fi

	# Si no había en autostart pero sí estaban activos, relanzar en mismos puertos
	if [[ $_relanzados -eq 0 && -n "$_proxy_activos" ]]; then
		for _pt in $_proxy_activos; do
			local _sc="wsproxy.py"
			[[ -f /etc/SSHPlus/wsproxy2.py ]] && _sc="wsproxy2.py"
			screen -dmS "ws${_pt}" python3 /etc/SSHPlus/$_sc $_pt 2>/dev/null
			((_relanzados++))
		done
	fi

	echo -e "\033[1;32mOK ($_relanzados sesiones)\033[0m"
fi

# Slowdns
if ps x | grep 'slowdns' | grep -v grep >/dev/null 2>&1; then
	echo -ne "\033[1;33m  Slowdns...         \033[0m"
	pkill -f slowdns 2>/dev/null; sleep 1
	grep 'slowdns' /etc/autostart 2>/dev/null | head -1 | bash 2>/dev/null &
	echo -e "\033[1;32mOK\033[0m"
fi

echo ""
echo -e "\033[1;32m✓ Todos los servicios han sido reiniciados.\033[0m"
sleep 3
}

function limit1() {
clear; echo -e "\n\033[1;32mINICIANDO O LIMITER...\033[0m"; echo ""
fun_bar 'screen -dmS limiter limiter' 'sleep 3'
[[ $(grep -wc "limiter" /etc/autostart 2>/dev/null) = '0' ]] && {
	echo "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >>/etc/autostart
} || {
	sed -i '/limiter/d' /etc/autostart
	echo "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >>/etc/autostart
}
echo -e "\n\033[1;32m  LIMITER ATIVO!\033[0m"; sleep 3; menu
}

function limit2() {
clear; echo -e "\033[1;32mPARANDO O LIMITER...\033[0m"; echo ""
fun_stplimiter() {
	sleep 1; screen -r -S "limiter" -X quit 2>/dev/null
	screen -wipe 1>/dev/null 2>/dev/null
	[[ $(grep -wc "limiter" /etc/autostart 2>/dev/null) != '0' ]] && sed -i '/limiter/d' /etc/autostart
	sleep 1
}
fun_bar 'fun_stplimiter' 'sleep 3'
echo -e "\n\033[1;31m LIMITER PARADO!\033[0m"; sleep 3; menu
}

function limit_ssh() {
[[ $(ps x | grep "limiter" | grep -v grep | wc -l) = '0' ]] && limit1 || limit2
}

function autoexec() {
if grep "menu;" /etc/profile >/dev/null 2>&1; then
	clear; echo -e "\033[1;32mDESATIVANDO AUTO EXECUÇÃO\033[0m"
	offautmenu() { sed -i '/menu;/d' /etc/profile; }
	fun_bar 'offautmenu'
	echo -e "\n\033[1;31mAUTO EXECUÇÃO DESATIVADO!\033[0m"; sleep 1.5s; menu
else
	clear; echo -e "\033[1;32mATIVANDO AUTO EXECUÇÃO\033[0m"
	autmenu() {
		grep -v "^menu;" /etc/profile >/tmp/tmpass && mv /tmp/tmpass /etc/profile
		echo "menu;" >>/etc/profile
	}
	fun_bar 'autmenu'
	echo -e "\n\033[1;32mAUTO EXECUÇÃO ATIVADO!\033[0m"; sleep 1.5s; menu
fi
}

