# ============================================================
# SPEEDTEST — corregido para Ubuntu 22+
# Usa speedtest-cli (pip) o el oficial speedtest.net CLI
# ============================================================
velocity() {
_UBUNTU_VER_V=$(lsb_release -rs 2>/dev/null | cut -d. -f1 || echo "0")
clear
echo -e "\E[38;5;18m╭━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╮\033[0m"
