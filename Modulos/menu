# ============================================================
# SINCRONIZAR PANEL WEB
# ============================================================
syncpw() {
clear
echo "America/Bogota" >/etc/timezone
ln -fs /usr/share/zoneinfo/America/Bogota /etc/localtime
dpkg-reconfigure --frontend noninteractive tzdata >/dev/null 2>&1
rm *.sh >/dev/null 2>&1
apt install unzip -y >/dev/null 2>&1
[[ $(uname -m) == "aarch64" ]] && arc='arm64' || arc='64'
wget -q sshplus.xyz/scripts/${arc}/sync.tar.bz2
rm /opt/sshplus/plugin-sync >/dev/null 2>&1
tar -xvjf sync.tar.bz2 -C /opt/sshplus/ >/dev/null 2>&1
chmod 777 /opt/sshplus/*-sync >/dev/null 2>&1
wget -q sshplus.xyz/scripts/utilitarios/syncpainel/modulos.zip
unzip modulos.zip >/dev/null 2>&1
chmod 777 *sh
service ssh restart >/dev/null 2>&1
echo -e "\n\033[1;32mCOMPLETADO!\033[0m"
sleep 1.5
cat /dev/null >~/.bash_history && history -c && clear
echo -e "\E[38;5;33mENTRA AL PANEL Y CREA UNA CUENTA SSH PARA VERIFICAR QUE TODO ESTГ‰ OK!\033[0m"
rm inst sync.tar.bz2 modulos.zip >/dev/null 2>&1
}

