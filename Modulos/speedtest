#!/bin/bash
# ============================================================
# SPEEDTEST — v2.0 compatible Ubuntu 18/20/22/24/25
# Garantiza resultados: speedtest-cli / ookla / curl fallback
# ============================================================
clear
echo ""
echo -e "\E[38;5;18m╭━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╮\033[0m"
echo -e "\E[38;5;18m┃\E[44;1;37m     PROBANDO VELOCIDAD DEL SERVIDOR     \E[0m\E[38;5;18m┃"
echo -e "\E[38;5;18m╰━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╯\033[0m"
echo ""

_UBUNTU_VER=$(lsb_release -rs 2>/dev/null | cut -d. -f1 || echo "0")
_ping_ms="" _down="" _up="" _link=""

# ── Intentar instalar speedtest si no está ───────────────────
_ensure_speedtest() {
    if command -v speedtest-cli &>/dev/null; then return 0; fi
    if command -v speedtest &>/dev/null; then return 0; fi

    echo -e "\033[1;33m  Instalando speedtest-cli...\033[0m"
    apt-get install -y python3-pip >/dev/null 2>&1

    if [[ "${_UBUNTU_VER:-0}" -ge 22 ]]; then
        pip3 install speedtest-cli --break-system-packages -q 2>/dev/null && return 0
        # Si PEP668 falla completamente, instalar en venv
        apt-get install -y python3-venv >/dev/null 2>&1
        python3 -m venv /opt/speedtest-env >/dev/null 2>&1
        /opt/speedtest-env/bin/pip install speedtest-cli -q 2>/dev/null
        ln -sf /opt/speedtest-env/bin/speedtest-cli /usr/local/bin/speedtest-cli 2>/dev/null
        command -v speedtest-cli &>/dev/null && return 0
    else
        pip3 install speedtest-cli -q 2>/dev/null && return 0
        pip install speedtest-cli -q 2>/dev/null && return 0
    fi

    # Intentar con ookla CLI
    echo -e "\033[1;33m  Intentando con Ookla CLI...\033[0m"
    curl -s https://packagecloud.io/install/repositories/ookla/speedtest-cli/script.deb.sh | bash >/dev/null 2>&1
    apt-get install -y speedtest >/dev/null 2>&1
    command -v speedtest &>/dev/null && return 0

    return 1
}

# ── Correr speedtest con timeout estricto ────────────────────
_run_speedtest() {
    local _bin _result _timeout=90

    command -v speedtest-cli &>/dev/null && _bin="speedtest-cli"
    [[ -z "$_bin" ]] && command -v speedtest &>/dev/null && _bin="speedtest"
    # venv fallback
    [[ -z "$_bin" && -f /opt/speedtest-env/bin/speedtest-cli ]] && \
        _bin="/opt/speedtest-env/bin/speedtest-cli"

    [[ -z "$_bin" ]] && return 1

    echo -e "\033[1;33m  Ejecutando prueba con $_bin...\033[0m"
    echo -e "\033[1;37m  Espere hasta 90 segundos...\033[0m"
    echo ""

    if [[ "$_bin" = "speedtest-cli" || "$_bin" = */speedtest-cli ]]; then
        # Correr con timeout y capturar salida
        _result=$(timeout $_timeout "$_bin" --simple 2>/dev/null)
        local _rc=$?
        if [[ $_rc -eq 124 ]]; then
            echo -e "\033[1;31m  Timeout — el servidor puede estar lento.\033[0m"
            return 1
        fi
        if [[ -z "$_result" ]]; then
            # Intentar sin --simple como fallback
            _result=$(timeout $_timeout "$_bin" 2>/dev/null | tail -10)
        fi
        _ping_ms=$(echo "$_result" | grep -i 'Ping\|Latencia' | grep -oP '[\d.]+\s*(ms)?' | head -1)
        _down=$(echo "$_result" | grep -i 'Download\|Descarga' | grep -oP '[\d.]+\s*\w+bit' | head -1)
        _up=$(echo "$_result" | grep -i 'Upload\|Subida' | grep -oP '[\d.]+\s*\w+bit' | head -1)
        # Link compartible (segunda llamada más rápida)
        _link=$(timeout 30 "$_bin" --share 2>/dev/null | grep -oP 'https?://\S+' | head -1)

    elif [[ "$_bin" = "speedtest" ]]; then
        # Ookla CLI — acepta licencia automáticamente
        _result=$(timeout $_timeout "$_bin" --accept-license --accept-gdpr --progress=no 2>/dev/null)
        local _rc=$?
        [[ $_rc -eq 124 ]] && { echo -e "\033[1;31m  Timeout.\033[0m"; return 1; }
        _ping_ms=$(echo "$_result" | grep -i 'Latency\|Ping\|Idle' | grep -oP '[\d.]+\s*ms' | head -1)
        _down=$(echo "$_result" | grep -i 'Download' | grep -oP '[\d.]+\s*\w+bps' | head -1)
        _up=$(echo "$_result" | grep -i 'Upload' | grep -oP '[\d.]+\s*\w+bps' | head -1)
        _link=$(echo "$_result" | grep -i 'Result URL\|Share' | grep -oP 'https?://\S+' | head -1)
    fi

    return 0
}

# ── Fallback: medir con curl si speedtest falla ───────────────
_run_curl_speedtest() {
    echo -e "\033[1;33m  Usando método alternativo con curl...\033[0m"
    echo ""

    # Ping a servidores conocidos
    _ping_ms=$(ping -c 3 -W 3 8.8.8.8 2>/dev/null | tail -1 | grep -oP '[\d.]+(?=/[\d.]+/[\d.]+)' | head -1)
    [[ -z "$_ping_ms" ]] && _ping_ms=$(ping -c 2 -W 3 1.1.1.1 2>/dev/null | tail -1 | grep -oP '[\d.]+' | head -1)

    # Download — descargar archivo de prueba y medir velocidad
    echo -e "\033[1;33m  Midiendo descarga...\033[0m"
    local _start _end _bytes _secs
    _start=$(date +%s%N)
    _bytes=$(curl -s --max-time 20 -w "%{size_download}" -o /dev/null \
        "https://speed.cloudflare.com/__down?bytes=25000000" 2>/dev/null || echo 0)
    _end=$(date +%s%N)
    _secs=$(echo "scale=3; ($_end - $_start) / 1000000000" | bc 2>/dev/null)
    if [[ -n "$_bytes" && -n "$_secs" && "$_secs" != "0" ]]; then
        _down_raw=$(echo "scale=2; ($_bytes * 8) / ($_secs * 1000000)" | bc 2>/dev/null)
        _down="${_down_raw} Mbps"
    fi

    # Upload — enviar datos y medir
    echo -e "\033[1;33m  Midiendo subida...\033[0m"
    _start=$(date +%s%N)
    _bytes_up=$(dd if=/dev/urandom bs=1M count=10 2>/dev/null | \
        curl -s --max-time 20 -w "%{speed_upload}" -o /dev/null \
        -X POST --data-binary @- "https://speed.cloudflare.com/__up" 2>/dev/null || echo 0)
    _end=$(date +%s%N)
    _secs=$(echo "scale=3; ($_end - $_start) / 1000000000" | bc 2>/dev/null)
    if [[ -n "$_bytes_up" && "$_bytes_up" != "0" ]]; then
        _up_raw=$(echo "scale=2; $_bytes_up * 8 / 1000000" | bc 2>/dev/null)
        _up="${_up_raw} Mbps"
    fi

    [[ -z "$_down" ]] && _down="N/A"
    [[ -z "$_up" ]] && _up="N/A"
    [[ -z "$_ping_ms" ]] && _ping_ms="N/A"
}

# ── Flujo principal ───────────────────────────────────────────
_ensure_speedtest
if command -v speedtest-cli &>/dev/null || command -v speedtest &>/dev/null || \
   [[ -f /opt/speedtest-env/bin/speedtest-cli ]]; then
    _run_speedtest
    # Si no obtuvo datos, usar curl
    if [[ -z "$_down" && -z "$_up" ]]; then
        echo -e "\033[1;33m  speedtest no devolvió datos, usando fallback...\033[0m"
        _run_curl_speedtest
    fi
else
    _run_curl_speedtest
fi

# ── Mostrar resultados ────────────────────────────────────────
clear
echo -e "\E[38;5;18m╭━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╮\033[0m"
echo -e "\E[38;5;18m┃\E[44;1;37m       RESULTADO DE VELOCIDAD            \E[0m\E[38;5;18m┃"
echo -e "\E[38;5;18m╰━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╯\033[0m"
echo ""
echo -e "\E[38;5;18m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
echo -e "\033[1;32mPING (LATENCIA) :\033[1;37m ${_ping_ms:-N/A}"
echo -e "\033[1;32mDESCARGA        :\033[1;37m ${_down:-N/A}"
echo -e "\033[1;32mSUBIDA          :\033[1;37m ${_up:-N/A}"
[[ -n "$_link" ]] && echo -e "\033[1;32mCOMPARTIR RESULTADO:\033[0m"
[[ -n "$_link" ]] && echo -e "\E[38;5;33m $_link\033[0m"
echo -e "\E[38;5;18m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
echo ""
echo -ne "\n\033[1;31mENTER \033[1;37mpara volver al \033[1;32mMENÚ!\033[0m"; read
