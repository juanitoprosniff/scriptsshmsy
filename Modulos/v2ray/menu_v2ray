#!/bin/bash
# ============================================================
# V2RAY/XRAY MULTI-PROTOCOL MULTI-PORT MANAGER
# Protocolos: VLESS · VMess · Trojan (WebSocket)
# Puertos HTTP: 80, 8080, 8880, 8888 (via NGINX)
# Puertos SSL:  443, 444, 8443        (via NGINX + TLS)
# Integración: SSH WS + SSL tunnel sin interferencia
# ============================================================

# ── Colores ──────────────────────────────────────────────────
RED='\033[0;31m';    GREEN='\033[0;32m';  YELLOW='\033[1;33m'
BLUE='\033[0;34m';   CYAN='\033[0;36m';  PURPLE='\033[0;35m'
WHITE='\033[1;37m';  NC='\033[0m'
C1='\E[38;5;18m';    C2='\E[38;5;196m';  C3='\E[38;5;33m'
C4='\E[38;5;195m';   C5='\E[38;5;40m'

# ── Rutas ────────────────────────────────────────────────────
XRAY_BIN="/usr/local/bin/xray"
XRAY_DIR="/etc/xray"
XRAY_CFG="$XRAY_DIR/config.json"
XRAY_DB="$XRAY_DIR/users.db"
XRAY_DOMAIN_FILE="$XRAY_DIR/domain.conf"
NGINX_HTTP_CONF="/etc/nginx/conf.d/xray-http.conf"
NGINX_SSL_CONF="/etc/nginx/conf.d/xray-ssl.conf"
XRAY_PORT_VLESS=10085
XRAY_PORT_VMESS=10086
XRAY_PORT_TROJAN=10087
WSPROXY_INT=2082
NGINX_INT=8000

# ── Utilidades internas ───────────────────────────────────────

_xray_installed() {
    [[ -x "$XRAY_BIN" && -f "$XRAY_CFG" ]]
}

_xray_running() {
    systemctl is-active --quiet xray 2>/dev/null
}

_gen_uuid() {
    if command -v uuidgen &>/dev/null; then
        uuidgen | tr '[:upper:]' '[:lower:]'
    else
        cat /proc/sys/kernel/random/uuid 2>/dev/null || \
        python3 -c "import uuid; print(str(uuid.uuid4()))"
    fi
}

_get_server_ip() {
    cat /etc/IP 2>/dev/null || \
    curl -s4 ifconfig.me 2>/dev/null || \
    hostname -I 2>/dev/null | awk '{print $1}'
}

_get_domain() {
    [[ -f "$XRAY_DOMAIN_FILE" ]] && head -1 "$XRAY_DOMAIN_FILE" || _get_server_ip
}

_get_tls_enabled() {
    [[ -f "$XRAY_DOMAIN_FILE" ]] && grep -q "^tls=yes" "$XRAY_DOMAIN_FILE"
}

_get_cert_file() {
    [[ -f "$XRAY_DOMAIN_FILE" ]] && grep "^cert=" "$XRAY_DOMAIN_FILE" | cut -d= -f2
}

_get_key_file() {
    [[ -f "$XRAY_DOMAIN_FILE" ]] && grep "^key=" "$XRAY_DOMAIN_FILE" | cut -d= -f2
}

_pause() {
    echo -ne "\n${C2}» ${WHITE}ENTER ${NC}para continuar: "; read -r
}

_header() {
    clear
    echo -e "${C1}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
    echo -e "${C1}┃${NC}\E[44;1;37m            V2RAY / XRAY MULTI-PORT MANAGER            ${NC}${C1}┃${NC}"
    echo -e "${C1}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
}

# ── Manipulación de config.json con Python3 ───────────────────

_xray_add_user_cfg() {
    local uuid="$1" name="$2"
    python3 - "$uuid" "$name" "$XRAY_CFG" <<'PYEOF'
import json, sys
uuid, name, cfg_path = sys.argv[1], sys.argv[2], sys.argv[3]
with open(cfg_path) as f: cfg = json.load(f)
for ib in cfg['inbounds']:
    proto = ib.get('protocol','')
    client = {'email': name, 'level': 0}
    if proto in ('vless',):
        client['id'] = uuid
        client['encryption'] = 'none'
    elif proto == 'vmess':
        client['id'] = uuid
        client['alterId'] = 0
    elif proto == 'trojan':
        client['password'] = uuid  # UUID como contraseña Trojan
    ib['settings']['clients'].append(client)
with open(cfg_path, 'w') as f: json.dump(cfg, f, indent=2)
print("OK")
PYEOF
}

_xray_del_user_cfg() {
    local uuid="$1"
    python3 - "$uuid" "$XRAY_CFG" <<'PYEOF'
import json, sys
uuid, cfg_path = sys.argv[1], sys.argv[2]
with open(cfg_path) as f: cfg = json.load(f)
for ib in cfg['inbounds']:
    clients = ib['settings'].get('clients', [])
    ib['settings']['clients'] = [
        c for c in clients
        if c.get('id', c.get('password','')) != uuid
    ]
with open(cfg_path, 'w') as f: json.dump(cfg, f, indent=2)
print("OK")
PYEOF
}

_xray_list_users_cfg() {
    python3 - "$XRAY_CFG" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f: cfg = json.load(f)
ids = {}
for ib in cfg['inbounds']:
    for c in ib['settings'].get('clients', []):
        uid = c.get('id', c.get('password',''))
        email = c.get('email', uid[:8])
        if uid not in ids:
            ids[uid] = email
for uid, email in ids.items():
    print(f"{uid}|{email}")
PYEOF
}

# ── Config URI generators ─────────────────────────────────────

_uri_vless_nontls() {
    local uuid="$1" name="$2" server="$3" port="$4" path="$5" sni_host="$6"
    local host_hdr="${sni_host:-$server}"
    printf 'vless://%s@%s:%s?encryption=none&security=none&type=ws&path=%s&host=%s#%s\n' \
        "$uuid" "$server" "$port" "$path" "$host_hdr" "$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name'))")"
}

_uri_vless_tls() {
    local uuid="$1" name="$2" server="$3" port="$4" path="$5" domain="$6" sni="$7"
    local sni_val="${sni:-$domain}"
    printf 'vless://%s@%s:%s?encryption=none&security=tls&sni=%s&type=ws&path=%s&host=%s&allowInsecure=1#%s\n' \
        "$uuid" "$server" "$port" "$sni_val" "$path" "$domain" "$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name'))")"
}

_uri_vmess() {
    local uuid="$1" name="$2" server="$3" port="$4" path="$5" tls="$6" sni_host="$7"
    local host_hdr="${sni_host:-$server}"
    local security="${tls:-none}"
    local sni_val="${sni_host:-$server}"
    local json
    json=$(python3 -c "
import json, base64
d = {
    'v':'2', 'ps':'$name', 'add':'$server', 'port':'$port',
    'id':'$uuid', 'aid':'0', 'scy':'auto', 'net':'ws',
    'type':'none', 'host':'$host_hdr', 'path':'$path',
    'tls':'$security', 'sni':'$sni_val', 'alpn':''
}
print(base64.b64encode(json.dumps(d).encode()).decode())
")
    echo "vmess://$json"
}

_uri_trojan_nontls() {
    local uuid="$1" name="$2" server="$3" port="$4" path="$5" sni_host="$6"
    local host_hdr="${sni_host:-$server}"
    printf 'trojan://%s@%s:%s?security=none&type=ws&path=%s&host=%s#%s\n' \
        "$uuid" "$server" "$port" "$path" "$host_hdr" "$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name'))")"
}

_uri_trojan_tls() {
    local uuid="$1" name="$2" server="$3" port="$4" path="$5" domain="$6" sni="$7"
    local sni_val="${sni:-$domain}"
    printf 'trojan://%s@%s:%s?security=tls&sni=%s&type=ws&path=%s&host=%s&allowInsecure=1#%s\n' \
        "$uuid" "$server" "$port" "$sni_val" "$path" "$domain" "$(python3 -c "import urllib.parse; print(urllib.parse.quote('$name'))")"
}

# ── Mostrar URIs para un usuario ──────────────────────────────

_show_user_uris() {
    local uuid="$1" name="$2"
    local server domain tls_on sni_host bug_host rev_sni

    server=$(_get_server_ip)
    domain=$(_get_domain)
    tls_on=$(_get_tls_enabled && echo "yes" || echo "no")

    _header
    echo -e ""
    echo -e "${WHITE}  Usuario : ${CYAN}$name${NC}"
    echo -e "${WHITE}  UUID    : ${YELLOW}$uuid${NC}"
    echo ""

    # Preguntar modo SNI/Bug
    echo -e "${WHITE}  ¿Configuración de SNI / Bug host?${NC}"
    echo -e "  ${CYAN}[1]${NC} Normal (sin bug host)"
    echo -e "  ${CYAN}[2]${NC} SNI / Bug host (CDN bypass)"
    echo -e "  ${CYAN}[3]${NC} Reverse SNI (dominio como dirección, bug como SNI)"
    echo -ne "\n  Elige [1-3]: "; read -r sni_mode

    case "$sni_mode" in
        2)
            echo -ne "  Bug host / SNI (ej: bug.cloudflare.com): "; read -r bug_host
            sni_host="${bug_host:-$server}"
            ;;
        3)
            echo -ne "  Bug host para SNI (ej: bug.cloudflare.com): "; read -r bug_host
            server="$domain"
            sni_host="${bug_host:-$domain}"
            rev_sni="yes"
            ;;
    esac

    echo ""
    echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${WHITE}  CONFIGS SIN TLS  (puertos: 80, 8080, 8880, 8888)${NC}"
    echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    for port in 80 8080 8880 8888; do
        echo ""
        echo -e "${YELLOW}  ── Puerto $port ──${NC}"

        echo -e "${CYAN}  [VLESS]${NC}"
        echo "  $(_uri_vless_nontls "$uuid" "$name" "$server" "$port" "/vless" "$sni_host")"

        echo -e "${CYAN}  [VMess]${NC}"
        echo "  $(_uri_vmess "$uuid" "$name" "$server" "$port" "/vmess" "none" "$sni_host")"

        echo -e "${CYAN}  [Trojan]${NC}"
        echo "  $(_uri_trojan_nontls "$uuid" "$name" "$server" "$port" "/trojan" "$sni_host")"
    done

    if [[ "$tls_on" == "yes" ]]; then
        echo ""
        echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${WHITE}  CONFIGS CON TLS  (puertos: 443, 444, 8443)${NC}"
        echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

        for port in 443 444 8443; do
            echo ""
            echo -e "${YELLOW}  ── Puerto $port (TLS) ──${NC}"
            local tls_server="${rev_sni:+$domain}"
            tls_server="${tls_server:-$server}"

            echo -e "${CYAN}  [VLESS+TLS]${NC}"
            echo "  $(_uri_vless_tls "$uuid" "$name" "$tls_server" "$port" "/vless" "$domain" "$sni_host")"

            echo -e "${CYAN}  [VMess+TLS]${NC}"
            echo "  $(_uri_vmess "$uuid" "$name" "$tls_server" "$port" "/vmess" "tls" "$sni_host")"

            echo -e "${CYAN}  [Trojan+TLS]${NC}"
            echo "  $(_uri_trojan_tls "$uuid" "$name" "$tls_server" "$port" "/trojan" "$domain" "$sni_host")"
        done
    fi

    echo ""
    _pause
}

# ── INSTALAR V2RAY/XRAY ───────────────────────────────────────

_detect_arch() {
    case "$(uname -m)" in
        x86_64|amd64)  echo "64" ;;
        aarch64|arm64) echo "arm64-v8a" ;;
        armv7*|armhf)  echo "arm32-v7a" ;;
        *)             echo "64" ;;
    esac
}

_install_deps_v2ray() {
    echo -ne "  ${YELLOW}Instalando dependencias...${NC} "
    apt-get update -qq >/dev/null 2>&1
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \
        nginx curl wget unzip jq openssl qrencode >/dev/null 2>&1
    echo -e "${GREEN}OK${NC}"
}

_download_xray() {
    echo -ne "  ${YELLOW}Descargando XRay...${NC} "
    local arch
    arch=$(_detect_arch)
    local api_url="https://api.github.com/repos/XTLS/Xray-core/releases/latest"
    local dl_url
    dl_url=$(curl -s --connect-timeout 10 "$api_url" 2>/dev/null | \
        grep "browser_download_url" | grep "Xray-linux-${arch}\.zip" | \
        head -1 | cut -d'"' -f4)

    if [[ -z "$dl_url" ]]; then
        dl_url="https://github.com/XTLS/Xray-core/releases/download/v25.4.30/Xray-linux-${arch}.zip"
    fi

    cd /tmp || return 1
    rm -rf xray_extract xray.zip
    if wget -q -O xray.zip "$dl_url" 2>/dev/null && [[ -s xray.zip ]]; then
        unzip -q xray.zip -d xray_extract 2>/dev/null
        install -m755 xray_extract/xray "$XRAY_BIN"
        rm -rf xray_extract xray.zip
        echo -e "${GREEN}OK  ($(${XRAY_BIN} version 2>/dev/null | head -1 | awk '{print $2}'))${NC}"
    else
        echo -e "${RED}FALLO - Verifica conexión a internet${NC}"
        return 1
    fi

    mkdir -p /usr/local/share/xray
    {
        wget -q -O /usr/local/share/xray/geoip.dat \
            "https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat" 2>/dev/null
        wget -q -O /usr/local/share/xray/geosite.dat \
            "https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat" 2>/dev/null
    } &
}

