    echo -e "  ${C2}|${C3}00${C2}|${NC}➜ ${C4}VOLVER${NC}"
    echo -ne "\n  ${C5}¿QUÉ DESEAS HACER ??: ${NC}"; read -r o

    case "$o" in
        1|01)  instalar_v2ray ;;
        2|02)  _xray_installed && v2ray_add_user      || { echo -e "  ${RED}Instala XRay primero (opción 01)${NC}"; sleep 2; } ;;
        3|03)  _xray_installed && v2ray_list_users    || { echo -e "  ${RED}Instala XRay primero${NC}"; sleep 2; } ;;
        4|04)  _xray_installed && v2ray_del_user      || { echo -e "  ${RED}Instala XRay primero${NC}"; sleep 2; } ;;
        5|05)  _xray_installed && v2ray_show_uris     || { echo -e "  ${RED}Instala XRay primero${NC}"; sleep 2; } ;;
        6|06)  _xray_installed && v2ray_change_ports  || { echo -e "  ${RED}Instala XRay primero${NC}"; sleep 2; } ;;
        7|07)  _xray_installed && v2ray_config_tls    || { echo -e "  ${RED}Instala XRay primero${NC}"; sleep 2; } ;;
        8|08)  v2ray_status ;;
        9|09)  _xray_installed && v2ray_restart_xray  || { echo -e "  ${RED}Instala XRay primero${NC}"; sleep 2; } ;;
        10)    v2ray_restart_nginx ;;
        11)    _xray_installed && v2ray_stop          || { echo -e "  ${RED}XRay no está instalado${NC}"; sleep 2; } ;;
        12)    _xray_installed && v2ray_uninstall     || { echo -e "  ${YELLOW}XRay no está instalado${NC}"; sleep 2; } ;;
        13)    v2ray_reparar ;;
        0|00)  return ;;
