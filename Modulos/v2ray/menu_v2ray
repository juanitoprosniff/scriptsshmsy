# ── DESINSTALAR ───────────────────────────────────────────────

v2ray_uninstall() {
    _header
    echo ""
    echo -e "  ${RED}┌─────────────────────────────────────────┐${NC}"
    echo -e "  ${RED}│     ¡ATENCIÓN! Desinstalando V2Ray     │${NC}"
    echo -e "  ${RED}└─────────────────────────────────────────┘${NC}"
    echo ""
    echo -ne "  ${RED}¿Confirmas la desinstalación? (escribe SI): ${NC}"; read -r confirm
    [[ "$confirm" != "SI" ]] && { echo -e "  ${YELLOW}Cancelado.${NC}"; sleep 1; return; }

    systemctl stop xray  >/dev/null 2>&1
    systemctl disable xray >/dev/null 2>&1
    rm -f /etc/systemd/system/xray.service
    systemctl daemon-reload >/dev/null 2>&1
    rm -f "$XRAY_BIN"
    rm -f "$NGINX_HTTP_CONF" "$NGINX_SSL_CONF"

    # Restaurar stunnel si hay backup
    [[ -f /etc/stunnel/stunnel.conf.xray_bak ]] && \
        cp /etc/stunnel/stunnel.conf.xray_bak /etc/stunnel/stunnel.conf && \
        systemctl restart stunnel4 >/dev/null 2>&1

    # Restaurar wsproxy en puertos externos
    local wsproxy_path
    wsproxy_path=$(find /etc/SSHPlus /etc -name "wsproxy.py" 2>/dev/null | head -1)
    if [[ -n "$wsproxy_path" && -f /etc/autostart ]]; then
        sed -i "/wsproxy.*\.py\s\+${WSPROXY_INT}/d" /etc/autostart
        echo "screen -dmS ws80 python3 ${wsproxy_path} 80" >> /etc/autostart
        screen -dmS ws80 python3 "$wsproxy_path" 80
    fi

    nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1

    echo -e "\n  ${GREEN}✓ V2Ray/XRay desinstalado.${NC}"
    echo -e "  ${YELLOW}  Los datos en $XRAY_DIR no fueron eliminados.${NC}"
    sleep 3
}

