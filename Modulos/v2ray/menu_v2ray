    _tls_active     && ts="${GREEN}TLS ON${NC}" || ts="${YELLOW}TLS OFF${NC}"
    uc=$(wc -l < "$XRAY_DB" 2>/dev/null || echo 0)

    echo -e "  ${WHITE}XRay: ${xs}  NGINX: ${ns}  ${ts}  Usuarios: ${WHITE}${uc}${NC}  ${is}"
