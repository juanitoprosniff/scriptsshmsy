#!/bin/bash
# ============================================================
# V2RAY / XRAY 1.8.23 — Manager simplificado
# Protocolos: VLESS + VMess (WebSocket)
# Diseño: puertos DEDICADOS, no interfiere con
#         wsproxy / stunnel / ssldispatcher / Dropbear
# NGINX/TLS son OPCIONALES y van en sus propios puertos
# ============================================================

RED='\033[0;31m';    GREEN='\033[0;32m';  YELLOW='\033[1;33m'
BLUE='\033[0;34m';   CYAN='\033[0;36m';  PURPLE='\033[0;35m'
WHITE='\033[1;37m';  NC='\033[0m'
C1='\E[38;5;18m';    C2='\E[38;5;196m';  C3='\E[38;5;33m'
C4='\E[38;5;195m';   C5='\E[38;5;40m'

# ── Rutas y constantes ───────────────────────────────────────
XRAY_BIN="/usr/local/bin/xray"
XRAY_DIR="/etc/xray"
XRAY_CFG="$XRAY_DIR/config.json"
XRAY_DB="$XRAY_DIR/users.db"
XRAY_PORTS_FILE="$XRAY_DIR/ports.conf"
XRAY_DOMAIN_FILE="$XRAY_DIR/domain.conf"

# Versión recomendada y estable de XRay (V2Ray-core fork)
XRAY_VERSION="v1.8.23"

# Puertos DEDICADOS por defecto (no chocan con wsproxy/stunnel/SSH)
DEFAULT_VLESS_PORT=2080
DEFAULT_VMESS_PORT=2095
DEFAULT_TLS_PORT=2096

# Path WebSocket (fijo, simple)
VLESS_PATH="/vlessws"
VMESS_PATH="/vmessws"

NGINX_CONF_V2="/etc/nginx/conf.d/v2ray-tls.conf"

# ── Helpers ──────────────────────────────────────────────────

_xray_installed()   { [[ -x "$XRAY_BIN" && -f "$XRAY_CFG" ]]; }
_xray_running()     { systemctl is-active --quiet xray 2>/dev/null; }
_nginx_installed()  { command -v nginx &>/dev/null; }
_nginx_running()    { systemctl is-active --quiet nginx 2>/dev/null; }

_gen_uuid() {
    if command -v uuidgen &>/dev/null; then
        uuidgen | tr '[:upper:]' '[:lower:]'
    elif [[ -r /proc/sys/kernel/random/uuid ]]; then
        cat /proc/sys/kernel/random/uuid
    else
        python3 -c "import uuid; print(str(uuid.uuid4()))"
    fi
}

_get_ip() {
    cat /etc/IP 2>/dev/null || \
    curl -s4 --connect-timeout 5 ifconfig.me 2>/dev/null || \
    hostname -I 2>/dev/null | awk '{print $1}'
}

_load_ports() {
    if [[ -f "$XRAY_PORTS_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$XRAY_PORTS_FILE"
    else
        VLESS_PORT=$DEFAULT_VLESS_PORT
        VMESS_PORT=$DEFAULT_VMESS_PORT
        TLS_PORT=$DEFAULT_TLS_PORT
    fi
}

_save_ports() {
    mkdir -p "$XRAY_DIR"
    cat > "$XRAY_PORTS_FILE" <<EOF
VLESS_PORT=${VLESS_PORT}
VMESS_PORT=${VMESS_PORT}
TLS_PORT=${TLS_PORT}
EOF
}

_get_domain() {
    [[ -f "$XRAY_DOMAIN_FILE" ]] && grep "^domain=" "$XRAY_DOMAIN_FILE" 2>/dev/null | cut -d= -f2
}

_tls_active() {
    [[ -f "$XRAY_DOMAIN_FILE" ]] && grep -q "^tls=yes" "$XRAY_DOMAIN_FILE" 2>/dev/null
}

_port_in_use() {
    local p="$1"
    ss -tlpn 2>/dev/null | grep -q ":${p}\b"
}

_pause() { echo -ne "\n${C2}» ${WHITE}ENTER ${NC}para continuar: "; read -r; }

_header() {
    clear
    echo -e "${C1}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
    echo -e "${C1}┃${NC}\E[44;1;37m            V2RAY / XRAY — VLESS + VMess               ${NC}${C1}┃${NC}"
    echo -e "${C1}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
}

# ── Detección de arquitectura ────────────────────────────────
_arch_xray() {
    case "$(uname -m)" in
        x86_64|amd64)   echo "64" ;;
        aarch64|arm64)  echo "arm64-v8a" ;;
        armv7*|armhf)   echo "arm32-v7a" ;;
        armv6*)         echo "arm32-v6" ;;
        *)              echo "64" ;;
    esac
}

# ── Manipulación del config con Python3 ──────────────────────

_cfg_add_user() {
    local uuid="$1" name="$2"
    python3 - "$uuid" "$name" "$XRAY_CFG" <<'PYEOF'
import json, sys
uuid, name, p = sys.argv[1], sys.argv[2], sys.argv[3]
with open(p) as f: cfg = json.load(f)
for ib in cfg['inbounds']:
    proto = ib.get('protocol','')
    if proto == 'vless':
        ib['settings']['clients'].append({'id': uuid, 'email': name, 'level': 0})
    elif proto == 'vmess':
        ib['settings']['clients'].append({'id': uuid, 'email': name, 'alterId': 0, 'level': 0})
with open(p, 'w') as f: json.dump(cfg, f, indent=2)
PYEOF
}

_cfg_del_user() {
    local uuid="$1"
    python3 - "$uuid" "$XRAY_CFG" <<'PYEOF'
import json, sys
uuid, p = sys.argv[1], sys.argv[2]
with open(p) as f: cfg = json.load(f)
for ib in cfg['inbounds']:
    ib['settings']['clients'] = [c for c in ib['settings'].get('clients', [])
                                  if c.get('id') != uuid]
with open(p, 'w') as f: json.dump(cfg, f, indent=2)
PYEOF
}

# ── Generador de URIs (UNA por usuario / protocolo) ───────────

_uri_vless() {
    local uuid="$1" name="$2" addr="$3" port="$4" host_hdr="$5" sni="$6" tls="$7"
    local sec="none" sni_arg=""
    if [[ "$tls" == "yes" ]]; then
        sec="tls"; sni_arg="&sni=${sni:-$host_hdr}&allowInsecure=1"
    fi
    local enc_name
    enc_name=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$name")
    printf 'vless://%s@%s:%s?encryption=none&security=%s&type=ws&path=%s&host=%s%s#%s\n' \
        "$uuid" "$addr" "$port" "$sec" "$VLESS_PATH" "$host_hdr" "$sni_arg" "$enc_name"
}

_uri_vmess() {
    local uuid="$1" name="$2" addr="$3" port="$4" host_hdr="$5" sni="$6" tls="$7"
    local tls_val="" sni_val=""
    [[ "$tls" == "yes" ]] && tls_val="tls" && sni_val="${sni:-$host_hdr}"
    python3 - "$uuid" "$name" "$addr" "$port" "$host_hdr" "$VMESS_PATH" "$tls_val" "$sni_val" <<'PYEOF'
import json, base64, sys
uid, name, addr, port, host, path, tls, sni = sys.argv[1:9]
d = {
    "v":"2","ps":name,"add":addr,"port":port,
    "id":uid,"aid":"0","scy":"auto","net":"ws",
    "type":"none","host":host,"path":path,
    "tls":tls,"sni":sni,"alpn":""
}
print("vmess://" + base64.b64encode(json.dumps(d).encode()).decode())
PYEOF
}

# ── INSTALAR XRay ─────────────────────────────────────────────

_install_deps() {
    echo -ne "  ${YELLOW}Instalando dependencias...${NC} "
    apt-get update -qq >/dev/null 2>&1
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \
        curl wget unzip jq openssl python3 >/dev/null 2>&1
    echo -e "${GREEN}OK${NC}"
}

_download_xray() {
    echo -ne "  ${YELLOW}Descargando XRay ${XRAY_VERSION}...${NC} "
    local arch dl_url
    arch=$(_arch_xray)
    dl_url="https://github.com/XTLS/Xray-core/releases/download/${XRAY_VERSION}/Xray-linux-${arch}.zip"

    cd /tmp || return 1
    rm -rf xray_dl xray.zip

    if ! wget -q --timeout=60 -O xray.zip "$dl_url" 2>/dev/null || [[ ! -s xray.zip ]]; then
        # Fallback al último release
        echo -ne "${YELLOW}fallback...${NC} "
        local api="https://api.github.com/repos/XTLS/Xray-core/releases/latest"
        dl_url=$(curl -s --connect-timeout 10 "$api" 2>/dev/null | \
            grep "browser_download_url" | grep "Xray-linux-${arch}\.zip" | head -1 | cut -d'"' -f4)
        [[ -n "$dl_url" ]] && wget -q --timeout=60 -O xray.zip "$dl_url" 2>/dev/null
    fi

    if [[ -s xray.zip ]]; then
        unzip -q xray.zip -d xray_dl
        install -m755 xray_dl/xray "$XRAY_BIN"
        rm -rf xray_dl xray.zip
        echo -e "${GREEN}OK  ($("$XRAY_BIN" version 2>/dev/null | head -1 | awk '{print $2}'))${NC}"
        return 0
    else
        echo -e "${RED}FALLO — Verifica internet${NC}"
        return 1
    fi
}

_create_config() {
    mkdir -p "$XRAY_DIR" /var/log/xray
    [[ -f "$XRAY_DB" ]] || touch "$XRAY_DB"
    _load_ports

    cat > "$XRAY_CFG" <<EOF
{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error":  "/var/log/xray/error.log"
  },
  "inbounds": [
    {
      "port": ${VLESS_PORT},
      "listen": "0.0.0.0",
      "protocol": "vless",
      "tag": "vless-in",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": { "path": "${VLESS_PATH}" }
      }
    },
    {
      "port": ${VMESS_PORT},
      "listen": "0.0.0.0",
      "protocol": "vmess",
      "tag": "vmess-in",
      "settings": { "clients": [] },
      "streamSettings": {
        "network": "ws",
        "wsSettings": { "path": "${VMESS_PATH}" }
      }
    }
  ],
  "outbounds": [
    { "protocol": "freedom",   "tag": "direct"  },
    { "protocol": "blackhole", "tag": "blocked" }
  ],
  "routing": {
    "rules": [
      { "type": "field", "ip": ["geoip:private"], "outboundTag": "blocked" }
    ]
  }
}
EOF
}

_create_systemd() {
    cat > /etc/systemd/system/xray.service <<'EOF'
[Unit]
Description=Xray Service
Documentation=https://github.com/XTLS/Xray-core
After=network.target nss-lookup.target

[Service]
User=root
ExecStart=/usr/local/bin/xray run -c /etc/xray/config.json
Restart=on-failure
RestartSec=5
LimitNOFILE=1000000

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable xray >/dev/null 2>&1
}

_fw_open() {
    for p in "$@"; do
        command -v ufw &>/dev/null && ufw allow "${p}/tcp" >/dev/null 2>&1
        command -v iptables &>/dev/null && {
            iptables -C INPUT -p tcp --dport "${p}" -j ACCEPT 2>/dev/null || \
            iptables -I INPUT -p tcp --dport "${p}" -j ACCEPT >/dev/null 2>&1
        }
    done
}

instalar_v2ray() {
    _header
    echo ""
    if _xray_installed; then
        echo -e "  ${YELLOW}XRay ya está instalado.${NC}"
        echo -ne "  ¿Reinstalar? (s/N): "; read -r ans
        [[ ! "$ans" =~ ^[sS]$ ]] && return
        systemctl stop xray 2>/dev/null
    fi

    # Pedir puertos
    echo ""
    echo -e "  ${WHITE}Puertos para V2Ray ${C4}(dedicados, no comparte con SSH/SSL/wsproxy)${NC}"
    echo -ne "  Puerto VLESS [${DEFAULT_VLESS_PORT}]: "; read -r p1
    echo -ne "  Puerto VMess [${DEFAULT_VMESS_PORT}]: "; read -r p2
    VLESS_PORT=${p1:-$DEFAULT_VLESS_PORT}
    VMESS_PORT=${p2:-$DEFAULT_VMESS_PORT}
    TLS_PORT=$DEFAULT_TLS_PORT

    # Verificar conflictos
    for pt in "$VLESS_PORT" "$VMESS_PORT"; do
        if _port_in_use "$pt"; then
            echo -e "  ${RED}⚠ Puerto $pt ya está en uso por otro servicio.${NC}"
            echo -ne "  ¿Continuar de todas formas? (s/N): "; read -r ok
            [[ ! "$ok" =~ ^[sS]$ ]] && return
        fi
    done

    echo ""
    _install_deps
    _download_xray || { echo -e "${RED}Abortando instalación.${NC}"; sleep 2; return 1; }

    echo -ne "  ${YELLOW}Creando configuración...${NC} "
    _create_config
    _save_ports
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Creando servicio systemd...${NC} "
    _create_systemd
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Abriendo puertos firewall (${VLESS_PORT}, ${VMESS_PORT})...${NC} "
    _fw_open "$VLESS_PORT" "$VMESS_PORT"
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Iniciando XRay...${NC} "
    systemctl start xray
    sleep 2
    if _xray_running; then
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}FALLO${NC}"
        echo -e "  ${YELLOW}Revisa: journalctl -u xray --no-pager -n 30${NC}"
    fi

    echo "$(date '+%Y-%m-%d %H:%M:%S')" > "$XRAY_DIR/installed"

    echo ""
    echo -e "${GREEN}  ┌───────────────────────────────────────────────────┐${NC}"
    echo -e "${GREEN}  │   ✓  V2Ray/XRay instalado y funcionando!          │${NC}"
    echo -e "${GREEN}  └───────────────────────────────────────────────────┘${NC}"
    echo ""
    echo -e "  ${WHITE}VLESS WS  → puerto ${CYAN}${VLESS_PORT}${WHITE}  path ${CYAN}${VLESS_PATH}${NC}"
    echo -e "  ${WHITE}VMess WS  → puerto ${CYAN}${VMESS_PORT}${WHITE}  path ${CYAN}${VMESS_PATH}${NC}"
    echo ""
    echo -e "  ${C4}► SSH / wsproxy / stunnel siguen funcionando normal.${NC}"
    echo -e "  ${C4}► Para TLS (HTTPS) usa la opción 07 del menú.${NC}"
    echo ""
    _pause
}

# ── GESTIÓN DE USUARIOS ───────────────────────────────────────

v2ray_add_user() {
    _header; echo ""
    echo -ne "  ${C5}Nombre del usuario: ${NC}"; read -r uname
    [[ -z "$uname" ]] && { echo -e "${RED}  Nombre vacío${NC}"; sleep 2; return; }

    # No permitir duplicados de nombre
    if grep -q "|${uname}$" "$XRAY_DB" 2>/dev/null; then
        echo -e "  ${RED}Ya existe un usuario con ese nombre.${NC}"; sleep 2; return
    fi

    local uuid
    uuid=$(_gen_uuid)
    echo -e "  ${WHITE}UUID generado: ${YELLOW}${uuid}${NC}"
    echo -ne "  ¿Usar UUID personalizado en su lugar? (s/N): "; read -r alt
    if [[ "$alt" =~ ^[sS]$ ]]; then
        echo -ne "  Ingresa UUID: "; read -r cu
        [[ -n "$cu" ]] && uuid="$cu"
    fi

    echo -ne "\n  ${YELLOW}Agregando usuario...${NC} "
    _cfg_add_user "$uuid" "$uname"
    echo "${uuid}|${uname}" >> "$XRAY_DB"
    systemctl restart xray >/dev/null 2>&1
    sleep 1
    if _xray_running; then
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}XRay falló al reiniciar — revisa config${NC}"
    fi

    echo ""
    echo -e "  ${WHITE}Usuario : ${CYAN}${uname}${NC}"
    echo -e "  ${WHITE}UUID    : ${YELLOW}${uuid}${NC}"
    echo ""
    echo -ne "  ${C5}¿Mostrar configuración (URI) ahora? (S/n): ${NC}"; read -r sh
    [[ ! "$sh" =~ ^[nN]$ ]] && _show_uri "$uuid" "$uname"
}

v2ray_list_users() {
    _header; echo ""
    if [[ ! -s "$XRAY_DB" ]]; then
        echo -e "  ${YELLOW}No hay usuarios registrados.${NC}"; _pause; return
    fi
    echo -e "  ${WHITE} #   UUID                                   Nombre${NC}"
    echo -e "  ${C1}─────────────────────────────────────────────────────${NC}"
    local i=1
    while IFS='|' read -r uuid name; do
        [[ -z "$uuid" ]] && continue
        printf "  ${CYAN}%-3s${NC} ${YELLOW}%-38s${NC} ${WHITE}%s${NC}\n" "$i" "$uuid" "$name"
        ((i++))
    done < "$XRAY_DB"
    _pause
}

v2ray_del_user() {
    _header; echo ""
    if [[ ! -s "$XRAY_DB" ]]; then
        echo -e "  ${YELLOW}No hay usuarios.${NC}"; _pause; return
    fi
    local -a uuids names
    local i=1
    while IFS='|' read -r uuid name; do
        [[ -z "$uuid" ]] && continue
        printf "  ${C2}|${C3}%-3s${C2}|${NC} ${WHITE}%-38s${NC} ${CYAN}%s${NC}\n" "$i" "$uuid" "$name"
        uuids+=("$uuid"); names+=("$name"); ((i++))
    done < "$XRAY_DB"
    echo ""
    echo -ne "  ${C5}Número a eliminar (0=cancelar): ${NC}"; read -r sel
    [[ "$sel" == "0" || -z "$sel" ]] && return
    local idx=$((sel-1)) u="${uuids[$((sel-1))]}" n="${names[$((sel-1))]}"
    [[ -z "$u" ]] && { echo -e "${RED}  Selección inválida${NC}"; sleep 2; return; }
    echo -ne "  ${RED}¿Eliminar a ${WHITE}${n}${RED}? (s/N): ${NC}"; read -r ok
    [[ ! "$ok" =~ ^[sS]$ ]] && return
    echo -ne "  ${YELLOW}Eliminando...${NC} "
    _cfg_del_user "$u"
    local tmp; tmp=$(mktemp)
    grep -v "^${u}|" "$XRAY_DB" > "$tmp" && mv "$tmp" "$XRAY_DB"
    systemctl restart xray >/dev/null 2>&1
    echo -e "${GREEN}OK${NC}"; sleep 2
}

# ── MOSTRAR URI (una sola, simple, con opciones SNI/Bug) ─────

_show_uri() {
    local uuid="$1" name="$2"
    _load_ports
    local ip domain tls_on
    ip=$(_get_ip)
    domain=$(_get_domain)
    _tls_active && tls_on="yes" || tls_on="no"

    _header
    echo ""
    echo -e "  ${WHITE}Usuario : ${CYAN}${name}${NC}"
    echo -e "  ${WHITE}UUID    : ${YELLOW}${uuid}${NC}"
    echo ""

    # Modo SNI
    echo -e "  ${WHITE}¿Modo de conexión?${NC}"
    echo -e "  ${CYAN}[1]${NC} Normal (server = IP del VPS)"
    echo -e "  ${CYAN}[2]${NC} SNI / Bug host (CDN bypass)"
    echo -e "  ${CYAN}[3]${NC} Reverse SNI (dominio como dirección, bug como SNI)"
    echo -ne "  Elige [1-3]: "; read -r mode

    local addr="$ip" host_hdr="$ip" sni=""
    case "$mode" in
        2)
            echo -ne "  Bug host / SNI (ej: bug.cloudflare.com): "; read -r bug
            addr="${bug:-$ip}"
            host_hdr="${domain:-$ip}"
            sni="$host_hdr"
            ;;
        3)
            echo -ne "  Bug host para SNI: "; read -r bug
            [[ -z "$domain" ]] && domain="$ip"
            addr="$domain"
            host_hdr="$domain"
            sni="${bug:-$domain}"
            ;;
    esac

    # Sin TLS
    echo ""
    echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${WHITE}  CONFIGURACIÓN SIN TLS${NC}"
    echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "  ${CYAN}[VLESS]${NC} puerto ${YELLOW}${VLESS_PORT}${NC}  path ${YELLOW}${VLESS_PATH}${NC}"
    echo -e "  $(_uri_vless "$uuid" "$name" "$addr" "$VLESS_PORT" "$host_hdr" "$sni" "no")"
    echo ""
    echo -e "  ${CYAN}[VMess]${NC} puerto ${YELLOW}${VMESS_PORT}${NC}  path ${YELLOW}${VMESS_PATH}${NC}"
    echo -e "  $(_uri_vmess "$uuid" "$name" "$addr" "$VMESS_PORT" "$host_hdr" "$sni" "no")"

    # Con TLS (si está activo)
    if [[ "$tls_on" == "yes" ]]; then
        local tls_addr="$addr"
        # En modo normal y dominio configurado, usa el dominio para TLS
        [[ "$mode" != "2" && "$mode" != "3" && -n "$domain" ]] && tls_addr="$domain"

        echo ""
        echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${WHITE}  CONFIGURACIÓN CON TLS  (NGINX puerto ${TLS_PORT})${NC}"
        echo -e "${C1}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        echo -e "  ${CYAN}[VLESS+TLS]${NC} puerto ${YELLOW}${TLS_PORT}${NC}  path ${YELLOW}${VLESS_PATH}${NC}"
        echo -e "  $(_uri_vless "$uuid" "$name" "$tls_addr" "$TLS_PORT" "${domain:-$host_hdr}" "${sni:-$domain}" "yes")"
        echo ""
        echo -e "  ${CYAN}[VMess+TLS]${NC} puerto ${YELLOW}${TLS_PORT}${NC}  path ${YELLOW}${VMESS_PATH}${NC}"
        echo -e "  $(_uri_vmess "$uuid" "$name" "$tls_addr" "$TLS_PORT" "${domain:-$host_hdr}" "${sni:-$domain}" "yes")"
    fi
    echo ""
    _pause
}

v2ray_show_uris() {
    _header; echo ""
    if [[ ! -s "$XRAY_DB" ]]; then
        echo -e "  ${YELLOW}No hay usuarios. Crea uno primero.${NC}"; _pause; return
    fi
    local -a uuids names
    local i=1
    while IFS='|' read -r uuid name; do
        [[ -z "$uuid" ]] && continue
        printf "  ${C2}|${C3}%-3s${C2}|${NC} ${CYAN}%-38s${NC} ${WHITE}%s${NC}\n" "$i" "$uuid" "$name"
        uuids+=("$uuid"); names+=("$name"); ((i++))
    done < "$XRAY_DB"
    echo ""
    echo -ne "  ${C5}Número de usuario: ${NC}"; read -r sel
    [[ -z "$sel" || "$sel" == "0" ]] && return
    local idx=$((sel-1))
    [[ -n "${uuids[$idx]}" ]] && _show_uri "${uuids[$idx]}" "${names[$idx]}" || \
        { echo -e "${RED}  Selección inválida${NC}"; sleep 2; }
}

# ── CAMBIAR PUERTOS ──────────────────────────────────────────

v2ray_change_ports() {
    _header; echo ""
    _load_ports
    echo -e "  ${WHITE}Puertos actuales:${NC}"
    echo -e "    VLESS : ${CYAN}${VLESS_PORT}${NC}"
    echo -e "    VMess : ${CYAN}${VMESS_PORT}${NC}"
    echo -e "    TLS   : ${CYAN}${TLS_PORT}${NC}"
    echo ""
    echo -ne "  Nuevo puerto VLESS [${VLESS_PORT}]: "; read -r np1
    echo -ne "  Nuevo puerto VMess [${VMESS_PORT}]: "; read -r np2
    echo -ne "  Nuevo puerto TLS   [${TLS_PORT}]: ";   read -r np3
    VLESS_PORT=${np1:-$VLESS_PORT}
    VMESS_PORT=${np2:-$VMESS_PORT}
    TLS_PORT=${np3:-$TLS_PORT}

    # Actualizar config.json
    python3 - "$XRAY_CFG" "$VLESS_PORT" "$VMESS_PORT" <<'PYEOF'
import json, sys
p, vp, mp = sys.argv[1], int(sys.argv[2]), int(sys.argv[3])
with open(p) as f: cfg = json.load(f)
for ib in cfg['inbounds']:
    if ib.get('tag') == 'vless-in':  ib['port'] = vp
    if ib.get('tag') == 'vmess-in':  ib['port'] = mp
with open(p, 'w') as f: json.dump(cfg, f, indent=2)
PYEOF
    _save_ports
    _fw_open "$VLESS_PORT" "$VMESS_PORT"

    # Re-generar NGINX si TLS activo
    _tls_active && _setup_nginx_tls "$(_get_domain)"

    systemctl restart xray  >/dev/null 2>&1
    _nginx_running && nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
    echo -e "\n  ${GREEN}✓ Puertos actualizados${NC}"; sleep 2
}

# ── NGINX + TLS (opcional, en puerto separado) ───────────────

_gen_selfsigned() {
    local domain="${1:-vps.local}"
    local cert="$XRAY_DIR/fullchain.pem"
    local key="$XRAY_DIR/privkey.pem"
    openssl req -x509 -newkey rsa:2048 -keyout "$key" -out "$cert" -days 3650 -nodes \
        -subj "/CN=${domain}" 2>/dev/null
    chmod 600 "$key"; chmod 644 "$cert"
    echo "${cert}|${key}"
}

_setup_nginx_tls() {
    local domain="$1"
    _load_ports
    local cert key
    cert=$(grep "^cert=" "$XRAY_DOMAIN_FILE" 2>/dev/null | cut -d= -f2)
    key=$(grep "^key="  "$XRAY_DOMAIN_FILE" 2>/dev/null | cut -d= -f2)
    [[ -z "$cert" || ! -f "$cert" ]] && cert="$XRAY_DIR/fullchain.pem"
    [[ -z "$key"  || ! -f "$key"  ]] && key="$XRAY_DIR/privkey.pem"

    # Borrar el viejo conf (legacy) si existe
    rm -f /etc/nginx/conf.d/xray-http.conf /etc/nginx/conf.d/xray-ssl.conf 2>/dev/null

    cat > "$NGINX_CONF_V2" <<EOF
# V2Ray TLS reverse proxy — puerto dedicado ${TLS_PORT}
# NO interfiere con otros puertos (80, 443, 8080, etc.)
map \$http_upgrade \$connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen ${TLS_PORT} ssl;
    listen [::]:${TLS_PORT} ssl;
    server_name ${domain} _;

    ssl_certificate     ${cert};
    ssl_certificate_key ${key};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    access_log off;

    location ${VLESS_PATH} {
        if (\$http_upgrade != "websocket") { return 404; }
        proxy_pass         http://127.0.0.1:${VLESS_PORT};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    \$http_upgrade;
        proxy_set_header   Connection \$connection_upgrade;
        proxy_set_header   Host       \$host;
        proxy_read_timeout 86400s;
    }
    location ${VMESS_PATH} {
        if (\$http_upgrade != "websocket") { return 404; }
        proxy_pass         http://127.0.0.1:${VMESS_PORT};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    \$http_upgrade;
        proxy_set_header   Connection \$connection_upgrade;
        proxy_set_header   Host       \$host;
        proxy_read_timeout 86400s;
    }
    location / { return 404; }
}
EOF
}

v2ray_config_tls() {
    _header; echo ""

    if ! _nginx_installed; then
        echo -e "  ${YELLOW}NGINX no está instalado.${NC}"
        echo -ne "  ¿Instalar NGINX ahora? (S/n): "; read -r ng
        [[ "$ng" =~ ^[nN]$ ]] && return
        echo -ne "  ${YELLOW}Instalando NGINX...${NC} "
        DEBIAN_FRONTEND=noninteractive apt-get install -y -qq nginx >/dev/null 2>&1
        _nginx_installed || { echo -e "${RED}FALLO${NC}"; sleep 2; return; }
        echo -e "${GREEN}OK${NC}"
    fi

    _load_ports
    local cur_dom; cur_dom=$(_get_domain)
    local tls_st; _tls_active && tls_st="${GREEN}ACTIVO${NC}" || tls_st="${RED}INACTIVO${NC}"
    echo -e "  ${WHITE}TLS actual    :${NC} ${tls_st}"
    echo -e "  ${WHITE}Dominio actual:${NC} ${CYAN}${cur_dom:-(ninguno)}${NC}"
    echo -e "  ${WHITE}Puerto TLS    :${NC} ${CYAN}${TLS_PORT}${NC}  ${YELLOW}(separado de 443/444/8443)${NC}"
    echo ""
    echo -e "  ${C2}|${C3}01${C2}|${NC} Activar/Actualizar TLS"
    echo -e "  ${C2}|${C3}02${C2}|${NC} Cambiar puerto TLS (default ${DEFAULT_TLS_PORT})"
    echo -e "  ${C2}|${C3}03${C2}|${NC} Desactivar TLS / NGINX"
    echo -e "  ${C2}|${C3}00${C2}|${NC} Volver"
    echo -ne "\n  ${C5}Opción: ${NC}"; read -r o

    case "$o" in
        1|01)
            echo -ne "  Dominio (ej: vpn.midominio.com) [${cur_dom:-vps.local}]: "; read -r d
            d="${d:-${cur_dom:-vps.local}}"
            echo ""
            echo -e "  ${CYAN}[1]${NC} Self-signed (rápido, requiere allowInsecure en cliente)"
            echo -e "  ${CYAN}[2]${NC} Pegar Cloudflare Origin Certificate"
            echo -ne "  Tipo [1/2]: "; read -r tc
            local cert="" key=""
            case "$tc" in
                2)
                    echo -e "\n  ${YELLOW}Pega el CERTIFICADO (fullchain). Termina con: END${NC}"
                    : > "$XRAY_DIR/fullchain.pem"
                    while IFS= read -r ln; do [[ "$ln" == "END" ]] && break; echo "$ln" >> "$XRAY_DIR/fullchain.pem"; done
                    echo -e "  ${YELLOW}Pega la LLAVE PRIVADA. Termina con: END${NC}"
                    : > "$XRAY_DIR/privkey.pem"
                    while IFS= read -r ln; do [[ "$ln" == "END" ]] && break; echo "$ln" >> "$XRAY_DIR/privkey.pem"; done
                    cert="$XRAY_DIR/fullchain.pem"; key="$XRAY_DIR/privkey.pem"
                    ;;
                *)
                    echo -ne "  ${YELLOW}Generando self-signed...${NC} "
                    local pair; pair=$(_gen_selfsigned "$d")
                    cert=$(echo "$pair"|cut -d'|' -f1); key=$(echo "$pair"|cut -d'|' -f2)
                    echo -e "${GREEN}OK${NC}"
                    ;;
            esac

            cat > "$XRAY_DOMAIN_FILE" <<EOF
domain=${d}
tls=yes
cert=${cert}
key=${key}
EOF
            _setup_nginx_tls "$d"
            _fw_open "$TLS_PORT"
            if nginx -t >/dev/null 2>&1; then
                systemctl enable nginx >/dev/null 2>&1
                systemctl restart nginx >/dev/null 2>&1
                echo -e "\n  ${GREEN}✓ TLS activo en puerto ${TLS_PORT} (dominio: ${d})${NC}"
            else
                echo -e "\n  ${RED}✗ NGINX config inválida:${NC}"
                nginx -t 2>&1 | sed 's/^/    /'
            fi
            sleep 3
            ;;
        2|02)
            echo -ne "  Nuevo puerto TLS [${TLS_PORT}]: "; read -r np
            TLS_PORT=${np:-$TLS_PORT}; _save_ports
            _tls_active && _setup_nginx_tls "$(_get_domain)"
            _fw_open "$TLS_PORT"
            nginx -t >/dev/null 2>&1 && systemctl restart nginx >/dev/null 2>&1
            echo -e "\n  ${GREEN}✓ Puerto TLS actualizado a ${TLS_PORT}${NC}"; sleep 2
            ;;
        3|03)
            rm -f "$NGINX_CONF_V2"
            sed -i 's/^tls=yes/tls=no/' "$XRAY_DOMAIN_FILE" 2>/dev/null
            nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
            echo -e "\n  ${YELLOW}TLS desactivado (config NGINX V2Ray eliminada)${NC}"; sleep 2
            ;;
    esac
}

# ── CONTROL DE SERVICIOS ─────────────────────────────────────

v2ray_restart_xray() {
    _header; echo ""
    echo -ne "  ${YELLOW}Reiniciando XRay...${NC} "
    systemctl restart xray
    sleep 2
    if _xray_running; then
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}FALLO${NC}"
        echo -e "\n  ${YELLOW}Últimos errores:${NC}"
        journalctl -u xray --no-pager -n 10 2>/dev/null | sed 's/^/    /'
    fi
    sleep 3
}

v2ray_restart_nginx() {
    _header; echo ""
    if ! _nginx_installed; then
        echo -e "  ${YELLOW}NGINX no está instalado.${NC}"
        echo -ne "  ¿Instalarlo? (s/N): "; read -r in
        if [[ "$in" =~ ^[sS]$ ]]; then
            echo -ne "  ${YELLOW}Instalando...${NC} "
            DEBIAN_FRONTEND=noninteractive apt-get install -y -qq nginx >/dev/null 2>&1
            _nginx_installed && echo -e "${GREEN}OK${NC}" || echo -e "${RED}FALLO${NC}"
        fi
        sleep 2; return
    fi

    echo -ne "  ${YELLOW}Validando configuración NGINX...${NC} "
    if ! nginx -t >/dev/null 2>&1; then
        echo -e "${RED}ERROR${NC}"
        nginx -t 2>&1 | sed 's/^/    /'
        echo ""
        echo -e "  ${YELLOW}► Solución: revisa /etc/nginx/conf.d/ y elimina configs problemáticos${NC}"
        echo -e "  ${YELLOW}  Configs V2Ray actual: ${NC}${NGINX_CONF_V2}"
        echo -ne "\n  ¿Eliminar config V2Ray y reintentar? (s/N): "; read -r el
        if [[ "$el" =~ ^[sS]$ ]]; then
            rm -f "$NGINX_CONF_V2"
            nginx -t >/dev/null 2>&1 && echo -e "  ${GREEN}✓ Config corregida${NC}"
        fi
        sleep 3; return
    fi
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Reiniciando NGINX...${NC} "
    systemctl enable nginx >/dev/null 2>&1
    systemctl restart nginx
    sleep 1
    if _nginx_running; then
        echo -e "${GREEN}OK${NC}"
        echo ""
        echo -e "  ${WHITE}Puertos NGINX activos:${NC}"
        ss -tlpn 2>/dev/null | grep nginx | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | \
            while read -r p; do echo -e "    ${CYAN}→ $p${NC}"; done
    else
        echo -e "${RED}FALLO${NC}"
        echo -e "\n  ${YELLOW}Últimos errores:${NC}"
        journalctl -u nginx --no-pager -n 10 2>/dev/null | sed 's/^/    /'
    fi
    sleep 3
}

v2ray_stop() {
    _header; echo ""
    echo -ne "  ${YELLOW}Deteniendo XRay...${NC} "
    systemctl stop xray
    _xray_running && echo -e "${RED}AÚN ACTIVO${NC}" || echo -e "${GREEN}OK${NC}"
    sleep 2
}

# ── ESTADO ───────────────────────────────────────────────────

v2ray_status() {
    _header; echo ""
    _load_ports
    local xs ns ts
    _xray_running   && xs="${GREEN}● ACTIVO${NC}"  || xs="${RED}● INACTIVO${NC}"
    _nginx_running  && ns="${GREEN}● ACTIVO${NC}"  || ns="${RED}● INACTIVO${NC}"
    _tls_active     && ts="${GREEN}● ACTIVO${NC}"  || ts="${YELLOW}● INACTIVO${NC}"

    echo -e "  ${WHITE}XRay     :${NC} ${xs}"
    echo -e "  ${WHITE}NGINX    :${NC} ${ns}"
    echo -e "  ${WHITE}TLS V2R  :${NC} ${ts}"
    echo ""
    local ver; ver=$("$XRAY_BIN" version 2>/dev/null | head -1 | awk '{print $2}')
    echo -e "  ${WHITE}Versión XRay   : ${CYAN}${ver:-?}${NC}"
    echo -e "  ${WHITE}Puerto VLESS   : ${CYAN}${VLESS_PORT}${WHITE}  (path ${CYAN}${VLESS_PATH}${WHITE})${NC}"
    echo -e "  ${WHITE}Puerto VMess   : ${CYAN}${VMESS_PORT}${WHITE}  (path ${CYAN}${VMESS_PATH}${WHITE})${NC}"
    _tls_active && echo -e "  ${WHITE}Puerto TLS     : ${CYAN}${TLS_PORT}${NC}"
    echo -e "  ${WHITE}Dominio        : ${CYAN}$(_get_domain || echo "(ninguno)")${NC}"
    echo -e "  ${WHITE}Usuarios       : ${CYAN}$(wc -l < "$XRAY_DB" 2>/dev/null || echo 0)${NC}"
    echo ""
    echo -e "  ${WHITE}Puertos en escucha de XRay:${NC}"
    ss -tlpn 2>/dev/null | grep xray | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | \
        while read -r p; do echo -e "    ${CYAN}→ ${p}${NC}"; done
    [[ -n "$ver" ]] && _nginx_running && {
        echo -e "  ${WHITE}Puertos en escucha de NGINX:${NC}"
        ss -tlpn 2>/dev/null | grep nginx | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | \
            while read -r p; do echo -e "    ${CYAN}→ ${p}${NC}"; done
    }
    _pause
}

# ── DESINSTALAR / RESTAURAR ──────────────────────────────────

v2ray_uninstall() {
    _header; echo ""
    echo -e "  ${RED}┌─────────────────────────────────────────────┐${NC}"
    echo -e "  ${RED}│      DESINSTALAR V2RAY                      │${NC}"
    echo -e "  ${RED}└─────────────────────────────────────────────┘${NC}"
    echo -ne "\n  ${RED}Confirma escribiendo SI: ${NC}"; read -r c
    [[ "$c" != "SI" ]] && return

    systemctl stop xray     >/dev/null 2>&1
    systemctl disable xray  >/dev/null 2>&1
    rm -f /etc/systemd/system/xray.service
    systemctl daemon-reload >/dev/null 2>&1
    rm -f "$XRAY_BIN"
    rm -f "$NGINX_CONF_V2"
    _nginx_running && nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
    echo -e "\n  ${GREEN}✓ XRay desinstalado.${NC} ${YELLOW}(Datos en $XRAY_DIR conservados)${NC}"
    sleep 3
}

v2ray_reparar() {
    _header; echo ""
    echo -e "  ${WHITE}REPARAR INSTALACIÓN ANTERIOR${NC}"
    echo -e "  ${C4}Restaura wsproxy / stunnel / ssldispatcher${NC}"
    echo -e "  ${C4}y elimina configs V2Ray viejos que rompían NGINX.${NC}"
    echo ""
    echo -ne "  ¿Continuar? (s/N): "; read -r ok
    [[ ! "$ok" =~ ^[sS]$ ]] && return

    # 1. Eliminar configs nginx antiguas
    echo -ne "  ${YELLOW}Limpiando configs NGINX antiguas...${NC} "
    rm -f /etc/nginx/conf.d/xray-http.conf \
          /etc/nginx/conf.d/xray-ssl.conf \
          /etc/nginx/conf.d/v2ray-tls.conf
    echo -e "${GREEN}OK${NC}"

    # 2. Restaurar stunnel
    if [[ -f /etc/stunnel/stunnel.conf.xray_bak ]]; then
        echo -ne "  ${YELLOW}Restaurando stunnel...${NC} "
        cp /etc/stunnel/stunnel.conf.xray_bak /etc/stunnel/stunnel.conf
        rm -f /etc/stunnel/stunnel.conf.xray_bak
        systemctl restart stunnel4 >/dev/null 2>&1
        echo -e "${GREEN}OK${NC}"
    fi

    # 3. Restaurar wsproxy en puerto 80
    local wsproxy_path
    wsproxy_path=$(find /etc/SSHPlus /etc -name "wsproxy.py" 2>/dev/null | head -1)
    if [[ -n "$wsproxy_path" ]]; then
        echo -ne "  ${YELLOW}Restaurando wsproxy en puerto 80...${NC} "
        # Matar wsproxy interno antiguo
        pkill -f "wsproxy.*2082" 2>/dev/null
        for s in $(screen -ls 2>/dev/null | grep ws2082 | awk '{print $1}'); do
            screen -r -S "$s" -X quit 2>/dev/null
        done
        # Limpiar autostart
        if [[ -f /etc/autostart ]]; then
            sed -i '/wsproxy.*2082/d'             /etc/autostart
            sed -i '/nginx -t.*nginx -s reload/d' /etc/autostart
            sed -i '/^nginx -t.*nginx 2>\/dev/d'  /etc/autostart
            # Restaurar ssldispatcher al backend wsproxy original
            sed -i 's|ssldispatcher\.py \([0-9]*\) \([^ ]*\) 127\.0\.0\.1:8000|ssldispatcher.py \1 \2 127.0.0.1:80|g' /etc/autostart
        fi
        # Reiniciar wsproxy y ssldispatcher
        screen -wipe >/dev/null 2>&1
        screen -dmS ws80 python3 "$wsproxy_path" 80 127.0.0.1:22
        local disp_path
        disp_path=$(find /etc/SSHPlus /etc -name "ssldispatcher.py" 2>/dev/null | head -1)
        if [[ -n "$disp_path" ]]; then
            for s in $(screen -ls 2>/dev/null | grep ssl_disp | awk '{print $1}'); do
                screen -r -S "$s" -X quit 2>/dev/null
            done
            pkill -f ssldispatcher 2>/dev/null
            sleep 1
            screen -dmS ssl_dispatcher python3 "$disp_path" 10443 127.0.0.1:143 127.0.0.1:80
        fi
        echo -e "${GREEN}OK${NC}"
    fi

    # 4. Detener nginx si está rompiendo cosas
    echo -ne "  ${YELLOW}Re-validando NGINX...${NC} "
    if _nginx_installed; then
        if nginx -t >/dev/null 2>&1; then
            systemctl restart nginx >/dev/null 2>&1
            echo -e "${GREEN}OK${NC}"
        else
            systemctl stop nginx >/dev/null 2>&1
            echo -e "${YELLOW}Detenido (config inválida limpiada)${NC}"
        fi
    else
        echo -e "${YELLOW}NGINX no instalado${NC}"
    fi

    echo ""
    echo -e "  ${GREEN}✓ Restauración completada.${NC}"
    echo -e "  ${WHITE}► Ahora reactiva wsproxy y SSL desde el menú Protocolos.${NC}"
    echo -e "  ${WHITE}► Después puedes reinstalar V2Ray (versión simple, dedicated ports).${NC}"
    _pause
}

# ── MENÚ PRINCIPAL ───────────────────────────────────────────

