v2ray_menu() {
while true; do
    _header

    local xray_st nginx_st tls_info users_count install_st
    _xray_installed && install_st="${GREEN}Instalado${NC}" || install_st="${RED}No instalado${NC}"
    _xray_running   && xray_st="${GREEN}● ON${NC}"  || xray_st="${RED}● OFF${NC}"
    systemctl is-active --quiet nginx 2>/dev/null && nginx_st="${GREEN}● ON${NC}" || nginx_st="${RED}● OFF${NC}"
    _get_tls_enabled && tls_info="${GREEN}TLS ON${NC}" || tls_info="${YELLOW}TLS OFF${NC}"
    users_count=$(wc -l < "$XRAY_DB" 2>/dev/null || echo 0)

    echo -e "${C1}┃${NC}  XRay: ${xray_st}  NGINX: ${nginx_st}  ${tls_info}  Usuarios: ${WHITE}${users_count}${NC}  Estado: ${install_st}"
    echo -e "${C1}┣━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┫${NC}"
    echo -e "${C1}┃${C2}|${C3}01${C2}|${NC}➜ ${C4}INSTALAR / REINSTALAR V2RAY         ${C2}|${C3}07${C2}|${NC}➜ ${C4}CONFIGURAR TLS${NC}      ${C1}┃${NC}"
    echo -e "${C1}┃${C2}|${C3}02${C2}|${NC}➜ ${C4}AGREGAR USUARIO                     ${C2}|${C3}08${C2}|${NC}➜ ${C4}REINICIAR${NC}           ${C1}┃${NC}"
    echo -e "${C1}┃${C2}|${C3}03${C2}|${NC}➜ ${C4}LISTAR USUARIOS                     ${C2}|${C3}09${C2}|${NC}➜ ${C4}ESTADO / PUERTOS${NC}    ${C1}┃${NC}"
    echo -e "${C1}┃${C2}|${C3}04${C2}|${NC}➜ ${C4}ELIMINAR USUARIO                    ${C2}|${C3}10${C2}|${NC}➜ ${C4}VER LOGS${NC}            ${C1}┃${NC}"
    echo -e "${C1}┃${C2}|${C3}05${C2}|${NC}➜ ${C4}VER CONFIGS / URIs                  ${C2}|${C3}11${C2}|${NC}➜ ${C4}DESINSTALAR${NC}         ${C1}┃${NC}"
    echo -e "${C1}┃${C2}|${C3}06${C2}|${NC}➜ ${C4}GENERAR UUID LIBRE                  ${C2}|${C3}00${C2}|${NC}➜ ${C4}VOLVER AL MENÚ${NC}      ${C1}┃${NC}"
    echo -e "${C1}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
    echo -ne "${C5}¿QUÉ DESEAS HACER ??: ${NC}"; read -r opt

    case "$opt" in
        1|01) instalar_v2ray ;;
        2|02) _xray_installed && v2ray_add_user    || { echo -e "  ${RED}Instala V2Ray primero (opción 01)${NC}"; sleep 2; } ;;
        3|03) _xray_installed && v2ray_list_users  || { echo -e "  ${RED}Instala V2Ray primero (opción 01)${NC}"; sleep 2; } ;;
        4|04) _xray_installed && v2ray_del_user    || { echo -e "  ${RED}Instala V2Ray primero (opción 01)${NC}"; sleep 2; } ;;
        5|05) _xray_installed && v2ray_show_uris   || { echo -e "  ${RED}Instala V2Ray primero (opción 01)${NC}"; sleep 2; } ;;
        6|06) v2ray_gen_uuid ;;
        7|07) _xray_installed && v2ray_config_tls  || { echo -e "  ${RED}Instala V2Ray primero (opción 01)${NC}"; sleep 2; } ;;
        8|08) _xray_installed && v2ray_restart     || { echo -e "  ${RED}Instala V2Ray primero (opción 01)${NC}"; sleep 2; } ;;
        9|09) v2ray_status ;;
        10)   v2ray_logs ;;
        11)   _xray_installed && v2ray_uninstall   || { echo -e "  ${YELLOW}V2Ray no está instalado.${NC}"; sleep 2; } ;;
        0|00) return ;;
        *) echo -e "\n  ${RED}Opción inválida${NC}"; sleep 1 ;;
    esac
done
}

# ── Auto-ejecución cuando se llama como script directo ────────
[[ "${BASH_SOURCE[0]}" == "$0" ]] && v2ray_menu
