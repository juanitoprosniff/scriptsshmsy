_gen_selfsigned() {
    local domain="${1:-vps.local}"
    local cert="$XRAY_DIR/fullchain.pem"
    local key="$XRAY_DIR/privkey.pem"
    openssl req -x509 -newkey rsa:4096 -keyout "$key" -out "$cert" -days 3650 -nodes \
        -subj "/C=US/ST=State/L=City/O=VPN/CN=${domain}" 2>/dev/null
    echo "${cert}|${key}"
}

_migrate_wsproxy() {
    local wsproxy_path
    wsproxy_path=$(find /etc/SSHPlus /etc -name "wsproxy.py" 2>/dev/null | head -1)
    [[ -z "$wsproxy_path" ]] && wsproxy_path="/etc/SSHPlus/wsproxy.py"

    # Detectar backend SSH del wsproxy actual (antes de migrar)
    local ssh_backend="127.0.0.1:22"
    if [[ -f /etc/autostart ]]; then
        local detected
        detected=$(grep -E "wsproxy.*\.py\s+80\b" /etc/autostart 2>/dev/null | \
            awk '{for(i=1;i<=NF;i++) if($i~/^127\.0\.0\.1:[0-9]+$/) {print $i; exit}}')
        [[ -n "$detected" ]] && ssh_backend="$detected"
    fi

    # Matar instancias wsproxy en puertos HTTP externos
    for pt in 80 8080 8880 8888; do
        pkill -f "wsproxy.*\.py.*\b${pt}\b" 2>/dev/null
    done
    for sess in $(screen -ls 2>/dev/null | \
            grep -E '\.(ws80|ws8080|ws8880|ws8888)\b' | awk '{print $1}'); do
        screen -r -S "$sess" -X quit 2>/dev/null
    done

    # Actualizar /etc/autostart
    if [[ -f /etc/autostart ]]; then
        sed -i '/wsproxy.*\.py\s\+80\b/d' /etc/autostart
        sed -i '/wsproxy.*\.py\s\+8080\b/d' /etc/autostart
        sed -i '/wsproxy.*\.py\s\+8880\b/d' /etc/autostart
        sed -i '/wsproxy.*\.py\s\+8888\b/d' /etc/autostart
        sed -i "/wsproxy.*\.py\s\+${WSPROXY_INT}\b/d" /etc/autostart
        # Actualizar ssldispatcher para apuntar al nginx interno
        sed -i "s|ssldispatcher\.py \([0-9]*\) \([^ ]*\) [^ ]*|ssldispatcher.py \1 \2 127.0.0.1:${NGINX_INT}|g" /etc/autostart
        # Agregar nginx y wsproxy interno al autostart
        echo "screen -dmS ws${WSPROXY_INT} python3 ${wsproxy_path} ${WSPROXY_INT} ${ssh_backend}" >> /etc/autostart
        grep -q "nginx" /etc/autostart || echo "nginx -t 2>/dev/null && nginx 2>/dev/null || nginx -s reload 2>/dev/null" >> /etc/autostart
    fi

    # Arrancar wsproxy en puerto interno
    screen -wipe >/dev/null 2>&1
    screen -dmS "ws${WSPROXY_INT}" python3 "${wsproxy_path}" "${WSPROXY_INT}" "${ssh_backend}"

    # Reiniciar ssldispatcher con nuevo backend HTTP
    for sess in $(screen -ls 2>/dev/null | grep -E 'ssl_disp|ssldispatch' | awk '{print $1}'); do
        screen -r -S "$sess" -X quit 2>/dev/null
    done
    pkill -f "ssldispatcher" 2>/dev/null
    local disp_path
    disp_path=$(find /etc/SSHPlus /etc -name "ssldispatcher.py" 2>/dev/null | head -1)
    if [[ -n "$disp_path" ]]; then
        sleep 1
        screen -dmS ssl_dispatcher python3 "$disp_path" 10443 127.0.0.1:143 "127.0.0.1:${NGINX_INT}"
    fi
}

_create_systemd_xray() {
    cat > /etc/systemd/system/xray.service <<'SYSTEMD'
[Unit]
Description=XRay Proxy Service
Documentation=https://xtls.github.io
After=network.target nss-lookup.target

[Service]
User=root
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart=/usr/local/bin/xray run -c /etc/xray/config.json
Restart=on-failure
RestartPreventExitStatus=23
LimitNPROC=10000
LimitNOFILE=1000000

[Install]
WantedBy=multi-user.target
SYSTEMD
    systemctl daemon-reload
    systemctl enable xray   >/dev/null 2>&1
    systemctl enable nginx  >/dev/null 2>&1
}

_fw_open_v2ray() {
    for pt in 80 443 444 2082 8080 8443 8880 8888; do
        command -v ufw &>/dev/null && ufw allow "${pt}/tcp" >/dev/null 2>&1
        command -v iptables &>/dev/null && {
            iptables -C INPUT -p tcp --dport "${pt}" -j ACCEPT 2>/dev/null || \
            iptables -I INPUT -p tcp --dport "${pt}" -j ACCEPT >/dev/null 2>&1
        }
    done
}

instalar_v2ray() {
    _header
    echo ""

    if _xray_installed; then
        echo -e "  ${YELLOW}XRay ya está instalado.${NC}"
        echo -ne "  ¿Reinstalar? (s/N): "; read -r ans
        [[ ! "$ans" =~ ^[sS]$ ]] && return
    fi

    echo ""
    _install_deps_v2ray
    _download_xray || return 1

    echo -ne "  ${YELLOW}Creando configuración XRay...${NC} "
    _create_initial_cfg
    echo -e "${GREEN}OK${NC}"

    # ── TLS/SSL ───────────────────────────────────────────────
    echo ""
    echo -e "  ${WHITE}━━━ Configuración TLS (puertos 443, 444, 8443) ━━━${NC}"
    echo -e "  ${C4}Si tienes dominio de Cloudflare puedes activar TLS.${NC}"
    echo -ne "\n  ${C5}¿Activar TLS ahora? (s/N): ${NC}"; read -r tls_ans

    local domain="" cert_file="" key_file=""

    if [[ "$tls_ans" =~ ^[sS]$ ]]; then
        echo -ne "  Ingresa tu dominio (ej: vpn.midominio.com): "; read -r domain
        [[ -z "$domain" ]] && domain="vps.local"

        echo ""
        echo -e "  Tipo de certificado:"
        echo -e "  ${CYAN}[1]${NC} Self-signed automático  ${YELLOW}(recomendado para pruebas)${NC}"
        echo -e "  ${CYAN}[2]${NC} Pegar Certificado de Cloudflare Origin"
        echo -ne "  Elige [1/2]: "; read -r cert_type

        case "$cert_type" in
            2)
                echo ""
                echo -e "  ${YELLOW}Pega el CERTIFICADO (fullchain.pem).${NC}"
                echo -e "  ${WHITE}Termina con una línea que solo contenga: END${NC}"
                local cert_lines=()
                while IFS= read -r line; do
                    [[ "$line" == "END" ]] && break
                    cert_lines+=("$line")
                done
                printf '%s\n' "${cert_lines[@]}" > "$XRAY_DIR/fullchain.pem"

                echo ""
                echo -e "  ${YELLOW}Pega la LLAVE PRIVADA (privkey.pem).${NC}"
                echo -e "  ${WHITE}Termina con una línea que solo contenga: END${NC}"
                local key_lines=()
                while IFS= read -r line; do
                    [[ "$line" == "END" ]] && break
                    key_lines+=("$line")
                done
                printf '%s\n' "${key_lines[@]}" > "$XRAY_DIR/privkey.pem"
                cert_file="$XRAY_DIR/fullchain.pem"
                key_file="$XRAY_DIR/privkey.pem"
                ;;
            *)
                echo -ne "  ${YELLOW}Generando certificado self-signed...${NC} "
                local pair
                pair=$(_gen_selfsigned "$domain")
                cert_file=$(echo "$pair" | cut -d'|' -f1)
                key_file=$(echo "$pair" | cut -d'|' -f2)
                echo -e "${GREEN}OK${NC}"
                ;;
        esac

        if [[ -f "$cert_file" && -f "$key_file" ]]; then
            # Desactivar stunnel en puertos SSL (NGINX toma control)
            echo -ne "  ${YELLOW}Reconfigurando stunnel (moviendo puertos SSL)...${NC} "
            if [[ -f /etc/stunnel/stunnel.conf ]]; then
                cp /etc/stunnel/stunnel.conf /etc/stunnel/stunnel.conf.xray_bak
                sed -i 's/^\(accept\s*=\s*443\b\)/;\1/' /etc/stunnel/stunnel.conf
                sed -i 's/^\(accept\s*=\s*444\b\)/;\1/' /etc/stunnel/stunnel.conf
                sed -i 's/^\(accept\s*=\s*8443\b\)/;\1/' /etc/stunnel/stunnel.conf
                systemctl restart stunnel4 >/dev/null 2>&1
            fi
            echo -e "${GREEN}OK${NC}"

            echo -ne "  ${YELLOW}Configurando NGINX SSL...${NC} "
            _write_nginx_ssl "$domain" "$cert_file" "$key_file"
            echo -e "${GREEN}OK${NC}"

            {
                echo "$domain"
                echo "tls=yes"
                echo "cert=$cert_file"
                echo "key=$key_file"
            } > "$XRAY_DOMAIN_FILE"
        fi
    fi

    echo -ne "  ${YELLOW}Configurando NGINX HTTP...${NC} "
    _write_nginx_http
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Migrando wsproxy al puerto interno ${WSPROXY_INT}...${NC} "
    _migrate_wsproxy
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Creando servicio systemd...${NC} "
    _create_systemd_xray
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Iniciando NGINX + XRay...${NC} "
    nginx -t >/dev/null 2>&1 && systemctl restart nginx >/dev/null 2>&1
    systemctl start xray >/dev/null 2>&1
    echo -e "${GREEN}OK${NC}"

    echo -ne "  ${YELLOW}Abriendo puertos firewall...${NC} "
    _fw_open_v2ray
    echo -e "${GREEN}OK${NC}"

    echo "$(date '+%Y-%m-%d %H:%M:%S')" > "$XRAY_DIR/installed"

    echo ""
    echo -e "${GREEN}  ┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${GREEN}  │   ✓  V2Ray/XRay instalado correctamente!        │${NC}"
    echo -e "${GREEN}  └─────────────────────────────────────────────────┘${NC}"
    echo ""
    echo -e "  ${WHITE}Protocolos activos:${NC}"
    echo -e "   ${CYAN}VLESS  WS${NC}  → /vless  (puertos 80, 8080, 8880, 8888)"
    echo -e "   ${CYAN}VMess  WS${NC}  → /vmess  (puertos 80, 8080, 8880, 8888)"
    echo -e "   ${CYAN}Trojan WS${NC}  → /trojan (puertos 80, 8080, 8880, 8888)"
    [[ -n "$domain" ]] && {
        echo -e "   ${CYAN}+ TLS${NC}     → mismos paths en 443, 444, 8443"
    }
    echo ""
    echo -e "  ${YELLOW}► SSH WebSocket sigue funcionando en todos los puertos${NC}"
    echo ""
    _pause
}

# ── GESTIÓN DE USUARIOS ───────────────────────────────────────

v2ray_add_user() {
    _header
    echo ""
    echo -ne "  ${C5}Nombre del usuario: ${NC}"; read -r uname
    [[ -z "$uname" ]] && { echo -e "${RED}  Nombre vacío${NC}"; sleep 2; return; }

    local uuid
    uuid=$(_gen_uuid)

    echo -ne "  ${YELLOW}¿Usar UUID generado ${CYAN}${uuid}${YELLOW}? (S/n): ${NC}"; read -r confirm_uuid
    if [[ "$confirm_uuid" =~ ^[nN]$ ]]; then
        echo -ne "  Ingresa UUID personalizado: "; read -r custom_uuid
        [[ -n "$custom_uuid" ]] && uuid="$custom_uuid"
    fi

    echo -ne "  ${YELLOW}Agregando usuario...${NC} "
    _xray_add_user_cfg "$uuid" "$uname" >/dev/null 2>&1

    # Guardar en DB
    echo "${uuid}|${uname}" >> "$XRAY_DB"

    # Reiniciar XRay para aplicar cambios
    systemctl restart xray >/dev/null 2>&1

    echo -e "${GREEN}OK${NC}"
    echo ""
    echo -e "  ${WHITE}Usuario creado:${NC}"
    echo -e "  ${CYAN}Nombre : ${WHITE}$uname${NC}"
    echo -e "  ${CYAN}UUID   : ${YELLOW}$uuid${NC}"
    echo ""

    echo -ne "  ${C5}¿Ver configuración/URIs ahora? (S/n): ${NC}"; read -r show_now
    [[ ! "$show_now" =~ ^[nN]$ ]] && _show_user_uris "$uuid" "$uname"
}

v2ray_list_users() {
    _header
    echo ""
    if [[ ! -s "$XRAY_DB" ]]; then
        echo -e "  ${YELLOW}No hay usuarios registrados.${NC}"
        _pause; return
    fi

    echo -e "  ${WHITE}#   UUID                                   Nombre${NC}"
    echo -e "  ${C1}────────────────────────────────────────────────────${NC}"
    local i=1
    while IFS='|' read -r uuid name; do
        [[ -z "$uuid" ]] && continue
        printf "  ${CYAN}%-3s${NC} ${YELLOW}%-38s${NC} ${WHITE}%s${NC}\n" "$i" "$uuid" "$name"
        ((i++))
    done < "$XRAY_DB"
    echo ""
    _pause
}

v2ray_del_user() {
    _header
    echo ""
    if [[ ! -s "$XRAY_DB" ]]; then
        echo -e "  ${YELLOW}No hay usuarios registrados.${NC}"
        _pause; return
    fi

    local i=1
    local -a uuids names
    while IFS='|' read -r uuid name; do
        [[ -z "$uuid" ]] && continue
        printf "  ${C2}|${C3}%-3s${C2}|${NC} ${WHITE}%-38s${NC} ${CYAN}%s${NC}\n" "$i" "$uuid" "$name"
        uuids+=("$uuid"); names+=("$name")
        ((i++))
    done < "$XRAY_DB"

    echo ""
    echo -ne "  ${C5}Número a eliminar (0=cancelar): ${NC}"; read -r sel
    [[ "$sel" == "0" || -z "$sel" ]] && return

    local idx=$((sel - 1))
    local del_uuid="${uuids[$idx]}" del_name="${names[$idx]}"
    [[ -z "$del_uuid" ]] && { echo -e "${RED}  Selección inválida${NC}"; sleep 2; return; }

    echo -ne "  ${RED}¿Eliminar a ${WHITE}${del_name}${RED}? (s/N): ${NC}"; read -r confirm
    [[ ! "$confirm" =~ ^[sS]$ ]] && return

    echo -ne "  ${YELLOW}Eliminando...${NC} "
    _xray_del_user_cfg "$del_uuid" >/dev/null 2>&1

    # Eliminar de DB
    local tmpdb; tmpdb=$(mktemp)
    grep -v "^${del_uuid}|" "$XRAY_DB" > "$tmpdb" && mv "$tmpdb" "$XRAY_DB"

    systemctl restart xray >/dev/null 2>&1
    echo -e "${GREEN}OK${NC}"
    echo -e "  ${CYAN}Usuario ${WHITE}${del_name}${CYAN} eliminado.${NC}"
    sleep 2
}

v2ray_show_uris() {
    _header
    echo ""
    if [[ ! -s "$XRAY_DB" ]]; then
        echo -e "  ${YELLOW}No hay usuarios. Agrega uno primero.${NC}"
        _pause; return
    fi

    local i=1
    local -a uuids names
    while IFS='|' read -r uuid name; do
        [[ -z "$uuid" ]] && continue
        printf "  ${C2}|${C3}%-3s${C2}|${NC} ${CYAN}%-38s${NC} ${WHITE}%s${NC}\n" "$i" "$uuid" "$name"
        uuids+=("$uuid"); names+=("$name")
        ((i++))
    done < "$XRAY_DB"

    echo ""
    echo -ne "  ${C5}Número de usuario (0=todos): ${NC}"; read -r sel

    if [[ "$sel" == "0" || -z "$sel" ]]; then
        for j in "${!uuids[@]}"; do
            _show_user_uris "${uuids[$j]}" "${names[$j]}"
        done
    else
        local idx=$((sel - 1))
        [[ -n "${uuids[$idx]}" ]] && _show_user_uris "${uuids[$idx]}" "${names[$idx]}"
    fi
}

v2ray_gen_uuid() {
    _header
    echo ""
    echo -e "  ${WHITE}UUID generado:${NC}"
    echo ""
    local uuid
    uuid=$(_gen_uuid)
    echo -e "  ${YELLOW}$uuid${NC}"
    echo ""
    echo -e "  ${C4}(Puedes usarlo al crear un nuevo usuario)${NC}"
    _pause
}

# ── CONFIGURACIÓN TLS ─────────────────────────────────────────

v2ray_config_tls() {
    _header
    echo ""
    local tls_status
    _get_tls_enabled && tls_status="${GREEN}ACTIVO${NC}" || tls_status="${RED}INACTIVO${NC}"
    local cur_domain; cur_domain=$(_get_domain)

    echo -e "  ${WHITE}Estado TLS actual : ${NC}${tls_status}"
    echo -e "  ${WHITE}Dominio actual    : ${CYAN}${cur_domain}${NC}"
    echo ""
    echo -e "  ${C2}|${C3}01${C2}|${NC} Configurar/Actualizar TLS con nuevo certificado"
    echo -e "  ${C2}|${C3}02${C2}|${NC} Desactivar TLS (volver a solo HTTP)"
    echo -e "  ${C2}|${C3}00${C2}|${NC} Volver"
    echo ""
    echo -ne "  ${C5}¿Qué deseas hacer?: ${NC}"; read -r opt

    case "$opt" in
        1|01)
            echo -ne "  Dominio: "; read -r new_domain
            [[ -z "$new_domain" ]] && new_domain="${cur_domain}"

            echo ""
            echo -e "  ${CYAN}[1]${NC} Self-signed   ${CYAN}[2]${NC} Cloudflare Origin Certificate"
            echo -ne "  Tipo [1/2]: "; read -r ctype

            local ncert nkey
            case "$ctype" in
                2)
                    echo -e "\n  ${YELLOW}Pega el CERTIFICADO, termina con: END${NC}"
                    local cl=()
                    while IFS= read -r l; do [[ "$l" == "END" ]] && break; cl+=("$l"); done
                    printf '%s\n' "${cl[@]}" > "$XRAY_DIR/fullchain.pem"

                    echo -e "  ${YELLOW}Pega la LLAVE PRIVADA, termina con: END${NC}"
                    local kl=()
                    while IFS= read -r l; do [[ "$l" == "END" ]] && break; kl+=("$l"); done
                    printf '%s\n' "${kl[@]}" > "$XRAY_DIR/privkey.pem"
                    ncert="$XRAY_DIR/fullchain.pem"; nkey="$XRAY_DIR/privkey.pem"
                    ;;
                *)
                    local p; p=$(_gen_selfsigned "$new_domain")
                    ncert=$(echo "$p"|cut -d'|' -f1); nkey=$(echo "$p"|cut -d'|' -f2)
                    ;;
            esac

            _write_nginx_ssl "$new_domain" "$ncert" "$nkey"
            { echo "$new_domain"; echo "tls=yes"; echo "cert=$ncert"; echo "key=$nkey"; } > "$XRAY_DOMAIN_FILE"
            nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
            echo -e "\n  ${GREEN}✓ TLS configurado en 443/444/8443${NC}"
            sleep 2
            ;;
        2|02)
            rm -f "$NGINX_SSL_CONF"
            sed -i 's/^tls=yes/tls=no/' "$XRAY_DOMAIN_FILE" 2>/dev/null
            # Restaurar stunnel si existe backup
            [[ -f /etc/stunnel/stunnel.conf.xray_bak ]] && \
                cp /etc/stunnel/stunnel.conf.xray_bak /etc/stunnel/stunnel.conf && \
                systemctl restart stunnel4 >/dev/null 2>&1
            nginx -t >/dev/null 2>&1 && systemctl reload nginx >/dev/null 2>&1
            echo -e "\n  ${YELLOW}TLS desactivado. Stunnel restaurado.${NC}"
            sleep 2
            ;;
    esac
}

