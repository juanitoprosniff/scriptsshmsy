}

_turbo_compresion() {
    if grep -q "^Compression yes" /etc/ssh/sshd_config 2>/dev/null; then
        sed -i '/^Compression/d' /etc/ssh/sshd_config
        echo "Compression no" >> /etc/ssh/sshd_config
        systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null
        echo -e "\n\033[1;33m✓ Compresión SSH DESACTIVADA\033[0m"
    else
        sed -i '/^Compression/d' /etc/ssh/sshd_config
        echo "Compression yes" >> /etc/ssh/sshd_config
        systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null
        echo -e "\n\033[1;32m✓ Compresión SSH (zlib) ACTIVADA\033[0m"
        echo -e "\033[1;37m  Reduce tráfico en redes lentas. En redes rápidas puede sumar latencia.\033[0m"
    fi
    sleep 2
}

_turbo_bbr() {
    if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q "bbr"; then
        sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;33m✓ BBR DESACTIVADO — restaurado a cubic\033[0m"
    else
        if ! modprobe tcp_bbr 2>/dev/null; then
            echo -e "\n\033[1;31m✗ Kernel no soporta BBR (requiere Linux 4.9+)\033[0m"
            echo -e "\033[1;33m  Kernel actual: $(uname -r)\033[0m"
            sleep 3; return
        fi
        sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
        echo "net.core.default_qdisc=fq" >> /etc/sysctl.conf
        echo "net.ipv4.tcp_congestion_control=bbr" >> /etc/sysctl.conf
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;32m✓ BBR ACTIVADO\033[0m"
        echo -e "\033[1;37m  Mejora velocidad y estabilidad con múltiples clientes simultáneos.\033[0m"
    fi
    sleep 2
}

_turbo_buffers() {
    if grep -q "^net.core.rmem_max=26214400" /etc/sysctl.conf 2>/dev/null; then
        sed -i '/net.core.rmem_max/d;/net.core.wmem_max/d;/net.core.rmem_default/d' /etc/sysctl.conf
        sed -i '/net.core.wmem_default/d;/net.ipv4.tcp_rmem/d;/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_mem/d;/net.core.netdev_max_backlog/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_no_metrics_save/d;/net.ipv4.tcp_window_scaling/d' /etc/sysctl.conf
        sed -i '/# MSYVPN Buffers/d' /etc/sysctl.conf
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;33m✓ Buffers RESTAURADOS a valores del sistema\033[0m"
    else
        # Limpiar antes de agregar para evitar duplicados
        sed -i '/net.core.rmem_max/d;/net.core.wmem_max/d;/net.core.rmem_default/d' /etc/sysctl.conf
        sed -i '/net.core.wmem_default/d;/net.ipv4.tcp_rmem/d;/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_mem/d;/net.core.netdev_max_backlog/d' /etc/sysctl.conf
        sed -i '/net.ipv4.tcp_no_metrics_save/d;/net.ipv4.tcp_window_scaling/d' /etc/sysctl.conf
        sed -i '/# MSYVPN Buffers/d' /etc/sysctl.conf
        cat >> /etc/sysctl.conf <<'BUFEOF'
# MSYVPN Buffers
net.core.rmem_max=26214400
net.core.wmem_max=26214400
net.core.rmem_default=1048576
net.core.wmem_default=1048576
net.ipv4.tcp_rmem=4096 1048576 26214400
net.ipv4.tcp_wmem=4096 1048576 26214400
net.ipv4.tcp_mem=65536 131072 262144
net.core.netdev_max_backlog=5000
net.ipv4.tcp_no_metrics_save=1
net.ipv4.tcp_window_scaling=1
BUFEOF
        sysctl -p >/dev/null 2>&1
        echo -e "\n\033[1;32m✓ Buffers OPTIMIZADOS (25 MB max rmem/wmem)\033[0m"
        echo -e "\033[1;37m  Permite manejar mejor múltiples túneles VPN simultáneos.\033[0m"
    fi
    sleep 2
}

