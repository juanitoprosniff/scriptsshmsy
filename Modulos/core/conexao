_turbo_todo_desactivar() {
    sed -i '/^Compression/d' /etc/ssh/sshd_config
    echo "Compression no" >> /etc/ssh/sshd_config
    systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null

    sed -i '/net.core.default_qdisc/d;/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
    sed -i '/net.core.rmem_max/d;/net.core.wmem_max/d;/net.core.rmem_default/d' /etc/sysctl.conf
    sed -i '/net.core.wmem_default/d;/net.ipv4.tcp_rmem/d;/net.ipv4.tcp_wmem/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_mem/d;/net.core.netdev_max_backlog/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_no_metrics_save/d;/net.ipv4.tcp_window_scaling/d' /etc/sysctl.conf
    sed -i '/# MSYVPN Buffers/d' /etc/sysctl.conf
    sysctl -p >/dev/null 2>&1
    echo -e "\n\033[1;33m✓ TURBO VPN DESACTIVADO — configuración original restaurada.\033[0m"
    sleep 2
}

