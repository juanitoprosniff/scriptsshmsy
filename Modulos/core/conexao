            && bbr_sts="\033[1;32m✓ ACTIVO " || bbr_sts="\033[1;31m✕ INACTIVO"
        grep -q "^Compression yes" /etc/ssh/sshd_config 2>/dev/null \
            && comp_sts="\033[1;32m✓ ACTIVO " || comp_sts="\033[1;31m✕ INACTIVO"
        grep -q "^net.core.rmem_max=26214400" /etc/sysctl.conf 2>/dev/null \
            && buf_sts="\033[1;32m✓ ACTIVO " || buf_sts="\033[1;31m✕ INACTIVO"

        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m1\033[1;31m] \033[1;33mSSH COMPRESIÓN (zlib)  $comp_sts\033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m2\033[1;31m] \033[1;33mBBR (Control TCP)      $bbr_sts\033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m3\033[1;31m] \033[1;33mBUFFERS DE RED         $buf_sts\033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m4\033[1;31m] \033[1;32mACTIVAR TODO  ◄ RECOMENDADO     \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m5\033[1;31m] \033[1;31mDESACTIVAR TODO (restaurar)     \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m6\033[1;31m] \033[1;33mVER ESTADO ACTUAL                \033[0;34m┃"
        echo -e "\033[0;34m┃\033[1;31m[\033[1;36m0\033[1;31m] \033[1;33mVOLVER                           \033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"
        echo -ne "\033[1;32mOpción: \033[1;37m"; read resp_turbo

        case $resp_turbo in
        1|01) _turbo_compresion ;;
        2|02) _turbo_bbr ;;
        3|03) _turbo_buffers ;;
        4|04) _turbo_todo_activar ;;
        5|05) _turbo_todo_desactivar ;;
        6|06) _turbo_ver_estado; echo -ne "\n\033[1;33mPresiona ENTER...\033[0m"; read ;;
        0|00) fun_conexao; return ;;
