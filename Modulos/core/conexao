_descargar_master_pubkey() {
    echo -e "\033[1;33mDescargando clave maestra desde GitHub...\033[0m"
    mkdir -p /etc/SSHPlus
    wget -q --timeout=30 \
        "${_REPO_BASE}/Modulos/proxy/master_pubkey.pub" \
        -O "$_MASTER_PUBKEY" 2>/dev/null

    if [[ -s "$_MASTER_PUBKEY" ]]; then
        chmod 644 "$_MASTER_PUBKEY"
        echo -e "\033[1;32m✓ Clave maestra instalada en $_MASTER_PUBKEY\033[0m"
        ssh-keygen -lf "$_MASTER_PUBKEY" 2>/dev/null && true
    else
        rm -f "$_MASTER_PUBKEY"
        echo -e "\033[1;31m✗ No se pudo descargar la clave maestra.\033[0m"
        echo -e "\033[1;33m  URL: ${_REPO_BASE}/Modulos/proxy/master_pubkey.pub\033[0m"
    fi
    sleep 2
}

# ============================================================
# INSTALAR DROPBEAR — función genérica para 2016 / 2020 / 2022
# Uso: _instalar_dropbear VER PUERTO SERVICIO DIRECTORIO
# Ej:  _instalar_dropbear "2020.81" "144" "dropbear-2020" "dropbear-2020"
# ============================================================
_instalar_dropbear() {
    local ver="$1" porta="$2" servicio="$3" directorio="$4"
    local tarball="dropbear-${ver}.tar.bz2"
    local dir_inst="/opt/${directorio}"
    local dir_conf="/etc/${directorio}"

    verif_ptrs "$porta"

    # Ubuntu 26+ y versión 2016: usar binario precompilado (GCC 14 no compila 2016)
    if [[ $_UBUNTU_VER -ge 26 && "$ver" == "2016.74" ]]; then
        echo -e "\033[1;33mUbuntu $_UBUNTU_VER detectado — instalando binario precompilado Dropbear $ver...\033[0m"
        apt-get install -y wget >/dev/null 2>&1
        mkdir -p "${dir_inst}/sbin" "${dir_inst}/bin" "$dir_conf"

        if [[ "$_ARCH" == "arm64" ]]; then
            _db_url="${_REPO_INST}/dropbear2016-bin-arm64"
            _dbkey_url="${_REPO_INST}/dropbearkey2016-bin-arm64"
        else
            _db_url="${_REPO_INST}/dropbear2016-bin-amd64"
            _dbkey_url="${_REPO_INST}/dropbearkey2016-bin-amd64"
        fi

        wget -q --timeout=60 -O "${dir_inst}/sbin/dropbear" "$_db_url"
        wget -q --timeout=60 -O "${dir_inst}/bin/dropbearkey" "$_dbkey_url"

        if [[ ! -s "${dir_inst}/sbin/dropbear" ]]; then
            echo -e "\033[1;31m⚠ No se pudo descargar el binario precompilado.\033[0m"
            echo -e "\033[1;33mSuba manualmente los binarios a ${dir_inst}/sbin/ e intente de nuevo.\033[0m"
            sleep 3; fun_conexao; return
        fi
        chmod +x "${dir_inst}/sbin/dropbear" "${dir_inst}/bin/dropbearkey"
        echo -e "\033[1;32m✓ Binario Dropbear $ver instalado\033[0m"
    else
        # Compilar desde fuente (funciona en Ubuntu 18-25 para todos, Ubuntu 26+ para 2020/2022)
        echo -e "\033[1;33mCompilando Dropbear $ver... (~3-5 min)\033[0m"
        apt-get update -y >/dev/null 2>&1
        apt-get install -y make gcc wget zlib1g-dev build-essential >/dev/null 2>&1

        cd /usr/src

        if [[ ! -s "$tarball" ]]; then
            echo -e "\033[1;33mDescargando $tarball...\033[0m"
            wget -q --timeout=90 "${_REPO_INST}/${tarball}" -O "$tarball"
        fi

        if [[ ! -s "$tarball" ]]; then
            echo -e "\033[1;31mNo se pudo descargar $tarball\033[0m"
            sleep 3; fun_conexao; return
        fi

        rm -rf "dropbear-${ver}" 2>/dev/null
        tar xjf "$tarball"
        cd "dropbear-${ver}"

        # Cambiar identificador SSH visible
        for hdr in sysoptions.h default_options.h; do
            [[ -f "$hdr" ]] && {
                sed -i 's|^#define LOCAL_IDENT.*|#define LOCAL_IDENT "SSH-2.0-ByJuanitoProSniff"|' "$hdr" 2>/dev/null
                sed -i 's/SSH-2.0-dropbear/SSH-2.0-ByJuanitoProSniff/g' "$hdr" 2>/dev/null
            }
        done

        ./configure --prefix="$dir_inst" \
            --disable-zlib \
            --disable-wtmp \
            --disable-lastlog >/dev/null 2>&1

        if make -j$(nproc) PROGRAMS="dropbear dropbearkey" >/dev/null 2>&1; then
            make install PROGRAMS="dropbear dropbearkey" >/dev/null 2>&1
        else
            echo -e "\033[1;31m⚠ ERROR: No se pudo compilar Dropbear $ver\033[0m"
            cd /root; sleep 3; fun_conexao; return
        fi

        if [[ ! -f "${dir_inst}/sbin/dropbear" ]]; then
            echo -e "\033[1;31m⚠ ERROR: Binario no encontrado tras compilación.\033[0m"
            cd /root; sleep 3; fun_conexao; return
        fi
        echo -e "\033[1;32m✓ Dropbear $ver compilado exitosamente\033[0m"
    fi

    # Crear directorio de config y generar claves SSH
    mkdir -p "$dir_conf"

    [[ ! -f "${dir_conf}/dropbear_rsa_host_key" ]] && \
        "${dir_inst}/bin/dropbearkey" -t rsa \
            -f "${dir_conf}/dropbear_rsa_host_key" -s 2048 >/dev/null 2>&1

    # DSS solo si lo soporta esta versión (2016 sí, 2020+ puede no tenerlo)
    "${dir_inst}/bin/dropbearkey" -t dss \
        -f "${dir_conf}/dropbear_dss_host_key" >/dev/null 2>&1 || true

    cat > "${dir_conf}/banner.txt" <<'BANEOF'
t.me/FREEINTERNETVPNMSY
BANEOF

    # Crear servicio systemd
    cat > "/etc/systemd/system/${servicio}.service" <<DBEOF
[Unit]
Description=Dropbear SSH ${ver} - Puerto ${porta}
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=${dir_inst}/sbin/dropbear -F -E -p ${porta} -r ${dir_conf}/dropbear_rsa_host_key -b ${dir_conf}/banner.txt -K 60 -I 300
ExecReload=/bin/kill -HUP \$MAINPID
Restart=always
RestartSec=3
KillMode=process

[Install]
WantedBy=multi-user.target
DBEOF

    systemctl daemon-reload
    systemctl enable "$servicio" >/dev/null 2>&1
    systemctl start "$servicio"
    _fw_open "$porta"

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Versión Dropbear $ver instalada:"
    "${dir_inst}/sbin/dropbear" -V 2>&1 | head -n 1
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    sleep 1

    if systemctl is-active "$servicio" >/dev/null 2>&1; then
        echo -e "\n\033[1;32m✓ DROPBEAR $ver ACTIVO EN PUERTO $porta!\033[0m"
    else
        echo -e "\n\033[1;33mVerifique con: systemctl status $servicio\033[0m"
    fi
    cd /root; sleep 3; fun_conexao
}

