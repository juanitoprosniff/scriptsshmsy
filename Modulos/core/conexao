fun_turbo_vpn() {
    while true; do
        clear
        echo -e "\033[0;34m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\033[0m"
        echo -e "\033[0;34m┃\E[42;1;37m         TURBO VPN — POTENCIAR VPS       \E[0m\033[0;34m┃"
        echo -e "\033[0;34m┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\033[0m"

        # Detectar estado actual de cada opción
        local bbr_sts comp_sts buf_sts
