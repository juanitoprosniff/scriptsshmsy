#!/bin/bash
# ============================================================
# CREAR USUARIO SSH вЂ” SSHMSY MANAGER
# Sin OpenVPN / Sin OpenSSH directo вЂ” usa Dropbear 2016
# FIXES:
#   - Eliminado todo cГіdigo OpenVPN
#   - DГ­as ilimitado: ingresar 0 o 99999
#   - Muestra puertos activos (Dropbear, Proxy WS, SSL, etc.)
# ============================================================
IP=$(cat /etc/IP 2>/dev/null || hostname -I | awk '{print $1}')
cor1='\033[41;1;37m'
cor2='\033[44;1;37m'
scor='\033[0m'

# FIX Dropbear 2016: registrar /bin/false en /etc/shells
# Dropbear 2016 rechaza el login si la shell del usuario no estГЎ
# en /etc/shells вЂ” criarusuario usa -s /bin/false por seguridad
grep -qx '/bin/false' /etc/shells 2>/dev/null || echo '/bin/false' >> /etc/shells
grep -qx '/usr/sbin/nologin' /etc/shells 2>/dev/null || echo '/usr/sbin/nologin' >> /etc/shells

# в”Ђв”Ђ FunciГіn: mostrar puertos activos в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
fun_show_ports() {
    echo -e "\033[1;33mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ PUERTOS ACTIVOS в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"

    # OpenSSH
    _ssh_ports=$(grep '^Port' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | xargs)
    [[ -n "$_ssh_ports" ]] && echo -e "\033[1;32mOpenSSH     :\033[1;37m $_ssh_ports\033[0m"

    # Dropbear 2016 (systemd o screen)
    _db16_port=""
    systemctl is-active dropbear-legacy >/dev/null 2>&1 && \
        _db16_port=$(systemctl show dropbear-legacy --property=ExecStart 2>/dev/null | grep -oP '(?<=-p )\d+' | head -1)
    [[ -z "$_db16_port" ]] && \
        _db16_port=$(screen -list 2>/dev/null | grep 'dropbear2016' | grep -oP '\d+(?=\.dropbear2016)' | head -1)
    [[ -n "$_db16_port" ]] && echo -e "\033[1;32mDropbear2016:\033[1;37m $_db16_port\033[0m"

    # Proxy WebSocket / SOCKS (Python)
    _py_ports=$(ss -tlpn 2>/dev/null | grep -E 'python|python3' | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | xargs)
    [[ -n "$_py_ports" ]] && echo -e "\033[1;32mProxy WS    :\033[1;37m $_py_ports\033[0m"

    # SSL / Stunnel
    _ssl_ports=$(ss -tlpn 2>/dev/null | grep 'stunnel' | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | xargs)
    [[ -n "$_ssl_ports" ]] && echo -e "\033[1;32mSSL/Stunnel :\033[1;37m $_ssl_ports\033[0m"

    # Nginx
    _nginx_ports=$(ss -tlpn 2>/dev/null | grep 'nginx' | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | xargs)
    [[ -n "$_nginx_ports" ]] && echo -e "\033[1;32mNginx       :\033[1;37m $_nginx_ports\033[0m"

    # V2Ray / Xray
    _v2_ports=$(ss -tlpn 2>/dev/null | grep -E 'v2ray|xray' | awk '{print $4}' | rev | cut -d: -f1 | rev | sort -u | xargs)
    [[ -n "$_v2_ports" ]] && echo -e "\033[1;32mV2Ray/Xray  :\033[1;37m $_v2_ports\033[0m"

    echo -e "\033[1;33mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
}

fun_bar() {
    comando[0]="$1"
    (
        [[ -e $HOME/fim ]] && rm $HOME/fim
        ${comando[0]} >/dev/null 2>&1
        touch $HOME/fim
    ) >/dev/null 2>&1 &
    tput civis
    echo -ne "\033[1;33mAGUARDE \033[1;37m- \033[1;33m["
    while true; do
        for ((i = 0; i < 18; i++)); do
            echo -ne "\033[1;31m#"
            sleep 0.1s
        done
        [[ -e $HOME/fim ]] && rm $HOME/fim && break
        echo -e "\033[1;33m]"
        sleep 1s
        tput cuu1
        tput dl1
        echo -ne "\033[1;33mAGUARDE \033[1;37m- \033[1;33m["
    done
    echo -e "\033[1;33m]\033[1;37m -\033[1;32m OK !\033[1;37m"
    tput cnorm
}

# в”Ђв”Ђ Token SSH в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
fun_usertoken() {
    clear
    echo -e "\033[0;34mв•­в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•®\033[0m"
    echo -e "\033[0;34mв”ѓ\E[44;1;37m              CREAR TOKEN SSH            \E[0m\033[0;34mв”ѓ"
    echo -e "\033[0;34mв•°в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•Ї\033[0m"
    echo ""
    echo -ne "\033[1;32mInsira o Token:\033[1;37m "
    read username
    [[ -z $username ]] && { echo -e "\n${cor1}Token vazio ou invalido!${scor}\n"; exit 1; }
    [[ "$(grep -wc $username /etc/passwd)" != '0' ]] && { echo -e "\n${cor1}Este Token jГЎ existe!${scor}\n"; exit 1; }
    [[ ${username} != ?(+|-)+([a-zA-Z0-9]) ]] && {
        echo -e "\n${cor1}Token invГЎlido! Sem espaГ§os, acentos ou caracteres especiais.${scor}\n"; exit 1
    }
    [[ ${#username} -lt 2 ]] && { echo -e "\n${cor1}Token muito curto (mГ­n. 2 caracteres)${scor}\n"; exit 1; }

    echo -ne "\033[1;32mDias para expirar \033[1;33m[0 = ilimitado]\033[1;32m:\033[1;37m "
    read dias
    [[ -z $dias ]] && { echo -e "\n${cor1}Numero de dias vazio!${scor}\n"; exit 1; }
    [[ ${dias} != +([0-9]) ]] && { echo -e "\n${cor1}NГєmero invГЎlido!${scor}\n"; exit 1; }

    echo -ne "\033[1;32mLimite de conexГµes:\033[1;37m "
    read sshlimiter
    [[ -z $sshlimiter ]] && { echo -e "\n${cor1}Limite de conexГµes vazio!${scor}\n"; exit 1; }
    [[ ${sshlimiter} != +([0-9]) || $sshlimiter -lt 1 ]] && {
        echo -e "\n${cor1}NГєmero de conexГµes invГЎlido (mГ­n. 1)!${scor}\n"; exit 1
    }

    password=$(cat /etc/SSHPlus/Token.txt 2>/dev/null)
    [[ -z "$password" ]] && { echo -e "\n${cor1}Token master nГЈo encontrado em /etc/SSHPlus/Token.txt${scor}\n"; exit 1; }

    # Calcular expiraciГіn
    if [[ "$dias" -eq 0 ]]; then
        final="2099-12-31"
        gui="Ilimitado"
    else
        final=$(date "+%Y-%m-%d" -d "+$dias days")
        gui=$(date "+%d/%m/%Y" -d "+$dias days")
    fi

    # FIX Dropbear 2016: usar hash MD5 ($1$) en vez de DES/SHA-512
    # Dropbear 2016 no soporta SHA-512 ($6$) que genera Ubuntu 22/24 con salt corto
    pass=$(perl -e 'print crypt($ARGV[0], "\$1\$sshmsy\$")' $password)
    useradd -e $final -M -s /bin/false -p $pass $username >/dev/null 2>&1
    [[ -d /etc/SSHPlus/senha ]] || mkdir -p /etc/SSHPlus/senha
    echo "$password" >/etc/SSHPlus/senha/$username
    echo "$username $sshlimiter" >>/root/usuarios.db


    echo -e "\033[0;34mв•°в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•Ї\033[0m"
    echo ""
    echo -e "\033[1;32mIP          :\033[1;37m $IP\033[0m"
    echo -e "\033[1;32mToken       :\033[1;37m $username\033[0m"
    echo -e "\033[1;32mExpira em   :\033[1;37m $gui\033[0m"
    echo -e "\033[1;32mConexГµes    :\033[1;37m $sshlimiter\033[0m"
    echo ""
    fun_show_ports
}

# в”Ђв”Ђ Verificar que el sistema estГ© instalado в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
[[ ! -e /usr/lib/sshplus ]] && exit 0

clear
echo -e "\033[0;34mв•­в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•®\033[0m"
echo -e "\033[0;34mв”ѓ\E[44;1;37m            CREAR USUARIO SSH            \E[0m\033[0;34mв”ѓ"
echo -e "\033[0;34mв•°в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•Ї\033[0m"
tput sgr0
echo ""
read -p "$(echo -ne "\033[1;32mDeseja usar Token? \033[1;33m[s/n]:\033[1;37m") " -e -i n resp

if [[ "$resp" = 's' ]]; then
    clear
    if [ -e "/etc/SSHPlus/Token.txt" ]; then
        fun_usertoken
    else
        clear
        echo -e "\033[1;31mNenhuma senha de Token cadastrada.\033[0m"
        echo ""
        echo -ne "\033[1;32mInforme uma senha para o Token: \033[1;37m "
        read senha
        [[ -z $senha ]] && { echo -e "\n${cor1}Senha vazia!${scor}\n"; exit 1; }
        [[ -d /etc/SSHPlus ]] || mkdir -p /etc/SSHPlus
        echo $senha >/etc/SSHPlus/Token.txt
        echo -e "\n\033[1;32mSenha cadastrada!\033[0m"
        sleep 1
        fun_usertoken
    fi

else
    # в”Ђв”Ђ Crear usuario normal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    clear
