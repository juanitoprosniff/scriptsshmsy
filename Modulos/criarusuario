    }
    [[ ${username} != ?(+|-)+([a-zA-Z0-9]) ]] && {
        echo -e "\n${cor1}Nome invГЎlido! Sem espaГ§os, acentos ou caracteres especiais.${scor}\n"; exit 1
    }
    [[ ${#username} -lt 2 ]] && { echo -e "\n${cor1}Nome muito curto (mГ­n. 2 caracteres)!${scor}\n"; exit 1; }
    [[ ${#username} -gt 10 ]] && { echo -e "\n${cor1}Nome muito longo (mГЎx. 10 caracteres)!${scor}\n"; exit 1; }

    echo -ne "\033[1;32mSenha:\033[1;37m "
